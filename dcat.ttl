@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/earthsemantics/OSO> a dcat:Dataset ;
    dcterms:identifier <https://w3id.org/earthsemantics/OSO> ;
    dcterms:title "Οντολογία θαλάσσιων παρατηρητηρίων"@el,
        "Observatories of the Seas Ontology"@en,
        "Ontología de los observatorios marinos"@es,
        "Ontologie des observatoires marins"@fr,
        "Ontologia degli osservatori marini"@it,
        "Ontologi for marine observatorier"@no,
        "Ontologia dos observatórios marinhos"@pt,
        "Ontologia observatoarelor marine"@ro ;
    dcterms:description "Οντολογία που περιγράφει θαλάσσια παρατηρητήρια, πλατφόρμες και σχετικές υποδομές όπως το EMSO-ERIC."@el,
        "An OWL ontology describing marine observatories, platforms, and related infrastructures such as EMSO-ERIC."@en,
        "Ontología que describe observatorios marinos, plataformas e infraestructuras relacionadas como EMSO-ERIC."@es,
        "Ontologie décrivant les observatoires marins, les plateformes et les infrastructures associées comme EMSO-ERIC."@fr,
        "Ontologia che descrive osservatori marini, piattaforme e infrastrutture di ricerca come EMSO-ERIC."@it,
        "Ontologi som beskriver marine observatorier, plattformer og tilknyttede infrastrukturer som EMSO-ERIC."@no,
        "Ontologia que descreve observatórios marinhos, plataformas e infraestruturas de investigação como o EMSO-ERIC."@pt,
        "Ontologie care descrie observatoare marine, platforme și infrastructuri asociate precum EMSO-ERIC."@ro ;
    dcterms:creator <https://ror.org/044jxhp58>,
        <https://ror.org/04xkqms46> ;
    dcterms:publisher <https://ror.org/04xkqms46> ;
    dcterms:rightsHolder <https://ror.org/04xkqms46> ;
    dcterms:issued "2025-04-04"^^xsd:date ;
    dcterms:modified "2026-04-08"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:language "el"^^xsd:language,
        "en"^^xsd:language,
        "es"^^xsd:language,
        "fr"^^xsd:language,
        "it"^^xsd:language,
        "no"^^xsd:language,
        "pt"^^xsd:language,
        "ro"^^xsd:language ;
    dcterms:accessRights <http://purl.org/coar/access_right/c_abf2> ;
    dcterms:provenance "Co-developed by the EMSO Data Management Service Group with FAIR alignment."@en ;
    dcterms:hasVersion "1.0.1" ;
    owl:versionInfo "1.0.1" ;
    dcat:version "1.0.1" ;
    foaf:depiction <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/oso.png> ;
    dcat:keyword "FAIR"@en,
        "marine observatory"@en,
        "ontology"@en,
        "research infrastructure"@en ;
    dcat:landingPage <https://w3id.org/earthsemantics/OSO> ;
    foaf:homepage <https://github.com/emso-eric/oso-ontology> ;
    foaf:page <https://earthportal.eu/ontologies/OSO> ;
    dcat:contactPoint [
        a vcard:Kind ;
        vcard:fn "EMSO Data Management Service Group" ;
        vcard:hasEmail <mailto:emso.dmsg@emso-eu.org>
    ] ;
    dcat:theme [
        a skos:Concept ;
        skos:prefLabel "ωκεανογραφία"@el,
            "oceanography"@en,
            "oceanografía"@es,
            "océanographie"@fr,
            "oceanografia"@it,
            "oseanografi"@no,
            "oceanografia"@pt,
            "oceanografie"@ro ;
        skos:exactMatch <http://www.wikidata.org/entity/Q43518> ;
        skos:closeMatch <http://eurovoc.europa.eu/2114> ;
        skos:inScheme <http://eurovoc.europa.eu/> ;
        skos:notation "2114"
    ] ;
    dcat:distribution
        <https://earthportal.eu/ontologies/OSO.ttl>,
        <https://earthportal.eu/ontologies/OSO.rdf>,
        <https://earthportal.eu/ontologies/OSO.owl>,
        <https://earthportal.eu/ontologies/OSO.csv>,
        <https://earthportal.eu/ontologies/OSO.diff>,
        <https://virtuoso.ifremer.fr/oso/sparql> .

# Distributions

<https://earthportal.eu/ontologies/OSO.ttl> a dcat:Distribution ;
    dcterms:title "OSO Turtle serialization"@en ;
    dcat:accessURL <https://earthportal.eu/ontologies/OSO.ttl> ;
    dcat:downloadURL <https://earthportal.eu/ontologies/OSO.ttl> ;
    dcterms:format <https://www.iana.org/assignments/media-types/text/turtle> .

<https://earthportal.eu/ontologies/OSO.rdf> a dcat:Distribution ;
    dcterms:title "OSO RDF/XML serialization"@en ;
    dcat:accessURL <https://earthportal.eu/ontologies/OSO.rdf> ;
    dcat:downloadURL <https://earthportal.eu/ontologies/OSO.rdf> ;
    dcterms:format <https://www.iana.org/assignments/media-types/application/rdf+xml> .

<https://earthportal.eu/ontologies/OSO.owl> a dcat:Distribution ;
    dcterms:title "OSO OWL serialization"@en ;
    dcat:accessURL <https://earthportal.eu/ontologies/OSO.owl> ;
    dcat:downloadURL <https://earthportal.eu/ontologies/OSO.owl> ;
    dcterms:format <https://www.iana.org/assignments/media-types/application/owl+xml> .

<https://earthportal.eu/ontologies/OSO.csv> a dcat:Distribution ;
    dcterms:title "OSO CSV export"@en ;
    dcat:accessURL <https://earthportal.eu/ontologies/OSO.csv> ;
    dcat:downloadURL <https://earthportal.eu/ontologies/OSO.csv> ;
    dcterms:format <https://www.iana.org/assignments/media-types/text/csv> .

<https://earthportal.eu/ontologies/OSO.diff> a dcat:Distribution ;
    dcterms:title "OSO diff file"@en ;
    dcat:accessURL <https://earthportal.eu/ontologies/OSO.diff> ;
    dcat:downloadURL <https://earthportal.eu/ontologies/OSO.diff> ;
    dcterms:format "text/plain" .

# SPARQL endpoint

<https://virtuoso.ifremer.fr/oso/sparql> a dcat:Distribution ;
    dcterms:title "OSO SPARQL endpoint"@en ;
    dcterms:description "SPARQL endpoint providing query access to the OSO ontology."@en ;
    dcat:accessURL <https://virtuoso.ifremer.fr/oso/sparql> ;
    dcterms:format <https://www.iana.org/assignments/media-types/application/sparql-query> .