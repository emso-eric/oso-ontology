        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>propertyDisjointWith</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#sameAs -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#sameAs">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#someValuesFrom -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#someValuesFrom">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <rdfs:comment>The property that determines the class that an existential property restriction refers to.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>someValuesFrom</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#sourceIndividual -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#sourceIndividual">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#NegativePropertyAssertion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>The property that determines the subject of a negative property assertion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>sourceIndividual</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#targetIndividual -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#targetIndividual">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#NegativePropertyAssertion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>The property that determines the object of a negative object property assertion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>targetIndividual</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#targetValue -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#targetValue">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#NegativePropertyAssertion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
        <rdfs:comment>The property that determines the value of a negative data property assertion.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>targetValue</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>The object property that relates every two individuals.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>topObjectProperty</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#unionOf -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#unionOf">
        <rdfs:domain rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
        <rdfs:comment>The property that determines the collection of classes or data ranges that build a union.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>unionOf</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#withRestrictions -->


    <ObjectProperty rdf:about="http://www.w3.org/2002/07/owl#withRestrictions">
        <rdfs:domain rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
        <rdfs:comment>The property that determines the collection of facet-value pairs that define a datatype restriction.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>withRestrictions</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2003/01/geo/wgs84_pos#location -->


    <ObjectProperty rdf:about="http://www.w3.org/2003/01/geo/wgs84_pos#location">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/based_near"/>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broadMatch -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broadMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broader"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowMatch"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has broader match</rdfs:label>
        <rdfs:label xml:lang="en">has broader match</rdfs:label>
        <rdfs:label xml:lang="es">has broader match</rdfs:label>
        <rdfs:label xml:lang="fr">has broader match</rdfs:label>
        <rdfs:label xml:lang="it">has broader match</rdfs:label>
        <rdfs:label xml:lang="no">has broader match</rdfs:label>
        <rdfs:label xml:lang="pt">has broader match</rdfs:label>
        <rdfs:label xml:lang="ro">has broader match</rdfs:label>
        <skos:definition xml:lang="en">skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#broaderTransitive"/>
        <inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <rdfs:comment xml:lang="el">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="en">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="es">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="it">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="no">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="pt">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="ro">Broader concepts are typically rendered as parents in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has broader</rdfs:label>
        <rdfs:label xml:lang="en">has broader</rdfs:label>
        <rdfs:label xml:lang="es">has broader</rdfs:label>
        <rdfs:label xml:lang="fr">has broader</rdfs:label>
        <rdfs:label xml:lang="it">has broader</rdfs:label>
        <rdfs:label xml:lang="no">has broader</rdfs:label>
        <rdfs:label xml:lang="pt">has broader</rdfs:label>
        <rdfs:label xml:lang="ro">has broader</rdfs:label>
        <skos:definition xml:lang="en">Relates a concept to a concept that is more general in meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#broaderTransitive -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#broaderTransitive">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowerTransitive"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="en">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="es">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="fr">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="it">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="no">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="pt">has broader transitive</rdfs:label>
        <rdfs:label xml:lang="ro">has broader transitive</rdfs:label>
        <skos:definition>skos:broaderTransitive is a transitive superproperty of skos:broader.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#closeMatch -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#closeMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has close match</rdfs:label>
        <rdfs:label xml:lang="en">has close match</rdfs:label>
        <rdfs:label xml:lang="es">has close match</rdfs:label>
        <rdfs:label xml:lang="fr">has close match</rdfs:label>
        <rdfs:label xml:lang="it">has close match</rdfs:label>
        <rdfs:label xml:lang="no">has close match</rdfs:label>
        <rdfs:label xml:lang="pt">has close match</rdfs:label>
        <rdfs:label xml:lang="ro">has close match</rdfs:label>
        <skos:definition xml:lang="en">skos:closeMatch is used to link two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications. In order to avoid the possibility of &quot;compound errors&quot; when combining mappings across more than two concept schemes, skos:closeMatch is not declared to be a transitive property.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#closeMatch"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:comment xml:lang="el">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="es">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="fr">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="it">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="no">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="pt">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:comment xml:lang="ro">skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has exact match</rdfs:label>
        <rdfs:label xml:lang="en">has exact match</rdfs:label>
        <rdfs:label xml:lang="es">has exact match</rdfs:label>
        <rdfs:label xml:lang="fr">has exact match</rdfs:label>
        <rdfs:label xml:lang="it">has exact match</rdfs:label>
        <rdfs:label xml:lang="no">has exact match</rdfs:label>
        <rdfs:label xml:lang="pt">has exact match</rdfs:label>
        <rdfs:label xml:lang="ro">has exact match</rdfs:label>
        <skos:definition xml:lang="en">skos:exactMatch is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. skos:exactMatch is a transitive property, and is a sub-property of skos:closeMatch.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#hasTopConcept -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#hasTopConcept">
        <inverseOf rdf:resource="http://www.w3.org/2004/02/skos/core#topConceptOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has top concept</rdfs:label>
        <rdfs:label xml:lang="en">has top concept</rdfs:label>
        <rdfs:label xml:lang="es">has top concept</rdfs:label>
        <rdfs:label xml:lang="fr">has top concept</rdfs:label>
        <rdfs:label xml:lang="it">has top concept</rdfs:label>
        <rdfs:label xml:lang="no">has top concept</rdfs:label>
        <rdfs:label xml:lang="pt">has top concept</rdfs:label>
        <rdfs:label xml:lang="ro">has top concept</rdfs:label>
        <skos:definition xml:lang="en">Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#inScheme -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#inScheme">
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">is in scheme</rdfs:label>
        <rdfs:label xml:lang="en">is in scheme</rdfs:label>
        <rdfs:label xml:lang="es">is in scheme</rdfs:label>
        <rdfs:label xml:lang="fr">is in scheme</rdfs:label>
        <rdfs:label xml:lang="it">is in scheme</rdfs:label>
        <rdfs:label xml:lang="no">is in scheme</rdfs:label>
        <rdfs:label xml:lang="pt">is in scheme</rdfs:label>
        <rdfs:label xml:lang="ro">is in scheme</rdfs:label>
        <skos:definition xml:lang="en">Relates a resource (for example a concept) to a concept scheme in which it is included.</skos:definition>
        <skos:scopeNote xml:lang="en">A concept may be a member of more than one concept scheme.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#mappingRelation -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#mappingRelation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdfs:comment xml:lang="el">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="en">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="es">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="fr">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="it">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="no">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="pt">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:comment xml:lang="ro">These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="en">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="es">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="fr">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="it">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="no">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="pt">is in mapping relation with</rdfs:label>
        <rdfs:label xml:lang="ro">is in mapping relation with</rdfs:label>
        <skos:definition xml:lang="en">Relates two concepts coming, by convention, from different schemes, and that have comparable meanings</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#member -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#member">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Collection"/>
        <rdfs:range>
            <Class>
                <unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Collection"/>
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                </unionOf>
            </Class>
        </rdfs:range>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">has member</rdfs:label>
        <skos:definition xml:lang="en">Relates a collection to one of its members.</skos:definition>
        <skos:prefLabel xml:lang="fr">a pour membre</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">are membru</skos:prefLabel>
        <skos:prefLabel xml:lang="it">ha membro</skos:prefLabel>
        <skos:prefLabel xml:lang="no">har medlem</skos:prefLabel>
        <skos:prefLabel xml:lang="en">has member</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">tem membro</skos:prefLabel>
        <skos:prefLabel xml:lang="es">tiene miembro</skos:prefLabel>
        <skos:prefLabel xml:lang="el">έχει μέλος</skos:prefLabel>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#memberList -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#memberList">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#OrderedCollection"/>
        <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
        <rdfs:comment xml:lang="el">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="en">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="es">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="fr">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="it">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="no">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="pt">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:comment xml:lang="ro">For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">has member list</rdfs:label>
        <skos:definition xml:lang="en">Relates an ordered collection to the RDF list containing its members.</skos:definition>
        <skos:prefLabel xml:lang="fr">a pour liste de membres</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">are listă de membri</skos:prefLabel>
        <skos:prefLabel xml:lang="it">ha elenco dei membri</skos:prefLabel>
        <skos:prefLabel xml:lang="no">har medlemsliste</skos:prefLabel>
        <skos:prefLabel xml:lang="en">has member list</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">tem lista de membros</skos:prefLabel>
        <skos:prefLabel xml:lang="es">tiene lista de miembros</skos:prefLabel>
        <skos:prefLabel xml:lang="el">έχει λίστα μελών</skos:prefLabel>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowMatch -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrowMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrower"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has narrower match</rdfs:label>
        <rdfs:label xml:lang="en">has narrower match</rdfs:label>
        <rdfs:label xml:lang="es">has narrower match</rdfs:label>
        <rdfs:label xml:lang="fr">has narrower match</rdfs:label>
        <rdfs:label xml:lang="it">has narrower match</rdfs:label>
        <rdfs:label xml:lang="no">has narrower match</rdfs:label>
        <rdfs:label xml:lang="pt">has narrower match</rdfs:label>
        <rdfs:label xml:lang="ro">has narrower match</rdfs:label>
        <skos:definition xml:lang="en">skos:narrowMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrower -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrower">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#narrowerTransitive"/>
        <rdfs:comment xml:lang="el">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="en">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="es">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="fr">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="it">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="no">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="pt">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:comment xml:lang="ro">Narrower concepts are typically rendered as children in a concept hierarchy (tree).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has narrower</rdfs:label>
        <rdfs:label xml:lang="en">has narrower</rdfs:label>
        <rdfs:label xml:lang="es">has narrower</rdfs:label>
        <rdfs:label xml:lang="fr">has narrower</rdfs:label>
        <rdfs:label xml:lang="it">has narrower</rdfs:label>
        <rdfs:label xml:lang="no">has narrower</rdfs:label>
        <rdfs:label xml:lang="pt">has narrower</rdfs:label>
        <rdfs:label xml:lang="ro">has narrower</rdfs:label>
        <skos:definition xml:lang="en">Relates a concept to a concept that is more specific in meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#narrowerTransitive -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#narrowerTransitive">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="en">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="es">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="fr">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="it">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="no">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="pt">has narrower transitive</rdfs:label>
        <rdfs:label xml:lang="ro">has narrower transitive</rdfs:label>
        <skos:definition>skos:narrowerTransitive is a transitive superproperty of skos:narrower.</skos:definition>
        <skos:scopeNote xml:lang="en">By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#related -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#related">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#semanticRelation"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:comment xml:lang="el">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="es">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="fr">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="it">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="no">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="pt">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:comment xml:lang="ro">skos:related is disjoint with skos:broaderTransitive</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has related</rdfs:label>
        <rdfs:label xml:lang="en">has related</rdfs:label>
        <rdfs:label xml:lang="es">has related</rdfs:label>
        <rdfs:label xml:lang="fr">has related</rdfs:label>
        <rdfs:label xml:lang="it">has related</rdfs:label>
        <rdfs:label xml:lang="no">has related</rdfs:label>
        <rdfs:label xml:lang="pt">has related</rdfs:label>
        <rdfs:label xml:lang="ro">has related</rdfs:label>
        <skos:definition xml:lang="en">Relates a concept to a concept with which there is an associative semantic relationship.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#relatedMatch -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#relatedMatch">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#mappingRelation"/>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#related"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">has related match</rdfs:label>
        <rdfs:label xml:lang="en">has related match</rdfs:label>
        <rdfs:label xml:lang="es">has related match</rdfs:label>
        <rdfs:label xml:lang="fr">has related match</rdfs:label>
        <rdfs:label xml:lang="it">has related match</rdfs:label>
        <rdfs:label xml:lang="no">has related match</rdfs:label>
        <rdfs:label xml:lang="pt">has related match</rdfs:label>
        <rdfs:label xml:lang="ro">has related match</rdfs:label>
        <skos:definition xml:lang="en">skos:relatedMatch is used to state an associative mapping link between two conceptual resources in different concept schemes.</skos:definition>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#semanticRelation -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#semanticRelation">
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="en">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="es">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="fr">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="it">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="no">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="pt">is in semantic relation with</rdfs:label>
        <rdfs:label xml:lang="ro">is in semantic relation with</rdfs:label>
        <skos:definition xml:lang="en">Links a concept to a concept related by meaning.</skos:definition>
        <skos:scopeNote xml:lang="en">This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts.</skos:scopeNote>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2004/02/skos/core#topConceptOf -->


    <ObjectProperty rdf:about="http://www.w3.org/2004/02/skos/core#topConceptOf">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="el">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="en">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="es">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="fr">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="it">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="no">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="pt">is top concept in scheme</rdfs:label>
        <rdfs:label xml:lang="ro">is top concept in scheme</rdfs:label>
        <skos:definition xml:lang="en">Relates a concept to the concept scheme that it is a top level concept of.</skos:definition>
    </ObjectProperty>
    


    <!-- http://xmlns.com/foaf/0.1/account -->


    <ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/account">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/OnlineAccount"/>
        <rdfs:comment>Indicates an account held by this agent.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://xmlns.com/foaf/0.1/"/>
        <rdfs:label>account</rdfs:label>
        <ns2:term_status>testing</ns2:term_status>
    </ObjectProperty>
    


    <!-- http://xmlns.com/foaf/0.1/accountServiceHomepage -->


    <ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/accountServiceHomepage">
