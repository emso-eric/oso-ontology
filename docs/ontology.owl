        <rdfs:label xml:lang="no">Planlagt</rdfs:label>
        <rdfs:label xml:lang="en">Planned</rdfs:label>
        <rdfs:label xml:lang="el">Σχεδιαζόμενο</rdfs:label>
        <skos:definition xml:lang="en">A site that is planned but not yet deployed or operational.</skos:definition>
        <skos:definition xml:lang="no">Et sted som er planlagt, men ennå ikke utplassert eller i drift.</skos:definition>
        <skos:definition xml:lang="pt">Um sítio planeado mas ainda não implantado nem operacional.</skos:definition>
        <skos:definition xml:lang="ro">Un sit planificat, dar încă nedesfășurat sau operațional.</skos:definition>
        <skos:definition xml:lang="fr">Un site planifié mais non encore déployé ni opérationnel.</skos:definition>
        <skos:definition xml:lang="es">Un sitio que está planificado pero aún no desplegado ni operativo.</skos:definition>
        <skos:definition xml:lang="it">Un sito pianificato ma non ancora implementato né operativo.</skos:definition>
        <skos:definition xml:lang="el">Σχεδιαζόμενο: τόπος που έχει προγραμματιστεί αλλά δεν έχει ακόμη αναπτυχθεί ή λειτουργήσει.</skos:definition>
        <skos:prefLabel xml:lang="it">Pianificato</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Planeado</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Planificado</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Planificat</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Planifié</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Planlagt</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Planned</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Σχεδιαζόμενο</skos:prefLabel>
    </owl:NamedIndividual>
    


