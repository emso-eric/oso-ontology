        <mod:competencyQuestion xml:lang="el">Ποιες πλατφόρμες ανήκουν σε έναν συγκεκριμένο σταθμό;</mod:competencyQuestion>
        <mod:competencyQuestion xml:lang="el">Ποιες ωκεανογραφικές αποστολές συνδέονται με μια περιφερειακή υποδομή;</mod:competencyQuestion>
        <mod:competencyQuestion xml:lang="el">Ποιο είναι το βάθος μιας πλατφόρμας;</mod:competencyQuestion>
        <mod:competencyQuestion xml:lang="el">Ποιοι οργανισμοί συμμετέχουν σε μια συγκεκριμένη υποδομή παρατήρησης;</mod:competencyQuestion>
        <mod:competencyQuestion xml:lang="el">Ποιοι σταθμοί αποτελούν μέρος μιας περιφερειακής υποδομής;</mod:competencyQuestion>
        <mod:competencyQuestion xml:lang="el">Ποιος είναι ο κύριος ερευνητής (PI) ή ο περιφερειακός υπεύθυνος;</mod:competencyQuestion>
        <mod:group rdf:resource="https://data.earthportal.eu/groups/DATA_TERRA"/>
        <mod:group rdf:resource="https://data.earthportal.eu/groups/IFREMER"/>
        <mod:group rdf:resource="https://data.earthportal.eu/groups/ODATIS"/>
        <mod:hierarchyProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <mod:maxDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</mod:maxDepth>
        <mod:ontologyInUse rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO_DMSG"/>
        <mod:ontologyInUse rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO_EVOLVE"/>
    </owl:Ontology>
    <rdf:Description rdf:nodeID="genid1">
        <rdf:type rdf:resource="http://www.w3.org/ns/adms#Identifier"/>
        <skos:notation>10.25504/FAIRsharing.654931</skos:notation>
        <skos:prefLabel xml:lang="en">FAIRsharing DOI for OSO</skos:prefLabel>
    </rdf:Description>
