    <!-- http://www.w3.org/2004/02/skos/core#hiddenLabel -->


    <AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#hiddenLabel">
        <rdfs:comment xml:lang="el">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="en">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="es">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="fr">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="it">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="no">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="pt">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="ro">The range of skos:hiddenLabel is the class of RDF plain literals.</rdfs:comment>
        <rdfs:comment xml:lang="el">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</rdfs:comment>
        <rdfs:comment xml:lang="en">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</rdfs:comment>
        <rdfs:comment xml:lang="es">skos:prefLabel, skos:altLabel and skos:hiddenLabel are pairwise disjoint properties.</rdfs:comment>
