        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date marking the end of deployment of an instrument, platform, or infrastructure.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Date marquant la fin du déploiement d’un instrument, d’une plateforme ou d’une infrastructure.</rdfs:comment>
        <rdfs:label xml:lang="pt">Data de fim da implantação</rdfs:label>
