        <skos:prefLabel xml:lang="ro">Ontologia observatoarelor marine</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Ontologie des observatoires marins</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Ontología de los observatorios marinos</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Οντολογία θαλάσσιων παρατηρητηρίων</skos:prefLabel>
