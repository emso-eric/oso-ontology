    <!-- https://w3id.org/earthsemantics/OSO#EMSO_EVOLVE -->


    <owl:NamedIndividual rdf:about="https://w3id.org/earthsemantics/OSO#EMSO_EVOLVE">
        <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#FundedProject"/>
        <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#European_Commission"/>
        <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#European_Union"/>
        <terms:identifier>HORIZON-INFRA-2025-01</terms:identifier>
        <schema:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2030-08-31</schema:endDate>
        <schema:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-09-01</schema:startDate>
        <terms:description xml:lang="no">EMSO EVOLVE er et europeisk prosjekt som støtter langsiktige havobservasjoner og miljømessig bærekraft innenfor rammen av EMSO ERIC.</terms:description>
        <terms:description xml:lang="es">EMSO EVOLVE es un proyecto europeo que apoya las observaciones oceánicas a largo plazo y la sostenibilidad medioambiental en el marco de EMSO ERIC.</terms:description>
        <terms:description xml:lang="fr">EMSO EVOLVE est un projet européen soutenant les observations océaniques à long terme et la durabilité environnementale dans le cadre d’EMSO ERIC.</terms:description>
        <terms:description xml:lang="ro">EMSO EVOLVE este un proiect european care sprijină observațiile oceanice pe termen lung și sustenabilitatea de mediu în cadrul EMSO ERIC.</terms:description>
        <terms:description xml:lang="en">EMSO EVOLVE is a European project supporting long-term ocean observations and environmental sustainability within the EMSO ERIC framework.</terms:description>
        <terms:description xml:lang="it">EMSO EVOLVE è un progetto europeo che sostiene le osservazioni oceaniche a lungo termine e la sostenibilità ambientale nel quadro di EMSO ERIC.</terms:description>
        <terms:description xml:lang="pt">EMSO EVOLVE é um projeto europeu que apoia observações oceânicas de longo prazo e a sustentabilidade ambiental no quadro do EMSO ERIC.</terms:description>
        <terms:description xml:lang="el">Το EMSO EVOLVE είναι ένα ευρωπαϊκό έργο που υποστηρίζει τις μακροπρόθεσμες ωκεάνιες παρατηρήσεις και την περιβαλλοντική βιωσιμότητα στο πλαίσιο του EMSO ERIC.</terms:description>
        <terms:title xml:lang="en">European VisiOn for Long-term Ocean Observations and EnVironmEntal Sustainability (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="no">Europeisk visjon for langsiktige havobservasjoner og miljømessig bærekraft (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="fr">Vision européenne pour les observations océaniques à long terme et la durabilité environnementale (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="it">Visione europea per osservazioni oceaniche a lungo termine e sostenibilità ambientale (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="es">Visión europea para observaciones oceánicas a largo plazo y sostenibilidad medioambiental (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="pt">Visão europeia para observações oceânicas de longo prazo e sustentabilidade ambiental (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="ro">Viziune europeană pentru observații oceanice pe termen lung și sustenabilitate de mediu (EMSO EVOLVE)</terms:title>
        <terms:title xml:lang="el">Ευρωπαϊκό Όραμα για μακροπρόθεσμες ωκεάνιες παρατηρήσεις και περιβαλλοντική βιωσιμότητα (EMSO EVOLVE)</terms:title>
