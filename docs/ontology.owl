        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2002/07/owl#"/>
        <rdfs:label>onProperties</rdfs:label>
    </ObjectProperty>
    


    <!-- http://www.w3.org/2002/07/owl#onProperty -->


