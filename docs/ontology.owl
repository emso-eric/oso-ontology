    <!-- https://w3id.org/earthsemantics/OSO#REVOSIMA -->


    <owl:NamedIndividual rdf:about="https://w3id.org/earthsemantics/OSO#REVOSIMA">
        <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#FundedProject"/>
        <skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q66811844"/>
        <foaf:homepage rdf:resource="https://www.ipgp.fr/en/observation/national-hosted-infrastructures/revosima/"/>
        <foaf:homepage rdf:resource="https://www.ipgp.fr/observation/infrastructures-nationales-hebergees/revosima/"/>
        <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#BRGM"/>
        <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#CNRS"/>
        <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#IPGP"/>
        <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#Ifremer"/>
        <OSO:hasLogo rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/2f70cd19809477fabc1c18af2ca0ea000f945d79/images/revosima.png"/>
        <terms:description xml:lang="no">REVOSIMA er overvåkingsnettverket for vulkanologi og seismologi på Mayotte, som støtter kontinuerlig observasjon av pågående seismo-vulkansk aktivitet.</terms:description>
        <terms:description xml:lang="es">REVOSIMA es la red de vigilancia volcanológica y sismológica de Mayotte que apoya la observación continua de la actividad sismo-volcánica en curso.</terms:description>
        <terms:description xml:lang="fr">REVOSIMA est le réseau de surveillance volcanologique et sismologique de Mayotte assurant le suivi continu de l’activité sismo-volcanique en cours.</terms:description>
        <terms:description xml:lang="ro">REVOSIMA este rețeaua de monitorizare vulcanologică și seismologică din Mayotte, care susține observarea continuă a activității seismo-vulcanice în desfășurare.</terms:description>
        <terms:description xml:lang="en">REVOSIMA is the Mayotte volcanological and seismological monitoring network supporting continuous observation of the ongoing seismo-volcanic activity.</terms:description>
        <terms:description xml:lang="it">REVOSIMA è la rete di monitoraggio vulcanologico e sismologico di Mayotte che supporta l’osservazione continua dell’attività sismo-vulcanica in corso.</terms:description>
        <terms:description xml:lang="pt">REVOSIMA é a rede de monitorização vulcanológica e sismológica de Mayotte, que apoia a observação contínua da atividade sismo-vulcânica em curso.</terms:description>
        <terms:description xml:lang="el">Το REVOSIMA είναι το δίκτυο ηφαιστειολογικής και σεισμολογικής παρακολούθησης της Μαγιότ, που υποστηρίζει τη συνεχή παρατήρηση της εν εξελίξει σεισμοηφαιστειακής δραστηριότητας.</terms:description>
        <rdfs:label xml:lang="el">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="en">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="es">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="fr">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="it">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="no">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="pt">REVOSIMA</rdfs:label>
        <rdfs:label xml:lang="ro">REVOSIMA</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://fr.wikipedia.org/wiki/Fani_Maor%C3%A9"/>
        <rdfs:seeAlso rdf:resource="https://fr.wikipedia.org/wiki/R%C3%A9seau_de_surveillance_volcanologique_et_sismologique_de_Mayotte"/>
        <rdfs:seeAlso rdf:resource="https://sextant.ifremer.fr/Ressources/Liste-des-catalogues-thematiques/Revosima"/>
        <rdfs:seeAlso rdf:resource="https://www.brgm.fr/fr/actualite/actualite/volcan-seismes-mayotte-surveillance-confiee-au-revosima"/>
        <skos:altLabel xml:lang="en">Mayotte Volcanological and Seismological Monitoring Network</skos:altLabel>
        <skos:altLabel xml:lang="fr">Réseau de surveillance volcanologique et sismologique de Mayotte</skos:altLabel>
        <skos:prefLabel xml:lang="el">REVOSIMA</skos:prefLabel>
        <skos:prefLabel xml:lang="en">REVOSIMA</skos:prefLabel>
