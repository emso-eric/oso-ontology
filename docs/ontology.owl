    <!-- https://w3id.org/earthsemantics/OSO#Planned -->


    <owl:NamedIndividual rdf:about="https://w3id.org/earthsemantics/OSO#Planned">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:label xml:lang="it">Pianificato</rdfs:label>
        <rdfs:label xml:lang="pt">Planeado</rdfs:label>
        <rdfs:label xml:lang="es">Planificado</rdfs:label>
        <rdfs:label xml:lang="ro">Planificat</rdfs:label>
