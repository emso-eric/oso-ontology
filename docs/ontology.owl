        <ns2:term_status>testing</ns2:term_status>
    </ObjectProperty>
    


    <!-- http://xmlns.com/foaf/0.1/aimChatID -->


    <ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/aimChatID">
