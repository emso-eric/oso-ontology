    <!-- https://w3id.org/earthsemantics/OSO#NOC -->


    <owl:NamedIndividual rdf:about="https://w3id.org/earthsemantics/OSO#NOC">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <skos:exactMatch rdf:resource="https://ror.org/00874hx02"/>
        <foaf:homepage rdf:resource="https://noc.ac.uk/"/>
        <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#United_Kingdom"/>
        <OSO:hasEDMO rdf:resource="https://edmo.seadatanet.org/report/17"/>
        <OSO:hasROR rdf:resource="https://ror.org/00874hx02"/>
        <terms:description xml:lang="es">El NOC es el Centro Nacional de Oceanografía del Reino Unido, dedicado a la ciencia y tecnología oceánica.</terms:description>
        <terms:description xml:lang="it">Il NOC è il Centro Nazionale di Oceanografia del Regno Unito, dedicato alla scienza e alla tecnologia oceanica.</terms:description>
        <terms:description xml:lang="fr">Le NOC est le Centre national d’océanographie du Royaume-Uni, dédié à la science et aux technologies océaniques.</terms:description>
        <terms:description xml:lang="no">NOC er Storbritannias nasjonale senter for oseanografi, dedikert til havforskning og teknologi.</terms:description>
        <terms:description xml:lang="ro">NOC este Centrul Național de Oceanografie al Regatului Unit, dedicat științei și tehnologiei oceanice.</terms:description>
        <terms:description xml:lang="en">NOC is the United Kingdom’s National Oceanography Centre, dedicated to ocean science and technology.</terms:description>
        <terms:description xml:lang="pt">O NOC é o Centro Nacional de Oceanografia do Reino Unido, dedicado à ciência e tecnologia oceânica.</terms:description>
