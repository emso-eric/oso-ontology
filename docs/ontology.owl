        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchProject"/>
        <rdfs:comment xml:lang="en">A research project supported by dedicated financial funding from one or more organizations or funding bodies.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un projet de recherche soutenu par un financement dédié provenant d&apos;une ou plusieurs organisations ou agences de financement.</rdfs:comment>
        <rdfs:label xml:lang="no">Finansiert prosjekt</rdfs:label>
        <rdfs:label xml:lang="en">Funded project</rdfs:label>
        <rdfs:label xml:lang="it">Progetto finanziato</rdfs:label>
        <rdfs:label xml:lang="ro">Proiect finanțat</rdfs:label>
        <rdfs:label xml:lang="fr">Projet financé</rdfs:label>
        <rdfs:label xml:lang="pt">Projeto financiado</rdfs:label>
        <rdfs:label xml:lang="es">Proyecto financiado</rdfs:label>
        <rdfs:label xml:lang="el">Χρηματοδοτούμενο έργο</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#Geometry -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#Geometry"/>
    


    <!-- https://w3id.org/earthsemantics/OSO#OceanographicCampaign -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#OceanographicCampaign">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns"/>
        <metadata:prefixIRI>omv:OceanographicCampaign</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">An oceanographic campaign linked to a Regional Facility</rdfs:comment>
        <rdfs:comment xml:lang="no">En havforskningskampanje knyttet til en regional infrastruktur</rdfs:comment>
        <rdfs:comment xml:lang="ro">O campanie oceanografică asociată unei infrastructuri regionale</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uma campanha oceanográfica associada a uma infraestrutura regional</rdfs:comment>
        <rdfs:comment xml:lang="it">Una campagna oceanografica collegata a una struttura regionale</rdfs:comment>
        <rdfs:comment xml:lang="es">Una campaña oceanográfica vinculada a una instalación regional</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une campagne océanographique liée à un noeud régional</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια ωκεανογραφική εκστρατεία που συνδέεται με μια περιφερειακή υποδομή</rdfs:comment>
        <rdfs:label xml:lang="it">Campagna oceanografica</rdfs:label>
        <rdfs:label xml:lang="fr">Campagne océanographique</rdfs:label>
        <rdfs:label xml:lang="pt">Campanha oceanográfica</rdfs:label>
        <rdfs:label xml:lang="ro">Campanie oceanografică</rdfs:label>
        <rdfs:label xml:lang="es">Campaña oceanográfica</rdfs:label>
        <rdfs:label xml:lang="en">Cruise</rdfs:label>
        <rdfs:label xml:lang="no">Kampanje</rdfs:label>
        <rdfs:label xml:lang="el">Ωκεανογραφική εκστρατεία</rdfs:label>
        <skos:prefLabel xml:lang="it">Campagna oceanografica</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Campagne océanographique</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Campanha oceanográfica</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Campanie oceanografică</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Campaña oceanográfica</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Cruise</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Kampanje</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Ωκεανογραφική εκστρατεία</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#Platform -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#Platform">
        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#Subsite"/>
        <metadata:prefixIRI>OSO:Platform</metadata:prefixIRI>
        <terms:source rdf:resource="http://vocab.nerc.ac.uk/collection/L06/current/"/>
        <rdfs:comment xml:lang="en">An observation platform, fixed or mobile, installed on a site or subsite, supporting one or more instruments or acquisition systems.</rdfs:comment>
        <rdfs:comment xml:lang="no">En observasjonsplattform, fast eller mobil, installert på et sted eller underområde, som støtter ett eller flere instrumenter eller innhentingssystemer.</rdfs:comment>
        <rdfs:comment xml:lang="ro">O platformă de observație, fixă sau mobilă, instalată într-un site sau subsite, care suportă unul sau mai multe instrumente sau sisteme de achiziție.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uma plataforma de observação, fixa ou móvel, instalada num local ou sublocal, suportando um ou mais instrumentos ou sistemas de aquisição.</rdfs:comment>
        <rdfs:comment xml:lang="it">Una piattaforma di osservazione, fissa o mobile, installata su un sito o sotto-sito, che supporta uno o più strumenti o sistemi di acquisizione.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una plataforma de observación, fija o móvil, instalada en un sitio o sub-sitio, que soporta uno o más instrumentos o sistemas de adquisición.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une plateforme d&apos;observation fixe ou mobile, installée sur un site ou un sous-site, supportant un ou plusieurs instruments ou systèmes d&apos;acquisition.</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια πλατφόρμα παρατήρησης, σταθερή ή κινητή, εγκατεστημένη σε έναν τόπο ή υποτοποθεσία, υποστηρίζοντας ένα ή περισσότερα όργανα ή συστήματα συλλογής δεδομένων.</rdfs:comment>
        <rdfs:label xml:lang="no">Observasjonsplattform</rdfs:label>
        <rdfs:label xml:lang="en">Observation Platform</rdfs:label>
        <rdfs:label xml:lang="it">Piattaforma di osservazione</rdfs:label>
        <rdfs:label xml:lang="es">Plataforma de observación</rdfs:label>
        <rdfs:label xml:lang="pt">Plataforma de observação</rdfs:label>
        <rdfs:label xml:lang="fr">Plateforme d&apos;observation</rdfs:label>
        <rdfs:label xml:lang="ro">Platformă de observație</rdfs:label>
        <rdfs:label xml:lang="el">Πλατφόρμα παρατήρησης</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://vocab.nerc.ac.uk/collection/L06/current/"/>
        <skos:prefLabel xml:lang="no">Observasjonsplattform</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Observation Platform</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Piattaforma di osservazione</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Plataforma de observación</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Plataforma de observação</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Plateforme d&apos;observation</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Platformă de observație</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Πλατφόρμα παρατήρησης</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#RegionalFacility -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#RegionalFacility">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <metadata:prefixIRI>OSO:RegionalFacility</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">A regional facility containing sites, associated with research infrastructures, oceanographic campaigns, organizations, and a Regional Team Leader.</rdfs:comment>
        <rdfs:comment xml:lang="es">Infraestructura regional que contiene sitios, asociada a infraestructuras de investigación, campañas oceanográficas, organizaciones y un líder de equipo regional.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Infraestrutura regional que contém locais, associada a infraestruturas de investigação, campanhas oceanográficas, organizações e um líder regional.</rdfs:comment>
        <rdfs:comment xml:lang="ro">Infrastructură regională care conține site-uri, asociată cu infrastructuri de cercetare, campanii oceanografice, organizații și un lider de echipă regional.</rdfs:comment>
        <rdfs:comment xml:lang="it">Infrastruttura regionale contenente siti, associata a infrastrutture di ricerca, campagne oceanografiche, organizzazioni e un coordinatore regionale.</rdfs:comment>
        <rdfs:comment xml:lang="no">Regional fasilitet som inneholder lokaliteter, tilknyttet forskningsinfrastrukturer, havkampanjer, organisasjoner og en regionalt ansvarlig.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une noeud régional comprenant plusieurs sites, liée à des infrastructures de recherche, des campagnes océanographiques, des organisations et un coordinateur régional.</rdfs:comment>
        <rdfs:comment xml:lang="el">Περιφερειακή υποδομή που περιλαμβάνει τοποθεσίες, συνδέεται με ερευνητικές υποδομές, ωκεανογραφικές εκστρατείες, οργανισμούς και έναν υπεύθυνο ομάδας.</rdfs:comment>
        <rdfs:label xml:lang="es">Infraestructura regional</rdfs:label>
        <rdfs:label xml:lang="pt">Infraestrutura regional</rdfs:label>
        <rdfs:label xml:lang="ro">Infrastructură regională</rdfs:label>
        <rdfs:label xml:lang="it">Infrastruttura regionale</rdfs:label>
        <rdfs:label xml:lang="fr">Nœud régional</rdfs:label>
        <rdfs:label xml:lang="en">Regional Facility</rdfs:label>
        <rdfs:label xml:lang="no">Regional fasilitet</rdfs:label>
        <rdfs:label xml:lang="el">Περιφερειακή υποδομή</rdfs:label>
        <skos:prefLabel xml:lang="es">Infraestructura regional</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Infraestrutura regional</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Infrastructură regională</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Infrastruttura regionale</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Nœud régional</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Regional Facility</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Regional fasilitet</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Περιφερειακή υποδομή</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#ResearchInfrastructure -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <metadata:prefixIRI>OSO:ResearchInfrastructure</metadata:prefixIRI>
        <rdfs:comment xml:lang="el">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="en">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="es">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="fr">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="it">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="no">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="pt">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:comment xml:lang="ro">A research infrastructure may bring together one or more Regional Facilities</rdfs:comment>
        <rdfs:label xml:lang="el">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="en">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="es">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="fr">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="it">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="no">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="pt">Research Infrastructure</rdfs:label>
        <rdfs:label xml:lang="ro">Research Infrastructure</rdfs:label>
        <skos:definition xml:lang="en">The following definition for RI from Article 2 (6) of the Regulation (EU) No 1291/2013 of 11 December 2013: `Establishing Horizon 2020 - the Framework Programme for Research and Innovation (2014- 2020)` applies: “RI are facilities, resources and services that are used by the research communities to conduct research and foster innovation in their fields. They include: major scientific equipment (or sets of instruments), knowledge-based resources such as collections, archives and scientific data, einfrastructures, such as data and computing systems and communication networks and any other tools that are essential to achieve excellence in research and innovation.” Accordingly, RI are implemented along different organisational models, including central sources and laboratories for experiments and measurement sessions, coordination and management of geographically distributed observatories or laboratories, remotely accessible resources for computing, data banks, physical sample repositories, surveys and longitudinal studies.</skos:definition>
        <skos:note xml:lang="en">RI</skos:note>
        <skos:note xml:lang="fr">RI</skos:note>
        <skos:prefLabel xml:lang="el">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Research Infrastructure</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Research Infrastructure</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#ResearchProject -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#ResearchProject">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Project"/>
        <rdfs:comment xml:lang="en">A structured scientific activity designed to produce new knowledge, data, or understanding within a defined scope and duration.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une activité scientifique structurée visant à produire de nouvelles connaissances, données ou compréhensions dans un périmètre et une durée définis.</rdfs:comment>
        <rdfs:label xml:lang="no">Forskningsprosjekt</rdfs:label>
        <rdfs:label xml:lang="it">Progetto di ricerca</rdfs:label>
        <rdfs:label xml:lang="ro">Proiect de cercetare</rdfs:label>
        <rdfs:label xml:lang="fr">Projet de recherche</rdfs:label>
        <rdfs:label xml:lang="pt">Projeto de investigação</rdfs:label>
        <rdfs:label xml:lang="es">Proyecto de investigación</rdfs:label>
        <rdfs:label xml:lang="en">Research project</rdfs:label>
        <rdfs:label xml:lang="el">Ερευνητικό έργο</rdfs:label>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <metadata:prefixIRI>omv:SeriesOfOceanographicCampaigns</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">A series of oceanographic campaigns linked to a Regional Facility.</rdfs:comment>
        <rdfs:comment xml:lang="no">En serie med havforskningskampanjer knyttet til en regional infrastruktur.</rdfs:comment>
        <rdfs:comment xml:lang="ro">O serie de campanii oceanografice asociate unei infrastructuri regionale.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uma série de campanhas oceanográficas associadas a uma infraestrutura regional.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una serie de campañas oceanográficas vinculadas a una instalación regional.</rdfs:comment>
        <rdfs:comment xml:lang="it">Una serie di campagne oceanografiche collegate a una struttura regionale.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une série de campagnes océanographiques liées à un noeud régional.</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια σειρά από ωκεανογραφικές εκστρατείες που συνδέονται με μια περιφερειακή υποδομή</rdfs:comment>
        <rdfs:label xml:lang="ro">Serie de campanii oceanografice</rdfs:label>
        <rdfs:label xml:lang="es">Serie de campañas oceanográficas</rdfs:label>
        <rdfs:label xml:lang="it">Serie di campagne oceanografiche</rdfs:label>
        <rdfs:label xml:lang="no">Serie med havforskningskampanjer</rdfs:label>
        <rdfs:label xml:lang="en">Series of Oceanographic Campaigns</rdfs:label>
        <rdfs:label xml:lang="fr">Série de campagnes océanographiques</rdfs:label>
        <rdfs:label xml:lang="pt">Série de campanhas oceanográficas</rdfs:label>
        <rdfs:label xml:lang="el">Σειρά ωκεανογραφικών εκστρατειών</rdfs:label>
        <skos:prefLabel xml:lang="ro">Serie de campanii oceanografice</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Serie de campañas oceanográficas</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Serie di campagne oceanografiche</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Serie med havforskningskampanjer</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Series of Oceanographic Campaigns</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Série de campagnes océanographiques</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Série de campanhas oceanográficas</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Σειρά ωκεανογραφικών εκστρατειών</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#Site -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#Site">
        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
        <metadata:prefixIRI>OSO:Site</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">A localized observatory site, attached to a regional facility, potentially hosting one or more measurement platforms.</rdfs:comment>
        <rdfs:comment xml:lang="no">Et lokalisert observasjonssted tilknyttet en regional fasilitet, som potensielt huser en eller flere måleplattformer.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Um local de observação localizado, associado a uma infraestrutura regional, podendo acolher uma ou mais plataformas de medição.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un site observatoire localisé, rattaché à un nœud régional, pouvant accueillir une ou plusieurs plateformes de mesure.</rdfs:comment>
        <rdfs:comment xml:lang="ro">Un site observator localizat, asociat cu o facilitate regională, care poate găzdui una sau mai multe platforme de măsurare.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un sitio de observación localizado, vinculado a una infraestructura regional, que puede albergar una o más plataformas de medición.</rdfs:comment>
        <rdfs:comment xml:lang="it">Un sito osservatorio localizzato, collegato a una struttura regionale, che può ospitare una o più piattaforme di misura.</rdfs:comment>
        <rdfs:comment xml:lang="el">Ένας τοπικός τόπος παρατήρησης, συνδεδεμένος με μια περιφερειακή υποδομή, που μπορεί να φιλοξενήσει μία ή περισσότερες πλατφόρμες μέτρησης.</rdfs:comment>
        <rdfs:label xml:lang="ro">Loc de observare</rdfs:label>
        <rdfs:label xml:lang="pt">Local de observação</rdfs:label>
        <rdfs:label xml:lang="no">Observasjonssted</rdfs:label>
        <rdfs:label xml:lang="en">Observatory Site</rdfs:label>
        <rdfs:label xml:lang="fr">Site d&apos;observation</rdfs:label>
        <rdfs:label xml:lang="es">Sitio de observación</rdfs:label>
        <rdfs:label xml:lang="it">Sito di osservazione</rdfs:label>
        <rdfs:label xml:lang="el">Τόπος παρατήρησης</rdfs:label>
        <skos:prefLabel xml:lang="ro">Loc de observare</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Local de observação</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Observasjonssted</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Observatory Site</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Site d&apos;observation</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Sitio de observación</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Sito di osservazione</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Τόπος παρατήρησης</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#SubPlatform -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#SubPlatform">
        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
        <metadata:prefixIRI>OSO:SubPlatform</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">An observation subplatform, a component or specific segment of a platform, dedicated to a particular type of measurement or instrumental configuration.</rdfs:comment>
        <rdfs:comment xml:lang="no">En underplattform for observasjon, en komponent eller spesifikt segment av en plattform, dedikert til en bestemt måletype eller instrumentkonfigurasjon.</rdfs:comment>
        <rdfs:comment xml:lang="ro">O subplatformă de observație, componentă sau segment specific al unei platforme, dedicată unui tip particular de măsurare sau configurație instrumentală.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Uma subplataforma de observação, componente ou segmento específico de uma plataforma, dedicada a um tipo particular de medição ou configuração instrumental.</rdfs:comment>
        <rdfs:comment xml:lang="it">Una sotto-piattaforma di osservazione, componente o segmento specifico di una piattaforma, dedicata a un tipo particolare di misurazione o configurazione strumentale.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una subplataforma de observación, componente o segmento específico de una plataforma, dedicada a un tipo particular de medición o configuración instrumental.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Une sous-plateforme d&apos;observation, élément constitutif ou segment spécifique d&apos;une plateforme, dédiée à un type particulier de mesure ou de configuration instrumentale.</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια υποπλατφόρμα παρατήρησης, συστατικό ή συγκεκριμένο τμήμα μιας πλατφόρμας, αφιερωμένη σε έναν συγκεκριμένο τύπο μέτρησης ή οργανολογικής διάταξης.</rdfs:comment>
        <rdfs:label xml:lang="en">Observation Subplatform</rdfs:label>
        <rdfs:label xml:lang="it">Sotto-piattaforma di osservazione</rdfs:label>
        <rdfs:label xml:lang="fr">Sous-plateforme d&apos;observation</rdfs:label>
        <rdfs:label xml:lang="es">Subplataforma de observación</rdfs:label>
        <rdfs:label xml:lang="pt">Subplataforma de observação</rdfs:label>
        <rdfs:label xml:lang="ro">Subplatformă de observație</rdfs:label>
        <rdfs:label xml:lang="no">Underplattform for observasjon</rdfs:label>
        <rdfs:label xml:lang="el">Υποπλατφόρμα παρατήρησης</rdfs:label>
        <skos:prefLabel xml:lang="en">Observation Subplatform</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Sotto-piattaforma di osservazione</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Sous-plateforme d&apos;observation</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Subplataforma de observación</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Subplataforma de observação</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Subplatformă de observație</skos:prefLabel>
        <skos:prefLabel xml:lang="no">Underplattform for observasjon</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Υποπλατφόρμα παρατήρησης</skos:prefLabel>
    </Class>
    


    <!-- https://w3id.org/earthsemantics/OSO#Subsite -->


    <Class rdf:about="https://w3id.org/earthsemantics/OSO#Subsite">
        <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
        <metadata:prefixIRI>OSO:Subsite</metadata:prefixIRI>
        <rdfs:comment xml:lang="en">A subsite of observation, a finer component of a site, enabling increased spatial granularity for measurement or instrumentation.</rdfs:comment>
        <rdfs:comment xml:lang="no">Et delområde for observasjon, en finere komponent av et sted, som muliggjør økt romlig granularitet for måling eller instrumentering.</rdfs:comment>
        <rdfs:comment xml:lang="pt">Um sublocal de observação, componente mais detalhado de um site, permitindo maior granularidade espacial para medições ou instrumentação.</rdfs:comment>
        <rdfs:comment xml:lang="it">Un sotto-sito di osservazione, componente più fine di un sito, che consente una maggiore granularità spaziale per le misurazioni o la strumentazione.</rdfs:comment>
        <rdfs:comment xml:lang="fr">Un sous-site d&apos;observation, composante plus fine d’un site, qui permet une granularité spatiale accrue pour la mesure ou l&apos;instrumentation.</rdfs:comment>
        <rdfs:comment xml:lang="ro">Un sub-site de observație, componentă mai detaliată a unui site, care permite o granularitate spațială crescută pentru măsurători sau instrumentare.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un sub-sitio de observación, componente más detallado de un sitio, que permite una mayor granularidad espacial para mediciones o instrumentación.</rdfs:comment>
        <rdfs:comment xml:lang="el">Μια υποτοποθεσία παρατήρησης, λεπτότερο συστατικό ενός τόπου, που επιτρέπει αυξημένη χωρική ανάλυση για μέτρηση ή οργανολογία.</rdfs:comment>
        <rdfs:label xml:lang="no">Delområde for observasjon</rdfs:label>
        <rdfs:label xml:lang="en">Observation Subsite</rdfs:label>
        <rdfs:label xml:lang="it">Sotto-sito di osservazione</rdfs:label>
        <rdfs:label xml:lang="fr">Sous-site d&apos;observation</rdfs:label>
        <rdfs:label xml:lang="ro">Sub-site de observație</rdfs:label>
        <rdfs:label xml:lang="es">Sub-sitio de observación</rdfs:label>
        <rdfs:label xml:lang="pt">Sublocal de observação</rdfs:label>
        <rdfs:label xml:lang="el">Υποτοποθεσία παρατήρησης</rdfs:label>
        <skos:prefLabel xml:lang="no">Delområde for observasjon</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Observation Subsite</skos:prefLabel>
        <skos:prefLabel xml:lang="it">Sotto-sito di osservazione</skos:prefLabel>
        <skos:prefLabel xml:lang="fr">Sous-site d&apos;observation</skos:prefLabel>
        <skos:prefLabel xml:lang="ro">Sub-site de observație</skos:prefLabel>
        <skos:prefLabel xml:lang="es">Sub-sitio de observación</skos:prefLabel>
        <skos:prefLabel xml:lang="pt">Sublocal de observação</skos:prefLabel>
        <skos:prefLabel xml:lang="el">Υποτοποθεσία παρατήρησης</skos:prefLabel>
    </Class>
    


