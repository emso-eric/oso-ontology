    <!-- https://w3id.org/earthsemantics/OSO#EuxRo01 -->


    <owl:NamedIndividual rdf:about="https://w3id.org/earthsemantics/OSO#EuxRo01">
        <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
        <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#EuxRo01_surface_buoy"/>
