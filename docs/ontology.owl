    <!-- https://w3id.org/earthsemantics/OSO#dateEndDeployment -->


    <DatatypeProperty rdf:about="https://w3id.org/earthsemantics/OSO#dateEndDeployment">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/endDate"/>
        <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
