                                                                    "está ligada a uma campanha"@pt ,
                                                                    "está vinculada a una campaña"@es ,
                                                                    "is linked to campaign"@en ,
                                                                    "è collegata a una campagna"@it ,
                                                                    "συνδέεται με εκστρατεία"@el ;
