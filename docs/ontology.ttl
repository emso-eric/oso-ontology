###  https://w3id.org/earthsemantics/OSO#isTestSite
<https://w3id.org/earthsemantics/OSO#isTestSite> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <https://w3id.org/earthsemantics/OSO#Site> ,
                                                             <https://w3id.org/earthsemantics/OSO#Subsite> ;
                                                 rdfs:range xsd:boolean ;
                                                 rdfs:comment "Angir om et sted eller delsted regnes som et teststed (true/false)."@no ,
                                                              "Indica se um sítio ou subsítio é considerado um sítio de teste (true/false)."@pt ,
                                                              "Indica se un sito o sottosito è considerato un sito di test (true/false)."@it ,
                                                              "Indica si un sitio o subsitio se considera un sitio de prueba (true/false)."@es ,
                                                              "Indicates whether a site or subsite is considered a test site (true/false)."@en ,
                                                              "Indică dacă un sit sau un subsit este considerat sit de testare (true/false)."@ro ,
                                                              "Indique si un site ou sous-site est considéré comme un site de test (true/false)."@fr ,
                                                              "Υποδεικνύει εάν ένας τόπος ή υποτόπος θεωρείται δοκιμαστικός τόπος (true/false)."@el ;
                                                 rdfs:label "er teststed"@no ,
                                                            "es sitio de prueba"@es ,
                                                            "est un site de test"@fr ,
                                                            "este sit de testare"@ro ,
                                                            "is test site"@en ,
                                                            "è un sito di test"@it ,
                                                            "é sítio de teste"@pt ,
                                                            "είναι δοκιμαστικός τόπος"@el ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "er teststed"@no ,
                                                                                                 "es sitio de prueba"@es ,
                                                                                                 "est un site de test"@fr ,
                                                                                                 "este sit de testare"@ro ,
                                                                                                 "is test site"@en ,
                                                                                                 "è un sito di test"@it ,
                                                                                                 "é sítio de teste"@pt ,
                                                                                                 "είναι δοκιμαστικός τόπος"@el .


