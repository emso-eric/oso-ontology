                                                                                                        "IC"@ro ,
                                                                                                        "II"@pt ,
                                                                                                        "IIdI"@es ,
                                                                                                        "IR"@fr ,
                                                                                                        "IR"@it ,
                                                                                                        "RI"@en ,
                                                                                                        "ΕΥ"@el ;
                                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "Forskningsinfrastruktur"@no ,
                                                                                                             "Infraestructura de Investigación"@es ,
                                                                                                             "Infraestrutura de Investigação"@pt ,
                                                                                                             "Infrastructure de recherche"@fr ,
