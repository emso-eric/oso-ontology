###  https://w3id.org/earthsemantics/OSO#Ligurian_Sea
<https://w3id.org/earthsemantics/OSO#Ligurian_Sea> rdf:type owl:NamedIndividual ,
                                                            <https://w3id.org/earthsemantics/OSO#RegionalFacility> ;
                                                   <https://w3id.org/earthsemantics/OSO#RegionalFacilityispartofRI> <https://w3id.org/earthsemantics/OSO#EMSO-France> ;
                                                   <https://w3id.org/earthsemantics/OSO#containsSite> <https://w3id.org/earthsemantics/OSO#BILLION> ,
                                                                                                      <https://w3id.org/earthsemantics/OSO#DYFAMED> ,
                                                                                                      <https://w3id.org/earthsemantics/OSO#LION> ,
                                                                                                      <https://w3id.org/earthsemantics/OSO#LO> ,
                                                                                                      <https://w3id.org/earthsemantics/OSO#Nice> ;
                                                   <https://w3id.org/earthsemantics/OSO#hasBoundingBox> <https://w3id.org/earthsemantics/OSO#Ligurian_Sea_RF_bbox> ;
                                                   <https://w3id.org/earthsemantics/OSO#hasERICMembership> <https://w3id.org/earthsemantics/OSO#Ligurian_Sea_EMSO_membership> ;
                                                   <https://w3id.org/earthsemantics/OSO#hasRegionalTeamLeader> <https://w3id.org/earthsemantics/OSO#Laurent_COPPOLA> ;
                                                   <https://w3id.org/earthsemantics/OSO#ledByOrganization> <https://w3id.org/earthsemantics/OSO#CNRS> ,
                                                                                                           <https://w3id.org/earthsemantics/OSO#Ifremer> ;
                                                   <https://w3id.org/earthsemantics/OSO#linkedToSeries> <https://w3id.org/earthsemantics/OSO#EMSO_LIGURE_OUEST> ,
                                                                                                        <https://w3id.org/earthsemantics/OSO#MOOSE-GE> ,
                                                                                                        <https://w3id.org/earthsemantics/OSO#MUG-OBS> ;
