###  http://www.w3.org/2000/01/rdf-schema#domain
rdfs:domain rdf:type owl:ObjectProperty ;
            rdfs:domain rdf:Property ;
            rdfs:range rdfs:Class ;
            rdfs:comment "A domain of the subject property." ;
            rdfs:isDefinedBy rdfs: ;
            rdfs:label "domain" .


###  http://www.w3.org/2000/01/rdf-schema#member
rdfs:member rdf:type owl:ObjectProperty ;
            rdfs:domain rdfs:Resource ;
            rdfs:range rdfs:Resource ;
            rdfs:comment "A member of the subject resource." ;
            rdfs:isDefinedBy rdfs: ;
            rdfs:label "member" .


###  http://www.w3.org/2000/01/rdf-schema#range
rdfs:range rdf:type owl:ObjectProperty ;
           rdfs:domain rdf:Property ;
           rdfs:range rdfs:Class ;
           rdfs:comment "A range of the subject property." ;
           rdfs:isDefinedBy rdfs: ;
           rdfs:label "range" .


###  http://www.w3.org/2000/01/rdf-schema#subClassOf
rdfs:subClassOf rdf:type owl:ObjectProperty ;
                rdfs:domain rdfs:Class ;
                rdfs:range rdfs:Class ;
                rdfs:comment "The subject is a subclass of a class." ;
                rdfs:isDefinedBy rdfs: ;
                rdfs:label "subClassOf" .


###  http://www.w3.org/2000/01/rdf-schema#subPropertyOf
rdfs:subPropertyOf rdf:type owl:ObjectProperty ;
                   rdfs:domain rdf:Property ;
                   rdfs:range rdf:Property ;
                   rdfs:comment "The subject is a subproperty of a property." ;
                   rdfs:isDefinedBy rdfs: ;
                   rdfs:label "subPropertyOf" .


###  http://www.w3.org/2002/07/owl#allValuesFrom
owl:allValuesFrom rdf:type owl:ObjectProperty ;
                  rdfs:domain owl:Restriction ;
                  rdfs:range rdfs:Class ;
                  rdfs:comment "The property that determines the class that a universal property restriction refers to." ;
                  rdfs:isDefinedBy owl: ;
                  rdfs:label "allValuesFrom" .


###  http://www.w3.org/2002/07/owl#annotatedProperty
owl:annotatedProperty rdf:type owl:ObjectProperty ;
                      rdfs:domain rdfs:Resource ;
                      rdfs:range rdfs:Resource ;
                      rdfs:comment "The property that determines the predicate of an annotated axiom or annotated annotation." ;
                      rdfs:isDefinedBy owl: ;
                      rdfs:label "annotatedProperty" .


###  http://www.w3.org/2002/07/owl#annotatedSource
owl:annotatedSource rdf:type owl:ObjectProperty ;
                    rdfs:domain rdfs:Resource ;
                    rdfs:range rdfs:Resource ;
                    rdfs:comment "The property that determines the subject of an annotated axiom or annotated annotation." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "annotatedSource" .


###  http://www.w3.org/2002/07/owl#annotatedTarget
owl:annotatedTarget rdf:type owl:ObjectProperty ;
                    rdfs:domain rdfs:Resource ;
                    rdfs:range rdfs:Resource ;
                    rdfs:comment "The property that determines the object of an annotated axiom or annotated annotation." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "annotatedTarget" .


###  http://www.w3.org/2002/07/owl#assertionProperty
owl:assertionProperty rdf:type owl:ObjectProperty ;
                      rdfs:domain owl:NegativePropertyAssertion ;
                      rdfs:range rdf:Property ;
                      rdfs:comment "The property that determines the predicate of a negative property assertion." ;
                      rdfs:isDefinedBy owl: ;
                      rdfs:label "assertionProperty" .


###  http://www.w3.org/2002/07/owl#bottomObjectProperty
owl:bottomObjectProperty rdf:type owl:ObjectProperty ;
                         rdfs:domain owl:Thing ;
                         rdfs:range owl:Thing ;
                         rdfs:comment "The object property that does not relate any two individuals." ;
                         rdfs:isDefinedBy owl: ;
                         rdfs:label "bottomObjectProperty" .


###  http://www.w3.org/2002/07/owl#complementOf
owl:complementOf rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Class ;
                 rdfs:range owl:Class ;
                 rdfs:comment "The property that determines that a given class is the complement of another class." ;
                 rdfs:isDefinedBy owl: ;
                 rdfs:label "complementOf" .


###  http://www.w3.org/2002/07/owl#datatypeComplementOf
owl:datatypeComplementOf rdf:type owl:ObjectProperty ;
                         rdfs:domain rdfs:Datatype ;
                         rdfs:range rdfs:Datatype ;
                         rdfs:comment "The property that determines that a given data range is the complement of another data range with respect to the data domain." ;
                         rdfs:isDefinedBy owl: ;
                         rdfs:label "datatypeComplementOf" .


###  http://www.w3.org/2002/07/owl#differentFrom
owl:differentFrom rdf:type owl:ObjectProperty ;
                  rdfs:domain owl:Thing ;
                  rdfs:range owl:Thing ;
                  rdfs:comment "The property that determines that two given individuals are different." ;
                  rdfs:isDefinedBy owl: ;
                  rdfs:label "differentFrom" .


###  http://www.w3.org/2002/07/owl#disjointUnionOf
owl:disjointUnionOf rdf:type owl:ObjectProperty ;
                    rdfs:domain owl:Class ;
                    rdfs:range rdf:List ;
                    rdfs:comment "The property that determines that a given class is equivalent to the disjoint union of a collection of other classes." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "disjointUnionOf" .


###  http://www.w3.org/2002/07/owl#disjointWith
owl:disjointWith rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Class ;
                 rdfs:range owl:Class ;
                 rdfs:comment "The property that determines that two given classes are disjoint." ;
                 rdfs:isDefinedBy owl: ;
                 rdfs:label "disjointWith" .


###  http://www.w3.org/2002/07/owl#distinctMembers
owl:distinctMembers rdf:type owl:ObjectProperty ;
                    rdfs:domain owl:AllDifferent ;
                    rdfs:range rdf:List ;
                    rdfs:comment "The property that determines the collection of pairwise different individuals in a owl:AllDifferent axiom." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "distinctMembers" .


###  http://www.w3.org/2002/07/owl#equivalentClass
owl:equivalentClass rdf:type owl:ObjectProperty ;
                    rdfs:domain rdfs:Class ;
                    rdfs:range rdfs:Class ;
                    rdfs:comment "The property that determines that two given classes are equivalent, and that is used to specify datatype definitions." ;
                    rdfs:isDefinedBy owl: ;
                    rdfs:label "equivalentClass" .


###  http://www.w3.org/2002/07/owl#equivalentProperty
owl:equivalentProperty rdf:type owl:ObjectProperty ;
                       rdfs:domain rdf:Property ;
                       rdfs:range rdf:Property ;
                       rdfs:comment "The property that determines that two given properties are equivalent." ;
                       rdfs:isDefinedBy owl: ;
                       rdfs:label "equivalentProperty" .


###  http://www.w3.org/2002/07/owl#hasKey
owl:hasKey rdf:type owl:ObjectProperty ;
           rdfs:domain owl:Class ;
           rdfs:range rdf:List ;
           rdfs:comment "The property that determines the collection of properties that jointly build a key." ;
           rdfs:isDefinedBy owl: ;
           rdfs:label "hasKey" .


###  http://www.w3.org/2002/07/owl#hasSelf
owl:hasSelf rdf:type owl:ObjectProperty ;
            rdfs:domain owl:Restriction ;
            rdfs:range rdfs:Resource ;
            rdfs:comment "The property that determines the property that a self restriction refers to." ;
            rdfs:isDefinedBy owl: ;
            rdfs:label "hasSelf" .


###  http://www.w3.org/2002/07/owl#hasValue
owl:hasValue rdf:type owl:ObjectProperty ;
             rdfs:domain owl:Restriction ;
             rdfs:range rdfs:Resource ;
             rdfs:comment "The property that determines the individual that a has-value restriction refers to." ;
             rdfs:isDefinedBy owl: ;
             rdfs:label "hasValue" .


###  http://www.w3.org/2002/07/owl#intersectionOf
owl:intersectionOf rdf:type owl:ObjectProperty ;
                   rdfs:domain rdfs:Class ;
                   rdfs:range rdf:List ;
                   rdfs:comment "The property that determines the collection of classes or data ranges that build an intersection." ;
                   rdfs:isDefinedBy owl: ;
                   rdfs:label "intersectionOf" .


###  http://www.w3.org/2002/07/owl#inverseOf
owl:inverseOf rdf:type owl:ObjectProperty ;
              rdfs:domain owl:ObjectProperty ;
              rdfs:range owl:ObjectProperty ;
              rdfs:comment "The property that determines that two given properties are inverse." ;
              rdfs:isDefinedBy owl: ;
              rdfs:label "inverseOf" .


###  http://www.w3.org/2002/07/owl#members
owl:members rdf:type owl:ObjectProperty ;
            rdfs:domain rdfs:Resource ;
            rdfs:range rdf:List ;
            rdfs:comment "The property that determines the collection of members in either a owl:AllDifferent, owl:AllDisjointClasses or owl:AllDisjointProperties axiom." ;
            rdfs:isDefinedBy owl: ;
            rdfs:label "members" .


###  http://www.w3.org/2002/07/owl#onClass
owl:onClass rdf:type owl:ObjectProperty ;
            rdfs:domain owl:Restriction ;
            rdfs:range owl:Class ;
            rdfs:comment "The property that determines the class that a qualified object cardinality restriction refers to." ;
            rdfs:isDefinedBy owl: ;
            rdfs:label "onClass" .


###  http://www.w3.org/2002/07/owl#onDataRange
owl:onDataRange rdf:type owl:ObjectProperty ;
                rdfs:domain owl:Restriction ;
                rdfs:range rdfs:Datatype ;
                rdfs:comment "The property that determines the data range that a qualified data cardinality restriction refers to." ;
                rdfs:isDefinedBy owl: ;
                rdfs:label "onDataRange" .


###  http://www.w3.org/2002/07/owl#onDatatype
owl:onDatatype rdf:type owl:ObjectProperty ;
               rdfs:domain rdfs:Datatype ;
               rdfs:range rdfs:Datatype ;
               rdfs:comment "The property that determines the datatype that a datatype restriction refers to." ;
               rdfs:isDefinedBy owl: ;
               rdfs:label "onDatatype" .


###  http://www.w3.org/2002/07/owl#onProperties
owl:onProperties rdf:type owl:ObjectProperty ;
                 rdfs:domain owl:Restriction ;
                 rdfs:range rdf:List ;
                 rdfs:comment "The property that determines the n-tuple of properties that a property restriction on an n-ary data range refers to." ;
                 rdfs:isDefinedBy owl: ;
                 rdfs:label "onProperties" .


###  http://www.w3.org/2002/07/owl#onProperty
owl:onProperty rdf:type owl:ObjectProperty ;
               rdfs:domain owl:Restriction ;
               rdfs:range rdf:Property ;
               rdfs:comment "The property that determines the property that a property restriction refers to." ;
               rdfs:isDefinedBy owl: ;
               rdfs:label "onProperty" .


###  http://www.w3.org/2002/07/owl#oneOf
owl:oneOf rdf:type owl:ObjectProperty ;
          rdfs:domain rdfs:Class ;
          rdfs:range rdf:List ;
          rdfs:comment "The property that determines the collection of individuals or data values that build an enumeration." ;
          rdfs:isDefinedBy owl: ;
          rdfs:label "oneOf" .


###  http://www.w3.org/2002/07/owl#propertyChainAxiom
owl:propertyChainAxiom rdf:type owl:ObjectProperty ;
                       rdfs:domain owl:ObjectProperty ;
                       rdfs:range rdf:List ;
                       rdfs:comment "The property that determines the n-tuple of properties that build a sub property chain of a given property." ;
                       rdfs:isDefinedBy owl: ;
                       rdfs:label "propertyChainAxiom" .


###  http://www.w3.org/2002/07/owl#propertyDisjointWith
owl:propertyDisjointWith rdf:type owl:ObjectProperty ;
                         rdfs:domain rdf:Property ;
                         rdfs:range rdf:Property ;
                         rdfs:comment "The property that determines that two given properties are disjoint." ;
                         rdfs:isDefinedBy owl: ;
                         rdfs:label "propertyDisjointWith" .


###  http://www.w3.org/2002/07/owl#sameAs
owl:sameAs rdf:type owl:ObjectProperty ;
           rdfs:domain owl:Thing .


###  http://www.w3.org/2002/07/owl#someValuesFrom
owl:someValuesFrom rdf:type owl:ObjectProperty ;
                   rdfs:domain owl:Restriction ;
                   rdfs:range rdfs:Class ;
                   rdfs:comment "The property that determines the class that an existential property restriction refers to." ;
                   rdfs:isDefinedBy owl: ;
                   rdfs:label "someValuesFrom" .


###  http://www.w3.org/2002/07/owl#sourceIndividual
owl:sourceIndividual rdf:type owl:ObjectProperty ;
                     rdfs:domain owl:NegativePropertyAssertion ;
                     rdfs:range owl:Thing ;
                     rdfs:comment "The property that determines the subject of a negative property assertion." ;
                     rdfs:isDefinedBy owl: ;
                     rdfs:label "sourceIndividual" .


###  http://www.w3.org/2002/07/owl#targetIndividual
owl:targetIndividual rdf:type owl:ObjectProperty ;
                     rdfs:domain owl:NegativePropertyAssertion ;
                     rdfs:range owl:Thing ;
                     rdfs:comment "The property that determines the object of a negative object property assertion." ;
                     rdfs:isDefinedBy owl: ;
                     rdfs:label "targetIndividual" .


###  http://www.w3.org/2002/07/owl#targetValue
owl:targetValue rdf:type owl:ObjectProperty ;
                rdfs:domain owl:NegativePropertyAssertion ;
                rdfs:range rdfs:Literal ;
                rdfs:comment "The property that determines the value of a negative data property assertion." ;
                rdfs:isDefinedBy owl: ;
                rdfs:label "targetValue" .


###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty rdf:type owl:ObjectProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range owl:Thing ;
                      rdfs:comment "The object property that relates every two individuals." ;
                      rdfs:isDefinedBy owl: ;
                      rdfs:label "topObjectProperty" .


###  http://www.w3.org/2002/07/owl#unionOf
owl:unionOf rdf:type owl:ObjectProperty ;
            rdfs:domain rdfs:Class ;
            rdfs:range rdf:List ;
            rdfs:comment "The property that determines the collection of classes or data ranges that build a union." ;
            rdfs:isDefinedBy owl: ;
            rdfs:label "unionOf" .


###  http://www.w3.org/2002/07/owl#withRestrictions
owl:withRestrictions rdf:type owl:ObjectProperty ;
                     rdfs:domain rdfs:Datatype ;
                     rdfs:range rdf:List ;
                     rdfs:comment "The property that determines the collection of facet-value pairs that define a datatype restriction." ;
                     rdfs:isDefinedBy owl: ;
                     rdfs:label "withRestrictions" .


###  http://www.w3.org/2003/01/geo/wgs84_pos#location
<http://www.w3.org/2003/01/geo/wgs84_pos#location> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/based_near> .


###  http://www.w3.org/2004/02/skos/core#broadMatch
<http://www.w3.org/2004/02/skos/core#broadMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#broader> ,
                                                                    <http://www.w3.org/2004/02/skos/core#mappingRelation> ;
                                                 owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrowMatch> ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "has broader match"@el ,
                                                            "has broader match"@en ,
                                                            "has broader match"@es ,
                                                            "has broader match"@fr ,
                                                            "has broader match"@it ,
                                                            "has broader match"@no ,
                                                            "has broader match"@pt ,
                                                            "has broader match"@ro ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#broaderTransitive> ;
                                              owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrower> ;
                                              rdfs:comment "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@el ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@en ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@es ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@fr ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@it ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@no ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@pt ,
                                                           "Broader concepts are typically rendered as parents in a concept hierarchy (tree)."@ro ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              rdfs:label "has broader"@el ,
                                                         "has broader"@en ,
                                                         "has broader"@es ,
                                                         "has broader"@fr ,
                                                         "has broader"@it ,
                                                         "has broader"@no ,
                                                         "has broader"@pt ,
                                                         "has broader"@ro ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept that is more general in meaning."@en ;
                                              <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#broaderTransitive
<http://www.w3.org/2004/02/skos/core#broaderTransitive> rdf:type owl:ObjectProperty ;
                                                        rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                        owl:inverseOf <http://www.w3.org/2004/02/skos/core#narrowerTransitive> ;
                                                        rdf:type owl:TransitiveProperty ;
                                                        rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                        rdfs:label "has broader transitive"@el ,
                                                                   "has broader transitive"@en ,
                                                                   "has broader transitive"@es ,
                                                                   "has broader transitive"@fr ,
                                                                   "has broader transitive"@it ,
                                                                   "has broader transitive"@no ,
                                                                   "has broader transitive"@pt ,
                                                                   "has broader transitive"@ro ;
                                                        <http://www.w3.org/2004/02/skos/core#definition> "skos:broaderTransitive is a transitive superproperty of skos:broader." ;
                                                        <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broaderTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ;
                                                 rdf:type owl:SymmetricProperty ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "has close match"@el ,
                                                            "has close match"@en ,
                                                            "has close match"@es ,
                                                            "has close match"@fr ,
                                                            "has close match"@it ,
                                                            "has close match"@no ,
                                                            "has close match"@pt ,
                                                            "has close match"@ro ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:closeMatch is used to link two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications. In order to avoid the possibility of \"compound errors\" when combining mappings across more than two concept schemes, skos:closeMatch is not declared to be a transitive property."@en .


###  http://www.w3.org/2004/02/skos/core#exactMatch
<http://www.w3.org/2004/02/skos/core#exactMatch> rdf:type owl:ObjectProperty ;
                                                 rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#closeMatch> ;
                                                 rdf:type owl:SymmetricProperty ,
                                                          owl:TransitiveProperty ;
                                                 rdfs:comment "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@el ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@en ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@es ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@fr ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@it ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@no ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@pt ,
                                                              "skos:exactMatch is disjoint with each of the properties skos:broadMatch and skos:relatedMatch."@ro ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "has exact match"@el ,
                                                            "has exact match"@en ,
                                                            "has exact match"@es ,
                                                            "has exact match"@fr ,
                                                            "has exact match"@it ,
                                                            "has exact match"@no ,
                                                            "has exact match"@pt ,
                                                            "has exact match"@ro ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "skos:exactMatch is used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. skos:exactMatch is a transitive property, and is a sub-property of skos:closeMatch."@en .


###  http://www.w3.org/2004/02/skos/core#hasTopConcept
<http://www.w3.org/2004/02/skos/core#hasTopConcept> rdf:type owl:ObjectProperty ;
                                                    owl:inverseOf <http://www.w3.org/2004/02/skos/core#topConceptOf> ;
                                                    rdfs:domain <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                    rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                    rdfs:label "has top concept"@el ,
                                                               "has top concept"@en ,
                                                               "has top concept"@es ,
                                                               "has top concept"@fr ,
                                                               "has top concept"@it ,
                                                               "has top concept"@no ,
                                                               "has top concept"@pt ,
                                                               "has top concept"@ro ;
                                                    <http://www.w3.org/2004/02/skos/core#definition> "Relates, by convention, a concept scheme to a concept which is topmost in the broader/narrower concept hierarchies for that scheme, providing an entry point to these hierarchies."@en .


###  http://www.w3.org/2004/02/skos/core#inScheme
<http://www.w3.org/2004/02/skos/core#inScheme> rdf:type owl:ObjectProperty ;
                                               rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               rdfs:label "is in scheme"@el ,
                                                          "is in scheme"@en ,
                                                          "is in scheme"@es ,
                                                          "is in scheme"@fr ,
                                                          "is in scheme"@it ,
                                                          "is in scheme"@no ,
                                                          "is in scheme"@pt ,
                                                          "is in scheme"@ro ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "Relates a resource (for example a concept) to a concept scheme in which it is included."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "A concept may be a member of more than one concept scheme."@en .


###  http://www.w3.org/2004/02/skos/core#mappingRelation
<http://www.w3.org/2004/02/skos/core#mappingRelation> rdf:type owl:ObjectProperty ;
                                                      rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                      rdfs:comment "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@el ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@en ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@es ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@fr ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@it ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@no ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@pt ,
                                                                   "These concept mapping relations mirror semantic relations, and the data model defined below is similar (with the exception of skos:exactMatch) to the data model defined for semantic relations. A distinct vocabulary is provided for concept mapping relations, to provide a convenient way to differentiate links within a concept scheme from links between concept schemes. However, this pattern of usage is not a formal requirement of the SKOS data model, and relies on informal definitions of best practice."@ro ;
                                                      rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                      rdfs:label "is in mapping relation with"@el ,
                                                                 "is in mapping relation with"@en ,
                                                                 "is in mapping relation with"@es ,
                                                                 "is in mapping relation with"@fr ,
                                                                 "is in mapping relation with"@it ,
                                                                 "is in mapping relation with"@no ,
                                                                 "is in mapping relation with"@pt ,
                                                                 "is in mapping relation with"@ro ;
                                                      <http://www.w3.org/2004/02/skos/core#definition> "Relates two concepts coming, by convention, from different schemes, and that have comparable meanings"@en .


###  http://www.w3.org/2004/02/skos/core#member
<http://www.w3.org/2004/02/skos/core#member> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <http://www.w3.org/2004/02/skos/core#Collection> ;
                                             rdfs:range [ rdf:type owl:Class ;
                                                          owl:unionOf ( <http://www.w3.org/2004/02/skos/core#Collection>
                                                                        <http://www.w3.org/2004/02/skos/core#Concept>
                                                                      )
                                                        ] ;
                                             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                             rdfs:label "has member"@en ;
                                             <http://www.w3.org/2004/02/skos/core#definition> "Relates a collection to one of its members."@en ;
                                             <http://www.w3.org/2004/02/skos/core#prefLabel> "a pour membre"@fr ,
                                                                                             "are membru"@ro ,
                                                                                             "ha membro"@it ,
                                                                                             "har medlem"@no ,
                                                                                             "has member"@en ,
                                                                                             "tem membro"@pt ,
                                                                                             "tiene miembro"@es ,
                                                                                             "έχει μέλος"@el .


###  http://www.w3.org/2004/02/skos/core#memberList
<http://www.w3.org/2004/02/skos/core#memberList> rdf:type owl:ObjectProperty ,
                                                          owl:FunctionalProperty ;
                                                 rdfs:domain <http://www.w3.org/2004/02/skos/core#OrderedCollection> ;
                                                 rdfs:range rdf:List ;
                                                 rdfs:comment """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@el ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@en ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@es ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@fr ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@it ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@no ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@pt ,
                                                              """For any resource, every item in the list given as the value of the
      skos:memberList property is also a value of the skos:member property."""@ro ;
                                                 rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "has member list"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "Relates an ordered collection to the RDF list containing its members."@en ;
                                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "a pour liste de membres"@fr ,
                                                                                                 "are listă de membri"@ro ,
                                                                                                 "ha elenco dei membri"@it ,
                                                                                                 "har medlemsliste"@no ,
                                                                                                 "has member list"@en ,
                                                                                                 "tem lista de membros"@pt ,
                                                                                                 "tiene lista de miembros"@es ,
                                                                                                 "έχει λίστα μελών"@el .


###  http://www.w3.org/2004/02/skos/core#narrowMatch
<http://www.w3.org/2004/02/skos/core#narrowMatch> rdf:type owl:ObjectProperty ;
                                                  rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ,
                                                                     <http://www.w3.org/2004/02/skos/core#narrower> ;
                                                  rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                  rdfs:label "has narrower match"@el ,
                                                             "has narrower match"@en ,
                                                             "has narrower match"@es ,
                                                             "has narrower match"@fr ,
                                                             "has narrower match"@it ,
                                                             "has narrower match"@no ,
                                                             "has narrower match"@pt ,
                                                             "has narrower match"@ro ;
                                                  <http://www.w3.org/2004/02/skos/core#definition> "skos:narrowMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#narrower
<http://www.w3.org/2004/02/skos/core#narrower> rdf:type owl:ObjectProperty ;
                                               rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#narrowerTransitive> ;
                                               rdfs:comment "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@el ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@en ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@es ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@fr ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@it ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@no ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@pt ,
                                                            "Narrower concepts are typically rendered as children in a concept hierarchy (tree)."@ro ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               rdfs:label "has narrower"@el ,
                                                          "has narrower"@en ,
                                                          "has narrower"@es ,
                                                          "has narrower"@fr ,
                                                          "has narrower"@it ,
                                                          "has narrower"@no ,
                                                          "has narrower"@pt ,
                                                          "has narrower"@ro ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept that is more specific in meaning."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:broader is only used to assert an immediate (i.e. direct) hierarchical link between two conceptual resources."@en .


###  http://www.w3.org/2004/02/skos/core#narrowerTransitive
<http://www.w3.org/2004/02/skos/core#narrowerTransitive> rdf:type owl:ObjectProperty ;
                                                         rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                                         rdf:type owl:TransitiveProperty ;
                                                         rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                         rdfs:label "has narrower transitive"@el ,
                                                                    "has narrower transitive"@en ,
                                                                    "has narrower transitive"@es ,
                                                                    "has narrower transitive"@fr ,
                                                                    "has narrower transitive"@it ,
                                                                    "has narrower transitive"@no ,
                                                                    "has narrower transitive"@pt ,
                                                                    "has narrower transitive"@ro ;
                                                         <http://www.w3.org/2004/02/skos/core#definition> "skos:narrowerTransitive is a transitive superproperty of skos:narrower." ;
                                                         <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:narrowerTransitive is not used to make assertions. Rather, the properties can be used to draw inferences about the transitive closure of the hierarchical relation, which is useful e.g. when implementing a simple query expansion algorithm in a search application."@en .


###  http://www.w3.org/2004/02/skos/core#related
<http://www.w3.org/2004/02/skos/core#related> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#semanticRelation> ;
                                              rdf:type owl:SymmetricProperty ;
                                              rdfs:comment "skos:related is disjoint with skos:broaderTransitive"@el ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@en ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@es ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@fr ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@it ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@no ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@pt ,
                                                           "skos:related is disjoint with skos:broaderTransitive"@ro ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                              rdfs:label "has related"@el ,
                                                         "has related"@en ,
                                                         "has related"@es ,
                                                         "has related"@fr ,
                                                         "has related"@it ,
                                                         "has related"@no ,
                                                         "has related"@pt ,
                                                         "has related"@ro ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to a concept with which there is an associative semantic relationship."@en .


###  http://www.w3.org/2004/02/skos/core#relatedMatch
<http://www.w3.org/2004/02/skos/core#relatedMatch> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#mappingRelation> ,
                                                                      <http://www.w3.org/2004/02/skos/core#related> ;
                                                   rdf:type owl:SymmetricProperty ;
                                                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                   rdfs:label "has related match"@el ,
                                                              "has related match"@en ,
                                                              "has related match"@es ,
                                                              "has related match"@fr ,
                                                              "has related match"@it ,
                                                              "has related match"@no ,
                                                              "has related match"@pt ,
                                                              "has related match"@ro ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "skos:relatedMatch is used to state an associative mapping link between two conceptual resources in different concept schemes."@en .


###  http://www.w3.org/2004/02/skos/core#semanticRelation
<http://www.w3.org/2004/02/skos/core#semanticRelation> rdf:type owl:ObjectProperty ;
                                                       rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                       rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                       rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                       rdfs:label "is in semantic relation with"@el ,
                                                                  "is in semantic relation with"@en ,
                                                                  "is in semantic relation with"@es ,
                                                                  "is in semantic relation with"@fr ,
                                                                  "is in semantic relation with"@it ,
                                                                  "is in semantic relation with"@no ,
                                                                  "is in semantic relation with"@pt ,
                                                                  "is in semantic relation with"@ro ;
                                                       <http://www.w3.org/2004/02/skos/core#definition> "Links a concept to a concept related by meaning."@en ;
                                                       <http://www.w3.org/2004/02/skos/core#scopeNote> "This property should not be used directly, but as a super-property for all properties denoting a relationship of meaning between concepts."@en .


###  http://www.w3.org/2004/02/skos/core#topConceptOf
<http://www.w3.org/2004/02/skos/core#topConceptOf> rdf:type owl:ObjectProperty ;
                                                   rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                   rdfs:domain <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                   rdfs:range <http://www.w3.org/2004/02/skos/core#ConceptScheme> ;
                                                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                   rdfs:label "is top concept in scheme"@el ,
                                                              "is top concept in scheme"@en ,
                                                              "is top concept in scheme"@es ,
                                                              "is top concept in scheme"@fr ,
                                                              "is top concept in scheme"@it ,
                                                              "is top concept in scheme"@no ,
                                                              "is top concept in scheme"@pt ,
                                                              "is top concept in scheme"@ro ;
                                                   <http://www.w3.org/2004/02/skos/core#definition> "Relates a concept to the concept scheme that it is a top level concept of."@en .


