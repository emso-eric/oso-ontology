                                                                    <https://w3id.org/earthsemantics/OSO#Subsite> ;
                                                        rdfs:range xsd:date ;
                                                        rdfs:comment "Date marking the end of deployment of an instrument, platform, or infrastructure."@en ,
                                                                     "Date marquant la fin du déploiement d’un instrument, d’une plateforme ou d’une infrastructure."@fr ;
