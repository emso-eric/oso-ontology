                                                         rdfs:domain <https://w3id.org/earthsemantics/OSO#BoundingBox> ;
                                                         rdfs:range xsd:float ;
                                                         rdfs:comment "Longitud oeste máxima de una caja geográfica delimitadora, correspondiente a westBoundLongitude en ISO 19115-3."@es ,
                                                                      "Longitude oeste máxima de uma caixa geográfica delimitadora, correspondente a westBoundLongitude na ISO 19115-3."@pt ,
                                                                      "Longitude ouest maximale d’une boîte englobante géographique, correspondant à westBoundLongitude dans l’ISO 19115-3."@fr ,
                                                                      "Longitudine ovest massima di un riquadro geografico, corrispondente a westBoundLongitude in ISO 19115-3."@it ,
                                                                      "Longitudinea vestică maximă a unei zone geografice delimitate, corespunzătoare westBoundLongitude din ISO 19115-3."@ro ,
                                                                      "Vestligste lengdegrad i en geografisk avgrensningsboks, tilsvarende westBoundLongitude i ISO 19115-3."@no ,
                                                                      "Westernmost longitude of a geographic bounding box, corresponding to westBoundLongitude in ISO 19115-3."@en ,
                                                                      "Το δυτικότερο γεωγραφικό μήκος ενός γεωγραφικού πλαισίου, που αντιστοιχεί στο westBoundLongitude του ISO 19115-3."@el ;
                                                         rdfs:label "longitud oeste máxima"@es ,
                                                                    "longitude oeste máxima"@pt ,
                                                                    "longitude ouest maximale"@fr ,
                                                                    "longitudine ovest massima"@it ,
                                                                    "longitudine vestică maximă"@ro ,
                                                                    "vestlig lengdegrad"@no ,
                                                                    "west bound longitude"@en ,
                                                                    "δυτικό όριο γεωγραφικού μήκους"@el ;
                                                         <http://www.w3.org/2004/02/skos/core#prefLabel> "longitud oeste máxima"@es ,
                                                                                                         "longitude oeste máxima"@pt ,
                                                                                                         "longitude ouest maximale"@fr ,
                                                                                                         "longitudine ovest massima"@it ,
                                                                                                         "longitudine vestică maximă"@ro ,
                                                                                                         "vestlig lengdegrad"@no ,
                                                                                                         "west bound longitude"@en ,
                                                                                                         "δυτικό όριο γεωγραφικού μήκους"@el .


