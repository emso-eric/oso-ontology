  "http://purl.org/dc/terms/description" : [ {
    "@language" : "no",
    "@value" : "EMSO databehandlingstjenestegruppe støtter dataforvaltning, interoperabilitet og FAIR-praksis i EMSO-fellesskapet."
  }, {
    "@language" : "es",
    "@value" : "El grupo de servicios de gestión de datos de EMSO apoya la gestión de datos, la interoperabilidad y las prácticas FAIR dentro de la comunidad EMSO."
  }, {
    "@language" : "ro",
    "@value" : "Grupul de servicii pentru gestionarea datelor EMSO sprijină gestionarea datelor, interoperabilitatea și practicile FAIR în cadrul comunității EMSO."
  }, {
    "@language" : "it",
    "@value" : "Il gruppo di servizio per la gestione dei dati EMSO supporta la gestione dei dati, l’interoperabilità e le pratiche FAIR all’interno della comunità EMSO."
  }, {
