  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A site that is planned but not yet deployed or operational."
  }, {
    "@language" : "no",
    "@value" : "Et sted som er planlagt, men ennå ikke utplassert eller i drift."
  }, {
    "@language" : "pt",
    "@value" : "Um sítio planeado mas ainda não implantado nem operacional."
  }, {
    "@language" : "ro",
    "@value" : "Un sit planificat, dar încă nedesfășurat sau operațional."
  }, {
    "@language" : "fr",
    "@value" : "Un site planifié mais non encore déployé ni opérationnel."
  }, {
    "@language" : "es",
    "@value" : "Un sitio que está planificado pero aún no desplegado ni operativo."
  }, {
    "@language" : "it",
    "@value" : "Un sito pianificato ma non ancora implementato né operativo."
  }, {
    "@language" : "el",
    "@value" : "Σχεδιαζόμενο: τόπος που έχει προγραμματιστεί αλλά δεν έχει ακόμη αναπτυχθεί ή λειτουργήσει."
  } ],
