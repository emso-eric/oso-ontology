  "http://omv.ontoware.org/2005/05/ontology#description" : [ {
    "@language" : "no",
    "@value" : "Ontologi som beskriver marine observatorier (regionale fasiliteter, steder, plattformer) for å støtte FAIR datastyring og interoperabilitet, spesielt i EMSO ERIC-konteksten."
  }, {
    "@language" : "ro",
    "@value" : "Ontologia care descrie observatoarele marine (facilități regionale, situri, platforme) pentru a susține gestionarea FAIR a datelor și interoperabilitatea, în special în contextul EMSO ERIC."
  }, {
    "@language" : "it",
    "@value" : "Ontologia che descrive gli osservatori marini (infrastrutture regionali, siti, piattaforme) per supportare la gestione FAIR dei dati e l’interoperabilità, in particolare nel contesto EMSO ERIC."
  }, {
    "@language" : "pt",
    "@value" : "Ontologia que descreve os observatórios marinhos (infraestruturas regionais, locais, plataformas) para apoiar a gestão FAIR de dados e a interoperabilidade, especialmente no contexto do EMSO ERIC."
  }, {
    "@language" : "fr",
    "@value" : "Ontologie décrivant les observatoires marins (infrastructures régionales, sites, plateformes) pour soutenir la gestion FAIR des données et l’interopérabilité, notamment dans le cadre d’EMSO ERIC."
  }, {
    "@language" : "en",
    "@value" : "Ontology describing marine observatories (Regional Facilities, Sites, Platforms) to support FAIR data management and interoperability, particularly in the EMSO ERIC context."
  }, {
    "@language" : "es",
    "@value" : "Ontología que describe los observatorios marinos (infraestructuras regionales, sitios, plataformas) para apoyar la gestión FAIR de datos y la interoperabilidad, especialmente en el contexto de EMSO ERIC."
  }, {
    "@language" : "el",
    "@value" : "Οντολογία που περιγράφει τα θαλάσσια παρατηρητήρια (περιφερειακές υποδομές, τοποθεσίες, πλατφόρμες) για την υποστήριξη της διαχείρισης δεδομένων FAIR και της διαλειτουργικότητας, ιδιαίτερα στο πλαίσιο του EMSO ERIC."
  } ],
  "http://omv.ontoware.org/2005/05/ontology#designedForOntologyTask" : [ {
    "@id" : "http://omv.ontoware.org/2005/05/ontology#AnnotationTask"
  }, {
