  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "pt",
    "@value" : "A OSO inclui alinhamentos semânticos selecionados com conceitos SWEET para melhorar a interoperabilidade com vocabulários das ciências da Terra e do ambiente."
  }, {
    "@language" : "es",
    "@value" : "Co-construcción con expertos del dominio y alineación iterativa con ontologías de referencia"
  }, {
    "@language" : "fr",
    "@value" : "Co-construction avec des experts métier et alignement itératif avec des ontologies de référence"
  }, {
    "@language" : "en",
    "@value" : "Co-construction with domain experts and iterative alignment with reference ontologies"
  }, {
    "@language" : "ro",
    "@value" : "Co-construcție cu experți din domeniu și aliniere iterativă cu ontologii de referință"
  }, {
    "@language" : "pt",
    "@value" : "Co-construção com especialistas no domínio e alinhamento iterativo com ontologias de referência"
  }, {
    "@language" : "it",
    "@value" : "Co-costruzione con esperti di dominio e allineamento iterativo con ontologie di riferimento"
  }, {
    "@language" : "ro",
    "@value" : "OSO include alinieri semantice selectate cu concepte SWEET pentru a îmbunătăți interoperabilitatea cu vocabularele din științele Pământului și ale mediului."
  }, {
    "@language" : "it",
    "@value" : "OSO include allineamenti semantici selezionati con concetti SWEET per migliorare l'interoperabilità con i vocabolari delle scienze della Terra e dell'ambiente."
  }, {
    "@language" : "en",
    "@value" : "OSO includes selected semantic alignments with SWEET concepts to improve interoperability with Earth and environmental science vocabularies."
  }, {
    "@language" : "fr",
    "@value" : "OSO inclut des alignements sémantiques ciblés avec des concepts SWEET afin d'améliorer l'interopérabilité avec les vocabulaires des sciences de la Terre et de l'environnement."
  }, {
    "@language" : "es",
    "@value" : "OSO incluye alineaciones semánticas seleccionadas con conceptos de SWEET para mejorar la interoperabilidad con vocabularios de ciencias de la Tierra y del medio ambiente."
  }, {
    "@language" : "no",
    "@value" : "OSO inkluderer utvalgte semantiske tilpasninger til SWEET-begreper for å forbedre interoperabiliteten med vokabularer innen jord- og miljøvitenskap."
  }, {
    "@language" : "no",
    "@value" : "Ontologi som beskriver forholdet mellom regionale fasiliteter, steder, plattformer, forskningsinfrastrukturer, organisasjoner, cruiser og de ansvarlige på hvert nivå."
  }, {
    "@language" : "it",
    "@value" : "Ontologia che descrive le relazioni tra strutture regionali, siti, piattaforme, infrastrutture di ricerca, organizzazioni, crociere e i responsabili di ciascun livello."
  }, {
    "@language" : "pt",
    "@value" : "Ontologia que descreve as relações entre instalações regionais, locais, plataformas, infraestruturas de investigação, organizações, cruzeiros e os responsáveis por cada nível."
  }, {
    "@language" : "ro",
    "@value" : "Ontologie care descrie relațiile dintre facilitățile regionale, siturile, platformele, infrastructurile de cercetare, organizațiile, croazierele și persoanele responsabile la fiecare nivel."
  }, {
    "@language" : "fr",
    "@value" : "Ontologie décrivant les relations entre les nœuds régionaux, les sites, les plateformes, les infrastructures de recherche, les organisations, les campagnes à la mer et les personnes responsables à chaque niveau."
  }, {
    "@language" : "en",
    "@value" : "Ontology describing the relationships between Regional Facilities, Sites, Platforms, Research Infrastructures, Organisations, Cruises, and the persons in charge of each level."
  }, {
    "@language" : "es",
    "@value" : "Ontología que describe las relaciones entre instalaciones regionales, emplazamientos, plataformas, infraestructuras de investigación, organizaciones, cruceros y las personas responsables de cada nivel."
  }, {
    "@language" : "no",
    "@value" : "Samskaping med fagpersoner og iterativ tilpasning til referanseontologier"
  }, {
    "@language" : "el",
    "@value" : "Οντολογία που περιγράφει τις σχέσεις μεταξύ περιφερειακών υποδομών, τοποθεσιών, πλατφορμών, ερευνητικών υποδομών, οργανισμών, αποστολών και των υπευθύνων σε κάθε επίπεδο."
  }, {
    "@language" : "el",
    "@value" : "Συνεκπόνηση με ειδικούς του τομέα και επαναληπτική ευθυγράμμιση με πρότυπες οντολογίες"
  }, {
    "@language" : "el",
    "@value" : "Το OSO περιλαμβάνει επιλεγμένες σημασιολογικές αντιστοιχίσεις με έννοιες SWEET, ώστε να βελτιωθεί η διαλειτουργικότητα με λεξιλόγια των επιστημών της Γης και του περιβάλλοντος."
  } ],
