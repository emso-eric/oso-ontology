}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#Platform",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://data.bioontology.org/metadata/prefixIRI" : [ {
    "@value" : "OSO:Platform"
  } ],
  "http://purl.org/dc/terms/source" : [ {
    "@id" : "http://vocab.nerc.ac.uk/collection/L06/current/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An observation platform, fixed or mobile, installed on a site or subsite, supporting one or more instruments or acquisition systems."
  }, {
    "@language" : "no",
    "@value" : "En observasjonsplattform, fast eller mobil, installert på et sted eller underområde, som støtter ett eller flere instrumenter eller innhentingssystemer."
  }, {
    "@language" : "ro",
    "@value" : "O platformă de observație, fixă sau mobilă, instalată într-un site sau subsite, care suportă unul sau mai multe instrumente sau sisteme de achiziție."
  }, {
    "@language" : "pt",
    "@value" : "Uma plataforma de observação, fixa ou móvel, instalada num local ou sublocal, suportando um ou mais instrumentos ou sistemas de aquisição."
  }, {
    "@language" : "it",
    "@value" : "Una piattaforma di osservazione, fissa o mobile, installata su un sito o sotto-sito, che supporta uno o più strumenti o sistemi di acquisizione."
  }, {
    "@language" : "es",
    "@value" : "Una plataforma de observación, fija o móvil, instalada en un sitio o sub-sitio, que soporta uno o más instrumentos o sistemas de adquisición."
  }, {
    "@language" : "fr",
    "@value" : "Une plateforme d'observation fixe ou mobile, installée sur un site ou un sous-site, supportant un ou plusieurs instruments ou systèmes d'acquisition."
  }, {
    "@language" : "el",
    "@value" : "Μια πλατφόρμα παρατήρησης, σταθερή ή κινητή, εγκατεστημένη σε έναν τόπο ή υποτοποθεσία, υποστηρίζοντας ένα ή περισσότερα όργανα ή συστήματα συλλογής δεδομένων."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "no",
    "@value" : "Observasjonsplattform"
  }, {
    "@language" : "en",
    "@value" : "Observation Platform"
  }, {
    "@language" : "it",
    "@value" : "Piattaforma di osservazione"
  }, {
    "@language" : "es",
    "@value" : "Plataforma de observación"
  }, {
    "@language" : "pt",
    "@value" : "Plataforma de observação"
  }, {
    "@language" : "fr",
    "@value" : "Plateforme d'observation"
  }, {
    "@language" : "ro",
    "@value" : "Platformă de observație"
  }, {
    "@language" : "el",
    "@value" : "Πλατφόρμα παρατήρησης"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "http://vocab.nerc.ac.uk/collection/L06/current/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/earthsemantics/OSO#Subsite"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
