}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#Smartbay_observatory",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/earthsemantics/OSO#Platform"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "el",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "en",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "es",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "fr",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "it",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "no",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "pt",
    "@value" : "Smartbay Observatory"
  }, {
    "@language" : "ro",
    "@value" : "Smartbay Observatory"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Galway Bay Cabled Observatory"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "https://terra-vocabulary.org/ncl/FAIR-Incubator/earthscienceplatforms/c_172cedf2"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "The SmartBay cabled observatory is connected to a shorestation via a 5km long subsea fibre optic power cable. This cable provides power to the observatory and facilitates high speed communication with the various instruments and sensors deployed. The observatory operates a core suite of sensors which measure several EOVs and other relevant environmental indicators. These instruments include CTD, Ph, dissolved oxygen, pco2, hydrophones, HD camera, flow cytometer and ADCP. These instruments are cabled to a central electronics node. This node also includes several additional ports and cables with multiple power and communications configurations which are available to host other novel sensors and instruments. The testing and demonstration of new and novel equipment is one of the main drivers behind the SmartBay facility, allowing researchers and industry the ability to trial their technology in the marine environment whilst also being in real time communication with their equipment at all times.\n\nEnvironmental data recorded by the various infrastructures at the SmartBay facility is streamed in real time to Marine Institute servers and subsequently to various online platforms and databases. The online data currently includes live video and audio, currents, wave data and feeds from the several instruments currently deployed."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
