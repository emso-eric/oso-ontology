}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#ResearchProject",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A structured scientific activity designed to produce new knowledge, data, or understanding within a defined scope and duration."
  }, {
    "@language" : "no",
    "@value" : "En strukturert vitenskapelig aktivitet som har som mål å produsere ny kunnskap, data eller forståelse innenfor et definert omfang og tidsrom."
  }, {
    "@language" : "ro",
    "@value" : "O activitate științifică structurată destinată să producă noi cunoștințe, date sau înțelegere într-un cadru și o durată definite."
  }, {
    "@language" : "pt",
    "@value" : "Uma atividade científica estruturada concebida para produzir novo conhecimento, dados ou compreensão dentro de um âmbito e duração definidos."
  }, {
    "@language" : "it",
    "@value" : "Un'attività scientifica strutturata progettata per produrre nuova conoscenza, dati o comprensione entro un ambito e una durata definiti."
  }, {
    "@language" : "es",
    "@value" : "Una actividad científica estructurada destinada a producir nuevo conocimiento, datos o comprensión dentro de un alcance y una duración definidos."
  }, {
    "@language" : "fr",
    "@value" : "Une activité scientifique structurée visant à produire de nouvelles connaissances, données ou compréhensions dans un périmètre et une durée définis."
  }, {
    "@language" : "el",
    "@value" : "Επιστημονική δραστηριότητα με σαφή δομή που αποσκοπεί στην παραγωγή νέας γνώσης, δεδομένων ή κατανόησης, εντός καθορισμένου πλαισίου και διάρκειας."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "no",
    "@value" : "Forskningsprosjekt"
  }, {
    "@language" : "it",
    "@value" : "Progetto di ricerca"
  }, {
    "@language" : "ro",
    "@value" : "Proiect de cercetare"
  }, {
    "@language" : "fr",
    "@value" : "Projet de recherche"
  }, {
    "@language" : "pt",
    "@value" : "Projeto de investigação"
  }, {
    "@language" : "es",
    "@value" : "Proyecto de investigación"
  }, {
    "@language" : "en",
    "@value" : "Research project"
  }, {
    "@language" : "el",
    "@value" : "Ερευνητικό έργο"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Project"
  } ]
