  "http://omv.ontoware.org/2005/05/ontology#ontologyPurpose" : [ {
    "@language" : "no",
    "@value" : "Beskrive strukturen og hovedkomponentene i marine observatorier for å forbedre datastyring, interoperabilitet og gjenbruk, spesielt i EMSO-forskningsinfrastrukturens kontekst."
  }, {
    "@language" : "pt",
    "@value" : "Descrever a estrutura e os principais componentes dos observatórios marinhos para melhorar a gestão de dados, a interoperabilidade e a reutilização, especialmente no contexto da infraestrutura de investigação EMSO."
  }, {
    "@language" : "en",
    "@value" : "Describe the structure and key components of marine observatories to improve data management, interoperability, and reuse, especially in the EMSO research infrastructure context."
  }, {
    "@language" : "es",
    "@value" : "Describir la estructura y los componentes clave de los observatorios marinos para mejorar la gestión de datos, la interoperabilidad y la reutilización, especialmente en el contexto de la infraestructura de investigación EMSO."
  }, {
    "@language" : "ro",
    "@value" : "Descrierea structurii și a componentelor cheie ale observatoarelor marine pentru a îmbunătăți gestionarea, interoperabilitatea și reutilizarea datelor, în special în contextul infrastructurii EMSO."
  }, {
    "@language" : "it",
    "@value" : "Descrivere la struttura e i principali componenti degli osservatori marini per migliorare la gestione, l'interoperabilità e il riutilizzo dei dati, in particolare nel contesto dell'infrastruttura di ricerca EMSO."
  }, {
    "@language" : "fr",
    "@value" : "Décrire la structure et les composants clés des observatoires marins afin d'améliorer la gestion, l'interopérabilité et la réutilisation des données, notamment dans le cadre de l'infrastructure de recherche EMSO."
  }, {
    "@language" : "el",
    "@value" : "Περιγραφή της δομής και των βασικών στοιχείων των θαλάσσιων παρατηρητηρίων για τη βελτίωση της διαχείρισης δεδομένων, της διαλειτουργικότητας και της επαναχρησιμοποίησης, ιδιαίτερα στο πλαίσιο της υποδομής EMSO."
  } ],
  "http://omv.ontoware.org/2005/05/ontology#reference" : [ {
