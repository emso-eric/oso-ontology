  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "El Marine Institute es el organismo nacional responsable de la investigación marina, el desarrollo tecnológico y la innovación."
  }, {
    "@language" : "it",
    "@value" : "Il Marine Institute è l’agenzia nazionale responsabile della ricerca marina, dello sviluppo tecnologico e dell’innovazione."
  }, {
    "@language" : "fr",
    "@value" : "Le Marine Institute est l’organisme national chargé de la recherche marine, du développement technologique et de l’innovation."
  }, {
    "@language" : "no",
    "@value" : "Marine Institute er det nasjonale organet ansvarlig for marin forskning, teknologisk utvikling og innovasjon."
  }, {
    "@language" : "ro",
    "@value" : "Marine Institute este agenția națională responsabilă pentru cercetarea marină, dezvoltarea tehnologică și inovarea."
