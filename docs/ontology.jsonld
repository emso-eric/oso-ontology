  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Collega un progetto finanziato alla sua estensione geografica, come un riquadro di delimitazione o un'area di copertura."
  }, {
    "@language" : "no",
    "@value" : "Knytter et finansiert prosjekt til dets geografiske utstrekning, for eksempel en avgrensningsboks eller et dekningsområde."
  }, {
    "@language" : "ro",
    "@value" : "Leagă un proiect finanțat de extinderea sa geografică, cum ar fi o bounding box sau o zonă de acoperire."
  }, {
    "@language" : "pt",
    "@value" : "Relaciona um projeto financiado com a sua extensão geográfica, como uma caixa delimitadora ou uma área de cobertura."
  }, {
    "@language" : "es",
    "@value" : "Relaciona un proyecto financiado con su extensión geográfica, como una caja envolvente o una zona de cobertura."
  }, {
    "@language" : "en",
    "@value" : "Relates a funded project to its geographical extent, such as a bounding box or spatial coverage."
  }, {
    "@language" : "fr",
    "@value" : "Relie un projet financé à son emprise géographique, comme une boîte englobante ou une zone de couverture."
  }, {
    "@language" : "el",
    "@value" : "Συνδέει ένα χρηματοδοτούμενο έργο με τη γεωγραφική του έκταση, όπως ένα οριοθετημένο πλαίσιο ή μια περιοχή κάλυψης."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/earthsemantics/OSO#FundedProject"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
