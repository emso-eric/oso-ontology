}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#EMSO_EVOLVE",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "no",
    "@value" : "EMSO EVOLVE er et europeisk prosjekt som støtter langsiktige havobservasjoner og miljømessig bærekraft innenfor rammen av EMSO ERIC."
  }, {
    "@language" : "es",
    "@value" : "EMSO EVOLVE es un proyecto europeo que apoya las observaciones oceánicas a largo plazo y la sostenibilidad medioambiental en el marco de EMSO ERIC."
  }, {
    "@language" : "fr",
    "@value" : "EMSO EVOLVE est un projet européen soutenant les observations océaniques à long terme et la durabilité environnementale dans le cadre d’EMSO ERIC."
  }, {
    "@language" : "ro",
    "@value" : "EMSO EVOLVE este un proiect european care sprijină observațiile oceanice pe termen lung și sustenabilitatea de mediu în cadrul EMSO ERIC."
  }, {
    "@language" : "en",
    "@value" : "EMSO EVOLVE is a European project supporting long-term ocean observations and environmental sustainability within the EMSO ERIC framework."
  }, {
    "@language" : "it",
    "@value" : "EMSO EVOLVE è un progetto europeo che sostiene le osservazioni oceaniche a lungo termine e la sostenibilità ambientale nel quadro di EMSO ERIC."
  }, {
    "@language" : "pt",
    "@value" : "EMSO EVOLVE é um projeto europeu que apoia observações oceânicas de longo prazo e a sustentabilidade ambiental no quadro do EMSO ERIC."
  }, {
    "@language" : "el",
    "@value" : "Το EMSO EVOLVE είναι ένα ευρωπαϊκό έργο που υποστηρίζει τις μακροπρόθεσμες ωκεάνιες παρατηρήσεις και την περιβαλλοντική βιωσιμότητα στο πλαίσιο του EMSO ERIC."
  } ],
  "http://purl.org/dc/terms/identifier" : [ {
    "@value" : "HORIZON-INFRA-2025-01"
  } ],
