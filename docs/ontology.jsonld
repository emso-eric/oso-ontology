}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#REVOSIMA",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "no",
    "@value" : "REVOSIMA er overvåkingsnettverket for vulkanologi og seismologi på Mayotte, som støtter kontinuerlig observasjon av pågående seismo-vulkansk aktivitet."
  }, {
    "@language" : "es",
    "@value" : "REVOSIMA es la red de vigilancia volcanológica y sismológica de Mayotte que apoya la observación continua de la actividad sismo-volcánica en curso."
  }, {
    "@language" : "fr",
    "@value" : "REVOSIMA est le réseau de surveillance volcanologique et sismologique de Mayotte assurant le suivi continu de l’activité sismo-volcanique en cours."
  }, {
    "@language" : "ro",
    "@value" : "REVOSIMA este rețeaua de monitorizare vulcanologică și seismologică din Mayotte, care susține observarea continuă a activității seismo-vulcanice în desfășurare."
  }, {
    "@language" : "en",
    "@value" : "REVOSIMA is the Mayotte volcanological and seismological monitoring network supporting continuous observation of the ongoing seismo-volcanic activity."
  }, {
    "@language" : "it",
    "@value" : "REVOSIMA è la rete di monitoraggio vulcanologico e sismologico di Mayotte che supporta l’osservazione continua dell’attività sismo-vulcanica in corso."
  }, {
    "@language" : "pt",
    "@value" : "REVOSIMA é a rede de monitorização vulcanológica e sismológica de Mayotte, que apoia a observação contínua da atividade sismo-vulcânica em curso."
  }, {
    "@language" : "el",
    "@value" : "Το REVOSIMA είναι το δίκτυο ηφαιστειολογικής και σεισμολογικής παρακολούθησης της Μαγιότ, που υποστηρίζει τη συνεχή παρατήρηση της εν εξελίξει σεισμοηφαιστειακής δραστηριότητας."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/earthsemantics/OSO#FundedProject"
  } ],
