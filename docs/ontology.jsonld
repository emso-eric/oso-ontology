  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "ro",
    "@value" : "A nu se confunda cu OpenScienceOntology (OSO) sau cu Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "it",
    "@value" : "Da non confondere con OpenScienceOntology (OSO) o Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "no",
    "@value" : "Må ikke forveksles med OpenScienceOntology (OSO) eller Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "es",
    "@value" : "No confundir con OpenScienceOntology (OSO) ni con Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "en",
    "@value" : "Not to be confused with OpenScienceOntology (OSO) or Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "pt",
    "@value" : "Não confundir com OpenScienceOntology (OSO) nem com Ontology for Scenario Orchestration (OSO)."
  }, {
    "@language" : "fr",
