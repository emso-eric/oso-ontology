    "@value" : "OSO:RegionalFacility"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A regional facility containing sites, associated with research infrastructures, oceanographic campaigns, organizations, and a Regional Team Leader."
  }, {
    "@language" : "es",
    "@value" : "Infraestructura regional que contiene sitios, asociada a infraestructuras de investigación, campañas oceanográficas, organizaciones y un líder de equipo regional."
  }, {
    "@language" : "pt",
    "@value" : "Infraestrutura regional que contém locais, associada a infraestruturas de investigação, campanhas oceanográficas, organizações e um líder regional."
  }, {
    "@language" : "ro",
    "@value" : "Infrastructură regională care conține site-uri, asociată cu infrastructuri de cercetare, campanii oceanografice, organizații și un lider de echipă regional."
  }, {
    "@language" : "it",
    "@value" : "Infrastruttura regionale contenente siti, associata a infrastrutture di ricerca, campagne oceanografiche, organizzazioni e un coordinatore regionale."
  }, {
    "@language" : "no",
    "@value" : "Regional fasilitet som inneholder lokaliteter, tilknyttet forskningsinfrastrukturer, havkampanjer, organisasjoner og en regionalt ansvarlig."
  }, {
    "@language" : "fr",
    "@value" : "Une noeud régional comprenant plusieurs sites, liée à des infrastructures de recherche, des campagnes océanographiques, des organisations et un coordinateur régional."
  }, {
    "@language" : "el",
    "@value" : "Περιφερειακή υποδομή που περιλαμβάνει τοποθεσίες, συνδέεται με ερευνητικές υποδομές, ωκεανογραφικές εκστρατείες, οργανισμούς και έναν υπεύθυνο ομάδας."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Infraestructura regional"
  }, {
