  "http://omv.ontoware.org/2005/05/ontology#version" : [ {
    "@value" : "1.0.5"
  } ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "pt",
    "@value" : "A ontologia OSO estrutura os observatórios marinhos em três níveis hierárquicos: infraestruturas regionais, locais e plataformas. Suporta a gestão FAIR de dados, a interoperabilidade e a integração de informações sobre infraestruturas marinhas, especialmente no contexto do EMSO ERIC."
  }, {
    "@language" : "it",
    "@value" : "L'ontologia OSO struttura gli osservatori marini in tre livelli gerarchici: infrastrutture regionali, siti e piattaforme. Supporta la gestione FAIR dei dati, l'interoperabilità e l'integrazione delle informazioni sulle infrastrutture marine, in particolare nel contesto EMSO ERIC."
  }, {
    "@language" : "fr",
    "@value" : "L'ontologie OSO structure les observatoires marins en trois niveaux hiérarchiques : infrastructures régionales, sites et plateformes. Elle soutient la gestion FAIR des données, l'interopérabilité et l'intégration des informations sur les infrastructures marines, notamment dans le cadre d'EMSO ERIC."
  }, {
    "@language" : "es",
    "@value" : "La ontología OSO estructura los observatorios marinos en tres niveles jerárquicos: infraestructuras regionales, sitios y plataformas. Apoya la gestión FAIR de datos, la interoperabilidad y la integración de información sobre infraestructuras marinas, especialmente en el contexto de EMSO ERIC."
  }, {
    "@language" : "no",
    "@value" : "OSO-ontologien strukturerer marine observatorier i tre hierarkiske nivåer: regionale fasiliteter, steder og plattformer. Den støtter FAIR datastyring, interoperabilitet og integrasjon av informasjon om marine infrastrukturer, spesielt i EMSO ERIC-konteksten."
  }, {
    "@language" : "ro",
    "@value" : "Ontologia OSO structurează observatoarele marine în trei niveluri ierarhice: facilități regionale, situri și platforme. Susține gestionarea FAIR a datelor, interoperabilitatea și integrarea informațiilor despre infrastructuri marine, în special în contextul EMSO ERIC."
  }, {
    "@language" : "en",
    "@value" : "The OSO ontology structures marine observatories into three hierarchical levels: Regional Facilities, Sites, and Platforms. It supports FAIR data management, interoperability, and integration of heterogeneous marine infrastructure information, particularly within the EMSO ERIC framework."
  }, {
    "@language" : "el",
    "@value" : "Η οντολογία OSO οργανώνει τα θαλάσσια παρατηρητήρια σε τρία ιεραρχικά επίπεδα: περιφερειακές υποδομές, τοποθεσίες και πλατφόρμες. Υποστηρίζει τη διαχείριση δεδομένων σύμφωνα με τις αρχές FAIR, τη διαλειτουργικότητα και την ενσωμάτωση πληροφοριών για θαλάσσιες υποδομές, ιδιαίτερα στο πλαίσιο του EMSO ERIC."
  } ],
  "http://purl.org/dc/terms/bibliographicCitation" : [ {
    "@language" : "en",
    "@value" : "Observatories of the Seas Ontology (OSO), version 1.0.5 EMSO ERIC / Ifremer. FAIRsharing DOI: 10.25504/FAIRsharing.654931."
  } ],
