}, {
  "@id" : "https://w3id.org/earthsemantics/OSO#Ligurian_Sea",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "ro",
    "@value" : "Această infrastructură regională acoperă o regiune marină activă seismic caracterizată printr-o pantă continentală îngustă și abruptă, reliefuri alpine, canioane submarine, instabilitatea versanților, influențe atmosferice puternice și implicații semnificative pentru riscurile seismice, tsunami și producția de biomasă marină."
  }, {
    "@language" : "fr",
    "@value" : "Cette installation régionale couvre une zone marine sismiquement active caractérisée par une pente continentale étroite et abrupte, des reliefs alpins, des canyons sous-marins, une instabilité des pentes, de fortes influences atmosphériques et des enjeux importants en matière de risques sismiques, de tsunamis et de production de biomasse marine."
  }, {
    "@language" : "no",
    "@value" : "Denne regionale infrastrukturen dekker et seismisk aktivt havområde preget av en smal og bratt kontinentalskråning, alpine relieffer, undersjøiske canyoner, skråningsustabilitet, sterke atmosfæriske påvirkninger og betydelige konsekvenser for seismisk risiko, tsunamier og marin biomasseproduksjon."
  }, {
    "@language" : "es",
    "@value" : "Esta infraestructura regional cubre una región marina sísmicamente activa caracterizada por una pendiente continental estrecha y abrupta, relieves alpinos, cañones submarinos, inestabilidad de laderas, fuertes influencias atmosféricas e importantes implicaciones en riesgos sísmicos, tsunamis y producción de biomasa marina."
  }, {
    "@language" : "pt",
    "@value" : "Esta infraestrutura regional cobre uma região marinha sismicamente ativa caracterizada por uma plataforma continental estreita e íngreme, relevos alpinos, canhões submarinos, instabilidade de encostas, fortes influências atmosféricas e implicações significativas para riscos sísmicos, tsunamis e produção de biomassa marinha."
  }, {
    "@language" : "it",
    "@value" : "Questa infrastruttura regionale copre una regione marina sismicamente attiva caratterizzata da una scarpata continentale stretta e ripida, rilievi alpini, canyon sottomarini, instabilità dei versanti, forti influenze atmosferiche e importanti implicazioni per il rischio sismico, gli tsunami e la produzione di biomassa marina."
  }, {
    "@language" : "en",
    "@value" : "This Regional Facility covers an active seismic marine region characterized by a narrow and steep continental slope, alpine reliefs, submarine canyons, slope instability, strong atmospheric inputs, and significant implications for seismic hazard, tsunami risk, and marine biomass production."
  }, {
    "@language" : "el",
    "@value" : "Αυτή η περιφερειακή υποδομή καλύπτει μια σεισμικά ενεργή θαλάσσια περιοχή που χαρακτηρίζεται από στενή και απότομη ηπειρωτική κλίση, αλπικά ανάγλυφα, υποθαλάσσια φαράγγια, αστάθεια πρανών, έντονες ατμοσφαιρικές επιδράσεις και σημαντικές επιπτώσεις σε σεισμικούς κινδύνους, τσουνάμι και παραγωγή θαλάσσιας βιομάζας."
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "https://w3id.org/earthsemantics/OSO#RegionalFacility"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Infraestructura regional que cubre una amplia zona marina del noroeste del Mediterráneo, incluyendo el mar de Liguria, la Riviera francesa, el golfo de León y el espacio marino intermedio."
  }, {
    "@language" : "pt",
    "@value" : "Infraestrutura regional que cobre uma vasta área marinha do noroeste do Mediterrâneo, incluindo o Mar da Ligúria, a Riviera Francesa, o Golfo do Leão e o espaço marinho intermédio."
  }, {
    "@language" : "ro",
    "@value" : "Infrastructură regională care acoperă o zonă marină extinsă din nord-vestul Mării Mediterane, incluzând Marea Ligurică, Riviera Franceză, Golful Lyon și spațiul marin intermediar."
  }, {
    "@language" : "it",
    "@value" : "Infrastruttura regionale che copre un’ampia area marina del Mediterraneo nord-occidentale, includendo il Mar Ligure, la Costa Azzurra, il Golfo del Leone e lo spazio marino intermedio."
  }, {
    "@language" : "fr",
    "@value" : "Installation régionale couvrant une vaste zone marine du nord-ouest de la Méditerranée, incluant la mer Ligure, la Côte d’Azur, le golfe du Lion ainsi que l’espace marin intermédiaire."
  }, {
    "@language" : "en",
    "@value" : "Regional Facility covering a broad north-western Mediterranean marine area, including the Ligurian Sea, the French Riviera, the Gulf of Lion, and the intermediate marine space."
  }, {
    "@language" : "no",
    "@value" : "Regional infrastruktur som dekker et bredt marint område i det nordvestlige Middelhavet, inkludert Liguriahavet, den franske rivieraen, Løvegolfen og det mellomliggende havområdet."
  }, {
    "@language" : "el",
    "@value" : "Περιφερειακή υποδομή που καλύπτει μια ευρεία θαλάσσια περιοχή στη βορειοδυτική Μεσόγειο, συμπεριλαμβανομένης της Λιγουρικής Θάλασσας, της Γαλλικής Ριβιέρας, του Κόλπου του Λέοντα και του ενδιάμεσου θαλάσσιου χώρου."
  } ],
