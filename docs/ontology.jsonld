  } ],
  "http://purl.org/dc/terms/coverage" : [ {
    "@language" : "ro",
    "@value" : "Acoperire globală, cu accent pe mările europene și infrastructurile de cercetare marine"
  }, {
    "@language" : "pt",
    "@value" : "Cobertura global, com foco nos mares europeus e nas infraestruturas de investigação marinha"
  }, {
    "@language" : "es",
    "@value" : "Cobertura global, con enfoque en los mares europeos y las infraestructuras de investigación marina"
  }, {
    "@language" : "it",
    "@value" : "Copertura globale, con focus sui mari europei e le infrastrutture di ricerca marine"
  }, {
    "@language" : "fr",
    "@value" : "Couverture mondiale, avec un focus sur les mers européennes et les infrastructures de recherche marines"
  }, {
    "@language" : "no",
    "@value" : "Global dekning, med fokus på europeiske havområder og marine forskningsinfrastrukturer"
  }, {
    "@language" : "en",
    "@value" : "Global, with a focus on European Seas and marine research infrastructures"
  }, {
    "@language" : "el",
    "@value" : "Παγκόσμια κάλυψη, με έμφαση στις ευρωπαϊκές θάλασσες και στις θαλάσσιες ερευνητικές υποδομές"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-04-04"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "https://orcid.org/0009-0008-1759-5254"
  }, {
    "@id" : "https://ror.org/02feahw73"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "no",
    "@value" : "Ontologi som beskriver kyst- og dyphavsobservatorier, inkludert alle EMSO-observatorier, som del av den europeiske tverrfaglige infrastrukturen for havbunn og vannsøyle. Må ikke forveksles med OpenScienceOntology (OSO)."
  }, {
    "@language" : "it",
    "@value" : "Ontologia che descrive gli osservatori marini costieri e d'altura, compresi tutti gli osservatori EMSO, nell'ambito dell'infrastruttura europea multidisciplinare dei fondali marini e della colonna d'acqua. Da non confondere con OpenScienceOntology (OSO)."
  }, {
    "@language" : "pt",
    "@value" : "Ontologia que descreve os observatórios costeiros e de mar aberto, incluindo todos os observatórios EMSO no âmbito da infraestrutura europeia multidisciplinar dos fundos marinhos e da coluna de água. Não deve ser confundida com OpenScienceOntology (OSO)."
  }, {
    "@language" : "ro",
    "@value" : "Ontologie care descrie observatoarele marine de coastă și de larg, inclusiv toate observatoarele EMSO, ca parte a infrastructurii europene multidisciplinare a fundului mării și a coloanei de apă. A nu se confunda cu OpenScienceOntology (OSO)."
  }, {
    "@language" : "fr",
    "@value" : "Ontologie décrivant les observatoires marins côtiers et hauturiers, incluant l’ensemble des observatoires EMSO, dans le cadre de l'infrastructure européenne multidisciplinaire dédiée aux fonds marins et à la colonne d’eau. À ne pas confondre avec l'OpenScienceOntology (OSO)."
  }, {
    "@language" : "en",
    "@value" : "Ontology describing coastal and open seas observatories, including all EMSO observatories as part of the European Multidisciplinary Seafloor and Water Column Observatories infrastructure. Not to be confused with the OpenScienceOntology (OSO)."
  }, {
    "@language" : "es",
    "@value" : "Ontología que describe los observatorios marinos costeros y de alta mar, incluyendo todos los observatorios EMSO en el marco de la infraestructura europea multidisciplinar para el fondo marino y la columna de agua. No debe confundirse con OpenScienceOntology (OSO)."
  }, {
    "@language" : "el",
    "@value" : "Οντολογία που περιγράφει τα παράκτια και ανοιχτά θαλάσσια παρατηρητήρια, συμπεριλαμβανομένων όλων των παρατηρητηρίων EMSO, στο πλαίσιο της ευρωπαϊκής πολυκλαδικής υποδομής για τον πυθμένα και τη στήλη του νερού. Να μην συγχέεται με το OpenScienceOntology (OSO)."
  } ],
