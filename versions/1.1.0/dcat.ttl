@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix void: <http://rdfs.org/ns/void#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/earthsemantics/OSO>
    a dcat:Dataset ,
      void:Dataset ,
      owl:Ontology ;

    dcterms:title "Observatories of the Seas Ontology"@en ;
    dcterms:alternative "OSO"@en ;

    dcterms:description "OSO is an ontology designed to describe marine observatories, research infrastructures, observation platforms, associated organisations, scientific activities and related metadata in a FAIR and interoperable way."@en ;

    dcterms:creator <https://orcid.org/0000-0001-8502-9812> ;
    pav:curatedBy <https://orcid.org/0000-0001-8502-9812> ;

    dcterms:publisher <https://ror.org/044jxhp58> ;

    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;

    dcterms:created "2025-03-01"^^xsd:date ;
    dcterms:modified "2026-06-30"^^xsd:date ;

    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/en> ;
    dcterms:language <http://id.loc.gov/vocabulary/iso639-1/fr> ;

    dcat:keyword
        "marine observatories"@en ,
        "research infrastructures"@en ,
        "semantic web"@en ,
        "ontology"@en ,
        "FAIR"@en ,
        "ocean observing systems"@en ;

    foaf:homepage <https://github.com/emso-eric/oso-ontology> ;

    dcat:landingPage <https://earthportal.eu/ontologies/OSO> ;

    dcterms:hasVersion <https://w3id.org/earthsemantics/OSO/1.1.0> ;

    owl:versionInfo "1.1.0"@en ;
    dcat:version "1.1.0" ;

    dcat:distribution
        <https://w3id.org/earthsemantics/OSO/OSO.ttl> ,
        <https://w3id.org/earthsemantics/OSO/OSO.owl> ,
        <https://w3id.org/earthsemantics/OSO/OSO.jsonld> ,
        <https://w3id.org/earthsemantics/OSO/OSO.nt> ,
        <https://w3id.org/earthsemantics/OSO/OSO.n3> ,
        <https://w3id.org/earthsemantics/OSO/OSO.trig> ,
        <https://w3id.org/earthsemantics/OSO/sparql> ,
        <https://doi.org/10.5281/zenodo.19497913> .

<https://w3id.org/earthsemantics/OSO/OSO.ttl>
    a dcat:Distribution ;
    dcterms:format "text/turtle" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/turtle> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.ttl> .

<https://w3id.org/earthsemantics/OSO/OSO.owl>
    a dcat:Distribution ;
    dcterms:format "application/rdf+xml" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/application/rdf+xml> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.owl> .

<https://w3id.org/earthsemantics/OSO/OSO.jsonld>
    a dcat:Distribution ;
    dcterms:format "application/ld+json" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/application/ld+json> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.jsonld> .

<https://w3id.org/earthsemantics/OSO/OSO.nt>
    a dcat:Distribution ;
    dcterms:format "application/n-triples" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/application/n-triples> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.nt> .

<https://w3id.org/earthsemantics/OSO/OSO.n3>
    a dcat:Distribution ;
    dcterms:format "text/n3" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/n3> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.n3> .

<https://w3id.org/earthsemantics/OSO/OSO.trig>
    a dcat:Distribution ;
    dcterms:format "application/trig" ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/application/trig> ;
    dcat:downloadURL <https://w3id.org/earthsemantics/OSO/OSO.trig> .

<https://w3id.org/earthsemantics/OSO/sparql>
    a dcat:DataService ;
    dcterms:title "OSO SPARQL endpoint"@en ;
    dcat:endpointURL <https://virtuoso.ifremer.fr/oso/sparql> ;
    dcat:landingPage <https://virtuoso.ifremer.fr/oso/> .