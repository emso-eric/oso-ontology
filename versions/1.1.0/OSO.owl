    <rdfs:label xml:lang="fr">Fani Maoré</rdfs:label>
    <rdfs:label xml:lang="en">Fani Maoré</rdfs:label>
    <skos:definition xml:lang="en">Submarine volcano discovered east of Mayotte during the 2018–present seismo-volcanic crisis.</skos:definition>
    <skos:definition xml:lang="fr">Volcan sous-marin découvert à l’est de Mayotte lors de la crise sismo-volcanique débutée en 2018.</skos:definition>
  </rdf:Description>
