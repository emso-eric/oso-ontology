    <skos:definition xml:lang="en">A long-term open-ocean observation site in the northwestern Mediterranean Sea associated with EMSO-France and dedicated to atmospheric, biogeochemical and oceanographic monitoring.</skos:definition>
    <skos:definition xml:lang="fr">Un site d’observation hauturière à long terme en Méditerranée nord-occidentale associé à EMSO-France et dédié au suivi atmosphérique, biogéochimique et océanographique.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#physical_oceanography">
