    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#R2"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#R3"/>
    <OSO:hasRegionalTeamLeader rdf:resource="https://w3id.org/earthsemantics/OSO#Davide_EMBRIACO"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#CNR"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#INFN"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#INGV"/>
    <schema1:url rdf:resource="http://www.moist.it/sites/western_ionian_sea/2"/>
    <rdfs:seeAlso rdf:resource="http://www.moist.it/sites/western_ionian_sea/2"/>
    <OSO:distanceFromLand rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">13</OSO:distanceFromLand>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2001-01-01</OSO:dateFirstDeployment>
    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2100</OSO:maxWaterDepth>
    <skos:definition xml:lang="en">Regional EMSO facility located in the western Ionian Sea, including several deep-sea observation sites and dedicated to long-term multidisciplinary marine monitoring.</skos:definition>
    <skos:definition xml:lang="it">Infrastruttura regionale EMSO situata nel Mar Ionio occidentale, comprendente diversi siti di osservazione in acque profonde e dedicata al monitoraggio marino multidisciplinare a lungo termine.</skos:definition>
    <rdfs:label xml:lang="el">Δυτική Ιόνια Θάλασσα</rdfs:label>
    <rdfs:label xml:lang="en">Western Ionian Sea</rdfs:label>
    <rdfs:label xml:lang="es">Mar Jónico occidental</rdfs:label>
    <rdfs:label xml:lang="fr">Mer Ionienne occidentale</rdfs:label>
    <rdfs:label xml:lang="it">Mar Ionio occidentale</rdfs:label>
    <rdfs:label xml:lang="no">Vestlige joniske hav</rdfs:label>
    <rdfs:label xml:lang="pt">Mar Jônico ocidental</rdfs:label>
    <rdfs:label xml:lang="ro">Marea Ionică de Vest</rdfs:label>
    <skos:prefLabel xml:lang="el">Δυτική Ιόνια Θάλασσα</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Western Ionian Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Mar Jónico occidental</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Mer Ionienne occidentale</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Mar Ionio occidentale</skos:prefLabel>
