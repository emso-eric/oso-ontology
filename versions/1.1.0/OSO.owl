    <rdfs:label xml:lang="fr">Site d’observation CONDOR</rdfs:label>
    <rdfs:label xml:lang="it">Sito osservativo CONDOR</rdfs:label>
    <rdfs:label xml:lang="no">CONDOR observasjonssted</rdfs:label>
    <rdfs:label xml:lang="pt">Sítio de observação CONDOR</rdfs:label>
    <rdfs:label xml:lang="ro">Sit de observare CONDOR</rdfs:label>
    <skos:prefLabel xml:lang="el">Σταθμός Condor</skos:prefLabel>
    <skos:prefLabel xml:lang="en">CONDOR Observatory Site</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Sitio de observación CONDOR</skos:prefLabel>
