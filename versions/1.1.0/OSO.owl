    <dcterms:title xml:lang="en">European VisiOn for Long-term Ocean Observations and EnVironmEntal Sustainability (EMSO EVOLVE)</dcterms:title>
    <dcterms:title xml:lang="es">Visión europea para observaciones oceánicas a largo plazo y sostenibilidad medioambiental (EMSO EVOLVE)</dcterms:title>
