  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#EuxRo01">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#EuxRo01_seabed_station"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#EuxRo01_surface_buoy"/>
    <OSO:hasGeometry rdf:resource="https://w3id.org/earthsemantics/OSO#EuxRo01_geom"/>
    <OSO:hasSiteResponsible rdf:resource="https://w3id.org/earthsemantics/OSO#Vlad_Rădulescu"/>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2013-06-01</OSO:dateFirstDeployment>
    <OSO:isTestSite rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</OSO:isTestSite>
    <rdfs:label xml:lang="el">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="en">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="es">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="fr">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="it">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="no">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="pt">EuxRo01</rdfs:label>
    <rdfs:label xml:lang="ro">EuxRo01</rdfs:label>
    <skos:prefLabel xml:lang="el">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="en">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="es">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="it">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="no">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">EuxRo01</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">EuxRo01</skos:prefLabel>
    <skos:definition xml:lang="en">An EMSO-EUXINUS observatory site in the western Black Sea, composed of a surface buoy acoustically linked to a seabed system and connected to the shore by satellite.</skos:definition>
    <skos:definition xml:lang="fr">Un site d’observation EMSO-EUXINUS en mer Noire occidentale, composé d’une bouée de surface reliée acoustiquement à un système fond de mer et connectée à la côte par satellite.</skos:definition>
    <skos:definition xml:lang="ro">Un sit de observare EMSO-EUXINUS în vestul Mării Negre, compus dintr-o geamandură de suprafață conectată acustic la un sistem de fund marin și legată de țărm prin satelit.</skos:definition>
    <dcterms:description xml:lang="en">Moored surface buoy acoustically linked with a seabed system and connected to the shore via satellite.</dcterms:description>
    <dcterms:description xml:lang="fr">Bouée de surface mouillée, reliée acoustiquement à un système fond de mer et connectée à la côte par satellite.</dcterms:description>
    <dcterms:description xml:lang="ro">Geamandură de suprafață ancorată, conectată acustic la un sistem de fund marin și legată de țărm prin satelit.</dcterms:description>
    <skos:altLabel xml:lang="en">EUXINUS EuxRo01 site</skos:altLabel>
    <skos:altLabel xml:lang="fr">Site EUXINUS EuxRo01</skos:altLabel>
    <skos:altLabel xml:lang="ro">Situl EUXINUS EuxRo01</skos:altLabel>
    <rdfs:seeAlso rdf:resource="https://www.euxinus.eu/emso_euxinus_network.html"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Subsite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <metadata:prefixIRI>OSO:Subsite</metadata:prefixIRI>
    <rdfs:comment xml:lang="en">A subsite of observation, a finer component of a site, enabling increased spatial granularity for measurement or instrumentation.</rdfs:comment>
    <rdfs:comment xml:lang="no">Et delområde for observasjon, en finere komponent av et sted, som muliggjør økt romlig granularitet for måling eller instrumentering.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Um sublocal de observação, componente mais detalhado de um site, permitindo maior granularidade espacial para medições ou instrumentação.</rdfs:comment>
    <rdfs:comment xml:lang="it">Un sotto-sito di osservazione, componente più fine di un sito, che consente una maggiore granularità spaziale per le misurazioni o la strumentazione.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Un sous-site d'observation, composante plus fine d’un site, qui permet une granularité spatiale accrue pour la mesure ou l'instrumentation.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Un sub-site de observație, componentă mai detaliată a unui site, care permite o granularitate spațială crescută pentru măsurători sau instrumentare.</rdfs:comment>
    <rdfs:comment xml:lang="es">Un sub-sitio de observación, componente más detallado de un sitio, que permite una mayor granularidad espacial para mediciones o instrumentación.</rdfs:comment>
    <rdfs:comment xml:lang="el">Μια υποτοποθεσία παρατήρησης, λεπτότερο συστατικό ενός τόπου, που επιτρέπει αυξημένη χωρική ανάλυση για μέτρηση ή οργανολογία.</rdfs:comment>
    <rdfs:label xml:lang="no">Delområde for observasjon</rdfs:label>
    <rdfs:label xml:lang="en">Observation Subsite</rdfs:label>
    <rdfs:label xml:lang="it">Sotto-sito di osservazione</rdfs:label>
    <rdfs:label xml:lang="fr">Sous-site d'observation</rdfs:label>
    <rdfs:label xml:lang="ro">Sub-site de observație</rdfs:label>
    <rdfs:label xml:lang="es">Sub-sitio de observación</rdfs:label>
    <rdfs:label xml:lang="pt">Sublocal de observação</rdfs:label>
    <rdfs:label xml:lang="el">Υποτοποθεσία παρατήρησης</rdfs:label>
    <skos:prefLabel xml:lang="no">Delområde for observasjon</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Observation Subsite</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Sotto-sito di osservazione</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Sous-site d'observation</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Sub-site de observație</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Sub-sitio de observación</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Sublocal de observação</skos:prefLabel>
    <skos:prefLabel xml:lang="el">Υποτοποθεσία παρατήρησης</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#EMBRC-France">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure"/>
    <OSO:isPartOf rdf:resource="https://w3id.org/earthsemantics/OSO#EMBRC"/>
