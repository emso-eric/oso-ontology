  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SemanticPortalFramework">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:label xml:lang="en">Semantic portal framework</rdfs:label>
    <rdfs:label xml:lang="fr">Framework de portail sémantique</rdfs:label>
    <rdfs:label xml:lang="es">Framework para portales semánticos</rdfs:label>
    <rdfs:label xml:lang="it">Framework per portali semantici</rdfs:label>
    <rdfs:label xml:lang="pt">Framework para portais semânticos</rdfs:label>
    <rdfs:label xml:lang="ro">Framework pentru portaluri semantice</rdfs:label>
    <rdfs:label xml:lang="no">Rammeverk for semantiske portaler</rdfs:label>
    <rdfs:label xml:lang="el">Πλαίσιο για σημασιολογικές πύλες</rdfs:label>
    <skos:definition xml:lang="en">A software framework used to build, deploy and manage semantic artefact repositories and ontology portals.</skos:definition>
    <skos:definition xml:lang="fr">Un framework logiciel utilisé pour construire, déployer et administrer des dépôts d’artefacts sémantiques et des portails d’ontologies.</skos:definition>
    <skos:definition xml:lang="es">Un framework de software utilizado para crear, desplegar y administrar repositorios de artefactos semánticos y portales de ontologías.</skos:definition>
    <skos:definition xml:lang="it">Un framework software utilizzato per creare, distribuire e gestire repository di artefatti semantici e portali di ontologie.</skos:definition>
    <skos:definition xml:lang="pt">Um framework de software utilizado para construir, implementar e gerir repositórios de artefactos semânticos e portais de ontologias.</skos:definition>
    <skos:definition xml:lang="ro">Un framework software utilizat pentru construirea, implementarea și administrarea depozitelor de artefacte semantice și a portalurilor de ontologii.</skos:definition>
    <skos:definition xml:lang="no">Et programvarerammeverk som brukes til å bygge, distribuere og administrere semantiske artefaktlagre og ontologiportaler.</skos:definition>
    <skos:definition xml:lang="el">Ένα πλαίσιο λογισμικού που χρησιμοποιείται για την ανάπτυξη, την εγκατάσταση και τη διαχείριση αποθετηρίων σημασιολογικών τεχνουργημάτων και πυλών οντολογιών.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Western_Mediterranean_Sea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <OSO:RegionalFacility_is_part_of_a_RI rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO-Italia"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Italy"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Ligurian_Sea"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Mediterranean_Sea"/>
    <OSO:hasERICMembership rdf:resource="https://w3id.org/earthsemantics/OSO#Western_Mediterranean_Sea_EMSO_membership"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#W1M3A"/>
    <OSO:hasRegionalTeamLeader rdf:resource="https://w3id.org/earthsemantics/OSO#Roberto_BOZZANO"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#CNR"/>
    <skos:definition xml:lang="en">Regional EMSO facility associated with the Ligurian Sea and dedicated to long-term multidisciplinary marine observation in the western Mediterranean Sea.</skos:definition>
    <skos:definition xml:lang="fr">Infrastructure régionale EMSO associée à la mer Ligure et dédiée à l’observation marine multidisciplinaire à long terme en Méditerranée occidentale.</skos:definition>
    <skos:definition xml:lang="it">Infrastruttura regionale EMSO associata al Mar Ligure e dedicata all’osservazione marina multidisciplinare a lungo termine nel Mediterraneo occidentale.</skos:definition>
    <rdfs:comment xml:lang="el">Ο περιφερειακός κόμβος 'Western Mediterranean Sea' αντιστοιχεί στη Λιγουρική Θάλασσα, όπως ορίζεται από τον Διεθνή Υδρογραφικό Οργανισμό.</rdfs:comment>
    <rdfs:comment xml:lang="en">The Regional Facility 'Western Mediterranean Sea' corresponds to the Ligurian Sea, as defined by the International Hydrographic Organization.</rdfs:comment>
    <rdfs:comment xml:lang="es">El nodo regional 'Western Mediterranean Sea' corresponde al mar de Liguria, según lo definido por la Organización Hidrográfica Internacional.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Le nœud régional 'Western Mediterranean Sea' correspond à la mer Ligure, telle que définie par l’Organisation hydrographique internationale.</rdfs:comment>
    <rdfs:comment xml:lang="it">Il nodo regionale 'Western Mediterranean Sea' corrisponde al Mar Ligure, come definito dall’Organizzazione Idrografica Internazionale.</rdfs:comment>
    <rdfs:comment xml:lang="no">Den regionale noden 'Western Mediterranean Sea' tilsvarer Liguriahavet, slik det er definert av Den internasjonale hydrografiske organisasjonen.</rdfs:comment>
    <rdfs:comment xml:lang="pt">O nó regional 'Western Mediterranean Sea' corresponde ao Mar da Ligúria, conforme definido pela Organização Hidrográfica Internacional.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Nodul regional 'Western Mediterranean Sea' corespunde Mării Ligurice, așa cum este definită de Organizația Hidrografică Internațională.</rdfs:comment>
    <rdfs:label xml:lang="el">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="en">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="es">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="fr">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="it">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="no">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="pt">Western Mediterranean Sea</rdfs:label>
    <rdfs:label xml:lang="ro">Western Mediterranean Sea</rdfs:label>
    <skos:prefLabel xml:lang="el">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Western Mediterranean Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Western Mediterranean Sea</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#W1M3A">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
