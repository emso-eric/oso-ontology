    <skos:altLabel xml:lang="en">Earth sciences semantic artefact repository</skos:altLabel>
    <skos:altLabel xml:lang="fr">Dépôt d’artefacts sémantiques pour les sciences de la Terre</skos:altLabel>
    <skos:altLabel xml:lang="es">Repositorio de artefactos semánticos para las ciencias de la Tierra</skos:altLabel>
    <skos:altLabel xml:lang="it">Repository di artefatti semantici per le scienze della Terra</skos:altLabel>
    <skos:altLabel xml:lang="pt">Repositório de artefactos semânticos para as ciências da Terra</skos:altLabel>
