    <schema1:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2018-07-04</schema1:startDate>
    <schema1:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2018-07-27</schema1:endDate>
    <skos:note xml:lang="en">Oceanographic campaign conducted in the Lucky Strike hydrothermal vent field on the Mid-Atlantic Ridge.</skos:note>
    <skos:note xml:lang="fr">Campagne océanographique réalisée sur le champ hydrothermal Lucky Strike au niveau de la dorsale médio-atlantique.</skos:note>
    <dcterms:description xml:lang="en">LUCKYDIVMIC is an oceanographic campaign dedicated to the study of hydrothermal ecosystems and microbial diversity at the Lucky Strike vent field on the Mid-Atlantic Ridge.</dcterms:description>
    <dcterms:description xml:lang="fr">LUCKYDIVMIC est une campagne océanographique dédiée à l’étude des écosystèmes hydrothermaux et de la diversité microbienne du champ hydrothermal Lucky Strike sur la dorsale médio-atlantique.</dcterms:description>
    <rdfs:label xml:lang="el">LUCKYDIVMIC</rdfs:label>
