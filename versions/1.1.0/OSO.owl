    <skos:definition xml:lang="en">Country located in Southern Europe and member state of the European Union, actively involved in marine research and EMSO activities.</skos:definition>
    <skos:definition xml:lang="fr">Pays situé en Europe du Sud et État membre de l’Union européenne, activement impliqué dans la recherche marine et les activités EMSO.</skos:definition>
    <skos:definition xml:lang="it">Paese situato nell’Europa meridionale e Stato membro dell’Unione europea, attivamente coinvolto nella ricerca marina e nelle attività EMSO.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#southBoundLatitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#BoundingBox"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <skos:definition xml:lang="en">Specifies the southernmost latitude of a geographic bounding box.</skos:definition>
    <skos:definition xml:lang="fr">Spécifie la latitude sud maximale d’une boîte englobante géographique.</skos:definition>
    <skos:definition xml:lang="es">Especifica la latitud sur máxima de una caja geográfica delimitadora.</skos:definition>
    <skos:definition xml:lang="it">Specifica la latitudine sud massima di un riquadro geografico.</skos:definition>
    <skos:definition xml:lang="pt">Especifica a latitude sul máxima de uma caixa geográfica delimitadora.</skos:definition>
    <skos:definition xml:lang="no">Angir den sørligste breddegraden i en geografisk avgrensningsboks.</skos:definition>
    <skos:definition xml:lang="ro">Specifică latitudinea sudică maximă a unei zone geografice delimitate.</skos:definition>
    <skos:definition xml:lang="el">Καθορίζει το νοτιότερο γεωγραφικό πλάτος ενός γεωγραφικού πλαισίου.</skos:definition>
    <rdfs:comment xml:lang="en">Southernmost latitude of a geographic bounding box, corresponding to southBoundLatitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Latitude sud maximale d’une boîte englobante géographique, correspondant à southBoundLatitude dans l’ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="es">Latitud sur máxima de una caja geográfica delimitadora, correspondiente a southBoundLatitude en ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="it">Latitudine sud massima di un riquadro geografico, corrispondente a southBoundLatitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Latitude sul máxima de uma caixa geográfica delimitadora, correspondente a southBoundLatitude na ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="no">Sørligste breddegrad i en geografisk avgrensningsboks, tilsvarende southBoundLatitude i ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Latitudinea sudică maximă a unei zone geografice delimitate, corespunzătoare southBoundLatitude din ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="el">Το νοτιότερο γεωγραφικό πλάτος ενός γεωγραφικού πλαισίου, που αντιστοιχεί στο southBoundLatitude του ISO 19115-3.</rdfs:comment>
    <rdfs:label xml:lang="el">νότιο όριο γεωγραφικού πλάτους</rdfs:label>
    <rdfs:label xml:lang="en">south bound latitude</rdfs:label>
    <rdfs:label xml:lang="es">latitud sur máxima</rdfs:label>
