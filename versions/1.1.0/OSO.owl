  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#RegionalFacility_is_linked_to_a_project">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchProject"/>
    <skos:definition xml:lang="en">Relates a regional facility to a research project with which it is associated.</skos:definition>
    <skos:definition xml:lang="fr">Relie une infrastructure régionale à un projet de recherche auquel elle est associée.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una infraestructura regional con un proyecto de investigación al que está asociada.</skos:definition>
    <skos:definition xml:lang="it">Collega un'infrastruttura regionale a un progetto di ricerca a cui è associata.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma infraestrutura regional a um projeto de investigação ao qual está associada.</skos:definition>
    <skos:definition xml:lang="no">Knytter en regional infrastruktur til et forskningsprosjekt som den er tilknyttet.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o infrastructură regională de un proiect de cercetare cu care este asociată.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια περιφερειακή υποδομή με ένα ερευνητικό έργο με το οποίο σχετίζεται.</skos:definition>
    <rdfs:comment xml:lang="en">Links a regional facility to a related research project.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une infrastructure régionale à un projet de recherche associé.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una infraestructura regional con un proyecto de investigación asociado.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'infrastruttura regionale a un progetto di ricerca associato.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma infraestrutura regional a um projeto de investigação associado.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en regional infrastruktur til et tilknyttet forskningsprosjekt.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o infrastructură regională de un proiect de cercetare asociat.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια περιφερειακή υποδομή με ένα σχετικό ερευνητικό έργο.</rdfs:comment>
    <rdfs:label xml:lang="el">Η περιφερειακή υποδομή συνδέεται με έργο</rdfs:label>
    <rdfs:label xml:lang="en">Regional Facility is linked to a project</rdfs:label>
    <rdfs:label xml:lang="es">La infraestructura regional está vinculada a un proyecto</rdfs:label>
    <rdfs:label xml:lang="fr">L’infrastructure régionale est liée à un projet</rdfs:label>
    <rdfs:label xml:lang="it">L'infrastruttura regionale è collegata a un progetto</rdfs:label>
    <rdfs:label xml:lang="no">Regional infrastruktur er knyttet til et prosjekt</rdfs:label>
    <rdfs:label xml:lang="pt">A infraestrutura regional está ligada a um projeto</rdfs:label>
    <rdfs:label xml:lang="ro">Infrastructura regională este legată de un proiect</rdfs:label>
    <skos:prefLabel xml:lang="el">Η περιφερειακή υποδομή συνδέεται με έργο</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Regional Facility is linked to a project</skos:prefLabel>
    <skos:prefLabel xml:lang="es">La infraestructura regional está vinculada a un proyecto</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">L’infrastructure régionale est liée à un projet</skos:prefLabel>
    <skos:prefLabel xml:lang="it">L'infrastruttura regionale è collegata a un progetto</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Regional infrastruktur er knyttet til et prosjekt</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">A infraestrutura regional está ligada a um projeto</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Infrastructura regională este legată de un proiect</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isTestSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
