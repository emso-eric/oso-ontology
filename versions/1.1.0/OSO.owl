    <skos:definition xml:lang="en">An ontology editor used for modelling, editing and maintaining OWL ontologies.</skos:definition>
    <skos:definition xml:lang="fr">Un éditeur d’ontologies utilisé pour modéliser, éditer et maintenir des ontologies OWL.</skos:definition>
    <skos:definition xml:lang="es">Un editor de ontologías utilizado para modelar, editar y mantener ontologías OWL.</skos:definition>
    <skos:definition xml:lang="it">Un editor di ontologie utilizzato per modellare, modificare e mantenere ontologie OWL.</skos:definition>
    <skos:definition xml:lang="pt">Um editor de ontologias utilizado para modelar, editar e manter ontologias OWL.</skos:definition>
    <skos:definition xml:lang="ro">Un editor de ontologii utilizat pentru modelarea, editarea și întreținerea ontologiilor OWL.</skos:definition>
    <skos:definition xml:lang="no">Et ontologiredigeringsverktøy som brukes til å modellere, redigere og vedlikeholde OWL-ontologier.</skos:definition>
    <skos:definition xml:lang="el">Ένας επεξεργαστής οντολογιών που χρησιμοποιείται για τη μοντελοποίηση, την επεξεργασία και τη συντήρηση οντολογιών OWL.</skos:definition>
    <schema1:name>Protégé</schema1:name>
    <schema1:url rdf:resource="https://protege.stanford.edu/"/>
    <schema1:publisher rdf:resource="https://w3id.org/earthsemantics/OSO#StanfordCenterForBiomedicalInformaticsResearch"/>
    <schema1:logo rdf:resource="https://w3id.org/earthsemantics/OSO#ProtegeLogo"/>
    <dcterms:type xml:lang="en">Ontology editor</dcterms:type>
    <dcterms:type xml:lang="fr">Éditeur d’ontologies</dcterms:type>
    <dcterms:type xml:lang="es">Editor de ontologías</dcterms:type>
    <dcterms:type xml:lang="it">Editor di ontologie</dcterms:type>
    <dcterms:type xml:lang="pt">Editor de ontologias</dcterms:type>
    <dcterms:type xml:lang="ro">Editor de ontologii</dcterms:type>
    <dcterms:type xml:lang="no">Ontologiredigeringsverktøy</dcterms:type>
    <dcterms:type xml:lang="el">Επεξεργαστής οντολογιών</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://protege.stanford.edu/"/>
    <rdfs:seeAlso rdf:resource="https://github.com/protegeproject/protege"/>
