    <dcterms:type xml:lang="ro">Cadru RDF</dcterms:type>
    <dcterms:type xml:lang="no">RDF-rammeverk</dcterms:type>
    <dcterms:type xml:lang="el">Πλαίσιο RDF</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://rdflib.readthedocs.io/"/>
    <rdfs:seeAlso rdf:resource="https://github.com/RDFLib/rdflib"/>
