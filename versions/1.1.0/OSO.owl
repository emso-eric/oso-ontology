    <skos:definition xml:lang="en">An EMSO-EUXINUS observatory site in the western Black Sea, composed of a surface buoy and a seabed station.</skos:definition>
    <skos:definition xml:lang="fr">Un site d’observation EMSO-EUXINUS en mer Noire occidentale, composé d’une bouée de surface et d’une station fond de mer.</skos:definition>
    <skos:definition xml:lang="ro">Un sit de observare EMSO-EUXINUS în vestul Mării Negre, compus dintr-o geamandură de suprafață și o stație de fund marin.</skos:definition>
    <skos:altLabel xml:lang="en">EUXINUS EuxRo02 site</skos:altLabel>
    <skos:altLabel xml:lang="fr">Site EUXINUS EuxRo02</skos:altLabel>
    <skos:altLabel xml:lang="ro">Situl EUXINUS EuxRo02</skos:altLabel>
  </rdf:Description>
