  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#ESTOC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#ESTOC_Subsurface_gliders"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#ESTOC_Subsurface_mooring"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#ESTOC_Moored_Surface_Buoy"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#ESTOC_Autonomous_Devices"/>
    <OSO:hasSiteResponsible rdf:resource="https://w3id.org/earthsemantics/OSO#Eric_DELORY"/>
    <OSO:isTestSite rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</OSO:isTestSite>
    <rdfs:label xml:lang="en">ESTOC</rdfs:label>
    <rdfs:label xml:lang="es">ESTOC</rdfs:label>
    <rdfs:label xml:lang="fr">ESTOC</rdfs:label>
    <skos:prefLabel xml:lang="en">ESTOC</skos:prefLabel>
    <skos:prefLabel xml:lang="es">ESTOC</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">ESTOC</skos:prefLabel>
    <skos:altLabel xml:lang="en">European Station for Time-Series in the Ocean of the Canary Islands</skos:altLabel>
    <skos:altLabel xml:lang="es">Estación Europea de Series Temporales Oceánicas de Canarias</skos:altLabel>
    <skos:altLabel xml:lang="fr">Station européenne de séries temporelles océaniques des Canaries</skos:altLabel>
    <skos:altLabel xml:lang="en">EMSO Canarias</skos:altLabel>
    <skos:altLabel xml:lang="es">EMSO Canarias</skos:altLabel>
    <skos:altLabel xml:lang="fr">EMSO Canarias</skos:altLabel>
    <dcterms:title xml:lang="en">ESTOC ocean observatory site</dcterms:title>
    <dcterms:title xml:lang="es">Sitio de observación oceánica ESTOC</dcterms:title>
    <dcterms:title xml:lang="fr">Site d’observation océanique ESTOC</dcterms:title>
    <dcterms:description xml:lang="en">Long-term open ocean observatory site operated by PLOCAN north of Gran Canaria as part of EMSO Canarias, supporting multidisciplinary ocean monitoring, glider missions and climate observations in the North Atlantic Ocean.</dcterms:description>
    <dcterms:description xml:lang="es">Sitio de observación oceánica de largo plazo operado por PLOCAN al norte de Gran Canaria como parte de EMSO Canarias, apoyando la monitorización multidisciplinar del océano, misiones de gliders y observaciones climáticas en el Atlántico Norte.</dcterms:description>
    <dcterms:description xml:lang="fr">Site d’observation océanique de long terme exploité par PLOCAN au nord de Grande Canarie dans le cadre d’EMSO Canarias, supportant des observations multidisciplinaires de l’océan, des missions de gliders et des études climatiques dans l’océan Atlantique Nord.</dcterms:description>
    <wgs84_pos:lat rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">29.1667</wgs84_pos:lat>
    <wgs84_pos:long rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-15.5000</wgs84_pos:long>
    <OSO:hasDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">3670</OSO:hasDepth>
    <prov:wasAssociatedWith rdf:resource="https://w3id.org/earthsemantics/OSO#PLOCAN"/>
