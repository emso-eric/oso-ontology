  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#westBoundLongitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#BoundingBox"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:comment xml:lang="en">Westernmost longitude of a geographic bounding box, corresponding to westBoundLongitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Longitude ouest maximale d’une boîte englobante géographique, correspondant à westBoundLongitude dans l’ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="es">Longitud oeste máxima de una caja geográfica delimitadora, correspondiente a westBoundLongitude en ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="it">Longitudine ovest massima di un riquadro geografico, corrispondente a westBoundLongitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Longitude oeste máxima de uma caixa geográfica delimitadora, correspondente a westBoundLongitude na ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="no">Vestligste lengdegrad i en geografisk avgrensningsboks, tilsvarende westBoundLongitude i ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Longitudinea vestică maximă a unei zone geografice delimitate, corespunzătoare westBoundLongitude din ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="el">Το δυτικότερο γεωγραφικό μήκος ενός γεωγραφικού πλαισίου, που αντιστοιχεί στο westBoundLongitude του ISO 19115-3.</rdfs:comment>
    <rdfs:label xml:lang="en">west bound longitude</rdfs:label>
    <rdfs:label xml:lang="fr">longitude ouest maximale</rdfs:label>
    <rdfs:label xml:lang="es">longitud oeste máxima</rdfs:label>
    <rdfs:label xml:lang="it">longitudine ovest massima</rdfs:label>
    <rdfs:label xml:lang="pt">longitude oeste máxima</rdfs:label>
    <rdfs:label xml:lang="no">vestlig lengdegrad</rdfs:label>
    <rdfs:label xml:lang="ro">longitudine vestică maximă</rdfs:label>
    <rdfs:label xml:lang="el">δυτικό όριο γεωγραφικού μήκους</rdfs:label>
    <skos:prefLabel xml:lang="en">west bound longitude</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">longitude ouest maximale</skos:prefLabel>
    <skos:prefLabel xml:lang="es">longitud oeste máxima</skos:prefLabel>
    <skos:prefLabel xml:lang="it">longitudine ovest massima</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">longitude oeste máxima</skos:prefLabel>
    <skos:prefLabel xml:lang="no">vestlig lengdegrad</skos:prefLabel>
