    <rdfs:label xml:lang="no">er kampanje knyttet til</rdfs:label>
    <rdfs:label xml:lang="ro">este campanie legată de</rdfs:label>
    <rdfs:label xml:lang="el">είναι εκστρατεία συνδεδεμένη με</rdfs:label>
    <skos:prefLabel xml:lang="en">is campaign linked to</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est une campagne liée à</skos:prefLabel>
