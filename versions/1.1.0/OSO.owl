  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Balearic_Sea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <OSO:hasERICMembership rdf:resource="https://w3id.org/earthsemantics/OSO#Balearic_Sea_EMSO_membership"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Spain"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Balearic_Sea"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#OBSEA"/>
    <OSO:hasRegionalTeamLeader rdf:resource="https://w3id.org/earthsemantics/OSO#Joaquin_DEL_RIO"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#UPC"/>
    <schema1:url rdf:resource="https://www.obsea.es/"/>
    <rdfs:seeAlso rdf:resource="https://www.obsea.es/"/>
    <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Balearic_Sea"/>
    <skos:exactMatch rdf:resource="http://dbpedia.org/resource/Balearic_Sea"/>
    <OSO:distanceFromLand rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2</OSO:distanceFromLand>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2009-03-14</OSO:dateFirstDeployment>
    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</OSO:maxWaterDepth>
    <geosparql:hasGeometry rdf:resource="https://w3id.org/earthsemantics/OSO#Balearic_Sea_RF_geometry"/>
    <skos:definition xml:lang="en">Regional EMSO facility associated with the Balearic Sea and the OBSEA cabled observatory, dedicated to coastal and marine observation activities.</skos:definition>
    <skos:definition xml:lang="fr">Infrastructure régionale EMSO associée à la mer des Baléares et à l’observatoire câblé OBSEA, dédiée aux activités d’observation côtière et marine.</skos:definition>
    <skos:definition xml:lang="es">Infraestructura regional EMSO asociada al mar Balear y al observatorio cableado OBSEA, dedicada a actividades de observación costera y marina.</skos:definition>
    <skos:definition xml:lang="ca">Infraestructura regional EMSO associada al mar Balear i a l’observatori cablejat OBSEA, dedicada a activitats d’observació costanera i marina.</skos:definition>
    <rdfs:label xml:lang="el">Βαλεαρίδα Θάλασσα</rdfs:label>
