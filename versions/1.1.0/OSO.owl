    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Coral_Sea"/>
    <skos:related rdf:resource="https://w3id.org/earthsemantics/OSO#KANADEEP_2"/>
    <rdfs:label xml:lang="el">KASEAOPE</rdfs:label>
    <rdfs:label xml:lang="en">KASEAOPE</rdfs:label>
    <rdfs:label xml:lang="es">KASEAOPE</rdfs:label>
    <rdfs:label xml:lang="fr">KASEAOPE</rdfs:label>
    <rdfs:label xml:lang="it">KASEAOPE</rdfs:label>
