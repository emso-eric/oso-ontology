    <rdfs:label xml:lang="es">está vinculada a una serie de campañas</rdfs:label>
    <rdfs:label xml:lang="it">è collegata a una serie di campagne</rdfs:label>
    <rdfs:label xml:lang="pt">está ligada a uma série de campanhas</rdfs:label>
    <rdfs:label xml:lang="no">er knyttet til kampanjeserie</rdfs:label>
    <rdfs:label xml:lang="ro">este legată de o serie de campanii</rdfs:label>
    <rdfs:label xml:lang="el">συνδέεται με σειρά εκστρατειών</rdfs:label>
    <skos:prefLabel xml:lang="en">is linked to campaign series</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est liée à une série de campagnes</skos:prefLabel>
    <skos:prefLabel xml:lang="es">está vinculada a una serie de campañas</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è collegata a una serie di campagne</skos:prefLabel>
