    <skos:prefLabel xml:lang="no">RDFLib</skos:prefLabel>
    <skos:prefLabel xml:lang="el">RDFLib</skos:prefLabel>
    <skos:definition xml:lang="en">An open-source Python framework for creating, parsing, querying, manipulating and serializing RDF graphs.</skos:definition>
    <skos:definition xml:lang="fr">Un framework Python open source permettant de créer, analyser, interroger, manipuler et sérialiser des graphes RDF.</skos:definition>
    <skos:definition xml:lang="es">Un framework de Python de código abierto para crear, analizar, consultar, manipular y serializar grafos RDF.</skos:definition>
    <skos:definition xml:lang="it">Un framework Python open source per creare, analizzare, interrogare, manipolare e serializzare grafi RDF.</skos:definition>
    <skos:definition xml:lang="pt">Um framework Python de código aberto para criar, analisar, consultar, manipular e serializar grafos RDF.</skos:definition>
    <skos:definition xml:lang="ro">Un framework Python open-source pentru crearea, analiza, interogarea, manipularea și serializarea grafurilor RDF.</skos:definition>
    <skos:definition xml:lang="no">Et åpen kildekode-basert Python-rammeverk for å opprette, analysere, spørre, manipulere og serialisere RDF-grafer.</skos:definition>
    <skos:definition xml:lang="el">Ένα πλαίσιο Python ανοικτού κώδικα για τη δημιουργία, ανάλυση, αναζήτηση, επεξεργασία και σειριοποίηση γράφων RDF.</skos:definition>
    <schema1:name>RDFLib</schema1:name>
    <schema1:url rdf:resource="https://rdflib.readthedocs.io/"/>
    <schema1:publisher rdf:resource="https://w3id.org/earthsemantics/OSO#RDFLibProject"/>
