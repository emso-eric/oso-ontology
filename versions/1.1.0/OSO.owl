    <dcterms:type xml:lang="fr">Dépôt d’artefacts sémantiques</dcterms:type>
    <dcterms:type xml:lang="es">Repositorio de artefactos semánticos</dcterms:type>
    <dcterms:type xml:lang="it">Repository di artefatti semantici</dcterms:type>
