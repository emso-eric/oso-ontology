    <dcterms:type xml:lang="ro">Instrument de vizualizare semantică</dcterms:type>
    <dcterms:type xml:lang="no">Verktøy for semantisk visualisering</dcterms:type>
    <dcterms:type xml:lang="el">Εργαλείο σημασιολογικής απεικόνισης</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://service.tib.eu/webvowl/#iri=https://earthportal.eu/ontologies/OSO"/>
    <rdfs:seeAlso rdf:resource="https://github.com/VisualDataWeb/WebVOWL"/>
