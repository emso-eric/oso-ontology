  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Planned">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Status"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdfs:label xml:lang="el">Σχεδιαζόμενο</rdfs:label>
    <rdfs:label xml:lang="en">Planned</rdfs:label>
    <rdfs:label xml:lang="es">Planificado</rdfs:label>
    <rdfs:label xml:lang="fr">Planifié</rdfs:label>
    <rdfs:label xml:lang="it">Pianificato</rdfs:label>
    <rdfs:label xml:lang="no">Planlagt</rdfs:label>
    <rdfs:label xml:lang="pt">Planeado</rdfs:label>
    <rdfs:label xml:lang="ro">Planificat</rdfs:label>
    <skos:prefLabel xml:lang="el">Σχεδιαζόμενο</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Planned</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Planificado</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Planifié</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Pianificato</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Planlagt</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Planeado</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Planificat</skos:prefLabel>
    <skos:altLabel xml:lang="en">Future site</skos:altLabel>
    <skos:altLabel xml:lang="fr">Site futur</skos:altLabel>
    <skos:altLabel xml:lang="pt">Sítio futuro</skos:altLabel>
    <skos:definition xml:lang="en">A site that is planned but not yet deployed or operational.</skos:definition>
    <skos:definition xml:lang="fr">Un site planifié mais non encore déployé ni opérationnel.</skos:definition>
    <skos:definition xml:lang="pt">Um sítio planeado mas ainda não implantado nem operacional.</skos:definition>
    <skos:definition xml:lang="es">Un sitio que está planificado pero aún no desplegado ni operativo.</skos:definition>
    <skos:definition xml:lang="it">Un sito pianificato ma non ancora implementato né operativo.</skos:definition>
    <skos:definition xml:lang="no">Et sted som er planlagt, men ennå ikke utplassert eller i drift.</skos:definition>
    <skos:definition xml:lang="ro">Un sit planificat, dar încă nedesfășurat sau operațional.</skos:definition>
    <skos:definition xml:lang="el">Σχεδιαζόμενο: τόπος που έχει προγραμματιστεί αλλά δεν έχει ακόμη αναπτυχθεί ή λειτουργήσει.</skos:definition>
    <skos:note xml:lang="en">Used to describe planned EMSO sites or infrastructures that are not yet operational.</skos:note>
    <skos:note xml:lang="fr">Utilisé pour décrire des sites ou infrastructures EMSO en projet et non encore opérationnels.</skos:note>
    <skos:note xml:lang="es">Utilizado para describir sitios o infraestructuras EMSO planificados que aún no están operativos.</skos:note>
    <skos:note xml:lang="it">Utilizzato per descrivere siti o infrastrutture EMSO pianificati ma non ancora operativi.</skos:note>
    <skos:note xml:lang="no">Brukes til å beskrive planlagte EMSO-steder eller infrastrukturer som ennå ikke er i drift.</skos:note>
    <skos:note xml:lang="pt">Utilizado para descrever sítios ou infraestruturas EMSO planeadas que ainda não estão operacionais.</skos:note>
    <skos:note xml:lang="ro">Utilizat pentru a descrie situri sau infrastructuri EMSO planificate care nu sunt încă operaționale.</skos:note>
    <skos:note xml:lang="el">Χρησιμοποιείται για την περιγραφή σχεδιαζόμενων τοποθεσιών ή υποδομών EMSO που δεν είναι ακόμη λειτουργικές.</skos:note>
  </rdf:Description>
