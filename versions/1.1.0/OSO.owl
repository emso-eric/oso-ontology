    <skos:prefLabel xml:lang="en">Protégé</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Protégé</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Protégé</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Protégé</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Protégé</skos:prefLabel>
