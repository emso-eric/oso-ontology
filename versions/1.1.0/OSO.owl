    <rdfs:label xml:lang="it">latitudine sud massima</rdfs:label>
    <rdfs:label xml:lang="no">sørlig breddegrad</rdfs:label>
    <rdfs:label xml:lang="pt">latitude sul máxima</rdfs:label>
    <rdfs:label xml:lang="ro">latitudine sudică maximă</rdfs:label>
    <skos:prefLabel xml:lang="el">νότιο όριο γεωγραφικού πλάτους</skos:prefLabel>
