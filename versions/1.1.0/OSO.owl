    <skos:prefLabel xml:lang="en">MARLEY</skos:prefLabel>
    <skos:prefLabel xml:lang="es">MARLEY</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">MARLEY</skos:prefLabel>
    <skos:prefLabel xml:lang="it">MARLEY</skos:prefLabel>
    <skos:prefLabel xml:lang="no">MARLEY</skos:prefLabel>
