  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#OntologyEngineeringWorkflow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/prov#Activity"/>
    <rdfs:label xml:lang="en">Collaborative ontology engineering workflow</rdfs:label>
    <rdfs:label xml:lang="fr">Workflow collaboratif d’ingénierie ontologique</rdfs:label>
    <rdfs:label xml:lang="es">Flujo de trabajo colaborativo de ingeniería ontológica</rdfs:label>
    <rdfs:label xml:lang="it">Flusso di lavoro collaborativo di ingegneria ontologica</rdfs:label>
    <rdfs:label xml:lang="pt">Fluxo de trabalho colaborativo de engenharia ontológica</rdfs:label>
    <rdfs:label xml:lang="ro">Flux de lucru colaborativ pentru ingineria ontologiilor</rdfs:label>
    <rdfs:label xml:lang="no">Samarbeidsbasert arbeidsflyt for ontologiteknikk</rdfs:label>
    <rdfs:label xml:lang="el">Συνεργατική ροή εργασίας για τη μηχανική οντολογιών</rdfs:label>
    <skos:prefLabel xml:lang="en">Collaborative ontology engineering workflow</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Workflow collaboratif d’ingénierie ontologique</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Flujo de trabajo colaborativo de ingeniería ontológica</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Flusso di lavoro collaborativo di ingegneria ontologica</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Fluxo de trabalho colaborativo de engenharia ontológica</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Flux de lucru colaborativ pentru ingineria ontologiilor</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Samarbeidsbasert arbeidsflyt for ontologiteknikk</skos:prefLabel>
    <skos:prefLabel xml:lang="el">Συνεργατική ροή εργασίας για τη μηχανική οντολογιών</skos:prefLabel>
    <skos:definition xml:lang="en">A collaborative ontology engineering workflow supporting the development, maintenance, versioning and FAIR publication of the Observatories of the Seas Ontology (OSO) within the EMSO semantic ecosystem.</skos:definition>
    <skos:definition xml:lang="fr">Un workflow collaboratif d’ingénierie ontologique soutenant le développement, la maintenance, le versionnement et la publication FAIR de l’Observatories of the Seas Ontology (OSO) au sein de l’écosystème sémantique EMSO.</skos:definition>
    <skos:definition xml:lang="es">Un flujo de trabajo colaborativo de ingeniería ontológica que apoya el desarrollo, mantenimiento, versionado y publicación FAIR de la Observatories of the Seas Ontology (OSO) dentro del ecosistema semántico de EMSO.</skos:definition>
    <skos:definition xml:lang="it">Un flusso di lavoro collaborativo di ingegneria ontologica che supporta lo sviluppo, la manutenzione, il versionamento e la pubblicazione FAIR della Observatories of the Seas Ontology (OSO) nell’ecosistema semantico di EMSO.</skos:definition>
    <skos:definition xml:lang="pt">Um fluxo de trabalho colaborativo de engenharia ontológica que apoia o desenvolvimento, a manutenção, o versionamento e a publicação FAIR da Observatories of the Seas Ontology (OSO) no ecossistema semântico do EMSO.</skos:definition>
    <skos:definition xml:lang="ro">Un flux de lucru colaborativ pentru ingineria ontologiilor care sprijină dezvoltarea, întreținerea, versionarea și publicarea FAIR a Observatories of the Seas Ontology (OSO) în cadrul ecosistemului semantic EMSO.</skos:definition>
    <skos:definition xml:lang="no">En samarbeidsbasert arbeidsflyt for ontologiteknikk som støtter utvikling, vedlikehold, versjonering og FAIR-publisering av Observatories of the Seas Ontology (OSO) i EMSOs semantiske økosystem.</skos:definition>
    <skos:definition xml:lang="el">Μια συνεργατική ροή εργασίας για τη μηχανική οντολογιών που υποστηρίζει την ανάπτυξη, τη συντήρηση, την έκδοση και τη FAIR δημοσίευση της Observatories of the Seas Ontology (OSO) στο σημασιολογικό οικοσύστημα του EMSO.</skos:definition>
    <prov:wasAssociatedWith rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO_DMSG"/>
    <prov:wasAssociatedWith rdf:resource="https://w3id.org/earthsemantics/OSO#Ifremer"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#Protege"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#GitHub"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#EarthPortal"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#OntoPortal"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#GitHubPages"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#Widoco"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#WebVOWL"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#RDFLib"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#YASGUI"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#OFAIRe"/>
    <prov:used rdf:resource="https://w3id.org/earthsemantics/OSO#Virtuoso"/>
    <prov:generated rdf:resource="https://w3id.org/earthsemantics/OSO#OSO"/>
    <dcterms:subject rdf:resource="http://www.wikidata.org/entity/Q324254"/>
    <dcterms:subject rdf:resource="http://www.wikidata.org/entity/Q2878974"/>
    <rdfs:seeAlso rdf:resource="https://github.com/emso-eric/oso-ontology"/>
    <rdfs:seeAlso rdf:resource="https://earthportal.eu/ontologies/OSO"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Protege">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
