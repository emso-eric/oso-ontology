  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#leadsSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#isSiteLedBy"/>
    <skos:definition xml:lang="en">Relates an organisation to a marine observation site for which it has a leadership or coordination role.</skos:definition>
    <skos:definition xml:lang="fr">Relie une organisation à un site d’observation marine pour lequel elle exerce un rôle de pilotage ou de coordination.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una organización con un sitio de observación marina para el que ejerce un papel de coordinación o liderazgo.</skos:definition>
    <skos:definition xml:lang="it">Collega un'organizzazione a un sito di osservazione marina per il quale svolge un ruolo di coordinamento o leadership.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma organização a um local de observação marinha para o qual exerce um papel de coordenação ou liderança.</skos:definition>
    <skos:definition xml:lang="no">Knytter en organisasjon til et marint observasjonssted som den leder eller koordinerer.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o organizație de un sit de observație marină pentru care exercită un rol de coordonare sau conducere.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει έναν οργανισμό με μια θαλάσσια τοποθεσία παρατήρησης για την οποία ασκεί ρόλο συντονισμού ή ηγεσίας.</skos:definition>
    <rdfs:comment xml:lang="en">Links an organisation to a site it leads.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une organisation à un site qu’elle pilote.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una organización con un sitio que coordina.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'organizzazione a un sito che coordina.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma organização a um local que coordena.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en organisasjon til et sted den leder.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o organizație de un sit pe care îl coordonează.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει έναν οργανισμό με μια τοποθεσία που συντονίζει.</rdfs:comment>
    <rdfs:label xml:lang="en">leads site</rdfs:label>
    <rdfs:label xml:lang="fr">pilote un site</rdfs:label>
    <rdfs:label xml:lang="es">coordina un sitio</rdfs:label>
    <rdfs:label xml:lang="it">coordina un sito</rdfs:label>
    <rdfs:label xml:lang="pt">coordena um local</rdfs:label>
    <rdfs:label xml:lang="no">leder sted</rdfs:label>
    <rdfs:label xml:lang="ro">coordonează un sit</rdfs:label>
    <rdfs:label xml:lang="el">συντονίζει τοποθεσία</rdfs:label>
    <skos:prefLabel xml:lang="en">leads site</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">pilote un site</skos:prefLabel>
    <skos:prefLabel xml:lang="es">coordina un sitio</skos:prefLabel>
    <skos:prefLabel xml:lang="it">coordina un sito</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">coordena um local</skos:prefLabel>
    <skos:prefLabel xml:lang="no">leder sted</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">coordonează un sit</skos:prefLabel>
    <skos:prefLabel xml:lang="el">συντονίζει τοποθεσία</skos:prefLabel>
  </rdf:Description>
