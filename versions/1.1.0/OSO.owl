    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Ireland"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Portugal"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Spain"/>
    <OSO:hasSpatialExtent rdf:resource="https://w3id.org/earthsemantics/OSO#AtlanticWhaleDeal_bbox"/>
    <schema1:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-01</schema1:startDate>
    <schema1:endDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-11-30</schema1:endDate>
    <schema1:url rdf:resource="https://www.atlanticarea.eu/discover-our-projects/approved-projects/atlantic-whale-deal"/>
    <OSO:hasLogo rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/AtlanticWhaleDeal.png"/>
    <schema1:logo rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/AtlanticWhaleDeal.png"/>
    <foaf:depiction rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/AtlanticWhaleDeal.png"/>
    <dcterms:title xml:lang="el">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="en">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="es">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="fr">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="it">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="no">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="pt">Atlantic Whale Deal</dcterms:title>
    <dcterms:title xml:lang="ro">Atlantic Whale Deal</dcterms:title>
    <rdfs:label xml:lang="el">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="en">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="es">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="fr">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="it">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="no">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="pt">Atlantic Whale Deal</rdfs:label>
    <rdfs:label xml:lang="ro">Atlantic Whale Deal</rdfs:label>
    <skos:prefLabel xml:lang="el">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Atlantic Whale Deal</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Atlantic Whale Deal</skos:prefLabel>
    <skos:definition xml:lang="en">Interreg Atlantic Area project aiming to reduce whale-ship collisions and support biodiversity protection in the Atlantic Area.</skos:definition>
    <skos:definition xml:lang="fr">Projet Interreg Espace Atlantique visant à réduire les collisions entre navires et baleines et à soutenir la protection de la biodiversité dans l’espace atlantique.</skos:definition>
    <dcterms:description xml:lang="en">The ATLANTIC WHALE DEAL aims to make sure that ships don't accidentally hit whales in the Atlantic Area.

Partners from different countries are working together to prevent these collisions that can damage biodiversity, trying out new and smart technologies to reduce ship strikes. They want to help the environment by capturing carbon (which is good for the planet) and making sure the ecosystem works well. This involves localization techniques to find whales, making maps to show where there's a risk of collisions, and creating tools to reduce noise in the ocean.

A team of experts in physics, engineering, biology, statistics, design, and social economics from four countries is teaming up with different organizations like the government, non-profit groups, schools, and businesses. The goal is to find solutions that work well and help society while also taking care of the planet.

ATLANTIC WHALE DEAL believes that by protecting whales, they're also making a positive impact on the world by keeping the environment healthy and preserving biodiversity.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SemanticVisualizationTool">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:label xml:lang="en">Semantic visualization tool</rdfs:label>
    <rdfs:label xml:lang="fr">Outil de visualisation sémantique</rdfs:label>
    <rdfs:label xml:lang="es">Herramienta de visualización semántica</rdfs:label>
    <rdfs:label xml:lang="it">Strumento di visualizzazione semantica</rdfs:label>
    <rdfs:label xml:lang="pt">Ferramenta de visualização semântica</rdfs:label>
    <rdfs:label xml:lang="ro">Instrument de vizualizare semantică</rdfs:label>
    <rdfs:label xml:lang="no">Verktøy for semantisk visualisering</rdfs:label>
    <rdfs:label xml:lang="el">Εργαλείο σημασιολογικής απεικόνισης</rdfs:label>
    <skos:definition xml:lang="en">A tool used to visualize semantic artefacts, RDF graphs or ontology structures.</skos:definition>
    <skos:definition xml:lang="fr">Un outil utilisé pour visualiser des artefacts sémantiques, des graphes RDF ou des structures d'ontologies.</skos:definition>
    <skos:definition xml:lang="es">Una herramienta utilizada para visualizar artefactos semánticos, grafos RDF o estructuras de ontologías.</skos:definition>
    <skos:definition xml:lang="it">Uno strumento utilizzato per visualizzare artefatti semantici, grafi RDF o strutture di ontologie.</skos:definition>
    <skos:definition xml:lang="pt">Uma ferramenta utilizada para visualizar artefactos semânticos, grafos RDF ou estruturas de ontologias.</skos:definition>
    <skos:definition xml:lang="ro">Un instrument utilizat pentru vizualizarea artefactelor semantice, a grafurilor RDF sau a structurilor de ontologii.</skos:definition>
    <skos:definition xml:lang="no">Et verktøy som brukes til å visualisere semantiske artefakter, RDF-grafer eller ontologistrukturer.</skos:definition>
    <skos:definition xml:lang="el">Ένα εργαλείο που χρησιμοποιείται για την απεικόνιση σημασιολογικών τεχνουργημάτων, γράφων RDF ή δομών οντολογιών.</skos:definition>
  </rdf:Description>
