    <dcat:keyword xml:lang="en">marine biology</dcat:keyword>
    <dcat:keyword xml:lang="en">marine biodiversity</dcat:keyword>
    <dcat:keyword xml:lang="en">marine biological resources</dcat:keyword>
    <dcat:keyword xml:lang="en">research infrastructure</dcat:keyword>
    <dcat:keyword xml:lang="en">blue biotechnology</dcat:keyword>
    <dcat:keyword xml:lang="fr">biologie marine</dcat:keyword>
    <dcat:keyword xml:lang="fr">biodiversité marine</dcat:keyword>
    <dcat:keyword xml:lang="fr">infrastructure de recherche</dcat:keyword>
    <rdfs:label xml:lang="el">EMBRC-France</rdfs:label>
    <rdfs:label xml:lang="en">EMBRC-France</rdfs:label>
    <rdfs:label xml:lang="es">EMBRC-France</rdfs:label>
