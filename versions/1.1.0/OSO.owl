  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isPlatformOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
