    <skos:prefLabel xml:lang="pt">LUCKYDIVMIC</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">LUCKYDIVMIC</skos:prefLabel>
    <skos:altLabel xml:lang="en">LuckyDivMic</skos:altLabel>
    <skos:altLabel xml:lang="fr">Campagne LUCKYDIVMIC</skos:altLabel>
    <skos:definition xml:lang="en">Oceanographic campaign dedicated to hydrothermal ecosystems and microbial diversity studies at the Lucky Strike vent field.</skos:definition>
    <skos:definition xml:lang="fr">Campagne océanographique dédiée à l’étude des écosystèmes hydrothermaux et de la diversité microbienne du champ hydrothermal Lucky Strike.</skos:definition>
    <skos:definition xml:lang="pt">Campanha oceanográfica dedicada ao estudo dos ecossistemas hidrotermais e da diversidade microbiana do campo hidrotermal Lucky Strike.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Project_is_led_by_an_Organization">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchProject"/>
    <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    <skos:definition xml:lang="en">Relates a research project to the organisation responsible for leading or coordinating it.</skos:definition>
    <skos:definition xml:lang="fr">Relie un projet de recherche à l’organisation responsable de sa direction ou de sa coordination.</skos:definition>
    <skos:definition xml:lang="es">Relaciona un proyecto de investigación con la organización responsable de liderarlo o coordinarlo.</skos:definition>
    <skos:definition xml:lang="it">Collega un progetto di ricerca all'organizzazione responsabile della sua direzione o coordinamento.</skos:definition>
    <skos:definition xml:lang="pt">Liga um projeto de investigação à organização responsável pela sua coordenação ou liderança.</skos:definition>
    <skos:definition xml:lang="no">Knytter et forskningsprosjekt til organisasjonen som leder eller koordinerer det.</skos:definition>
    <skos:definition xml:lang="ro">Leagă un proiect de cercetare de organizația responsabilă de coordonarea sau conducerea acestuia.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει ένα ερευνητικό έργο με τον οργανισμό που είναι υπεύθυνος για τη διεύθυνση ή τον συντονισμό του.</skos:definition>
    <rdfs:comment xml:lang="en">Indicates the organization responsible for leading or coordinating a research project.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Indique l'organisation responsable de la direction ou de la coordination d’un projet de recherche.</rdfs:comment>
    <rdfs:comment xml:lang="es">Indica la organización responsable de dirigir o coordinar un proyecto de investigación.</rdfs:comment>
    <rdfs:comment xml:lang="it">Indica l'organizzazione responsabile della direzione o del coordinamento di un progetto di ricerca.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Indica a organização responsável pela liderança ou coordenação de um projeto de investigação.</rdfs:comment>
    <rdfs:comment xml:lang="no">Angir organisasjonen som er ansvarlig for å lede eller koordinere et forskningsprosjekt.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Indică organizația responsabilă de coordonarea sau conducerea unui proiect de cercetare.</rdfs:comment>
    <rdfs:comment xml:lang="el">Υποδεικνύει τον οργανισμό που είναι υπεύθυνος για τη διεύθυνση ή τον συντονισμό ενός ερευνητικού έργου.</rdfs:comment>
