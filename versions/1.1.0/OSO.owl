  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#membershipInERIC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#ERICMembership"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#ERIC"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#hasERICMembership"/>
    <skos:definition xml:lang="en">Relates an ERIC membership entity to the ERIC organisation in which the membership applies.</skos:definition>
    <skos:definition xml:lang="fr">Relie une entité d’adhésion ERIC à l’organisation ERIC concernée par cette adhésion.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una entidad de membresía ERIC con la organización ERIC a la que corresponde la adhesión.</skos:definition>
    <skos:definition xml:lang="it">Collega un'entità di adesione ERIC all'organizzazione ERIC a cui si riferisce l'adesione.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma entidade de adesão ERIC à organização ERIC à qual a adesão se aplica.</skos:definition>
    <skos:definition xml:lang="no">Knytter en ERIC-medlemskapsenhet til ERIC-organisasjonen medlemskapet gjelder for.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o entitate de apartenență ERIC de organizația ERIC la care se aplică apartenența.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια οντότητα συμμετοχής ERIC με τον οργανισμό ERIC στον οποίο εφαρμόζεται η συμμετοχή.</skos:definition>
    <rdfs:comment xml:lang="en">Links an ERIC membership entity to the ERIC organisation concerned.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une entité d’adhésion ERIC à l’organisation ERIC concernée.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una entidad de membresía ERIC con la organización ERIC correspondiente.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'entità di adesione ERIC all'organizzazione ERIC corrispondente.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma entidade de adesão ERIC à organização ERIC correspondente.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en ERIC-medlemskapsenhet til den aktuelle ERIC-organisasjonen.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o entitate de apartenență ERIC de organizația ERIC corespunzătoare.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια οντότητα συμμετοχής ERIC με τον αντίστοιχο οργανισμό ERIC.</rdfs:comment>
    <rdfs:label xml:lang="el">συμμετοχή σε ERIC</rdfs:label>
    <rdfs:label xml:lang="en">membership in ERIC</rdfs:label>
    <rdfs:label xml:lang="es">membresía en un ERIC</rdfs:label>
    <rdfs:label xml:lang="fr">appartenance à un ERIC</rdfs:label>
    <rdfs:label xml:lang="it">appartenenza a un ERIC</rdfs:label>
    <rdfs:label xml:lang="no">medlemskap i et ERIC</rdfs:label>
    <rdfs:label xml:lang="pt">participação em um ERIC</rdfs:label>
    <rdfs:label xml:lang="ro">apartenență la un ERIC</rdfs:label>
    <skos:prefLabel xml:lang="el">συμμετοχή σε ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="en">membership in ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="es">membresía en un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">appartenance à un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="it">appartenenza a un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="no">medlemskap i et ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">participação em um ERIC</skos:prefLabel>
