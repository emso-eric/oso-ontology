  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#RDFFramework">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:label xml:lang="en">RDF framework</rdfs:label>
    <rdfs:label xml:lang="fr">Framework RDF</rdfs:label>
    <rdfs:label xml:lang="es">Framework RDF</rdfs:label>
    <rdfs:label xml:lang="it">Framework RDF</rdfs:label>
    <rdfs:label xml:lang="pt">Framework RDF</rdfs:label>
    <rdfs:label xml:lang="ro">Cadru RDF</rdfs:label>
    <rdfs:label xml:lang="no">RDF-rammeverk</rdfs:label>
    <rdfs:label xml:lang="el">Πλαίσιο RDF</rdfs:label>
    <skos:definition xml:lang="en">A software framework used to create, parse, manipulate, serialize or validate RDF graphs.</skos:definition>
    <skos:definition xml:lang="fr">Un framework logiciel utilisé pour créer, analyser, manipuler, sérialiser ou valider des graphes RDF.</skos:definition>
    <skos:definition xml:lang="es">Un framework software utilizado para crear, analizar, manipular, serializar o validar grafos RDF.</skos:definition>
    <skos:definition xml:lang="it">Un framework software utilizzato per creare, analizzare, manipolare, serializzare o validare grafi RDF.</skos:definition>
    <skos:definition xml:lang="pt">Um framework de software utilizado para criar, analisar, manipular, serializar ou validar grafos RDF.</skos:definition>
    <skos:definition xml:lang="ro">Un cadru software utilizat pentru crearea, parsarea, manipularea, serializarea sau validarea grafurilor RDF.</skos:definition>
    <skos:definition xml:lang="no">Et programvarerammeverk som brukes til å opprette, analysere, manipulere, serialisere eller validere RDF-grafer.</skos:definition>
    <skos:definition xml:lang="el">Ένα πλαίσιο λογισμικού που χρησιμοποιείται για τη δημιουργία, την ανάλυση, τον χειρισμό, τη σειριοποίηση ή την επικύρωση γράφων RDF.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isCountryOf">
