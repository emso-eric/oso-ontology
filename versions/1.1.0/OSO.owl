  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#LO">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <OSO:Site_has_a_Subsite rdf:resource="https://w3id.org/earthsemantics/OSO#ANTARES"/>
    <OSO:Site_has_a_Subsite rdf:resource="https://w3id.org/earthsemantics/OSO#BJS"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#ALBATROSS"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#MII"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#France"/>
    <OSO:hasLocation rdf:resource="https://w3id.org/earthsemantics/OSO#French_riviera"/>
    <OSO:hasSiteResponsible rdf:resource="https://w3id.org/earthsemantics/OSO#Dominique_LEFEVRE"/>
    <OSO:hasSiteResponsible rdf:resource="https://w3id.org/earthsemantics/OSO#Séverine_MARTINI"/>
    <OSO:Site_is_part_of_a_RI rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO-France"/>
    <schema1:url rdf:resource="https://www.emso-fr.org/Ligure-Ouest"/>
    <schema1:url rdf:resource="https://www.emso-fr.org/fr/Ligure-Ouest"/>
    <rdfs:seeAlso rdf:resource="https://www.emso-fr.org/Ligure-Ouest"/>
    <rdfs:seeAlso rdf:resource="https://www.emso-fr.org/fr/Ligure-Ouest"/>
    <rdfs:seeAlso rdf:resource="https://emso.eu/observatories-node/ligurian-sea/"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Ligurian_Sea"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Mediterranean_Sea"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/French_Riviera"/>
    <OSO:distanceFromLand rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">23</OSO:distanceFromLand>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#gYearMonth">2019-01</OSO:dateFirstDeployment>
    <OSO:isTestSite rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</OSO:isTestSite>
    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2475</OSO:maxWaterDepth>
    <skos:note xml:lang="en">Part of the EMSO-France marine observation infrastructure in the north-western Mediterranean Sea.</skos:note>
    <skos:note xml:lang="fr">Fait partie de l’infrastructure d’observation marine EMSO-France en Méditerranée nord-occidentale.</skos:note>
    <dcterms:description xml:lang="en">LO (Ligure Ouest) is a marine observation site located in the north-western Mediterranean Sea and dedicated to long-term oceanographic monitoring and deep-sea observation activities.</dcterms:description>
    <dcterms:description xml:lang="fr">LO (Ligure Ouest) est un site d’observation marine situé en Méditerranée nord-occidentale et dédié aux activités de suivi océanographique à long terme et d’observation des grands fonds.</dcterms:description>
    <rdfs:comment xml:lang="fr">LO : Ligure Ouest</rdfs:comment>
    <rdfs:comment xml:lang="en">LO: Western Ligurian site</rdfs:comment>
    <rdfs:label xml:lang="el">LO</rdfs:label>
    <rdfs:label xml:lang="en">LO</rdfs:label>
    <rdfs:label xml:lang="es">LO</rdfs:label>
    <rdfs:label xml:lang="fr">LO</rdfs:label>
    <rdfs:label xml:lang="it">LO</rdfs:label>
    <rdfs:label xml:lang="no">LO</rdfs:label>
    <rdfs:label xml:lang="pt">LO</rdfs:label>
    <rdfs:label xml:lang="ro">LO</rdfs:label>
    <skos:prefLabel xml:lang="el">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="en">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="es">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="it">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="no">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">LO</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">LO</skos:prefLabel>
    <skos:altLabel xml:lang="fr">Ligure Ouest</skos:altLabel>
    <skos:altLabel xml:lang="en">Western Ligurian</skos:altLabel>
    <skos:altLabel xml:lang="en">Ligurian Sea West</skos:altLabel>
    <skos:altLabel xml:lang="fr">Site Ligure Ouest</skos:altLabel>
    <skos:definition xml:lang="en">Marine observation site located in the western Ligurian Sea and operated within the EMSO-France research infrastructure.</skos:definition>
    <skos:definition xml:lang="fr">Site d’observation marine situé dans l’ouest de la mer Ligure et exploité dans le cadre de l’infrastructure de recherche EMSO-France.</skos:definition>
    <skos:definition xml:lang="pt">Sítio de observação marinha localizado no oeste do mar da Ligúria e operado no âmbito da infraestrutura de investigação EMSO-France.</skos:definition>
  </rdf:Description>
