    <rdfs:label xml:lang="ro">federează infrastructură de cercetare</rdfs:label>
    <skos:prefLabel xml:lang="el">ομοσπονδοποιεί ερευνητική υποδομή</skos:prefLabel>
    <skos:prefLabel xml:lang="en">federates research infrastructure</skos:prefLabel>
    <skos:prefLabel xml:lang="es">federa infraestructura de investigación</skos:prefLabel>
