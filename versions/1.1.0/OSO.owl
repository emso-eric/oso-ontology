  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#FAIRAssessmentTool">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:label xml:lang="en">FAIR assessment tool</rdfs:label>
    <rdfs:label xml:lang="fr">Outil d'évaluation FAIR</rdfs:label>
    <rdfs:label xml:lang="es">Herramienta de evaluación FAIR</rdfs:label>
    <rdfs:label xml:lang="it">Strumento di valutazione FAIR</rdfs:label>
    <rdfs:label xml:lang="pt">Ferramenta de avaliação FAIR</rdfs:label>
    <rdfs:label xml:lang="ro">Instrument de evaluare FAIR</rdfs:label>
    <rdfs:label xml:lang="no">FAIR-evalueringsverktøy</rdfs:label>
    <rdfs:label xml:lang="el">Εργαλείο αξιολόγησης FAIR</rdfs:label>
    <skos:definition xml:lang="en">A software tool used to assess the FAIRness of semantic artefacts.</skos:definition>
    <skos:definition xml:lang="fr">Un outil logiciel utilisé pour évaluer le niveau de conformité FAIR d'artefacts sémantiques.</skos:definition>
    <skos:definition xml:lang="es">Una herramienta de software utilizada para evaluar el grado de conformidad FAIR de artefactos semánticos.</skos:definition>
    <skos:definition xml:lang="it">Uno strumento software utilizzato per valutare il livello di conformità FAIR degli artefatti semantici.</skos:definition>
    <skos:definition xml:lang="pt">Uma ferramenta de software utilizada para avaliar o nível de conformidade FAIR de artefactos semânticos.</skos:definition>
    <skos:definition xml:lang="ro">Un instrument software utilizat pentru evaluarea nivelului de conformitate FAIR al artefactelor semantice.</skos:definition>
    <skos:definition xml:lang="no">Et programvareverktøy som brukes til å evaluere FAIR-nivået til semantiske artefakter.</skos:definition>
    <skos:definition xml:lang="el">Ένα εργαλείο λογισμικού που χρησιμοποιείται για την αξιολόγηση του επιπέδου FAIR σημασιολογικών τεχνουργημάτων.</skos:definition>
  </rdf:Description>
