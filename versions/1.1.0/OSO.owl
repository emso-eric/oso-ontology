  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#hasEDMO">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Resource"/>
    <skos:definition xml:lang="en">Relates an organisation to its EDMO (European Directory of Marine Organisations) identifier.</skos:definition>
    <skos:definition xml:lang="fr">Relie une organisation à son identifiant EDMO (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="es">Relaciona una organización con su identificador EDMO (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="it">Collega un'organizzazione al suo identificatore EDMO (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="pt">Liga uma organização ao seu identificador EDMO (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="no">Knytter en organisasjon til dens EDMO-identifikator (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="ro">Leagă o organizație de identificatorul său EDMO (European Directory of Marine Organisations).</skos:definition>
    <skos:definition xml:lang="el">Συνδέει έναν οργανισμό με το αναγνωριστικό EDMO (European Directory of Marine Organisations).</skos:definition>
    <rdfs:comment xml:lang="en">This property links an Organisation to its EDMO (European Directory of Marine Organisations) identifier.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Cette propriété relie une organisation à son identifiant EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="es">Esta propiedad vincula una Organización con su identificador EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="it">Questa proprietà collega un'Organizzazione al suo identificatore EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="pt">Esta propriedade liga uma Organização ao seu identificador EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="no">Denne egenskapen kobler en organisasjon til dens EDMO-identifikator (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="ro">Această proprietate leagă o organizație de identificatorul său EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:comment xml:lang="el">Αυτή η ιδιότητα συνδέει έναν Οργανισμό με το αναγνωριστικό EDMO (European Directory of Marine Organisations).</rdfs:comment>
    <rdfs:label xml:lang="el">έχει EDMO</rdfs:label>
    <rdfs:label xml:lang="en">has an EDMO</rdfs:label>
    <rdfs:label xml:lang="es">tiene un EDMO</rdfs:label>
    <rdfs:label xml:lang="fr">a un EDMO</rdfs:label>
    <rdfs:label xml:lang="it">ha un EDMO</rdfs:label>
    <rdfs:label xml:lang="no">har en EDMO</rdfs:label>
