  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#CTD">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <OSO:hasPlatformCategory rdf:resource="http://vocab.nerc.ac.uk/collection/R25/current/CTD_TEMP/"/>
    <skos:closeMatch rdf:resource="http://vocab.nerc.ac.uk/collection/L22/current/TOOL0022/"/>
    <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q1024499"/>
