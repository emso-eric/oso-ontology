  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#MARLEY">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <OSO:isPartOfNetwork rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO-France"/>
    <OSO:isLinkedToCampaign rdf:resource="https://w3id.org/earthsemantics/OSO#ChEReef_2022"/>
    <OSO:isLinkedToCampaignSeries rdf:resource="https://w3id.org/earthsemantics/OSO#CHEREEF_OBS"/>
    <dcterms:isReferencedBy rdf:resource="https://doi.org/10.17882/111225"/>
    <rdfs:seeAlso rdf:resource="https://www.life-marha.fr/node/483"/>
    <rdfs:seeAlso rdf:resource="https://www.life-marha.fr/habitats-marins"/>
    <rdfs:seeAlso rdf:resource="https://www.seanoe.org/data/01001/111225/"/>
    <rdfs:seeAlso rdf:resource="https://doi.org/10.17882/111225"/>
    <rdfs:seeAlso rdf:resource="https://rd-technologiques.ifremer.fr/A-propos/Actualites-Archives-de-2013-a-2025/2022/L-observatoire-fond-de-Mer-MARLEY-Projet-MARHA"/>
    <rdfs:seeAlso rdf:resource="https://www.ifremer.fr/fr/presse/une-premiere-des-coraux-d-eau-froide-etudies-en-aquarium-sous-pression-pour-tester-leur"/>
    <rdfs:seeAlso rdf:resource="https://campagnes.flotteoceanographique.fr/series/248/"/>
    <rdfs:seeAlso rdf:resource="https://doi.org/10.18142/248"/>
