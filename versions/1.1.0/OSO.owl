  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#NorEMSO">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/cerif/vocab/Organisation"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure"/>
    <OSO:isLedByPerson rdf:resource="https://w3id.org/earthsemantics/OSO#Thibault_BARREYRE"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Norway"/>
    <OSO:isManagedBy rdf:resource="https://w3id.org/earthsemantics/OSO#UiB"/>
    <OSO:isManagedBy rdf:resource="https://w3id.org/earthsemantics/OSO#NORCE"/>
    <schema1:url rdf:resource="https://www.uib.no/en/noremso/"/>
    <rdfs:seeAlso rdf:resource="https://www4.uib.no/en/research/research-projects/noremso"/>
    <rdfs:seeAlso rdf:resource="https://www.norceresearch.no/en/projects/noremso-the-norwegian-node-for-the-european-multidisciplinary-seafloor-and-water-column-observatory"/>
    <rdfs:seeAlso rdf:resource="https://emso.eu/2024/04/11/noremso-advancing-marine-observations-in-the-nordic-seas/"/>
    <rdfs:seeAlso rdf:resource="https://www.gceocean.no/media/2887/202019-havlab-noremso.pdf"/>
    <schema1:sameAs rdf:resource="https://x.com/nor_emso"/>
    <dcterms:description xml:lang="en">NorEMSO is the Norwegian contribution to the EMSO research infrastructure.</dcterms:description>
    <dcterms:description xml:lang="no">NorEMSO er det norske bidraget til EMSO forskningsinfrastrukturen.</dcterms:description>
    <skos:definition xml:lang="en">The Norwegian component of EMSO ERIC, operating multidisciplinary ocean observatories in the Nordic Seas through moorings, gliders, and integrated seabed-water column observatories.</skos:definition>
    <skos:definition xml:lang="no">Den norske komponenten av EMSO ERIC, som driver tverrfaglige havobservatorier i de nordiske havområdene gjennom fortøyde systemer, glidere og integrerte havbunns- og vannsøyleobservatorier.</skos:definition>
