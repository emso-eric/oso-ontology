  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#E1M3A_mooring">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <OSO:hasPlatformCategory rdf:resource="http://vocab.nerc.ac.uk/collection/L06/current/48/"/>
    <skos:closeMatch rdf:resource="https://terra-vocabulary.org/ncl/FAIR-Incubator/earthscienceplatforms/c_63600fe1"/>
    <rdfs:seeAlso rdf:resource="https://poseidon.hcmr.gr/"/>
    <rdfs:seeAlso rdf:resource="https://www.jerico-ri.eu/infrastructure/e1-m3a-buoy/"/>
    <dcterms:identifier>WMO 61277</dcterms:identifier>
    <skos:notation>WMO 61277</skos:notation>
    <rdfs:label xml:lang="el">Αγκυροβολημένη πλατφόρμα E1M3A</rdfs:label>
    <rdfs:label xml:lang="en">E1M3A mooring</rdfs:label>
    <rdfs:label xml:lang="es">Fondeo E1M3A</rdfs:label>
    <rdfs:label xml:lang="fr">Mouillage E1M3A</rdfs:label>
    <rdfs:label xml:lang="it">Ormeggio E1M3A</rdfs:label>
    <rdfs:label xml:lang="no">E1M3A-fortøyning</rdfs:label>
    <rdfs:label xml:lang="pt">Fundeio E1M3A</rdfs:label>
    <rdfs:label xml:lang="ro">Sistem de ancorare E1M3A</rdfs:label>
    <skos:prefLabel xml:lang="el">Αγκυροβολημένη πλατφόρμα E1M3A</skos:prefLabel>
    <skos:prefLabel xml:lang="en">E1M3A mooring</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Fondeo E1M3A</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Mouillage E1M3A</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Ormeggio E1M3A</skos:prefLabel>
    <skos:prefLabel xml:lang="no">E1M3A-fortøyning</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Fundeio E1M3A</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Sistem de ancorare E1M3A</skos:prefLabel>
    <skos:altLabel xml:lang="en">POSEIDON E1-M3A buoy</skos:altLabel>
    <skos:altLabel xml:lang="en">E1-M3A buoy</skos:altLabel>
    <skos:altLabel xml:lang="fr">Bouée E1M3A</skos:altLabel>
    <skos:altLabel xml:lang="pt">Plataforma E1M3A</skos:altLabel>
    <skos:definition xml:lang="en">An oceanographic mooring platform deployed in the Cretan Sea as part of the POSEIDON and EMSO observation networks.</skos:definition>
    <skos:definition xml:lang="fr">Une plateforme de mouillage océanographique déployée en mer de Crète dans le cadre des réseaux d’observation POSEIDON et EMSO.</skos:definition>
    <skos:definition xml:lang="pt">Uma plataforma de fundeio oceanográfico implantada no mar de Creta no âmbito das redes de observação POSEIDON e EMSO.</skos:definition>
    <skos:definition xml:lang="el">Μια ωκεανογραφική πλατφόρμα αγκυροβόλησης που έχει αναπτυχθεί στο Κρητικό Πέλαγος στο πλαίσιο των δικτύων παρατήρησης POSEIDON και EMSO.</skos:definition>
  </rdf:Description>
