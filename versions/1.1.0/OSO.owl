  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Marmara">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Turkey"/>
