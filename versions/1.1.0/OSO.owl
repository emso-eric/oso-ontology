    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#ULPGC"/>
    <schema1:url rdf:resource="https://plocan.eu/en/installations/ocean-observatory"/>
    <OSO:distanceFromLand rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">60</OSO:distanceFromLand>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1994-01-01</OSO:dateFirstDeployment>
    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3630</OSO:maxWaterDepth>
    <skos:closeMatch rdf:resource="http://www.wikidata.org/entity/Q5813"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Canary_Islands"/>
    <skos:closeMatch rdf:resource="http://marineregions.org/mrgid/3742"/>
    <skos:altLabel xml:lang="en">EMSO Canarias</skos:altLabel>
    <skos:altLabel xml:lang="en">ESTOC observatory</skos:altLabel>
    <skos:altLabel xml:lang="es">Observatorio EMSO Canarias</skos:altLabel>
    <skos:altLabel xml:lang="fr">Observatoire EMSO Canarias</skos:altLabel>
    <skos:definition xml:lang="en">A Regional Facility of EMSO located in the Canary Islands area and dedicated to long-term ocean observation in the subtropical North Atlantic Ocean.</skos:definition>
    <skos:definition xml:lang="fr">Une infrastructure régionale EMSO située dans la région des Canaries et dédiée à l’observation océanique à long terme dans l’Atlantique Nord subtropical.</skos:definition>
    <skos:definition xml:lang="es">Una infraestructura regional de EMSO situada en la región de Canarias y dedicada a la observación oceánica a largo plazo en el océano Atlántico Norte subtropical.</skos:definition>
    <dcterms:description xml:lang="en">EMSO Canarias, a.k.a. ESTOC (29º10’ N, 15º30’ W) is a monitoring time-series program...</dcterms:description>
    <rdfs:comment xml:lang="en">Canarias Regional Facility is linked to the Atlantic Whale Deal project, notably regarding issues of collisions between ships and marine mammals.</rdfs:comment>
    <rdfs:comment xml:lang="fr">L’infrastructure régionale Canarias est liée au projet Atlantic Whale Deal, notamment concernant les collisions entre navires et mammifères marins.</rdfs:comment>
    <rdfs:comment xml:lang="es">La infraestructura regional Canarias está vinculada al proyecto Atlantic Whale Deal, especialmente en relación con las colisiones entre buques y mamíferos marinos.</rdfs:comment>
    <rdfs:label xml:lang="el">Κανάρια</rdfs:label>
    <rdfs:label xml:lang="en">Canarias</rdfs:label>
    <rdfs:label xml:lang="es">Canarias</rdfs:label>
    <rdfs:label xml:lang="fr">Canarias</rdfs:label>
    <rdfs:label xml:lang="it">Canarias</rdfs:label>
    <rdfs:label xml:lang="no">Kanariøyene</rdfs:label>
    <rdfs:label xml:lang="pt">Canárias</rdfs:label>
    <rdfs:label xml:lang="ro">Canarias</rdfs:label>
