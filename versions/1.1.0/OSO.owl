  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Mohn_Seabed_Station">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <OSO:hasPlatformCategory rdf:resource="http://vocab.nerc.ac.uk/collection/L06/current/11/"/>
