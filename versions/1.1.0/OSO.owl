    <rdfs:label xml:lang="ro">este coordonată de o organizație</rdfs:label>
    <rdfs:label xml:lang="el">συντονίζεται από οργανισμό</rdfs:label>
    <skos:prefLabel xml:lang="en">is led by organisation</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est pilotée par une organisation</skos:prefLabel>
    <skos:prefLabel xml:lang="es">está coordinada por una organización</skos:prefLabel>
