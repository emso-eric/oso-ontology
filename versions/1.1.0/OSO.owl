  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#northBoundLatitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#BoundingBox"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <skos:definition xml:lang="en">Specifies the northernmost latitude of a geographic bounding box.</skos:definition>
    <skos:definition xml:lang="fr">Spécifie la latitude nord maximale d’une boîte englobante géographique.</skos:definition>
    <skos:definition xml:lang="es">Especifica la latitud norte máxima de una caja geográfica delimitadora.</skos:definition>
    <skos:definition xml:lang="it">Specifica la latitudine nord massima di un riquadro geografico.</skos:definition>
    <skos:definition xml:lang="pt">Especifica a latitude norte máxima de uma caixa geográfica delimitadora.</skos:definition>
    <skos:definition xml:lang="no">Angir den nordligste breddegraden i en geografisk avgrensningsboks.</skos:definition>
    <skos:definition xml:lang="ro">Specifică latitudinea nordică maximă a unei zone geografice delimitate.</skos:definition>
    <skos:definition xml:lang="el">Καθορίζει το βορειότερο γεωγραφικό πλάτος ενός γεωγραφικού πλαισίου.</skos:definition>
    <rdfs:comment xml:lang="en">Northernmost latitude of a geographic bounding box, corresponding to northBoundLatitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Latitude nord maximale d’une boîte englobante géographique, correspondant à northBoundLatitude dans l’ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="es">Latitud norte máxima de una caja geográfica delimitadora, correspondiente a northBoundLatitude en ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="it">Latitudine nord massima di un riquadro geografico, corrispondente a northBoundLatitude in ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Latitude norte máxima de uma caixa geográfica delimitadora, correspondente a northBoundLatitude na ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="no">Nordligste breddegrad i en geografisk avgrensningsboks, tilsvarende northBoundLatitude i ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Latitudinea nordică maximă a unei zone geografice delimitate, corespunzătoare northBoundLatitude din ISO 19115-3.</rdfs:comment>
    <rdfs:comment xml:lang="el">Το βορειότερο γεωγραφικό πλάτος ενός γεωγραφικού πλαισίου, που αντιστοιχεί στο northBoundLatitude του ISO 19115-3.</rdfs:comment>
    <rdfs:label xml:lang="el">βόρειο όριο γεωγραφικού πλάτους</rdfs:label>
    <rdfs:label xml:lang="en">northBoundLatitude</rdfs:label>
    <rdfs:label xml:lang="es">latitud norte máxima</rdfs:label>
    <rdfs:label xml:lang="fr">latitude nord maximale</rdfs:label>
    <rdfs:label xml:lang="it">latitudine nord massima</rdfs:label>
    <rdfs:label xml:lang="no">nordlig breddegrad</rdfs:label>
    <rdfs:label xml:lang="pt">latitude norte máxima</rdfs:label>
    <rdfs:label xml:lang="ro">latitudine nordică maximă</rdfs:label>
    <skos:prefLabel xml:lang="el">βόρειο όριο γεωγραφικού πλάτους</skos:prefLabel>
    <skos:prefLabel xml:lang="en">northBoundLatitude</skos:prefLabel>
    <skos:prefLabel xml:lang="es">latitud norte máxima</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">latitude nord maximale</skos:prefLabel>
    <skos:prefLabel xml:lang="it">latitudine nord massima</skos:prefLabel>
    <skos:prefLabel xml:lang="no">nordlig breddegrad</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">latitude norte máxima</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">latitudine nordică maximă</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isPrincipalInvestigatorOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://schema.org/Person"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#Platform"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#hasPrincipalInvestigator"/>
    <rdfs:comment xml:lang="en">Links a Principal Investigator to the platform for which they are responsible.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie un responsable scientifique à la plateforme dont il est responsable.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona un investigador principal con la plataforma de la que es responsable.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un Principal Investigator alla piattaforma di cui è responsabile.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga um investigador principal à plataforma pela qual é responsável.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en hovedansvarlig forsker til plattformen vedkommende er ansvarlig for.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă un investigator principal de platforma pentru care este responsabil.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει έναν κύριο ερευνητή με την πλατφόρμα για την οποία είναι υπεύθυνος.</rdfs:comment>
    <rdfs:label xml:lang="en">is Principal Investigator of</rdfs:label>
    <rdfs:label xml:lang="fr">est responsable scientifique de</rdfs:label>
    <rdfs:label xml:lang="es">es investigador principal de</rdfs:label>
    <rdfs:label xml:lang="it">è Principal Investigator di</rdfs:label>
    <rdfs:label xml:lang="pt">é investigador principal de</rdfs:label>
    <rdfs:label xml:lang="no">er hovedansvarlig forsker for</rdfs:label>
    <rdfs:label xml:lang="ro">este investigator principal al</rdfs:label>
    <rdfs:label xml:lang="el">είναι κύριος ερευνητής της</rdfs:label>
    <skos:prefLabel xml:lang="en">is Principal Investigator of</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est responsable scientifique de</skos:prefLabel>
    <skos:prefLabel xml:lang="es">es investigador principal de</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è Principal Investigator di</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">é investigador principal de</skos:prefLabel>
    <skos:prefLabel xml:lang="no">er hovedansvarlig forsker for</skos:prefLabel>
