  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#EMSO-PT">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure"/>
    <OSO:isLedByPerson rdf:resource="https://w3id.org/earthsemantics/OSO#Zuzia_STROYNOWSKI"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Portugal"/>
    <OSO:isManagedBy rdf:resource="https://w3id.org/earthsemantics/OSO#IPMA"/>
    <schema1:url rdf:resource="https://emso.waveweb.pt/en/"/>
    <rdfs:seeAlso rdf:resource="https://emso.waveweb.pt/en/"/>
    <rdfs:seeAlso rdf:resource="https://emso.eu/observatories-node/azores-islands/"/>
    <rdfs:seeAlso rdf:resource="https://www.cesam-la.pt/en/projects/emso-pt-european-multidisciplinary-seafloor-observatory-portugal/"/>
    <rdfs:seeAlso rdf:resource="https://www.fct.pt/en/media/noticias/emso-pt-project-and-the-importance-of-sea-observatories/"/>
    <rdfs:seeAlso rdf:resource="https://lsts.fe.up.pt/project/emso-pt"/>
    <foaf:depiction rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_portugal.png"/>
    <schema1:logo rdf:resource="https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_portugal.png"/>
    <dcat:keyword xml:lang="en">marine observatory</dcat:keyword>
    <dcat:keyword xml:lang="en">deep-sea observatory</dcat:keyword>
    <dcat:keyword xml:lang="en">ocean observation</dcat:keyword>
    <dcat:keyword xml:lang="en">research infrastructure</dcat:keyword>
    <dcat:keyword xml:lang="en">Azores</dcat:keyword>
    <dcat:keyword xml:lang="en">EMSO</dcat:keyword>
    <dcat:keyword xml:lang="pt">observatório marinho</dcat:keyword>
    <dcat:keyword xml:lang="pt">observação oceânica</dcat:keyword>
    <dcat:keyword xml:lang="pt">infraestrutura de investigação</dcat:keyword>
    <dcat:keyword xml:lang="pt">Açores</dcat:keyword>
    <dcterms:description xml:lang="en">EMSO Portugal is the Portuguese contribution to the EMSO European research infrastructure, coordinating long-term multidisciplinary ocean observation activities and technological developments, particularly in the Azores and Atlantic regions.</dcterms:description>
    <dcterms:description xml:lang="fr">EMSO Portugal est la contribution portugaise à l’infrastructure de recherche européenne EMSO, coordonnant des activités d’observation océanique multidisciplinaire à long terme et des développements technologiques, notamment dans les régions des Açores et de l’Atlantique.</dcterms:description>
    <dcterms:description xml:lang="pt">O EMSO Portugal é a contribuição portuguesa para a infraestrutura europeia de investigação EMSO, coordenando atividades de observação oceânica multidisciplinar de longo prazo e desenvolvimentos tecnológicos, particularmente nas regiões dos Açores e do Atlântico.</dcterms:description>
    <skos:definition xml:lang="en">The Portuguese component of EMSO ERIC, contributing to long-term multidisciplinary marine observation, notably through observatory activities in the Azores region.</skos:definition>
    <skos:definition xml:lang="fr">La composante portugaise d’EMSO ERIC, contribuant à l’observation marine multidisciplinaire à long terme, notamment à travers des activités d’observation dans la région des Açores.</skos:definition>
    <skos:definition xml:lang="pt">A componente portuguesa do EMSO ERIC, que contribui para a observação marinha multidisciplinar de longo prazo, nomeadamente através de atividades de observação na região dos Açores.</skos:definition>
    <rdfs:label xml:lang="el">EMSO Portugal</rdfs:label>
    <rdfs:label xml:lang="en">EMSO Portugal</rdfs:label>
    <rdfs:label xml:lang="es">EMSO Portugal</rdfs:label>
    <rdfs:label xml:lang="fr">EMSO Portugal</rdfs:label>
    <rdfs:label xml:lang="it">EMSO Portugal</rdfs:label>
