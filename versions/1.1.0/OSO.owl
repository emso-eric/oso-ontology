    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">780</OSO:maxWaterDepth>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Brittany"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Bay_of_Biscay"/>
    <dcterms:spatial rdf:resource="https://w3id.org/earthsemantics/OSO#Lampaul_Canyon"/>
    <rdfs:label xml:lang="el">MARLEY</rdfs:label>
    <rdfs:label xml:lang="en">MARLEY</rdfs:label>
    <rdfs:label xml:lang="es">MARLEY</rdfs:label>
