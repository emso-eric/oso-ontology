  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Hellenic_Arc_EMSO_membership">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#ERICMembership"/>
    <OSO:membershipInERIC rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO"/>
    <OSO:isERICMembershipOf rdf:resource="https://w3id.org/earthsemantics/OSO#Hellenic_Arc"/>
    <schema1:startDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2016-09-29</schema1:startDate>
    <prov:startedAtTime rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-09-29T00:00:00+00:00</prov:startedAtTime>
    <rdfs:label xml:lang="en">Hellenic Arc EMSO membership</rdfs:label>
    <rdfs:label xml:lang="fr">Adhésion de Hellenic Arc à EMSO</rdfs:label>
    <rdfs:label xml:lang="el">Συμμετοχή του Ελληνικού Τόξου στο EMSO</rdfs:label>
    <skos:prefLabel xml:lang="en">Hellenic Arc EMSO membership</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Adhésion de Hellenic Arc à EMSO</skos:prefLabel>
    <skos:prefLabel xml:lang="el">Συμμετοχή του Ελληνικού Τόξου στο EMSO</skos:prefLabel>
    <skos:definition xml:lang="en">Membership relation indicating that the Hellenic Arc Regional Facility is part of EMSO from 29 September 2016.</skos:definition>
    <skos:definition xml:lang="fr">Relation d’adhésion indiquant que la Regional Facility Hellenic Arc fait partie d’EMSO depuis le 29 septembre 2016.</skos:definition>
    <skos:definition xml:lang="el">Σχέση συμμετοχής που δηλώνει ότι η Περιφερειακή Εγκατάσταση Hellenic Arc αποτελεί μέρος του EMSO από τις 29 Σεπτεμβρίου 2016.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#hasERICMembership">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#ERICMembership"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#isERICMembershipOf"/>
    <skos:definition xml:lang="en">Relates a regional facility to its ERIC membership entity.</skos:definition>
    <skos:definition xml:lang="fr">Relie une infrastructure régionale à son entité d’adhésion ERIC.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una infraestructura regional con su entidad de membresía ERIC.</skos:definition>
    <skos:definition xml:lang="it">Collega un'infrastruttura regionale alla sua entità di adesione ERIC.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma infraestrutura regional à sua entidade de adesão ERIC.</skos:definition>
    <skos:definition xml:lang="no">Knytter en regional infrastruktur til dens ERIC-medlemskapsenhet.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o infrastructură regională de entitatea sa de apartenență ERIC.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια περιφερειακή υποδομή με την οντότητα συμμετοχής ERIC της.</skos:definition>
    <rdfs:comment xml:lang="en">Links a regional facility to its membership within an ERIC infrastructure.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Relie une infrastructure régionale à son appartenance à un ERIC.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una infraestructura regional con su membresía dentro de una infraestructura ERIC.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'infrastruttura regionale alla sua adesione a un'infrastruttura ERIC.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma infraestrutura regional à sua participação em uma infraestrutura ERIC.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en regional infrastruktur til medlemskapet i en ERIC-infrastruktur.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o infrastructură regională de apartenența sa la o infrastructură ERIC.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια περιφερειακή υποδομή με τη συμμετοχή της σε μια υποδομή ERIC.</rdfs:comment>
    <rdfs:label xml:lang="el">έχει συμμετοχή σε ERIC</rdfs:label>
    <rdfs:label xml:lang="en">has ERIC membership</rdfs:label>
    <rdfs:label xml:lang="es">tiene membresía en un ERIC</rdfs:label>
    <rdfs:label xml:lang="fr">a une appartenance à un ERIC</rdfs:label>
    <rdfs:label xml:lang="it">ha un'appartenenza a un ERIC</rdfs:label>
    <rdfs:label xml:lang="no">har medlemskap i et ERIC</rdfs:label>
    <rdfs:label xml:lang="pt">tem participação em um ERIC</rdfs:label>
    <rdfs:label xml:lang="ro">are apartenență la un ERIC</rdfs:label>
    <skos:prefLabel xml:lang="el">έχει συμμετοχή σε ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="en">has ERIC membership</skos:prefLabel>
    <skos:prefLabel xml:lang="es">tiene membresía en un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">a une appartenance à un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="it">ha un'appartenenza a un ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="no">har medlemskap i et ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">tem participação em um ERIC</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">are apartenență la un ERIC</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#RegionalFacility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <metadata:prefixIRI>OSO:RegionalFacility</metadata:prefixIRI>
    <skos:closeMatch rdf:resource="http://sweetontology.net/humanResearch/Observatory"/>
    <rdfs:seeAlso rdf:resource="http://sweetontology.net/humanResearch/"/>
    <rdfs:comment xml:lang="en">A regional facility containing sites, associated with research infrastructures, oceanographic campaigns, organizations, and a Regional Team Leader.</rdfs:comment>
    <rdfs:comment xml:lang="es">Infraestructura regional que contiene sitios, asociada a infraestructuras de investigación, campañas oceanográficas, organizaciones y un líder de equipo regional.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Infraestrutura regional que contém locais, associada a infraestruturas de investigação, campanhas oceanográficas, organizações e um líder regional.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Infrastructură regională care conține site-uri, asociată cu infrastructuri de cercetare, campanii oceanografice, organizații și un lider de echipă regional.</rdfs:comment>
    <rdfs:comment xml:lang="it">Infrastruttura regionale contenente siti, associata a infrastrutture di ricerca, campagne oceanografiche, organizzazioni e un coordinatore regionale.</rdfs:comment>
    <rdfs:comment xml:lang="no">Regional fasilitet som inneholder lokaliteter, tilknyttet forskningsinfrastrukturer, havkampanjer, organisasjoner og en regionalt ansvarlig.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Un nœud régional comprenant plusieurs sites, lié à des infrastructures de recherche, des campagnes océanographiques, des organisations et un coordinateur régional.</rdfs:comment>
    <rdfs:comment xml:lang="el">Περιφερειακή υποδομή που περιλαμβάνει τοποθεσίες, συνδέεται με ερευνητικές υποδομές, ωκεανογραφικές εκστρατείες, οργανισμούς και έναν υπεύθυνο ομάδας.</rdfs:comment>
    <rdfs:label xml:lang="es">Infraestructura regional</rdfs:label>
    <rdfs:label xml:lang="pt">Infraestrutura regional</rdfs:label>
    <rdfs:label xml:lang="ro">Infrastructură regională</rdfs:label>
    <rdfs:label xml:lang="it">Infrastruttura regionale</rdfs:label>
    <rdfs:label xml:lang="fr">Nœud régional</rdfs:label>
    <rdfs:label xml:lang="en">Regional Facility</rdfs:label>
    <rdfs:label xml:lang="no">Regional fasilitet</rdfs:label>
    <rdfs:label xml:lang="el">Περιφερειακή υποδομή</rdfs:label>
    <skos:prefLabel xml:lang="es">Infraestructura regional</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Infraestrutura regional</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Infrastructură regională</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Infrastruttura regionale</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Nœud régional</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Regional Facility</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Regional fasilitet</skos:prefLabel>
    <skos:prefLabel xml:lang="el">Περιφερειακή υποδομή</skos:prefLabel>
    <skos:altLabel xml:lang="en">EMSO Regional Facility</skos:altLabel>
    <skos:altLabel xml:lang="en">European Multidisciplinary Seafloor and Water Column Observatory Regional Facility</skos:altLabel>
    <skos:altLabel xml:lang="en">EMSO regional observatory node</skos:altLabel>
    <skos:altLabel xml:lang="en">Regional marine observatory</skos:altLabel>
    <skos:altLabel xml:lang="fr">Infrastructure régionale EMSO</skos:altLabel>
    <skos:altLabel xml:lang="fr">Nœud régional EMSO</skos:altLabel>
    <skos:definition xml:lang="en">A multidisciplinary marine research infrastructure dedicated to long-term observation of the seafloor and water column.</skos:definition>
    <skos:definition xml:lang="fr">Une infrastructure de recherche marine multidisciplinaire dédiée à l’observation à long terme du plancher océanique et de la colonne d’eau.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#hasLogo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#FundedProject"/>
    <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Image"/>
    <skos:definition xml:lang="en">Relates a funded project to its logo image.</skos:definition>
    <skos:definition xml:lang="fr">Relie un projet financé à son image de logo.</skos:definition>
    <skos:definition xml:lang="es">Relaciona un proyecto financiado con su imagen de logotipo.</skos:definition>
    <skos:definition xml:lang="it">Collega un progetto finanziato alla sua immagine del logo.</skos:definition>
    <skos:definition xml:lang="pt">Liga um projeto financiado à sua imagem de logótipo.</skos:definition>
    <skos:definition xml:lang="no">Knytter et finansiert prosjekt til dets logo.</skos:definition>
    <skos:definition xml:lang="ro">Leagă un proiect finanțat de imaginea siglei sale.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει ένα χρηματοδοτούμενο έργο με την εικόνα του λογότυπού του.</skos:definition>
    <rdfs:comment xml:lang="en">This property links a funded project to an image resource representing its logo.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Cette propriété relie un projet financé à une ressource image représentant son logo.</rdfs:comment>
    <rdfs:comment xml:lang="es">Esta propiedad vincula un proyecto financiado con un recurso de imagen que representa su logotipo.</rdfs:comment>
    <rdfs:comment xml:lang="it">Questa proprietà collega un progetto finanziato a una risorsa immagine che rappresenta il suo logo.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Esta propriedade liga um projeto financiado a um recurso de imagem que representa o seu logótipo.</rdfs:comment>
    <rdfs:comment xml:lang="no">Denne egenskapen kobler et finansiert prosjekt til en bilderessurs som representerer logoen.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Această proprietate leagă un proiect finanțat de o resursă imagine care reprezintă sigla sa.</rdfs:comment>
    <rdfs:comment xml:lang="el">Αυτή η ιδιότητα συνδέει ένα χρηματοδοτούμενο έργο με έναν πόρο εικόνας που αναπαριστά το λογότυπό του.</rdfs:comment>
    <rdfs:label xml:lang="el">έχει λογότυπο</rdfs:label>
    <rdfs:label xml:lang="en">has logo</rdfs:label>
    <rdfs:label xml:lang="es">tiene logotipo</rdfs:label>
    <rdfs:label xml:lang="fr">a un logo</rdfs:label>
    <rdfs:label xml:lang="it">ha un logo</rdfs:label>
    <rdfs:label xml:lang="no">har logo</rdfs:label>
    <rdfs:label xml:lang="pt">tem logótipo</rdfs:label>
    <rdfs:label xml:lang="ro">are siglă</rdfs:label>
    <skos:prefLabel xml:lang="el">έχει λογότυπο</skos:prefLabel>
    <skos:prefLabel xml:lang="en">has logo</skos:prefLabel>
    <skos:prefLabel xml:lang="es">tiene logotipo</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">a un logo</skos:prefLabel>
    <skos:prefLabel xml:lang="it">ha un logo</skos:prefLabel>
    <skos:prefLabel xml:lang="no">har logo</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">tem logótipo</skos:prefLabel>
