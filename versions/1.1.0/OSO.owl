    <rdfs:label xml:lang="pt">Plataforma de observação</rdfs:label>
    <rdfs:label xml:lang="fr">Plateforme d'observation</rdfs:label>
    <rdfs:label xml:lang="ro">Platformă de observație</rdfs:label>
    <rdfs:label xml:lang="el">Πλατφόρμα παρατήρησης</rdfs:label>
    <skos:prefLabel xml:lang="no">Observasjonsplattform</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Observation Platform</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Piattaforma di osservazione</skos:prefLabel>
