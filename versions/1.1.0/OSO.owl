    <OSO:hasERICMembership rdf:resource="https://w3id.org/earthsemantics/OSO#Western_Ionian_Sea_EMSO_membership"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#SN1"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#Calipso"/>
