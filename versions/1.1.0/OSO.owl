    <skos:prefLabel xml:lang="fr">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Widoco</skos:prefLabel>
    <skos:prefLabel xml:lang="el">Widoco</skos:prefLabel>
    <skos:definition xml:lang="en">An open-source tool used to automatically generate human-readable documentation for OWL ontologies.</skos:definition>
    <skos:definition xml:lang="fr">Un outil open source permettant de générer automatiquement une documentation lisible par l’humain pour les ontologies OWL.</skos:definition>
    <skos:definition xml:lang="es">Una herramienta de código abierto utilizada para generar automáticamente documentación legible para ontologías OWL.</skos:definition>
    <skos:definition xml:lang="it">Uno strumento open source utilizzato per generare automaticamente documentazione leggibile per ontologie OWL.</skos:definition>
    <skos:definition xml:lang="pt">Uma ferramenta open source utilizada para gerar automaticamente documentação legível para ontologias OWL.</skos:definition>
    <skos:definition xml:lang="ro">Un instrument open-source utilizat pentru generarea automată a documentației lizibile pentru ontologii OWL.</skos:definition>
    <skos:definition xml:lang="no">Et åpen kildekode-verktøy som brukes til automatisk å generere lesbar dokumentasjon for OWL-ontologier.</skos:definition>
    <skos:definition xml:lang="el">Ένα εργαλείο ανοικτού κώδικα που χρησιμοποιείται για την αυτόματη δημιουργία αναγνώσιμης τεκμηρίωσης για οντολογίες OWL.</skos:definition>
    <schema1:name>Widoco</schema1:name>
    <schema1:url rdf:resource="https://github.com/dgarijo/Widoco"/>
    <schema1:publisher rdf:resource="https://w3id.org/earthsemantics/OSO#OntologyEngineeringGroup"/>
    <schema1:logo rdf:resource="https://w3id.org/earthsemantics/OSO#WidocoLogo"/>
    <dcterms:type xml:lang="en">Semantic documentation tool</dcterms:type>
    <dcterms:type xml:lang="fr">Outil de documentation sémantique</dcterms:type>
    <dcterms:type xml:lang="es">Herramienta de documentación semántica</dcterms:type>
    <dcterms:type xml:lang="it">Strumento di documentazione semantica</dcterms:type>
    <dcterms:type xml:lang="pt">Ferramenta de documentação semântica</dcterms:type>
    <dcterms:type xml:lang="ro">Instrument de documentare semantică</dcterms:type>
    <dcterms:type xml:lang="no">Verktøy for semantisk dokumentasjon</dcterms:type>
    <dcterms:type xml:lang="el">Εργαλείο σημασιολογικής τεκμηρίωσης</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://github.com/dgarijo/Widoco"/>
    <rdfs:seeAlso rdf:resource="https://dgarijo.github.io/Widoco/"/>
  </rdf:Description>
