  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SemanticRepository">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticEcosystemResource"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Catalog"/>
    <rdfs:label xml:lang="en">Semantic repository</rdfs:label>
    <rdfs:label xml:lang="fr">Dépôt sémantique</rdfs:label>
    <rdfs:label xml:lang="es">Repositorio semántico</rdfs:label>
    <rdfs:label xml:lang="it">Repository semantico</rdfs:label>
    <rdfs:label xml:lang="pt">Repositório semântico</rdfs:label>
    <rdfs:label xml:lang="ro">Depozit semantic</rdfs:label>
    <rdfs:label xml:lang="no">Semantisk repositorium</rdfs:label>
    <rdfs:label xml:lang="el">Σημασιολογικό αποθετήριο</rdfs:label>
    <skos:definition xml:lang="en">A catalogue or repository used to publish, index, discover and share semantic artefacts.</skos:definition>
    <skos:definition xml:lang="fr">Un catalogue ou dépôt utilisé pour publier, indexer, découvrir et partager des artefacts sémantiques.</skos:definition>
    <skos:definition xml:lang="es">Un catálogo o repositorio utilizado para publicar, indexar, descubrir y compartir artefactos semánticos.</skos:definition>
    <skos:definition xml:lang="it">Un catalogo o repository utilizzato per pubblicare, indicizzare, scoprire e condividere artefatti semantici.</skos:definition>
    <skos:definition xml:lang="pt">Um catálogo ou repositório utilizado para publicar, indexar, descobrir e partilhar artefactos semânticos.</skos:definition>
    <skos:definition xml:lang="ro">Un catalog sau depozit utilizat pentru publicarea, indexarea, descoperirea și partajarea artefactelor semantice.</skos:definition>
    <skos:definition xml:lang="no">Et katalog eller repositorium som brukes til å publisere, indeksere, oppdage og dele semantiske artefakter.</skos:definition>
    <skos:definition xml:lang="el">Ένας κατάλογος ή αποθετήριο που χρησιμοποιείται για τη δημοσίευση, την ευρετηρίαση, την ανακάλυψη και την ανταλλαγή σημασιολογικών τεχνουργημάτων.</skos:definition>
  </rdf:Description>
