    <skos:definition xml:lang="no">En åpen kildekode-basert webapplikasjon som brukes til å visualisere OWL-ontologier som interaktive grafer.</skos:definition>
    <skos:definition xml:lang="el">Μια διαδικτυακή εφαρμογή ανοικτού κώδικα που χρησιμοποιείται για την οπτικοποίηση οντολογιών OWL ως διαδραστικών γραφημάτων.</skos:definition>
    <schema1:name>WebVOWL</schema1:name>
    <schema1:url rdf:resource="https://service.tib.eu/webvowl/#iri=https://earthportal.eu/ontologies/OSO"/>
    <schema1:publisher rdf:resource="https://w3id.org/earthsemantics/OSO#OntologyEngineeringGroup"/>
    <schema1:logo rdf:resource="https://w3id.org/earthsemantics/OSO#WebVOWLLogo"/>
