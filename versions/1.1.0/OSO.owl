    <rdfs:label xml:lang="it">è piattaforma di</rdfs:label>
    <rdfs:label xml:lang="pt">é plataforma de</rdfs:label>
    <rdfs:label xml:lang="no">er plattform for</rdfs:label>
    <rdfs:label xml:lang="ro">este platformă a</rdfs:label>
    <rdfs:label xml:lang="el">είναι πλατφόρμα της</rdfs:label>
    <skos:prefLabel xml:lang="en">is platform of</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est une plateforme de</skos:prefLabel>
    <skos:prefLabel xml:lang="es">es plataforma de</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è piattaforma di</skos:prefLabel>
