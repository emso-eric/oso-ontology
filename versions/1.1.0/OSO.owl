    <skos:altLabel xml:lang="en">CONDOR</skos:altLabel>
    <skos:altLabel xml:lang="en">Condor Station</skos:altLabel>
    <skos:altLabel xml:lang="pt">Observatório Condor</skos:altLabel>
    <skos:altLabel xml:lang="fr">Station Condor</skos:altLabel>
    <skos:definition xml:lang="en">An ocean observatory site associated with EMSO-PT and located on the Condor Seamount in the Azores region.</skos:definition>
    <skos:definition xml:lang="fr">Un site d’observation océanique associé à EMSO-PT et situé sur le mont sous-marin Condor dans la région des Açores.</skos:definition>
    <skos:definition xml:lang="pt">Um sítio de observação oceânica associado ao EMSO-PT e localizado no monte submarino Condor na região dos Açores.</skos:definition>
    <skos:definition xml:lang="no">Et oseanobservasjonssted tilknyttet EMSO-PT og lokalisert ved Condor-sjøfjellet i Azorene.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isLinkedToCampaignSeries">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#isCampaignSeriesLinkedTo"/>
    <rdfs:comment xml:lang="en">A Regional Facility may be linked to one or more series of oceanographic campaigns.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Une infrastructure régionale peut être liée à une ou plusieurs séries de campagnes océanographiques.</rdfs:comment>
    <rdfs:comment xml:lang="es">Una infraestructura regional puede estar vinculada a una o varias series de campañas oceanográficas.</rdfs:comment>
    <rdfs:comment xml:lang="it">Una infrastruttura regionale può essere collegata a una o più serie di campagne oceanografiche.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Uma infraestrutura regional pode estar ligada a uma ou mais séries de campanhas oceanográficas.</rdfs:comment>
    <rdfs:comment xml:lang="no">En regional infrastruktur kan være knyttet til én eller flere serier av oseanografiske kampanjer.</rdfs:comment>
    <rdfs:comment xml:lang="ro">O infrastructură regională poate fi legată de una sau mai multe serii de campanii oceanografice.</rdfs:comment>
    <rdfs:comment xml:lang="el">Μια περιφερειακή υποδομή μπορεί να συνδέεται με μία ή περισσότερες σειρές ωκεανογραφικών εκστρατειών.</rdfs:comment>
    <rdfs:label xml:lang="en">is linked to campaign series</rdfs:label>
