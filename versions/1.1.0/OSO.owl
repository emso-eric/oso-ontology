    <rdfs:label xml:lang="pt">tem geometria</rdfs:label>
    <rdfs:label xml:lang="no">har geometri</rdfs:label>
    <rdfs:label xml:lang="ro">are geometrie</rdfs:label>
    <rdfs:label xml:lang="el">έχει γεωμετρία</rdfs:label>
