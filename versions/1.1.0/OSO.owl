    <rdfs:label xml:lang="it">è un sito di test</rdfs:label>
    <rdfs:label xml:lang="no">er teststed</rdfs:label>
    <rdfs:label xml:lang="pt">é sítio de teste</rdfs:label>
    <rdfs:label xml:lang="ro">este sit de testare</rdfs:label>
    <skos:prefLabel xml:lang="el">είναι δοκιμαστικός τόπος</skos:prefLabel>
    <skos:prefLabel xml:lang="en">is test site</skos:prefLabel>
    <skos:prefLabel xml:lang="es">es sitio de prueba</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est un site de test</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è un sito di test</skos:prefLabel>
    <skos:prefLabel xml:lang="no">er teststed</skos:prefLabel>
