    <rdfs:label xml:lang="fr">Mer des Baléares</rdfs:label>
    <rdfs:label xml:lang="it">Mar Balear</rdfs:label>
    <rdfs:label xml:lang="no">Balearhavet</rdfs:label>
    <rdfs:label xml:lang="pt">Mar Balear</rdfs:label>
    <rdfs:label xml:lang="ro">Marea Balearelor</rdfs:label>
    <rdfs:label xml:lang="ca">Mar Balear</rdfs:label>
    <skos:prefLabel xml:lang="el">Βαλεαρίδα Θάλασσα</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Balearic Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Mar Balear</skos:prefLabel>
