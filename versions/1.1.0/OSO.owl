  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isCampaignSeriesLinkedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#isLinkedToCampaignSeries"/>
    <rdfs:comment xml:lang="en">Links a series of oceanographic campaigns to the Regional Facility associated with it.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une série de campagnes océanographiques à l’infrastructure régionale qui lui est associée.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una serie de campañas oceanográficas con la infraestructura regional asociada.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega una serie di campagne oceanografiche all'infrastruttura regionale associata.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma série de campanhas oceanográficas à infraestrutura regional associada.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en serie av oseanografiske kampanjer til den tilknyttede regionale infrastrukturen.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o serie de campanii oceanografice de infrastructura regională asociată.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια σειρά ωκεανογραφικών εκστρατειών με τη σχετική περιφερειακή υποδομή.</rdfs:comment>
    <rdfs:label xml:lang="en">is campaign series linked to</rdfs:label>
    <rdfs:label xml:lang="fr">est une série de campagnes liée à</rdfs:label>
    <rdfs:label xml:lang="es">es serie de campañas vinculada a</rdfs:label>
    <rdfs:label xml:lang="it">è una serie di campagne collegata a</rdfs:label>
    <rdfs:label xml:lang="pt">é série de campanhas ligada a</rdfs:label>
    <rdfs:label xml:lang="no">er kampanjeserie knyttet til</rdfs:label>
    <rdfs:label xml:lang="ro">este serie de campanii legată de</rdfs:label>
    <rdfs:label xml:lang="el">είναι σειρά εκστρατειών συνδεδεμένη με</rdfs:label>
    <skos:prefLabel xml:lang="en">is campaign series linked to</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est une série de campagnes liée à</skos:prefLabel>
    <skos:prefLabel xml:lang="es">es serie de campañas vinculada a</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è una serie di campagne collegata a</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">é série de campanhas ligada a</skos:prefLabel>
