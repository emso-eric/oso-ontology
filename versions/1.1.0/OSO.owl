  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isLedByPerson">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure"/>
    <rdfs:range rdf:resource="http://schema.org/Person"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#leadsResearchInfrastructure"/>
    <skos:definition xml:lang="en">Relates a research infrastructure to the person responsible for leading it.</skos:definition>
    <skos:definition xml:lang="fr">Relie une infrastructure de recherche à la personne chargée de la diriger.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una infraestructura de investigación con la persona responsable de dirigirla.</skos:definition>
    <skos:definition xml:lang="it">Collega un'infrastruttura di ricerca alla persona responsabile della sua direzione.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma infraestrutura de investigação à pessoa responsável pela sua liderança.</skos:definition>
    <skos:definition xml:lang="no">Knytter en forskningsinfrastruktur til personen som leder den.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o infrastructură de cercetare de persoana responsabilă de conducerea acesteia.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια ερευνητική υποδομή με το πρόσωπο που είναι υπεύθυνο για τη διεύθυνσή της.</skos:definition>
    <rdfs:comment xml:lang="en">Links a research infrastructure to its scientific or operational leader.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une infrastructure de recherche à son responsable scientifique ou opérationnel.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una infraestructura de investigación con su responsable científico u operativo.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'infrastruttura di ricerca al suo responsabile scientifico o operativo.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma infraestrutura de investigação ao seu responsável científico ou operacional.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en forskningsinfrastruktur til dens vitenskapelige eller operative leder.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o infrastructură de cercetare de conducătorul său științific sau operațional.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια ερευνητική υποδομή με τον επιστημονικό ή επιχειρησιακό υπεύθυνό της.</rdfs:comment>
    <rdfs:label xml:lang="el">Η ερευνητική υποδομή διευθύνεται από</rdfs:label>
    <rdfs:label xml:lang="en">Research Infrastructure is led by</rdfs:label>
    <rdfs:label xml:lang="es">La infraestructura de investigación está dirigida por</rdfs:label>
    <rdfs:label xml:lang="fr">L’infrastructure de recherche est dirigée par</rdfs:label>
    <rdfs:label xml:lang="it">L'infrastruttura di ricerca è diretta da</rdfs:label>
    <rdfs:label xml:lang="no">Forskningsinfrastrukturen ledes av</rdfs:label>
    <rdfs:label xml:lang="pt">A infraestrutura de investigação é liderada por</rdfs:label>
    <rdfs:label xml:lang="ro">Infrastructura de cercetare este condusă de</rdfs:label>
    <skos:prefLabel xml:lang="el">Η ερευνητική υποδομή διευθύνεται από</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Research Infrastructure is led by</skos:prefLabel>
    <skos:prefLabel xml:lang="es">La infraestructura de investigación está dirigida por</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">L’infrastructure de recherche est dirigée par</skos:prefLabel>
    <skos:prefLabel xml:lang="it">L'infrastruttura di ricerca è diretta da</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Forskningsinfrastrukturen ledes av</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">A infraestrutura de investigação é liderada por</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Infrastructura de cercetare este condusă de</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#CollaborativeDevelopmentPlatform">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:label xml:lang="en">Collaborative development platform</rdfs:label>
    <rdfs:label xml:lang="fr">Plateforme de développement collaboratif</rdfs:label>
    <rdfs:label xml:lang="es">Plataforma de desarrollo colaborativo</rdfs:label>
    <rdfs:label xml:lang="it">Piattaforma di sviluppo collaborativo</rdfs:label>
    <rdfs:label xml:lang="pt">Plataforma de desenvolvimento colaborativo</rdfs:label>
    <rdfs:label xml:lang="ro">Platformă de dezvoltare colaborativă</rdfs:label>
    <rdfs:label xml:lang="no">Plattform for samarbeidsutvikling</rdfs:label>
    <rdfs:label xml:lang="el">Πλατφόρμα συνεργατικής ανάπτυξης</rdfs:label>
    <skos:definition xml:lang="en">A software platform supporting collaborative software development, version control, issue tracking and source code management.</skos:definition>
    <skos:definition xml:lang="fr">Une plateforme logicielle prenant en charge le développement collaboratif, le contrôle de version, le suivi des tickets et la gestion du code source.</skos:definition>
    <skos:definition xml:lang="es">Una plataforma de software que permite el desarrollo colaborativo, el control de versiones, el seguimiento de incidencias y la gestión del código fuente.</skos:definition>
    <skos:definition xml:lang="it">Una piattaforma software che supporta lo sviluppo collaborativo, il controllo di versione, il tracciamento delle issue e la gestione del codice sorgente.</skos:definition>
    <skos:definition xml:lang="pt">Uma plataforma de software que suporta o desenvolvimento colaborativo, o controlo de versões, o acompanhamento de problemas e a gestão do código-fonte.</skos:definition>
    <skos:definition xml:lang="ro">O platformă software care sprijină dezvoltarea colaborativă, controlul versiunilor, urmărirea problemelor și gestionarea codului sursă.</skos:definition>
    <skos:definition xml:lang="no">En programvareplattform som støtter samarbeidsbasert programvareutvikling, versjonskontroll, saksoppfølging og håndtering av kildekode.</skos:definition>
    <skos:definition xml:lang="el">Μια πλατφόρμα λογισμικού που υποστηρίζει τη συνεργατική ανάπτυξη λογισμικού, τον έλεγχο εκδόσεων, την παρακολούθηση ζητημάτων και τη διαχείριση πηγαίου κώδικα.</skos:definition>
  </rdf:Description>
