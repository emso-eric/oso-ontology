  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#GitHub">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#CollaborativeDevelopmentPlatform"/>
    <rdf:type rdf:resource="http://schema.org/WebApplication"/>
    <dcterms:subject rdf:resource="http://www.wikidata.org/entity/Q364"/>
    <rdfs:label xml:lang="en">GitHub</rdfs:label>
    <rdfs:label xml:lang="fr">GitHub</rdfs:label>
    <rdfs:label xml:lang="es">GitHub</rdfs:label>
    <rdfs:label xml:lang="it">GitHub</rdfs:label>
    <rdfs:label xml:lang="pt">GitHub</rdfs:label>
    <rdfs:label xml:lang="ro">GitHub</rdfs:label>
    <rdfs:label xml:lang="no">GitHub</rdfs:label>
    <rdfs:label xml:lang="el">GitHub</rdfs:label>
    <skos:prefLabel xml:lang="en">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="es">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="it">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="no">GitHub</skos:prefLabel>
    <skos:prefLabel xml:lang="el">GitHub</skos:prefLabel>
    <skos:definition xml:lang="en">A web-based platform used for source code hosting, version control, issue tracking and collaborative development of the OSO ontology.</skos:definition>
    <skos:definition xml:lang="fr">Une plateforme web utilisée pour l’hébergement du code source, le contrôle de version, le suivi des tickets et le développement collaboratif de l’ontologie OSO.</skos:definition>
    <skos:definition xml:lang="es">Una plataforma web utilizada para alojar código fuente, gestionar versiones, realizar el seguimiento de incidencias y desarrollar colaborativamente la ontología OSO.</skos:definition>
    <skos:definition xml:lang="it">Una piattaforma web utilizzata per l’hosting del codice sorgente, il controllo di versione, il tracciamento delle issue e lo sviluppo collaborativo dell’ontologia OSO.</skos:definition>
    <skos:definition xml:lang="pt">Uma plataforma web utilizada para alojamento de código-fonte, controlo de versões, acompanhamento de problemas e desenvolvimento colaborativo da ontologia OSO.</skos:definition>
    <skos:definition xml:lang="ro">O platformă web utilizată pentru găzduirea codului sursă, controlul versiunilor, urmărirea problemelor și dezvoltarea colaborativă a ontologiei OSO.</skos:definition>
    <skos:definition xml:lang="no">En nettbasert plattform brukt til kildekodehosting, versjonskontroll, saksoppfølging og samarbeidsbasert utvikling av OSO-ontologien.</skos:definition>
    <skos:definition xml:lang="el">Μια διαδικτυακή πλατφόρμα που χρησιμοποιείται για φιλοξενία πηγαίου κώδικα, έλεγχο εκδόσεων, παρακολούθηση ζητημάτων και συνεργατική ανάπτυξη της οντολογίας OSO.</skos:definition>
    <schema1:name>GitHub</schema1:name>
    <schema1:url rdf:resource="https://github.com/"/>
    <schema1:logo rdf:resource="https://w3id.org/earthsemantics/OSO#GitHubLogo"/>
    <schema1:publisher rdf:resource="https://w3id.org/earthsemantics/OSO#GitHubInc"/>
    <dcterms:type xml:lang="en">Collaborative development platform</dcterms:type>
    <dcterms:type xml:lang="fr">Plateforme de développement collaboratif</dcterms:type>
    <dcterms:type xml:lang="es">Plataforma de desarrollo colaborativo</dcterms:type>
    <dcterms:type xml:lang="it">Piattaforma di sviluppo collaborativo</dcterms:type>
    <dcterms:type xml:lang="pt">Plataforma de desenvolvimento colaborativo</dcterms:type>
    <dcterms:type xml:lang="ro">Platformă de dezvoltare colaborativă</dcterms:type>
    <dcterms:type xml:lang="no">Plattform for samarbeidsutvikling</dcterms:type>
    <dcterms:type xml:lang="el">Πλατφόρμα συνεργατικής ανάπτυξης</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://github.com/"/>
    <rdfs:seeAlso rdf:resource="https://github.com/emso-eric/oso-ontology"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#TUPEM_SubSurface_Mooring_deployment_2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
