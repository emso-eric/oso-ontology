    <skos:altLabel xml:lang="fr">Observatoire européen multidisciplinaire des fonds marins et de la colonne d’eau</skos:altLabel>
    <skos:definition xml:lang="en">A European Research Infrastructure Consortium dedicated to long-term multidisciplinary observation of the seafloor and the water column, integrating regional facilities, observatory sites, platforms and data services across European seas.</skos:definition>
    <skos:definition xml:lang="fr">Un consortium européen pour une infrastructure de recherche dédié à l’observation multidisciplinaire à long terme du plancher océanique et de la colonne d’eau, intégrant des infrastructures régionales, des sites d’observation, des plateformes et des services de données dans les mers européennes.</skos:definition>
    <skos:definition xml:lang="it">Un consorzio europeo per un’infrastruttura di ricerca dedicato all’osservazione multidisciplinare a lungo termine del fondale marino e della colonna d’acqua, integrando infrastrutture regionali, siti osservativi, piattaforme e servizi dati nei mari europei.</skos:definition>
    <dcat:keyword xml:lang="en">marine research infrastructure</dcat:keyword>
    <dcat:keyword xml:lang="en">seafloor observatory</dcat:keyword>
    <dcat:keyword xml:lang="en">water column observation</dcat:keyword>
    <dcat:keyword xml:lang="en">long-term ocean observation</dcat:keyword>
    <dcat:keyword xml:lang="en">ocean observing system</dcat:keyword>
    <dcat:keyword xml:lang="en">marine observatory</dcat:keyword>
    <dcat:keyword xml:lang="en">European ocean observation</dcat:keyword>
    <dcat:keyword xml:lang="en">digital research infrastructure</dcat:keyword>
    <dcat:keyword xml:lang="en">European Research Infrastructure Consortium</dcat:keyword>
    <dcat:keyword xml:lang="en">ERIC</dcat:keyword>
    <dcat:keyword xml:lang="en">EMSO</dcat:keyword>
    <dcat:keyword xml:lang="fr">infrastructure de recherche marine</dcat:keyword>
    <dcat:keyword xml:lang="fr">observatoire des fonds marins</dcat:keyword>
    <dcat:keyword xml:lang="fr">observation de la colonne d’eau</dcat:keyword>
    <dcat:keyword xml:lang="fr">observation océanique à long terme</dcat:keyword>
    <dcat:keyword xml:lang="fr">système d’observation de l’océan</dcat:keyword>
    <dcat:keyword xml:lang="fr">observatoire marin</dcat:keyword>
    <dcat:keyword xml:lang="fr">observation européenne de l’océan</dcat:keyword>
    <dcat:keyword xml:lang="fr">infrastructure de recherche numérique</dcat:keyword>
