    <rdfs:seeAlso rdf:resource="https://smartbay.marine.ie/"/>
    <skos:definition xml:lang="en">Marine observation and test site located in Galway Bay, supporting real-time ocean monitoring and marine technology trials.</skos:definition>
    <rdfs:label xml:lang="el">SmartBay</rdfs:label>
    <rdfs:label xml:lang="en">SmartBay</rdfs:label>
    <rdfs:label xml:lang="es">SmartBay</rdfs:label>
    <rdfs:label xml:lang="fr">SmartBay</rdfs:label>
