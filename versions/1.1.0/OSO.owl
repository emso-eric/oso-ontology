  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Widoco">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticDocumentationTool"/>
    <rdf:type rdf:resource="http://schema.org/SoftwareApplication"/>
    <rdfs:label xml:lang="en">Widoco</rdfs:label>
    <rdfs:label xml:lang="fr">Widoco</rdfs:label>
    <rdfs:label xml:lang="es">Widoco</rdfs:label>
