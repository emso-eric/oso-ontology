  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SemanticDatabase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticTool"/>
    <rdfs:subClassOf rdf:resource="http://schema.org/SoftwareApplication"/>
    <rdfs:label xml:lang="en">Semantic database</rdfs:label>
    <rdfs:label xml:lang="fr">Base de données sémantique</rdfs:label>
    <rdfs:label xml:lang="es">Base de datos semántica</rdfs:label>
    <rdfs:label xml:lang="it">Base di dati semantica</rdfs:label>
    <rdfs:label xml:lang="pt">Base de dados semântica</rdfs:label>
    <rdfs:label xml:lang="ro">Bază de date semantică</rdfs:label>
    <rdfs:label xml:lang="no">Semantisk database</rdfs:label>
    <rdfs:label xml:lang="el">Σημασιολογική βάση δεδομένων</rdfs:label>
    <skos:definition xml:lang="en">A software system designed to store, manage and query semantic data such as RDF graphs and knowledge graphs.</skos:definition>
    <skos:definition xml:lang="fr">Un système logiciel conçu pour stocker, gérer et interroger des données sémantiques telles que des graphes RDF et des graphes de connaissances.</skos:definition>
    <skos:definition xml:lang="es">Un sistema de software diseñado para almacenar, gestionar y consultar datos semánticos como grafos RDF y grafos de conocimiento.</skos:definition>
    <skos:definition xml:lang="it">Un sistema software progettato per archiviare, gestire e interrogare dati semantici come grafi RDF e grafi della conoscenza.</skos:definition>
    <skos:definition xml:lang="pt">Um sistema de software concebido para armazenar, gerir e consultar dados semânticos, como grafos RDF e grafos de conhecimento.</skos:definition>
    <skos:definition xml:lang="ro">Un sistem software conceput pentru stocarea, gestionarea și interogarea datelor semantice, precum grafuri RDF și grafuri de cunoștințe.</skos:definition>
    <skos:definition xml:lang="no">Et programvaresystem utviklet for å lagre, administrere og spørre semantiske data som RDF-grafer og kunnskapsgrafer.</skos:definition>
    <skos:definition xml:lang="el">Ένα λογισμικό σύστημα σχεδιασμένο για την αποθήκευση, διαχείριση και υποβολή ερωτημάτων σε σημασιολογικά δεδομένα, όπως γράφοι RDF και γράφοι γνώσης.</skos:definition>
  </rdf:Description>
