  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#hasCountry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="http://schema.org/addressCountry"/>
    <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
