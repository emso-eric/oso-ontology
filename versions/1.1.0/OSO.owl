  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#RegionalFacility_is_part_of_a_RI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#ResearchInfrastructure"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#hasRegionalFacility"/>
    <skos:definition xml:lang="en">Relates a regional facility to the research infrastructure of which it is part.</skos:definition>
    <skos:definition xml:lang="fr">Relie une infrastructure régionale à l’infrastructure de recherche dont elle fait partie.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una infraestructura regional con la infraestructura de investigación de la que forma parte.</skos:definition>
    <skos:definition xml:lang="it">Collega un'infrastruttura regionale all'infrastruttura di ricerca di cui fa parte.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma infraestrutura regional à infraestrutura de investigação da qual faz parte.</skos:definition>
    <skos:definition xml:lang="no">Knytter en regional infrastruktur til forskningsinfrastrukturen den er en del av.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o infrastructură regională de infrastructura de cercetare din care face parte.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια περιφερειακή υποδομή με την ερευνητική υποδομή της οποίας αποτελεί μέρος.</skos:definition>
    <rdfs:comment xml:lang="en">Links a regional facility to its parent research infrastructure.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une infrastructure régionale à son infrastructure de recherche parente.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una infraestructura regional con su infraestructura de investigación principal.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'infrastruttura regionale alla sua infrastruttura di ricerca principale.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma infraestrutura regional à sua infraestrutura de investigação principal.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en regional infrastruktur til dens overordnede forskningsinfrastruktur.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o infrastructură regională de infrastructura sa principală de cercetare.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια περιφερειακή υποδομή με τη μητρική της ερευνητική υποδομή.</rdfs:comment>
    <rdfs:label xml:lang="el">Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής</rdfs:label>
    <rdfs:label xml:lang="en">Regional Facility is part of a Research Infrastructure</rdfs:label>
    <rdfs:label xml:lang="es">La infraestructura regional forma parte de una infraestructura de investigación</rdfs:label>
    <rdfs:label xml:lang="fr">L’infrastructure régionale fait partie d’une infrastructure de recherche</rdfs:label>
    <rdfs:label xml:lang="it">L'infrastruttura regionale fa parte di un'infrastruttura di ricerca</rdfs:label>
    <rdfs:label xml:lang="no">Regional infrastruktur er del av en forskningsinfrastruktur</rdfs:label>
    <rdfs:label xml:lang="pt">A infraestrutura regional faz parte de uma infraestrutura de investigação</rdfs:label>
    <rdfs:label xml:lang="ro">Infrastructura regională face parte dintr-o infrastructură de cercetare</rdfs:label>
    <skos:prefLabel xml:lang="el">Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Regional Facility is part of a Research Infrastructure</skos:prefLabel>
    <skos:prefLabel xml:lang="es">La infraestructura regional forma parte de una infraestructura de investigación</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">L’infrastructure régionale fait partie d’une infrastructure de recherche</skos:prefLabel>
    <skos:prefLabel xml:lang="it">L'infrastruttura regionale fa parte di un'infrastruttura di ricerca</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Regional infrastruktur er del av en forskningsinfrastruktur</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">A infraestrutura regional faz parte de uma infraestrutura de investigação</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Infrastructura regională face parte dintr-o infrastructură de cercetare</skos:prefLabel>
  </rdf:Description>
