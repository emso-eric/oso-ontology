  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#EUXINUS">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#FundedProject"/>
    <rdf:type rdf:resource="https://w3id.org/cerif/vocab/Project"/>
    <rdf:type rdf:resource="http://schema.org/Project"/>
    <OSO:Project_is_led_by_an_Organization rdf:resource="https://w3id.org/earthsemantics/OSO#GeoEcoMar"/>
    <prov:wasAssociatedWith rdf:resource="https://w3id.org/earthsemantics/OSO#GeoEcoMar"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Romania"/>
    <OSO:hasLocation rdf:resource="https://w3id.org/earthsemantics/OSO#Black_Sea"/>
    <schema1:url rdf:resource="https://www.euxinus.eu/index_en.html"/>
    <rdfs:seeAlso rdf:resource="https://www.euxinus.eu/index_en.html"/>
    <rdfs:seeAlso rdf:resource="https://www.euxinus.eu/emso_euxinus_network.html"/>
    <dcterms:title xml:lang="en">EUXINUS project</dcterms:title>
    <dcterms:title xml:lang="fr">Projet EUXINUS</dcterms:title>
    <dcterms:title xml:lang="ro">Proiectul EUXINUS</dcterms:title>
    <rdfs:label xml:lang="en">EUXINUS</rdfs:label>
    <rdfs:label xml:lang="fr">EUXINUS</rdfs:label>
    <rdfs:label xml:lang="ro">EUXINUS</rdfs:label>
    <skos:prefLabel xml:lang="en">EUXINUS</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">EUXINUS</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">EUXINUS</skos:prefLabel>
    <skos:altLabel xml:lang="en">IOSIN EMSO-EUXINUS network</skos:altLabel>
    <skos:altLabel xml:lang="fr">Réseau IOSIN EMSO-EUXINUS</skos:altLabel>
    <skos:altLabel xml:lang="ro">Rețeaua IOSIN EMSO-EUXINUS</skos:altLabel>
    <skos:definition xml:lang="en">Regional Black Sea observing network providing real-time marine geohazard alerts and coastal water monitoring through marine and coastal observatories.</skos:definition>
    <skos:definition xml:lang="fr">Réseau régional d’observation de la mer Noire fournissant des alertes temps réel sur les aléas géologiques marins et le suivi des eaux côtières via des observatoires marins et côtiers.</skos:definition>
    <skos:definition xml:lang="ro">Rețea regională de observare a Mării Negre care furnizează alerte în timp real privind riscurile geologice marine și monitorizarea apelor costiere prin observatoare marine și costiere.</skos:definition>
    <dcterms:description xml:lang="en">The EUXINUS network consists of three offshore observatories and one coastal observatory. Romania contributes to EMSO ERIC through GeoEcoMar by providing real-time data on water-column parameters and early-warning information related to marine hazards.</dcterms:description>
    <dcterms:description xml:lang="fr">Le réseau EUXINUS comprend trois observatoires offshore et un observatoire côtier. La Roumanie contribue à EMSO ERIC par l’intermédiaire de GeoEcoMar en fournissant des données temps réel sur la colonne d’eau et des informations d’alerte précoce liées aux aléas marins.</dcterms:description>
    <dcterms:description xml:lang="ro">Rețeaua EUXINUS este formată din trei observatoare offshore și un observator de coastă. România contribuie la EMSO ERIC prin GeoEcoMar, furnizând date în timp real despre coloana de apă și informații de avertizare timpurie privind riscurile marine.</dcterms:description>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Western_Ionian_Sea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <OSO:RegionalFacility_is_part_of_a_RI rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO-Italia"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Italy"/>
