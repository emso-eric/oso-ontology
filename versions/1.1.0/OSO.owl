  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SemanticTool">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/earthsemantics/OSO#SemanticEcosystemResource"/>
    <rdfs:subClassOf rdf:resource="http://schema.org/SoftwareApplication"/>
    <rdfs:label xml:lang="en">Semantic tool</rdfs:label>
    <rdfs:label xml:lang="fr">Outil sémantique</rdfs:label>
    <rdfs:label xml:lang="es">Herramienta semántica</rdfs:label>
    <rdfs:label xml:lang="it">Strumento semantico</rdfs:label>
    <rdfs:label xml:lang="pt">Ferramenta semântica</rdfs:label>
    <rdfs:label xml:lang="ro">Instrument semantic</rdfs:label>
    <rdfs:label xml:lang="no">Semantisk verktøy</rdfs:label>
    <rdfs:label xml:lang="el">Σημασιολογικό εργαλείο</rdfs:label>
    <skos:definition xml:lang="en">A software tool used throughout the lifecycle of semantic artefacts.</skos:definition>
    <skos:definition xml:lang="fr">Un outil logiciel utilisé tout au long du cycle de vie des artefacts sémantiques.</skos:definition>
    <skos:definition xml:lang="es">Una herramienta informática utilizada durante todo el ciclo de vida de los artefactos semánticos.</skos:definition>
    <skos:definition xml:lang="it">Uno strumento software utilizzato durante l'intero ciclo di vita degli artefatti semantici.</skos:definition>
    <skos:definition xml:lang="pt">Uma ferramenta de software utilizada ao longo do ciclo de vida dos artefactos semânticos.</skos:definition>
    <skos:definition xml:lang="ro">Un instrument software utilizat pe parcursul întregului ciclu de viață al artefactelor semantice.</skos:definition>
    <skos:definition xml:lang="no">Et programvareverktøy som brukes gjennom hele livssyklusen til semantiske artefakter.</skos:definition>
    <skos:definition xml:lang="el">Ένα λογισμικό που χρησιμοποιείται σε ολόκληρο τον κύκλο ζωής των σημασιολογικών τεχνουργημάτων.</skos:definition>
  </rdf:Description>
