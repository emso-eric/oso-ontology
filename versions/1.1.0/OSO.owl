    <skos:definition xml:lang="en">Researcher involved in ocean observation systems, mooring technologies and marine monitoring infrastructures.</skos:definition>
    <skos:definition xml:lang="it">Ricercatore coinvolto nei sistemi di osservazione oceanica, nelle tecnologie di ormeggio e nelle infrastrutture di monitoraggio marino.</skos:definition>
  </rdf:Description>
