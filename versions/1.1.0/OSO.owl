    <skos:prefLabel xml:lang="en">EMBRC-France</skos:prefLabel>
    <skos:prefLabel xml:lang="es">EMBRC-France</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">EMBRC-France</skos:prefLabel>
