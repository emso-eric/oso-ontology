  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#LUCKYDIVMIC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#OceanographicCampaign"/>
    <dcterms:identifier>10.17600/18001345</dcterms:identifier>
    <dcterms:isReferencedBy rdf:resource="https://doi.org/10.17600/18001345"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Azores"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/North_Atlantic_Ocean"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Mid-Atlantic_Ridge"/>
    <rdfs:seeAlso rdf:resource="https://doi.org/10.17600/18001345"/>
