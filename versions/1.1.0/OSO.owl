  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isSiteLedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#leadsSite"/>
    <skos:definition xml:lang="en">Relates a marine observation site to the organisation responsible for leading or coordinating it.</skos:definition>
    <skos:definition xml:lang="fr">Relie un site d’observation marine à l’organisation chargée de son pilotage ou de sa coordination.</skos:definition>
    <skos:definition xml:lang="es">Relaciona un sitio de observación marina con la organización responsable de liderarlo o coordinarlo.</skos:definition>
    <skos:definition xml:lang="it">Collega un sito di osservazione marina all'organizzazione responsabile del suo coordinamento o della sua gestione.</skos:definition>
    <skos:definition xml:lang="pt">Liga um local de observação marinha à organização responsável pela sua coordenação ou liderança.</skos:definition>
    <skos:definition xml:lang="no">Knytter et marint observasjonssted til organisasjonen som leder eller koordinerer det.</skos:definition>
    <skos:definition xml:lang="ro">Leagă un sit de observație marină de organizația responsabilă de coordonarea sau conducerea acestuia.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια θαλάσσια τοποθεσία παρατήρησης με τον οργανισμό που είναι υπεύθυνος για τον συντονισμό ή τη διαχείρισή της.</skos:definition>
    <rdfs:comment xml:lang="en">Links a site to the organisation that leads it.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie un site à l’organisation qui le pilote.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona un sitio con la organización que lo coordina.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un sito all'organizzazione che lo coordina.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga um local à organização que o coordena.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter et sted til organisasjonen som leder det.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă un sit de organizația care îl coordonează.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια τοποθεσία με τον οργανισμό που τη συντονίζει.</rdfs:comment>
    <rdfs:label xml:lang="en">is site led by</rdfs:label>
    <rdfs:label xml:lang="fr">est piloté par</rdfs:label>
    <rdfs:label xml:lang="es">está coordinado por</rdfs:label>
    <rdfs:label xml:lang="it">è coordinato da</rdfs:label>
    <rdfs:label xml:lang="pt">é coordenado por</rdfs:label>
    <rdfs:label xml:lang="no">ledes av</rdfs:label>
    <rdfs:label xml:lang="ro">este coordonat de</rdfs:label>
    <rdfs:label xml:lang="el">συντονίζεται από</rdfs:label>
    <skos:prefLabel xml:lang="en">is site led by</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est piloté par</skos:prefLabel>
    <skos:prefLabel xml:lang="es">está coordinado por</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è coordinato da</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">é coordenado por</skos:prefLabel>
    <skos:prefLabel xml:lang="no">ledes av</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">este coordonat de</skos:prefLabel>
    <skos:prefLabel xml:lang="el">συντονίζεται από</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#South_Cape_Seabed_Station">
