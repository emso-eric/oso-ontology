  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Smartbay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#Site"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#Smartbay_buoy"/>
    <OSO:containsPlatform rdf:resource="https://w3id.org/earthsemantics/OSO#Smartbay_observatory"/>
    <OSO:hasSiteResponsible rdf:resource="https://w3id.org/earthsemantics/OSO#Alan_BERRY"/>
    <OSO:hasCountry rdf:resource="https://w3id.org/earthsemantics/OSO#Ireland"/>
    <OSO:distanceFromLand rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</OSO:distanceFromLand>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2015-10-08</OSO:dateFirstDeployment>
    <OSO:isTestSite rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</OSO:isTestSite>
    <OSO:maxWaterDepth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">27</OSO:maxWaterDepth>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Galway_Bay"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Atlantic_Ocean"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Ireland"/>
    <schema1:url rdf:resource="https://data.marine.ie/geonetwork/srv/api/records/ie.marine.data:dataset.4825"/>
    <schema1:url rdf:resource="https://smartbay.marine.ie/"/>
