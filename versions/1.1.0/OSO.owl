  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Canarias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <OSO:RegionalFacility_is_linked_to_a_project rdf:resource="https://w3id.org/earthsemantics/OSO#Atlantic_Whale_Deal"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Canary_Islands"/>
    <OSO:hasERICMembership rdf:resource="https://w3id.org/earthsemantics/OSO#Canarias_EMSO_membership"/>
