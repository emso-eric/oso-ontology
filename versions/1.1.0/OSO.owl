    <skos:prefLabel xml:lang="en">KANADEEP 2</skos:prefLabel>
    <skos:prefLabel xml:lang="es">KANADEEP 2</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">KANADEEP 2</skos:prefLabel>
    <skos:prefLabel xml:lang="it">KANADEEP 2</skos:prefLabel>
