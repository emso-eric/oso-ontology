    <skos:prefLabel xml:lang="el">δυτικό όριο γεωγραφικού μήκους</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#Ligurian_Sea">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Ligurian_Sea"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Mediterranean_Sea"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/French_Riviera"/>
    <dcterms:spatial rdf:resource="http://dbpedia.org/resource/Gulf_of_Lion"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/French_Riviera"/>
    <skos:closeMatch rdf:resource="http://dbpedia.org/resource/Gulf_of_Lion"/>
    <skos:exactMatch rdf:resource="https://www.wikidata.org/entity/Q182822"/>
    <OSO:RegionalFacility_is_part_of_a_RI rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO-France"/>
    <OSO:hasERICMembership rdf:resource="https://w3id.org/earthsemantics/OSO#Ligurian_Sea_EMSO_membership"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#DYFAMED"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#LION"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#BILLION"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#LO"/>
    <OSO:containsSite rdf:resource="https://w3id.org/earthsemantics/OSO#Nice"/>
    <OSO:hasBoundingBox rdf:resource="https://w3id.org/earthsemantics/OSO#Ligurian_Sea_RF_bbox"/>
    <OSO:hasRegionalTeamLeader rdf:resource="https://w3id.org/earthsemantics/OSO#Laurent_COPPOLA"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#CNRS"/>
    <OSO:isLedByOrganization rdf:resource="https://w3id.org/earthsemantics/OSO#Ifremer"/>
    <OSO:isLinkedToCampaignSeries rdf:resource="https://w3id.org/earthsemantics/OSO#EMSO_LIGURE_OUEST"/>
    <OSO:isLinkedToCampaignSeries rdf:resource="https://w3id.org/earthsemantics/OSO#MOOSE-GE"/>
    <OSO:isLinkedToCampaignSeries rdf:resource="https://w3id.org/earthsemantics/OSO#MUG-OBS"/>
    <schema1:url rdf:resource="https://www.emso-fr.org/"/>
    <schema1:url rdf:resource="https://www.emso-fr.org/fr/Ligure-Ouest"/>
    <rdfs:seeAlso rdf:resource="https://www.emso-fr.org/fr/Ligure-Ouest"/>
    <rdfs:seeAlso rdf:resource="https://emso.eu/observatories-node/ligurian-sea/"/>
    <rdfs:seeAlso rdf:resource="https://www.wikidata.org/wiki/Q182822"/>
    <OSO:dateFirstDeployment rdf:datatype="http://www.w3.org/2001/XMLSchema#date">1998-01-01</OSO:dateFirstDeployment>
    <skos:note xml:lang="en">Regional Facility associated with long-term multidisciplinary observation of the north-western Mediterranean Sea.</skos:note>
    <skos:note xml:lang="fr">Regional Facility associée à l’observation multidisciplinaire à long terme de la Méditerranée nord-occidentale.</skos:note>
    <skos:note xml:lang="it">Regional Facility associata all’osservazione multidisciplinare a lungo termine del Mediterraneo nord-occidentale.</skos:note>
    <skos:definition xml:lang="en">Regional Facility of EMSO-France dedicated to multidisciplinary marine observation in the Ligurian Sea and north-western Mediterranean region.</skos:definition>
    <skos:definition xml:lang="fr">Regional Facility d’EMSO-France dédiée à l’observation marine multidisciplinaire en mer Ligure et en Méditerranée nord-occidentale.</skos:definition>
    <skos:definition xml:lang="it">Regional Facility di EMSO-France dedicata all’osservazione marina multidisciplinare nel Mar Ligure e nel Mediterraneo nord-occidentale.</skos:definition>
    <rdfs:comment xml:lang="en">Regional Facility covering a broad north-western Mediterranean marine area, including the Ligurian Sea, the French Riviera, the Gulf of Lion, and the intermediate marine space.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Installation régionale couvrant une vaste zone marine du nord-ouest de la Méditerranée, incluant la mer Ligure, la Côte d’Azur, le golfe du Lion ainsi que l’espace marin intermédiaire.</rdfs:comment>
    <rdfs:comment xml:lang="it">Infrastruttura regionale che copre un’ampia area marina del Mediterraneo nord-occidentale, includendo il Mar Ligure, la Costa Azzurra, il Golfo del Leone e lo spazio marino intermedio.</rdfs:comment>
    <dcterms:description xml:lang="en">This Regional Facility covers an active seismic marine region characterized by a narrow and steep continental slope, alpine reliefs, submarine canyons, slope instability, strong atmospheric inputs, and significant implications for seismic hazard, tsunami risk, and marine biomass production.</dcterms:description>
    <dcterms:description xml:lang="fr">Cette installation régionale couvre une zone marine sismiquement active caractérisée par une pente continentale étroite et abrupte, des reliefs alpins, des canyons sous-marins, une instabilité des pentes, de fortes influences atmosphériques et des enjeux importants en matière de risques sismiques, de tsunamis et de production de biomasse marine.</dcterms:description>
    <dcterms:description xml:lang="it">Questa infrastruttura regionale copre una regione marina sismicamente attiva caratterizzata da una scarpata continentale stretta e ripida, rilievi alpini, canyon sottomarini, instabilità dei versanti, forti influenze atmosferiche e importanti implicazioni per il rischio sismico, gli tsunami e la produzione di biomassa marina.</dcterms:description>
    <rdfs:label xml:lang="en">Ligurian Sea</rdfs:label>
    <rdfs:label xml:lang="fr">Mer Ligure</rdfs:label>
    <rdfs:label xml:lang="es">Mar de Liguria</rdfs:label>
    <rdfs:label xml:lang="it">Mar Ligure</rdfs:label>
    <rdfs:label xml:lang="pt">Mar da Ligúria</rdfs:label>
    <rdfs:label xml:lang="ro">Marea Ligurică</rdfs:label>
    <rdfs:label xml:lang="el">Λιγουρική Θάλασσα</rdfs:label>
    <rdfs:label xml:lang="no">Liguriahavet</rdfs:label>
    <skos:prefLabel xml:lang="en">Ligurian Sea</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Mer Ligure</skos:prefLabel>
