  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#isERICMembershipOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="https://w3id.org/earthsemantics/OSO#ERICMembership"/>
    <rdfs:range rdf:resource="https://w3id.org/earthsemantics/OSO#RegionalFacility"/>
    <owl:inverseOf rdf:resource="https://w3id.org/earthsemantics/OSO#hasERICMembership"/>
    <skos:definition xml:lang="en">Relates an ERIC membership entity to the regional facility benefiting from or participating in the ERIC membership.</skos:definition>
    <skos:definition xml:lang="fr">Relie une entité d’adhésion ERIC à la regional facility bénéficiant ou participant à cette adhésion.</skos:definition>
    <skos:definition xml:lang="es">Relaciona una entidad de membresía ERIC con la infraestructura regional que participa o se beneficia de dicha membresía.</skos:definition>
    <skos:definition xml:lang="it">Collega un'entità di adesione ERIC alla infrastruttura regionale che partecipa o beneficia di tale adesione.</skos:definition>
    <skos:definition xml:lang="pt">Liga uma entidade de adesão ERIC à infraestrutura regional que participa ou beneficia dessa adesão.</skos:definition>
    <skos:definition xml:lang="no">Knytter en ERIC-medlemskapsenhet til den regionale infrastrukturen som deltar i eller drar nytte av medlemskapet.</skos:definition>
    <skos:definition xml:lang="ro">Leagă o entitate de apartenență ERIC de infrastructura regională care participă sau beneficiază de această apartenență.</skos:definition>
    <skos:definition xml:lang="el">Συνδέει μια οντότητα συμμετοχής ERIC με την περιφερειακή υποδομή που συμμετέχει ή επωφελείται από αυτήν τη συμμετοχή.</skos:definition>
    <rdfs:comment xml:lang="en">Links an ERIC membership entity to the regional facility concerned.</rdfs:comment>
    <rdfs:comment xml:lang="fr">Lie une entité d’adhésion ERIC à la regional facility concernée.</rdfs:comment>
    <rdfs:comment xml:lang="es">Relaciona una entidad de membresía ERIC con la infraestructura regional correspondiente.</rdfs:comment>
    <rdfs:comment xml:lang="it">Collega un'entità di adesione ERIC alla infrastruttura regionale corrispondente.</rdfs:comment>
    <rdfs:comment xml:lang="pt">Liga uma entidade de adesão ERIC à infraestrutura regional correspondente.</rdfs:comment>
    <rdfs:comment xml:lang="no">Knytter en ERIC-medlemskapsenhet til den aktuelle regionale infrastrukturen.</rdfs:comment>
    <rdfs:comment xml:lang="ro">Leagă o entitate de apartenență ERIC de infrastructura regională corespunzătoare.</rdfs:comment>
    <rdfs:comment xml:lang="el">Συνδέει μια οντότητα συμμετοχής ERIC με την αντίστοιχη περιφερειακή υποδομή.</rdfs:comment>
    <rdfs:label xml:lang="el">είναι συμμετοχή σε ERIC του</rdfs:label>
    <rdfs:label xml:lang="en">is ERIC membership of</rdfs:label>
    <rdfs:label xml:lang="es">es membresía en un ERIC de</rdfs:label>
    <rdfs:label xml:lang="fr">est une appartenance à un ERIC de</rdfs:label>
    <rdfs:label xml:lang="it">è appartenenza a un ERIC di</rdfs:label>
    <rdfs:label xml:lang="no">er medlemskap i et ERIC for</rdfs:label>
    <rdfs:label xml:lang="pt">é participação em um ERIC de</rdfs:label>
    <rdfs:label xml:lang="ro">este apartenență la un ERIC a</rdfs:label>
    <skos:prefLabel xml:lang="el">είναι συμμετοχή σε ERIC του</skos:prefLabel>
    <skos:prefLabel xml:lang="en">is ERIC membership of</skos:prefLabel>
    <skos:prefLabel xml:lang="es">es membresía en un ERIC de</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">est une appartenance à un ERIC de</skos:prefLabel>
    <skos:prefLabel xml:lang="it">è appartenenza a un ERIC di</skos:prefLabel>
    <skos:prefLabel xml:lang="no">er medlemskap i et ERIC for</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">é participação em um ERIC de</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">este apartenență la un ERIC a</skos:prefLabel>
  </rdf:Description>
