    <skos:altLabel xml:lang="en">Conductivity Temperature Depth</skos:altLabel>
    <skos:altLabel xml:lang="en">Conductivity-Temperature-Depth instrument</skos:altLabel>
    <skos:altLabel xml:lang="en">Conductivity Temperature Depth probe</skos:altLabel>
    <skos:altLabel xml:lang="fr">Sonde CTD</skos:altLabel>
    <skos:altLabel xml:lang="fr">Sonde Conductivité Température Profondeur</skos:altLabel>
    <skos:altLabel xml:lang="no">CTD-sonde</skos:altLabel>
    <skos:altLabel xml:lang="es">Sonda CTD</skos:altLabel>
    <skos:altLabel xml:lang="pt">Sonda CTD</skos:altLabel>
    <skos:altLabel xml:lang="it">Sonda CTD</skos:altLabel>
    <skos:definition xml:lang="en">An oceanographic instrument used to measure conductivity, temperature and pressure (depth) in seawater, often deployed together with water sampling bottles on a rosette system.</skos:definition>
    <skos:definition xml:lang="fr">Instrument océanographique utilisé pour mesurer la conductivité, la température et la pression (profondeur) dans l’eau de mer, souvent déployé avec des bouteilles de prélèvement sur une rosette océanographique.</skos:definition>
  </rdf:Description>
