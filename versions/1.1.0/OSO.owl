    <skos:prefLabel xml:lang="el">KASEAOPE</skos:prefLabel>
    <skos:prefLabel xml:lang="en">KASEAOPE</skos:prefLabel>
    <skos:prefLabel xml:lang="es">KASEAOPE</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">KASEAOPE</skos:prefLabel>
    <skos:prefLabel xml:lang="it">KASEAOPE</skos:prefLabel>
    <skos:prefLabel xml:lang="no">KASEAOPE</skos:prefLabel>
