    <skos:prefLabel xml:lang="en">CTD</skos:prefLabel>
    <skos:prefLabel xml:lang="es">CTD</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">CTD</skos:prefLabel>
    <skos:prefLabel xml:lang="it">CTD</skos:prefLabel>
    <skos:prefLabel xml:lang="no">CTD</skos:prefLabel>
