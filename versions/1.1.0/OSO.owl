    <skos:prefLabel xml:lang="el">Έργο RDFLib</skos:prefLabel>
    <skos:definition xml:lang="en">An open-source community maintaining the RDFLib framework for working with RDF data in Python.</skos:definition>
    <skos:definition xml:lang="fr">Une communauté open source assurant le développement et la maintenance du framework RDFLib pour manipuler des données RDF en Python.</skos:definition>
    <skos:definition xml:lang="es">Una comunidad de código abierto que desarrolla y mantiene el framework RDFLib para manipular datos RDF en Python.</skos:definition>
    <skos:definition xml:lang="it">Una comunità open source che sviluppa e mantiene il framework RDFLib per la gestione dei dati RDF in Python.</skos:definition>
    <skos:definition xml:lang="pt">Uma comunidade open source que desenvolve e mantém o framework RDFLib para manipulação de dados RDF em Python.</skos:definition>
    <skos:definition xml:lang="ro">O comunitate open-source care dezvoltă și întreține framework-ul RDFLib pentru manipularea datelor RDF în Python.</skos:definition>
    <skos:definition xml:lang="no">Et åpen kildekode-fellesskap som utvikler og vedlikeholder RDFLib-rammeverket for RDF-data i Python.</skos:definition>
    <skos:definition xml:lang="el">Μια κοινότητα ανοικτού κώδικα που αναπτύσσει και συντηρεί το πλαίσιο RDFLib για τη διαχείριση δεδομένων RDF στην Python.</skos:definition>
    <schema1:name>RDFLib Project</schema1:name>
    <schema1:url rdf:resource="https://github.com/RDFLib/rdflib"/>
    <schema1:logo rdf:resource="https://w3id.org/earthsemantics/OSO#RDFLibLogo"/>
    <dcterms:type xml:lang="en">Open-source software project</dcterms:type>
    <dcterms:type xml:lang="fr">Projet logiciel open source</dcterms:type>
    <dcterms:type xml:lang="es">Proyecto de software de código abierto</dcterms:type>
    <dcterms:type xml:lang="it">Progetto software open source</dcterms:type>
    <dcterms:type xml:lang="pt">Projeto de software open source</dcterms:type>
    <dcterms:type xml:lang="ro">Proiect software open-source</dcterms:type>
    <dcterms:type xml:lang="no">Programvareprosjekt med åpen kildekode</dcterms:type>
    <dcterms:type xml:lang="el">Έργο λογισμικού ανοικτού κώδικα</dcterms:type>
    <rdfs:seeAlso rdf:resource="https://github.com/RDFLib/rdflib"/>
