    <dcterms:title xml:lang="fr">Institut français de recherche pour l’exploitation de la mer</dcterms:title>
    <dcterms:title xml:lang="en">French National Institute for Ocean Science and Technology</dcterms:title>
    <dcterms:description xml:lang="en">Ifremer is the French national institute for ocean science and technology. It conducts research, provides expertise and shares marine data to improve knowledge of the ocean, protect marine environments, and support the sustainable management of marine resources and ecosystems.</dcterms:description>
    <dcterms:description xml:lang="fr">Ifremer est l’institut français de recherche pour l’exploitation de la mer. Il conduit des recherches, apporte de l’expertise et partage des données marines afin d’améliorer la connaissance de l’océan, de protéger les milieux marins et d’accompagner la gestion durable des ressources et des écosystèmes marins.</dcterms:description>
    <rdfs:label xml:lang="el">Ifremer</rdfs:label>
    <rdfs:label xml:lang="en">Ifremer</rdfs:label>
    <rdfs:label xml:lang="es">Ifremer</rdfs:label>
    <rdfs:label xml:lang="fr">Ifremer</rdfs:label>
    <rdfs:label xml:lang="it">Ifremer</rdfs:label>
    <rdfs:label xml:lang="no">Ifremer</rdfs:label>
    <rdfs:label xml:lang="pt">Ifremer</rdfs:label>
    <rdfs:label xml:lang="ro">Ifremer</rdfs:label>
    <skos:prefLabel xml:lang="el">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="en">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="es">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="fr">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="it">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="no">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="pt">Ifremer</skos:prefLabel>
    <skos:prefLabel xml:lang="ro">Ifremer</skos:prefLabel>
    <skos:altLabel xml:lang="en">IFREMER</skos:altLabel>
    <skos:altLabel xml:lang="fr">IFREMER</skos:altLabel>
    <skos:altLabel xml:lang="fr">Institut français de recherche pour l’exploitation de la mer</skos:altLabel>
    <skos:altLabel xml:lang="en">French National Institute for Ocean Science and Technology</skos:altLabel>
    <skos:altLabel xml:lang="en">French Research Institute for Exploitation of the Sea</skos:altLabel>
    <skos:definition xml:lang="en">French public research institute dedicated to ocean science, marine technology, marine data, ocean observation, biodiversity, fisheries, aquaculture and the sustainable management of marine resources and ecosystems.</skos:definition>
    <skos:definition xml:lang="fr">Institut public français de recherche dédié aux sciences et technologies de l’océan, aux données marines, à l’observation de l’océan, à la biodiversité, aux pêches, à l’aquaculture et à la gestion durable des ressources et des écosystèmes marins.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/earthsemantics/OSO#SeaMoNEast">
