    <skos:altLabel xml:lang="en">Laboratory of Informatics, Robotics and Microelectronics of Montpellier</skos:altLabel>
    <skos:altLabel xml:lang="fr">Laboratoire d'Informatique, de Robotique et de Microélectronique de Montpellier</skos:altLabel>
    <skos:altLabel xml:lang="es">Laboratorio de Informática, Robótica y Microelectrónica de Montpellier</skos:altLabel>
