###  https://w3id.org/earthsemantics/OSO#Atlantic_Whale_Deal
OSO:Atlantic_Whale_Deal
    rdf:type owl:NamedIndividual , OSO:FundedProject , cerif:Project , schema:Project ;
    # Metadata completeness: ~85% (recommended: 2/5 ; optional: 1/6).
