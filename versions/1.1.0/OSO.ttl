                                  "Distanța față de coastă exprimată în mile marine (NM)."@ro ,
                                  "Απόσταση από την ακτή εκφρασμένη σε ναυτικά μίλια (NM)."@el ;
                     rdfs:label "distance from land"@en ,
                                "distance à la côte"@fr ,
                                "distancia a la costa"@es ,
                                "distanza dalla costa"@it ,
                                "distância à costa"@pt ,
                                "avstand fra kysten"@no ,
                                "distanța față de coastă"@ro ,
                                "απόσταση από την ακτή"@el ;
                     skos:prefLabel "distance from land"@en ,
                                    "distance à la côte"@fr ,
                                    "distancia a la costa"@es ,
                                    "distanza dalla costa"@it ,
                                    "distância à costa"@pt ,
                                    "avstand fra kysten"@no ,
                                    "distanța față de coastă"@ro ,
