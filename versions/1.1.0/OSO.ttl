###  https://w3id.org/earthsemantics/OSO#RegionalFacility_is_linked_to_a_project
OSO:RegionalFacility_is_linked_to_a_project rdf:type owl:ObjectProperty ;
                                            rdfs:domain OSO:RegionalFacility ;
                                            rdfs:range OSO:ResearchProject ;
                                            skos:definition "Relates a regional facility to a research project with which it is associated."@en ,
                                                            "Relie une infrastructure régionale à un projet de recherche auquel elle est associée."@fr ,
                                                            "Relaciona una infraestructura regional con un proyecto de investigación al que está asociada."@es ,
                                                            "Collega un'infrastruttura regionale a un progetto di ricerca a cui è associata."@it ,
                                                            "Liga uma infraestrutura regional a um projeto de investigação ao qual está associada."@pt ,
                                                            "Knytter en regional infrastruktur til et forskningsprosjekt som den er tilknyttet."@no ,
                                                            "Leagă o infrastructură regională de un proiect de cercetare cu care este asociată."@ro ,
                                                            "Συνδέει μια περιφερειακή υποδομή με ένα ερευνητικό έργο με το οποίο σχετίζεται."@el ;
                                            rdfs:comment "Links a regional facility to a related research project."@en ,
                                                         "Lie une infrastructure régionale à un projet de recherche associé."@fr ,
                                                         "Relaciona una infraestructura regional con un proyecto de investigación asociado."@es ,
                                                         "Collega un'infrastruttura regionale a un progetto di ricerca associato."@it ,
                                                         "Liga uma infraestrutura regional a um projeto de investigação associado."@pt ,
                                                         "Knytter en regional infrastruktur til et tilknyttet forskningsprosjekt."@no ,
                                                         "Leagă o infrastructură regională de un proiect de cercetare asociat."@ro ,
                                                         "Συνδέει μια περιφερειακή υποδομή με ένα σχετικό ερευνητικό έργο."@el ;
                                            rdfs:label "Η περιφερειακή υποδομή συνδέεται με έργο"@el ,
                                                       "Regional Facility is linked to a project"@en ,
                                                       "La infraestructura regional está vinculada a un proyecto"@es ,
                                                       "L’infrastructure régionale est liée à un projet"@fr ,
                                                       "L'infrastruttura regionale è collegata a un progetto"@it ,
                                                       "Regional infrastruktur er knyttet til et prosjekt"@no ,
                                                       "A infraestrutura regional está ligada a um projeto"@pt ,
                                                       "Infrastructura regională este legată de un proiect"@ro ;
                                            skos:prefLabel "Η περιφερειακή υποδομή συνδέεται με έργο"@el ,
                                                           "Regional Facility is linked to a project"@en ,
                                                           "La infraestructura regional está vinculada a un proyecto"@es ,
                                                           "L’infrastructure régionale est liée à un projet"@fr ,
                                                           "L'infrastruttura regionale è collegata a un progetto"@it ,
                                                           "Regional infrastruktur er knyttet til et prosjekt"@no ,
                                                           "A infraestrutura regional está ligada a um projeto"@pt ,
