###  https://w3id.org/earthsemantics/OSO#RegionalFacility_is_part_of_a_RI
OSO:RegionalFacility_is_part_of_a_RI rdf:type owl:ObjectProperty ;
                                     rdfs:domain OSO:RegionalFacility ;
                                     rdfs:range OSO:ResearchInfrastructure ;
                                     owl:inverseOf OSO:hasRegionalFacility ;
                                     skos:definition "Relates a regional facility to the research infrastructure of which it is part."@en ,
                                                     "Relie une infrastructure régionale à l’infrastructure de recherche dont elle fait partie."@fr ,
                                                     "Relaciona una infraestructura regional con la infraestructura de investigación de la que forma parte."@es ,
                                                     "Collega un'infrastruttura regionale all'infrastruttura di ricerca di cui fa parte."@it ,
                                                     "Liga uma infraestrutura regional à infraestrutura de investigação da qual faz parte."@pt ,
                                                     "Knytter en regional infrastruktur til forskningsinfrastrukturen den er en del av."@no ,
                                                     "Leagă o infrastructură regională de infrastructura de cercetare din care face parte."@ro ,
                                                     "Συνδέει μια περιφερειακή υποδομή με την ερευνητική υποδομή της οποίας αποτελεί μέρος."@el ;
                                     rdfs:comment "Links a regional facility to its parent research infrastructure."@en ,
                                                  "Lie une infrastructure régionale à son infrastructure de recherche parente."@fr ,
                                                  "Relaciona una infraestructura regional con su infraestructura de investigación principal."@es ,
                                                  "Collega un'infrastruttura regionale alla sua infrastruttura di ricerca principale."@it ,
                                                  "Liga uma infraestrutura regional à sua infraestrutura de investigação principal."@pt ,
                                                  "Knytter en regional infrastruktur til dens overordnede forskningsinfrastruktur."@no ,
                                                  "Leagă o infrastructură regională de infrastructura sa principală de cercetare."@ro ,
                                                  "Συνδέει μια περιφερειακή υποδομή με τη μητρική της ερευνητική υποδομή."@el ;
                                     rdfs:label "Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής"@el ,
                                                "Regional Facility is part of a Research Infrastructure"@en ,
                                                "La infraestructura regional forma parte de una infraestructura de investigación"@es ,
                                                "L’infrastructure régionale fait partie d’une infrastructure de recherche"@fr ,
                                                "L'infrastruttura regionale fa parte di un'infrastruttura di ricerca"@it ,
                                                "Regional infrastruktur er del av en forskningsinfrastruktur"@no ,
                                                "A infraestrutura regional faz parte de uma infraestrutura de investigação"@pt ,
                                                "Infrastructura regională face parte dintr-o infrastructură de cercetare"@ro ;
                                     skos:prefLabel "Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής"@el ,
                                                    "Regional Facility is part of a Research Infrastructure"@en ,
                                                    "La infraestructura regional forma parte de una infraestructura de investigación"@es ,
                                                    "L’infrastructure régionale fait partie d’une infrastructure de recherche"@fr ,
                                                    "L'infrastruttura regionale fa parte di un'infrastruttura di ricerca"@it ,
                                                    "Regional infrastruktur er del av en forskningsinfrastruktur"@no ,
                                                    "A infraestrutura regional faz parte de uma infraestrutura de investigação"@pt ,
                                                    "Infrastructura regională face parte dintr-o infrastructură de cercetare"@ro .

###  https://w3id.org/earthsemantics/OSO#RegionalFacility_is_related_to_RI
OSO:RegionalFacility_is_related_to_RI rdf:type owl:ObjectProperty ;
                                      rdfs:domain OSO:RegionalFacility ;
                                      rdfs:range OSO:ResearchInfrastructure ;
                                      skos:definition "Relates a regional facility to a research infrastructure with which it has an association, without necessarily being formally part of it."@en ,
                                                      "Relie une infrastructure régionale à une infrastructure de recherche avec laquelle elle possède une association, sans nécessairement en faire formellement partie."@fr ,
                                                      "Relaciona una infraestructura regional con una infraestructura de investigación con la que mantiene una asociación, sin formar necesariamente parte formal de ella."@es ,
                                                      "Collega un'infrastruttura regionale a un'infrastruttura di ricerca con cui ha un'associazione, senza necessariamente farne formalmente parte."@it ,
                                                      "Liga uma infraestrutura regional a uma infraestrutura de investigação com a qual possui uma associação, sem necessariamente fazer formalmente parte dela."@pt ,
                                                      "Knytter en regional infrastruktur til en forskningsinfrastruktur som den har en tilknytning til, uten nødvendigvis å være formelt en del av den."@no ,
                                                      "Leagă o infrastructură regională de o infrastructură de cercetare cu care are o asociere, fără a face neapărat parte oficial din aceasta."@ro ,
                                                      "Συνδέει μια περιφερειακή υποδομή με μια ερευνητική υποδομή με την οποία έχει σχέση, χωρίς απαραίτητα να αποτελεί επίσημα μέρος της."@el ;
                                      rdfs:comment "A regional facility may be related to one or more research infrastructures without a formal part-whole relationship."@en ,
                                                   "Une infrastructure régionale peut être liée à une ou plusieurs infrastructures de recherche sans relation formelle de composition."@fr ,
                                                   "Una infraestructura regional puede estar relacionada con una o varias infraestructuras de investigación sin una relación formal de pertenencia."@es ,
                                                   "Un'infrastruttura regionale può essere collegata a una o più infrastrutture di ricerca senza una relazione formale di appartenenza."@it ,
                                                   "Uma infraestrutura regional pode estar relacionada com uma ou mais infraestruturas de investigação sem uma relação formal de pertença."@pt ,
                                                   "En regional infrastruktur kan være knyttet til en eller flere forskningsinfrastrukturer uten et formelt del-forhold."@no ,
                                                   "O infrastructură regională poate fi legată de una sau mai multe infrastructuri de cercetare fără o relație formală de apartenență."@ro ,
                                                   "Μια περιφερειακή υποδομή μπορεί να σχετίζεται με μία ή περισσότερες ερευνητικές υποδομές χωρίς επίσημη σχέση μέρους-όλου."@el ;
                                      rdfs:label "Η περιφερειακή υποδομή σχετίζεται με ερευνητική υποδομή"@el ,
                                                 "Regional Facility is related to a Research Infrastructure"@en ,
                                                 "La infraestructura regional está relacionada con una infraestructura de investigación"@es ,
                                                 "L’infrastructure régionale est liée à une infrastructure de recherche"@fr ,
                                                 "L'infrastruttura regionale è collegata a un'infrastruttura di ricerca"@it ,
                                                 "Regional infrastruktur er relatert til en forskningsinfrastruktur"@no ,
                                                 "A infraestrutura regional está relacionada com uma infraestrutura de investigação"@pt ,
                                                 "Infrastructura regională este legată de o infrastructură de cercetare"@ro ;
                                      skos:prefLabel "Η περιφερειακή υποδομή σχετίζεται με ερευνητική υποδομή"@el ,
                                                     "Regional Facility is related to a Research Infrastructure"@en ,
                                                     "La infraestructura regional está relacionada con una infraestructura de investigación"@es ,
                                                     "L’infrastructure régionale est liée à une infrastructure de recherche"@fr ,
                                                     "L'infrastruttura regionale è collegata a un'infrastruttura di ricerca"@it ,
                                                     "Regional infrastruktur er relatert til en forskningsinfrastruktur"@no ,
                                                     "A infraestrutura regional está relacionada com uma infraestrutura de investigação"@pt ,
                                                     "Infrastructura regională este legată de o infrastructură de cercetare"@ro .

