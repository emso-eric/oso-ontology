                                          "Μια πλατφόρμα μπορεί να έχει κανέναν, έναν ή περισσότερους κύριους ερευνητές."@el ;
                             rdfs:label "has Principal Investigator"@en ,
                                        "a pour responsable scientifique"@fr ,
                                        "tiene investigador principal"@es ,
                                        "ha Principal Investigator"@it ,
                                        "tem investigador principal"@pt ,
                                        "har hovedansvarlig forsker"@no ,
                                        "are investigator principal"@ro ,
                                        "έχει κύριο ερευνητή"@el ;
                             skos:prefLabel "has Principal Investigator"@en ,
