### https://w3id.org/earthsemantics/OSO#OFAIRe
OSO:OFAIRe
    rdf:type owl:NamedIndividual ,
             OSO:FAIRAssessmentTool ,
             schema:WebApplication ;
    schema:name "Ontology FAIRness Evaluator (O'FAIRe)" ;
    schema:alternateName "O'FAIRe" ;
    schema:sameAs <https://www.wikidata.org/entity/Q124653420> ;
    rdfs:label
        "O'FAIRe"@en ,
