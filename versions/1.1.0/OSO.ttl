###  https://w3id.org/earthsemantics/OSO#hasSpatialExtent
OSO:hasSpatialExtent rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf geosparql:hasGeometry ;
                     rdfs:domain OSO:FundedProject ;
                     rdfs:range OSO:BoundingBox ;
                     owl:inverseOf OSO:isSpatialExtentOf ;
                     rdfs:comment "Relates a funded project to its geographical extent, such as a bounding box or spatial coverage."@en ,
                                  "Relie un projet financé à son emprise géographique, comme une boîte englobante ou une zone de couverture."@fr ,
                                  "Relaciona un proyecto financiado con su extensión geográfica, como una caja envolvente o una zona de cobertura."@es ,
                                  "Collega un progetto finanziato alla sua estensione geografica, come un riquadro di delimitazione o un'area di copertura."@it ,
                                  "Relaciona um projeto financiado com a sua extensão geográfica, como uma caixa delimitadora ou uma área de cobertura."@pt ,
                                  "Knytter et finansiert prosjekt til dets geografiske utstrekning, for eksempel en avgrensningsboks eller et dekningsområde."@no ,
                                  "Leagă un proiect finanțat de extinderea sa geografică, cum ar fi o bounding box sau o zonă de acoperire."@ro ,
                                  "Συνδέει ένα χρηματοδοτούμενο έργο με τη γεωγραφική του έκταση, όπως ένα οριοθετημένο πλαίσιο ή μια περιοχή κάλυψης."@el ;
                     rdfs:label "has spatial extent"@en ,
                                "a une emprise spatiale"@fr ,
                                "tiene extensión espacial"@es ,
                                "ha estensione spaziale"@it ,
                                "tem extensão espacial"@pt ,
                                "har romlig utstrekning"@no ,
                                "are extindere spațială"@ro ,
                                "έχει χωρική έκταση"@el ;
                     skos:prefLabel "has spatial extent"@en ,
                                    "a une emprise spatiale"@fr ,
                                    "tiene extensión espacial"@es ,
                                    "ha estensione spaziale"@it ,
                                    "tem extensão espacial"@pt ,
                                    "har romlig utstrekning"@no ,
                                    "are extindere spațială"@ro ,
                                    "έχει χωρική έκταση"@el .

###  https://w3id.org/earthsemantics/OSO#Planned
OSO:Planned rdf:type owl:NamedIndividual ,
                     OSO:Status ,
                     skos:Concept ;
            rdfs:label "Σχεδιαζόμενο"@el ,
                       "Planned"@en ,
                       "Planificado"@es ,
                       "Planifié"@fr ,
                       "Pianificato"@it ,
                       "Planlagt"@no ,
                       "Planeado"@pt ,
                       "Planificat"@ro ;
            skos:prefLabel "Σχεδιαζόμενο"@el ,
                           "Planned"@en ,
                           "Planificado"@es ,
                           "Planifié"@fr ,
                           "Pianificato"@it ,
                           "Planlagt"@no ,
                           "Planeado"@pt ,
                           "Planificat"@ro ;
            skos:altLabel "Future site"@en ,
                          "Site futur"@fr ,
                          "Sítio futuro"@pt ;
            skos:definition "A site that is planned but not yet deployed or operational."@en ,
                            "Un site planifié mais non encore déployé ni opérationnel."@fr ,
                            "Um sítio planeado mas ainda não implantado nem operacional."@pt ,
                            "Un sitio que está planificado pero aún no desplegado ni operativo."@es ,
                            "Un sito pianificato ma non ancora implementato né operativo."@it ,
                            "Et sted som er planlagt, men ennå ikke utplassert eller i drift."@no ,
                            "Un sit planificat, dar încă nedesfășurat sau operațional."@ro ,
                            "Σχεδιαζόμενο: τόπος που έχει προγραμματιστεί αλλά δεν έχει ακόμη αναπτυχθεί ή λειτουργήσει."@el ;
            skos:note "Used to describe planned EMSO sites or infrastructures that are not yet operational."@en ,
                      "Utilisé pour décrire des sites ou infrastructures EMSO en projet et non encore opérationnels."@fr ,
                      "Utilizado para describir sitios o infraestructuras EMSO planificados que aún no están operativos."@es ,
                      "Utilizzato per descrivere siti o infrastrutture EMSO pianificati ma non ancora operativi."@it ,
                      "Brukes til å beskrive planlagte EMSO-steder eller infrastrukturer som ennå ikke er i drift."@no ,
                      "Utilizado para descrever sítios ou infraestruturas EMSO planeadas que ainda não estão operacionais."@pt ,
                      "Utilizat pentru a descrie situri sau infrastructuri EMSO planificate care nu sunt încă operaționale."@ro ,
                      "Χρησιμοποιείται για την περιγραφή σχεδιαζόμενων τοποθεσιών ή υποδομών EMSO που δεν είναι ακόμη λειτουργικές."@el .

