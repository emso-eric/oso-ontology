###  https://w3id.org/earthsemantics/OSO#Platform
OSO:Platform rdf:type owl:Class ;
             rdfs:subClassOf OSO:Subsite ;
             metadata:prefixIRI "OSO:Platform" ;
             dcterms:source <http://vocab.nerc.ac.uk/collection/L06/current/> ;
             rdfs:seeAlso <http://vocab.nerc.ac.uk/collection/L06/current/> ;
             rdfs:comment "An observation platform, fixed or mobile, installed on a site or subsite, supporting one or more instruments or acquisition systems."@en ,
                          "En observasjonsplattform, fast eller mobil, installert på et sted eller underområde, som støtter ett eller flere instrumenter eller innhentingssystemer."@no ,
                          "O platformă de observație, fixă sau mobilă, instalată într-un site sau subsite, care suportă unul sau mai multe instrumente sau sisteme de achiziție."@ro ,
                          "Uma plataforma de observação, fixa ou móvel, instalada num local ou sublocal, suportando um ou mais instrumentos ou sistemas de aquisição."@pt ,
                          "Una piattaforma di osservazione, fissa o mobile, installata su un sito o sotto-sito, che supporta uno o più strumenti o sistemi di acquisizione."@it ,
                          "Una plataforma de observación, fija o móvil, instalada en un sitio o sub-sitio, que soporta uno o más instrumentos o sistemas de adquisición."@es ,
                          "Une plateforme d'observation fixe ou mobile, installée sur un site ou un sous-site, supportant un ou plusieurs instruments ou systèmes d'acquisition."@fr ,
                          "Μια πλατφόρμα παρατήρησης, σταθερή ή κινητή, εγκατεστημένη σε έναν τόπο ή υποτοποθεσία, υποστηρίζοντας ένα ή περισσότερα όργανα ή συστήματα συλλογής δεδομένων."@el ;
             rdfs:label "Observasjonsplattform"@no ,
                        "Observation Platform"@en ,
                        "Piattaforma di osservazione"@it ,
                        "Plataforma de observación"@es ,
                        "Plataforma de observação"@pt ,
                        "Plateforme d'observation"@fr ,
                        "Platformă de observație"@ro ,
                        "Πλατφόρμα παρατήρησης"@el ;
             skos:prefLabel "Observasjonsplattform"@no ,
                            "Observation Platform"@en ,
                            "Piattaforma di osservazione"@it ,
                            "Plataforma de observación"@es ,
                            "Plataforma de observação"@pt ,
                            "Plateforme d'observation"@fr ,
                            "Platformă de observație"@ro ,
                            "Πλατφόρμα παρατήρησης"@el .
###  https://w3id.org/earthsemantics/OSO#RegionalFacility
OSO:RegionalFacility rdf:type owl:Class ;
                     rdfs:subClassOf owl:Thing ;
                     metadata:prefixIRI "OSO:RegionalFacility" ;
                     skos:closeMatch sweetHumanResearch:Observatory ;
                     rdfs:seeAlso <http://sweetontology.net/humanResearch/> ;
                     rdfs:comment "A regional facility containing sites, associated with research infrastructures, oceanographic campaigns, organizations, and a Regional Team Leader."@en ,
                                  "Infraestructura regional que contiene sitios, asociada a infraestructuras de investigación, campañas oceanográficas, organizaciones y un líder de equipo regional."@es ,
                                  "Infraestrutura regional que contém locais, associada a infraestruturas de investigação, campanhas oceanográficas, organizações e um líder regional."@pt ,
                                  "Infrastructură regională care conține site-uri, asociată cu infrastructuri de cercetare, campanii oceanografice, organizații și un lider de echipă regional."@ro ,
                                  "Infrastruttura regionale contenente siti, associata a infrastrutture di ricerca, campagne oceanografiche, organizzazioni e un coordinatore regionale."@it ,
                                  "Regional fasilitet som inneholder lokaliteter, tilknyttet forskningsinfrastrukturer, havkampanjer, organisasjoner og en regionalt ansvarlig."@no ,
                                  "Un nœud régional comprenant plusieurs sites, lié à des infrastructures de recherche, des campagnes océanographiques, des organisations et un coordinateur régional."@fr ,
                                  "Περιφερειακή υποδομή που περιλαμβάνει τοποθεσίες, συνδέεται με ερευνητικές υποδομές, ωκεανογραφικές εκστρατείες, οργανισμούς και έναν υπεύθυνο ομάδας."@el ;
                     rdfs:label "Infraestructura regional"@es ,
                                "Infraestrutura regional"@pt ,
                                "Infrastructură regională"@ro ,
                                "Infrastruttura regionale"@it ,
                                "Nœud régional"@fr ,
                                "Regional Facility"@en ,
                                "Regional fasilitet"@no ,
                                "Περιφερειακή υποδομή"@el ;
                     skos:prefLabel "Infraestructura regional"@es ,
                                    "Infraestrutura regional"@pt ,
                                    "Infrastructură regională"@ro ,
                                    "Infrastruttura regionale"@it ,
                                    "Nœud régional"@fr ,
                                    "Regional Facility"@en ,
                                    "Regional fasilitet"@no ,
                                    "Περιφερειακή υποδομή"@el ;
                     skos:altLabel "EMSO Regional Facility"@en ,
                                   "European Multidisciplinary Seafloor and Water Column Observatory Regional Facility"@en ,
                                   "EMSO regional observatory node"@en ,
                                   "Regional marine observatory"@en ,
                                   "Infrastructure régionale EMSO"@fr ,
                                   "Nœud régional EMSO"@fr ;
                     skos:definition "A multidisciplinary marine research infrastructure dedicated to long-term observation of the seafloor and water column."@en ,
                                     "Une infrastructure de recherche marine multidisciplinaire dédiée à l’observation à long terme du plancher océanique et de la colonne d’eau."@fr .
###  https://w3id.org/earthsemantics/OSO#ResearchInfrastructure
OSO:ResearchInfrastructure rdf:type owl:Class ;
                           rdfs:subClassOf foaf:Organization ,
                                           cerif:Organisation ;
                           metadata:prefixIRI "OSO:ResearchInfrastructure" ;
                           rdfs:comment "Μια ερευνητική υποδομή μπορεί να συγκεντρώνει μία ή περισσότερες Περιφερειακές Εγκαταστάσεις."@el ,
                                        "A research infrastructure may bring together one or more Regional Facilities."@en ,
                                        "Una infraestructura de investigación puede reunir una o más Instalaciones Regionales."@es ,
                                        "Une infrastructure de recherche peut regrouper une ou plusieurs installations régionales."@fr ,
                                        "Una infrastruttura di ricerca può riunire una o più Strutture Regionali."@it ,
                                        "En forskningsinfrastruktur kan samle én eller flere regionale fasiliteter."@no ,
                                        "Uma infraestrutura de investigação pode reunir uma ou mais Instalações Regionais."@pt ,
                                        "O infrastructură de cercetare poate reuni una sau mai multe facilități regionale."@ro ;
                           rdfs:label "Ερευνητική Υποδομή"@el ,
                                      "Research Infrastructure"@en ,
                                      "Infraestructura de Investigación"@es ,
                                      "Infrastructure de recherche"@fr ,
                                      "Infrastruttura di Ricerca"@it ,
                                      "Forskningsinfrastruktur"@no ,
                                      "Infraestrutura de Investigação"@pt ,
                                      "Infrastructură de cercetare"@ro ;
                           skos:definition "The following definition for RI from Article 2 (6) of the Regulation (EU) No 1291/2013 of 11 December 2013: `Establishing Horizon 2020 - the Framework Programme for Research and Innovation (2014-2020)` applies: “RI are facilities, resources and services that are used by the research communities to conduct research and foster innovation in their fields. They include: major scientific equipment (or sets of instruments), knowledge-based resources such as collections, archives and scientific data, e-infrastructures, such as data and computing systems and communication networks and any other tools that are essential to achieve excellence in research and innovation.” Accordingly, RI are implemented along different organisational models, including central sources and laboratories for experiments and measurement sessions, coordination and management of geographically distributed observatories or laboratories, remotely accessible resources for computing, data banks, physical sample repositories, surveys and longitudinal studies."@en ;
                           skos:note "ΕΥ"@el ,
                                     "RI"@en ,
                                     "IIdI"@es ,
                                     "IR"@fr ,
                                     "IR"@it ,
                                     "FI"@no ,
                                     "II"@pt ,
                                     "IC"@ro ;
                           skos:prefLabel "Ερευνητική Υποδομή"@el ,
                                          "Research Infrastructure"@en ,
                                          "Infraestructura de Investigación"@es ,
                                          "Infrastructure de recherche"@fr ,
                                          "Infrastruttura di Ricerca"@it ,
                                          "Forskningsinfrastruktur"@no ,
                                          "Infraestrutura de Investigação"@pt ,
                                          "Infrastructură de cercetare"@ro .
###  https://w3id.org/earthsemantics/OSO#ResearchProject
OSO:ResearchProject rdf:type owl:Class ;
                    rdfs:subClassOf foaf:Project ;
                    rdfs:label "Ερευνητικό έργο"@el ,
                               "Research project"@en ,
                               "Proyecto de investigación"@es ,
                               "Projet de recherche"@fr ,
                               "Progetto di ricerca"@it ,
                               "Forskningsprosjekt"@no ,
                               "Projeto de investigação"@pt ,
                               "Proiect de cercetare"@ro ;
                    rdfs:comment 
                               "Επιστημονική δραστηριότητα με σαφή δομή που αποσκοπεί στην παραγωγή νέας γνώσης, δεδομένων ή κατανόησης, εντός καθορισμένου πλαισίου και διάρκειας."@el ,
                               "A structured scientific activity designed to produce new knowledge, data, or understanding within a defined scope and duration."@en ,
                               "Una actividad científica estructurada destinada a producir nuevo conocimiento, datos o comprensión dentro de un alcance y una duración definidos."@es ,
                               "Une activité scientifique structurée visant à produire de nouvelles connaissances, données ou compréhensions dans un périmètre et une durée définis."@fr ,
                               "Un'attività scientifica strutturata progettata per produrre nuova conoscenza, dati o comprensione entro un ambito e una durata definiti."@it ,
                               "En strukturert vitenskapelig aktivitet som har som mål å produsere ny kunnskap, data eller forståelse innenfor et definert omfang og tidsrom."@no ,
                               "Uma atividade científica estruturada concebida para produzir novo conhecimento, dados ou compreensão dentro de um âmbito e duração definidos."@pt ,
                               "O activitate științifică structurată destinată să producă noi cunoștințe, date sau înțelegere într-un cadru și o durată definite."@ro .
###  https://w3id.org/earthsemantics/OSO#SeriesOfOceanographicCampaigns
OSO:SeriesOfOceanographicCampaigns rdf:type owl:Class ;
                                   rdfs:subClassOf owl:Thing ;
                                   rdfs:seeAlso OSO:OceanographicCampaign ;
                                   metadata:prefixIRI "omv:SeriesOfOceanographicCampaigns" ;
                                   rdfs:comment "A thematic or temporal grouping of related oceanographic campaigns linked to a Regional Facility."@en ,
                                                "En tematisk eller tidsmessig gruppering av relaterte havforskningskampanjer knyttet til en regional infrastruktur."@no ,
                                                "O grupare tematică sau temporală de campanii oceanografice asociate unei infrastructuri regionale."@ro ,
                                                "Um agrupamento temático ou temporal de campanhas oceanográficas relacionadas, associado a uma infraestrutura regional."@pt ,
                                                "Una agrupación temática o temporal de campañas oceanográficas relacionadas, vinculada a una instalación regional."@es ,
                                                "Un raggruppamento tematico o temporale di campagne oceanografiche correlate, collegato a una struttura regionale."@it ,
                                                "Un regroupement thématique ou temporel de campagnes océanographiques liées à un noeud régional."@fr ,
                                                "Μια θεματική ή χρονική ομαδοποίηση συναφών ωκεανογραφικών εκστρατειών που συνδέεται με μια περιφερειακή υποδομή."@el ;
                                   rdfs:label "Serie de campanii oceanografice"@ro ,
                                              "Serie de campañas oceanográficas"@es ,
                                              "Serie di campagne oceanografiche"@it ,
                                              "Serie med havforskningskampanjer"@no ,
                                              "Series of Oceanographic Campaigns"@en ,
                                              "Série de campagnes océanographiques"@fr ,
                                              "Série de campanhas oceanográficas"@pt ,
                                              "Σειρά ωκεανογραφικών εκστρατειών"@el ;
                                   skos:prefLabel "Serie de campanii oceanografice"@ro ,
                                                  "Serie de campañas oceanográficas"@es ,
                                                  "Serie di campagne oceanografiche"@it ,
                                                  "Serie med havforskningskampanjer"@no ,
                                                  "Series of Oceanographic Campaigns"@en ,
                                                  "Série de campagnes océanographiques"@fr ,
                                                  "Série de campanhas oceanográficas"@pt ,
                                                  "Σειρά ωκεανογραφικών εκστρατειών"@el .
###  https://w3id.org/earthsemantics/OSO#Site
OSO:Site rdf:type owl:Class ;
         rdfs:subClassOf OSO:RegionalFacility ;
         metadata:prefixIRI "OSO:Site" ;
         skos:closeMatch sweetRealmOcean:OceanRegion ;
         rdfs:seeAlso <http://sweetontology.net/realmOcean/> ;
         rdfs:comment "A localized observatory site, attached to a regional facility, potentially hosting one or more measurement platforms."@en ,
                      "Et lokalisert observasjonssted tilknyttet en regional fasilitet, som potensielt huser en eller flere måleplattformer."@no ,
                      "Um local de observação localizado, associado a uma infraestrutura regional, podendo acolher uma ou mais plataformas de medição."@pt ,
                      "Un site observatoire localisé, rattaché à un nœud régional, pouvant accueillir une ou plusieurs plateformes de mesure."@fr ,
                      "Un site observator localizat, asociat cu o facilitate regională, care poate găzdui una sau mai multe platforme de măsurare."@ro ,
                      "Un sitio de observación localizado, vinculado a una infraestructura regional, que puede albergar una o más plataformas de medición."@es ,
                      "Un sito osservatorio localizzato, collegato a una struttura regionale, che può ospitare una o più piattaforme di misura."@it ,
                      "Ένας τοπικός τόπος παρατήρησης, συνδεδεμένος με μια περιφερειακή υποδομή, που μπορεί να φιλοξενήσει μία ή περισσότερες πλατφόρμες μέτρησης."@el ;
         rdfs:label "Loc de observare"@ro ,
                    "Local de observação"@pt ,
                    "Observasjonssted"@no ,
                    "Observatory Site"@en ,
                    "Site d'observation"@fr ,
                    "Sitio de observación"@es ,
                    "Sito di osservazione"@it ,
                    "Τόπος παρατήρησης"@el ;
         skos:prefLabel "Loc de observare"@ro ,
                        "Local de observação"@pt ,
                        "Observasjonssted"@no ,
                        "Observatory Site"@en ,
                        "Site d'observation"@fr ,
                        "Sitio de observación"@es ,
                        "Sito di osservazione"@it ,
                        "Τόπος παρατήρησης"@el .
###  https://w3id.org/earthsemantics/OSO#SubPlatform
OSO:SubPlatform rdf:type owl:Class ;
                rdfs:subClassOf OSO:Platform ;
                metadata:prefixIRI "OSO:SubPlatform" ;
                rdfs:comment "An observation subplatform, a component or specific segment of a platform, dedicated to a particular type of measurement or instrumental configuration."@en ,
                             "En underplattform for observasjon, en komponent eller spesifikt segment av en plattform, dedikert til en bestemt måletype eller instrumentkonfigurasjon."@no ,
                             "O subplatformă de observație, componentă sau segment specific al unei platforme, dedicată unui tip particular de măsurare sau configurație instrumentală."@ro ,
                             "Uma subplataforma de observação, componente ou segmento específico de uma plataforma, dedicada a um tipo particular de medição ou configuração instrumental."@pt ,
                             "Una sotto-piattaforma di osservazione, componente o segmento specifico di una piattaforma, dedicata a un tipo particolare di misurazione o configurazione strumentale."@it ,
                             "Una subplataforma de observación, componente o segmento específico de una plataforma, dedicada a un tipo particular de medición o configuración instrumental."@es ,
                             "Une sous-plateforme d'observation, élément constitutif ou segment spécifique d'une plateforme, dédiée à un type particulier de mesure ou de configuration instrumentale."@fr ,
                             "Μια υποπλατφόρμα παρατήρησης, συστατικό ή συγκεκριμένο τμήμα μιας πλατφόρμας, αφιερωμένη σε έναν συγκεκριμένο τύπο μέτρησης ή οργανολογικής διάταξης."@el ;
                rdfs:label "Observation Subplatform"@en ,
                           "Sotto-piattaforma di osservazione"@it ,
                           "Sous-plateforme d'observation"@fr ,
                           "Subplataforma de observación"@es ,
                           "Subplataforma de observação"@pt ,
                           "Subplatformă de observație"@ro ,
                           "Underplattform for observasjon"@no ,
                           "Υποπλατφόρμα παρατήρησης"@el ;
                skos:prefLabel "Observation Subplatform"@en ,
                               "Sotto-piattaforma di osservazione"@it ,
                               "Sous-plateforme d'observation"@fr ,
                               "Subplataforma de observación"@es ,
                               "Subplataforma de observação"@pt ,
                               "Subplatformă de observație"@ro ,
                               "Underplattform for observasjon"@no ,
                               "Υποπλατφόρμα παρατήρησης"@el .
###  https://w3id.org/earthsemantics/OSO#Subsite
OSO:Subsite rdf:type owl:Class ;
            rdfs:subClassOf OSO:Site ;
            metadata:prefixIRI "OSO:Subsite" ;
            rdfs:comment "A subsite of observation, a finer component of a site, enabling increased spatial granularity for measurement or instrumentation."@en ,
                         "Et delområde for observasjon, en finere komponent av et sted, som muliggjør økt romlig granularitet for måling eller instrumentering."@no ,
                         "Um sublocal de observação, componente mais detalhado de um site, permitindo maior granularidade espacial para medições ou instrumentação."@pt ,
                         "Un sotto-sito di osservazione, componente più fine di un sito, che consente una maggiore granularità spaziale per le misurazioni o la strumentazione."@it ,
                         "Un sous-site d'observation, composante plus fine d’un site, qui permet une granularité spatiale accrue pour la mesure ou l'instrumentation."@fr ,
                         "Un sub-site de observație, componentă mai detaliată a unui site, care permite o granularitate spațială crescută pentru măsurători sau instrumentare."@ro ,
                         "Un sub-sitio de observación, componente más detallado de un sitio, que permite una mayor granularidad espacial para mediciones o instrumentación."@es ,
                         "Μια υποτοποθεσία παρατήρησης, λεπτότερο συστατικό ενός τόπου, που επιτρέπει αυξημένη χωρική ανάλυση για μέτρηση ή οργανολογία."@el ;
            rdfs:label "Delområde for observasjon"@no ,
                       "Observation Subsite"@en ,
                       "Sotto-sito di osservazione"@it ,
                       "Sous-site d'observation"@fr ,
                       "Sub-site de observație"@ro ,
                       "Sub-sitio de observación"@es ,
                       "Sublocal de observação"@pt ,
                       "Υποτοποθεσία παρατήρησης"@el ;
            skos:prefLabel "Delområde for observasjon"@no ,
                           "Observation Subsite"@en ,
                           "Sotto-sito di osservazione"@it ,
                           "Sous-site d'observation"@fr ,
                           "Sub-site de observație"@ro ,
                           "Sub-sitio de observación"@es ,
                           "Sublocal de observação"@pt ,
                           "Υποτοποθεσία παρατήρησης"@el .


##################################################################################################################################
# 05. REGIONAL FACILITIES
##################################################################################################################################
###  https://w3id.org/earthsemantics/OSO#Azores
OSO:Azores rdf:type owl:NamedIndividual ,
                    OSO:RegionalFacility ;
           OSO:RegionalFacility_is_part_of_a_RI OSO:EMSO-France ;
           OSO:hasERICMembership OSO:Azores_EMSO_membership ;
