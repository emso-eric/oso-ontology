###  https://w3id.org/earthsemantics/OSO#isCountryOf
OSO:isCountryOf rdf:type owl:ObjectProperty ;
                rdfs:domain <http://dbpedia.org/ontology/Country> ;
                rdfs:range foaf:Organization ,
                            OSO:RegionalFacility ,
                            OSO:ResearchInfrastructure ;
                owl:inverseOf OSO:hasCountry ;
                rdfs:comment "Links a country to an associated organisation or research infrastructure."@en ,
                             "Lie un pays à une organisation ou infrastructure de recherche associée."@fr ,
                             "Relaciona un país con una organización o infraestructura de investigación asociada."@es ,
                             "Collega un paese a un'organizzazione o infrastruttura di ricerca associata."@it ,
                             "Liga um país a uma organização ou infraestrutura de investigação associada."@pt ,
                             "Knytter et land til en tilhørende organisasjon eller forskningsinfrastruktur."@no ,
                             "Leagă o țară de o organizație sau infrastructură de cercetare asociată."@ro ,
                             "Συνδέει μια χώρα με έναν σχετικό οργανισμό ή ερευνητική υποδομή."@el ;
                rdfs:label "είναι χώρα του"@el ,
