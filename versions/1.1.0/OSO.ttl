###  https://w3id.org/earthsemantics/OSO#hasROR
OSO:hasROR rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain foaf:Organization ;
           rdfs:range xsd:anyURI ;
           skos:definition "Relates an organisation to its ROR (Research Organization Registry) identifier."@en ,
                           "Relie une organisation à son identifiant ROR (Research Organization Registry)."@fr ,
                           "Relaciona una organización con su identificador ROR (Research Organization Registry)."@es ,
                           "Collega un'organizzazione al suo identificatore ROR (Research Organization Registry)."@it ,
                           "Liga uma organização ao seu identificador ROR (Research Organization Registry)."@pt ,
                           "Knytter en organisasjon til dens ROR-identifikator (Research Organization Registry)."@no ,
                           "Leagă o organizație de identificatorul său ROR (Research Organization Registry)."@ro ,
                           "Συνδέει έναν οργανισμό με το αναγνωριστικό ROR (Research Organization Registry)."@el ;
           rdfs:comment "This property links an Organisation to its ROR (Research Organization Registry) identifier."@en ,
                        "Cette propriété relie une organisation à son identifiant ROR (Research Organization Registry)."@fr ,
                        "Esta propiedad vincula una Organización con su identificador ROR (Research Organization Registry)."@es ,
                        "Questa proprietà collega un'Organizzazione al suo identificatore ROR (Research Organization Registry)."@it ,
                        "Esta propriedade liga uma Organização ao seu identificador ROR (Research Organization Registry)."@pt ,
                        "Denne egenskapen kobler en organisasjon til dens ROR-identifikator (Research Organization Registry)."@no ,
                        "Această proprietate leagă o organizație de identificatorul său ROR (Research Organization Registry)."@ro ,
                        "Αυτή η ιδιότητα συνδέει έναν Οργανισμό με το αναγνωριστικό ROR (Research Organization Registry)."@el ;
           rdfs:label "έχει ROR"@el ,
                      "has a ROR"@en ,
                      "tiene un ROR"@es ,
                      "a un ROR"@fr ,
                      "ha un ROR"@it ,
                      "har en ROR"@no ,
                      "tem um ROR"@pt ,
                      "are un ROR"@ro ;
           skos:prefLabel "έχει ROR"@el ,
                          "has a ROR"@en ,
                          "tiene un ROR"@es ,
                          "a un ROR"@fr ,
                          "ha un ROR"@it ,
                          "har en ROR"@no ,
                          "tem um ROR"@pt ,
                          "are un ROR"@ro .

