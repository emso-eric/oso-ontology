##################################################################################################################################
# 04. CLASSES
##################################################################################################################################

### https://w3id.org/earthsemantics/OSO#SemanticPortalFramework
OSO:SemanticPortalFramework
    rdf:type owl:Class ;
    rdfs:subClassOf OSO:SemanticTool ;
    rdfs:label
        "Semantic portal framework"@en ,
        "Framework de portail sémantique"@fr ,
        "Framework para portales semánticos"@es ,
        "Framework per portali semantici"@it ,
        "Framework para portais semânticos"@pt ,
        "Framework pentru portaluri semantice"@ro ,
        "Rammeverk for semantiske portaler"@no ,
        "Πλαίσιο για σημασιολογικές πύλες"@el ;
    skos:definition
        "A software framework used to build, deploy and manage semantic artefact repositories and ontology portals."@en ,
        "Un framework logiciel utilisé pour construire, déployer et administrer des dépôts d’artefacts sémantiques et des portails d’ontologies."@fr ,
        "Un framework de software utilizado para crear, desplegar y administrar repositorios de artefactos semánticos y portales de ontologías."@es ,
        "Un framework software utilizzato per creare, distribuire e gestire repository di artefatti semantici e portali di ontologie."@it ,
        "Um framework de software utilizado para construir, implementar e gerir repositórios de artefactos semânticos e portais de ontologias."@pt ,
        "Un framework software utilizat pentru construirea, implementarea și administrarea depozitelor de artefacte semantice și a portalurilor de ontologii."@ro ,
        "Et programvarerammeverk som brukes til å bygge, distribuere og administrere semantiske artefaktlagre og ontologiportaler."@no ,
        "Ένα πλαίσιο λογισμικού που χρησιμοποιείται για την ανάπτυξη, την εγκατάσταση και τη διαχείριση αποθετηρίων σημασιολογικών τεχνουργημάτων και πυλών οντολογιών."@el .

### https://w3id.org/earthsemantics/OSO#CollaborativeDevelopmentPlatform
OSO:CollaborativeDevelopmentPlatform
    rdf:type owl:Class ;
    rdfs:subClassOf OSO:SemanticTool ;
    rdfs:label
        "Collaborative development platform"@en ,
        "Plateforme de développement collaboratif"@fr ,
        "Plataforma de desarrollo colaborativo"@es ,
        "Piattaforma di sviluppo collaborativo"@it ,
        "Plataforma de desenvolvimento colaborativo"@pt ,
        "Platformă de dezvoltare colaborativă"@ro ,
        "Plattform for samarbeidsutvikling"@no ,
        "Πλατφόρμα συνεργατικής ανάπτυξης"@el ;
    skos:definition
        "A software platform supporting collaborative software development, version control, issue tracking and source code management."@en ,
        "Une plateforme logicielle prenant en charge le développement collaboratif, le contrôle de version, le suivi des tickets et la gestion du code source."@fr ,
        "Una plataforma de software que permite el desarrollo colaborativo, el control de versiones, el seguimiento de incidencias y la gestión del código fuente."@es ,
        "Una piattaforma software che supporta lo sviluppo collaborativo, il controllo di versione, il tracciamento delle issue e la gestione del codice sorgente."@it ,
        "Uma plataforma de software que suporta o desenvolvimento colaborativo, o controlo de versões, o acompanhamento de problemas e a gestão do código-fonte."@pt ,
        "O platformă software care sprijină dezvoltarea colaborativă, controlul versiunilor, urmărirea problemelor și gestionarea codului sursă."@ro ,
        "En programvareplattform som støtter samarbeidsbasert programvareutvikling, versjonskontroll, saksoppfølging og håndtering av kildekode."@no ,
        "Μια πλατφόρμα λογισμικού που υποστηρίζει τη συνεργατική ανάπτυξη λογισμικού, τον έλεγχο εκδόσεων, την παρακολούθηση ζητημάτων και τη διαχείριση πηγαίου κώδικα."@el .

### https://w3id.org/earthsemantics/OSO#SemanticEcosystemResource
OSO:SemanticEcosystemResource
    rdf:type owl:Class ;
    rdfs:label
        "Semantic ecosystem resource"@en ,
        "Ressource d’écosystème sémantique"@fr ,
        "Recurso del ecosistema semántico"@es ,
        "Risorsa dell'ecosistema semantico"@it ,
        "Recurso do ecossistema semântico"@pt ,
        "Resursă a ecosistemului semantic"@ro ,
        "Ressurs i det semantiske økosystemet"@no ,
        "Πόρος του σημασιολογικού οικοσυστήματος"@el ;
    skos:definition
        "A resource used to design, maintain, publish, document, validate or reuse semantic artefacts."@en ,
        "Une ressource utilisée pour concevoir, maintenir, publier, documenter, valider ou réutiliser des artefacts sémantiques."@fr ,
        "Un recurso utilizado para diseñar, mantener, publicar, documentar, validar o reutilizar artefactos semánticos."@es ,
        "Una risorsa utilizzata per progettare, mantenere, pubblicare, documentare, validare o riutilizzare artefatti semantici."@it ,
        "Um recurso utilizado para conceber, manter, publicar, documentar, validar ou reutilizar artefactos semânticos."@pt ,
        "O resursă utilizată pentru proiectarea, întreținerea, publicarea, documentarea, validarea sau reutilizarea artefactelor semantice."@ro ,
        "En ressurs som brukes til å utvikle, vedlikeholde, publisere, dokumentere, validere eller gjenbruke semantiske artefakter."@no ,
        "Ένας πόρος που χρησιμοποιείται για τον σχεδιασμό, τη συντήρηση, τη δημοσίευση, την τεκμηρίωση, την επικύρωση ή την επαναχρησιμοποίηση σημασιολογικών τεχνουργημάτων."@el .

### https://w3id.org/earthsemantics/OSO#SemanticTool
OSO:SemanticTool
    rdf:type owl:Class ;
    rdfs:subClassOf
        OSO:SemanticEcosystemResource ,
        schema:SoftwareApplication ;
    rdfs:label
        "Semantic tool"@en ,
        "Outil sémantique"@fr ,
        "Herramienta semántica"@es ,
