                                    "Liga uma campanha oceanográfica à infraestrutura regional associada."@pt ,
                                    "Knytter en oseanografisk kampanje til den tilknyttede regionale infrastrukturen."@no ,
                                    "Leagă o campanie oceanografică de infrastructura regională asociată."@ro ,
                                    "Συνδέει μια ωκεανογραφική εκστρατεία με τη σχετική περιφερειακή υποδομή."@el ;
                       rdfs:label "is campaign linked to"@en ,
                                  "est une campagne liée à"@fr ,
                                  "es campaña vinculada a"@es ,
                                  "è una campagna collegata a"@it ,
                                  "é campanha ligada a"@pt ,
                                  "er kampanje knyttet til"@no ,
                                  "este campanie legată de"@ro ,
                                  "είναι εκστρατεία συνδεδεμένη με"@el ;
                       skos:prefLabel "is campaign linked to"@en ,
                                      "est une campagne liée à"@fr ,
                                      "es campaña vinculada a"@es ,
                                      "è una campagna collegata a"@it ,
                                      "é campanha ligada a"@pt ,
                                      "er kampanje knyttet til"@no ,
                                      "este campanie legată de"@ro ,
                                      "είναι εκστρατεία συνδεδεμένη με"@el .

