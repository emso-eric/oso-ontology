    ##############################################################################
    # Ontology statistics (OSO v1.1.0)
    #
    # These metrics are reviewed and recomputed for each OSO release.
    # They are embedded directly in the ontology to improve interoperability,
    # transparency and FAIRness (OMV, VoID, O'FAIRe), independently of
    # ontology portal-specific metric implementations.
    #
    # Unless otherwise stated, metrics are computed from the asserted ontology.
    # Metric values apply only to this ontology version and should be recomputed
    # for each new OSO release.
    #
    # References:
    # - BioPortal ontology metrics:
    #   https://www.bioontology.org/wiki/Ontology_Metrics
    # - W3C VoID Vocabulary:
    #   https://www.w3.org/TR/void/
    ##################################################################################
    
    # Maximum depth of the asserted class hierarchy (rdfs:subClassOf).
    # Computed from the ontology using Protégé 5.6.9.
    mod:maxDepth 5 ;

    # Number of named OWL classes.
    # Computed from the ontology using Protégé 5.6.9.
    omv:numberOfClasses 84 ;

    # Total number of object and data properties (annotation properties excluded).
    # Computed from the ontology using Protégé 5.6.9.
    omv:numberOfProperties 172 ;

    # Number of named individuals.
    # Computed from the ontology using Protégé 5.6.9.
    omv:numberOfIndividuals 761 ;

    # Total number of OWL axioms.
    # Computed from the ontology using Protégé 5.6.9.
    omv:numberOfAxioms 24767 ;

    # Number of RDF triples in the distributed Turtle serialisation.
    # Computed from the Turtle source using RDFLib 7.6.0 (len(Graph)).
    void:triples 15107 ;

    # Total number of ontology entities.
    # OSO convention: classes + object/data properties + individuals.
    void:entities 1017 ;
    ##################################################################################
