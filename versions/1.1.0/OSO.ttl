###  https://w3id.org/earthsemantics/OSO#dateEndDeployment
OSO:dateEndDeployment rdf:type owl:DatatypeProperty ;
                      rdfs:subPropertyOf schema:endDate ;
                      rdfs:domain OSO:Platform ,
                                  OSO:SubPlatform ,
                                  OSO:RegionalFacility ,
                                  OSO:Site ,
                                  OSO:Subsite ;
                      rdfs:range xsd:date ;
                      rdfs:label "Ημερομηνία λήξης εγκατάστασης"@el ,
                                 "Deployment end date"@en ,
                                 "Fecha de finalización del despliegue"@es ,
                                 "Date de fin du déploiement"@fr ,
                                 "Data di fine del dispiegamento"@it ,
                                 "Sluttdato for utplassering"@no ,
                                 "Data de fim da implantação"@pt ,
                                 "Data încheierii desfășurării"@ro ;
                      skos:prefLabel "Ημερομηνία λήξης εγκατάστασης"@el ,
                                     "Deployment end date"@en ,
                                     "Fecha de finalización del despliegue"@es ,
                                     "Date de fin du déploiement"@fr ,
                                     "Data di fine del dispiegamento"@it ,
                                     "Sluttdato for utplassering"@no ,
                                     "Data de fim da implantação"@pt ,
                                     "Data încheierii desfășurării"@ro ;
                      rdfs:comment "Date marking the end of operational deployment of an instrument, platform, site, or infrastructure."@en ,
                                   "Date marquant la fin du déploiement opérationnel d’un instrument, d’une plateforme, d’un site ou d’une infrastructure."@fr ,
                                   "Fecha que marca el final del despliegue operativo de un instrumento, plataforma, sitio o infraestructura."@es ,
                                   "Data che segna la fine del dispiegamento operativo di uno strumento, piattaforma, sito o infrastruttura."@it ,
                                   "Data que marca o fim da implantação operacional de um instrumento, plataforma, local ou infraestrutura."@pt ,
                                   "Dato som markerer slutten på den operative utplasseringen av et instrument, en plattform, et sted eller en infrastruktur."@no ,
                                   "Data care marchează sfârșitul desfășurării operaționale a unui instrument, platforme, sit sau infrastructuri."@ro ,
                                   "Ημερομηνία που σηματοδοτεί το τέλος της επιχειρησιακής εγκατάστασης ενός οργάνου, πλατφόρμας, τοποθεσίας ή υποδομής."@el .

###  https://w3id.org/earthsemantics/OSO#dateFirstDeployment
