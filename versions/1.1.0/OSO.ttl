##################################################################################################################################
# 02. OBJECT PROPERTIES
##################################################################################################################################

###  https://w3id.org/earthsemantics/OSO#associatedWithRI
OSO:associatedWithRI rdf:type owl:ObjectProperty ;
                     rdfs:domain OSO:RegionalFacility ;
                     rdfs:range OSO:ResearchInfrastructure ;
                     rdfs:comment "Μια Περιφερειακή Εγκατάσταση συνδέεται με μία ή περισσότερες Ερευνητικές Υποδομές."@el ,
                                  "A Regional Facility is associated with one or more Research Infrastructures."@en ,
                                  "Una Instalación Regional está asociada con una o más Infraestructuras de Investigación."@es ,
                                  "Une installation régionale est associée à une ou plusieurs infrastructures de recherche."@fr ,
                                  "Una Struttura Regionale è associata a una o più Infrastrutture di Ricerca."@it ,
                                  "En regional fasilitet er knyttet til én eller flere forskningsinfrastrukturer."@no ,
                                  "Uma Instalação Regional está associada a uma ou mais Infraestruturas de Investigação."@pt ,
                                  "O facilitate regională este asociată cu una sau mai multe infrastructuri de cercetare."@ro ;
                     rdfs:label "Η Περιφερειακή Εγκατάσταση συνδέεται με μια Ερευνητική Υποδομή"@el ,
                                "Regional Facility is associated with a Research Infrastructure"@en ,
                                "La Instalación Regional está asociada con una Infraestructura de Investigación"@es ,
                                "L'installation régionale est associée à une infrastructure de recherche"@fr ,
                                "La Struttura Regionale è associata a una Infrastruttura di Ricerca"@it ,
                                "Regional fasilitet er knyttet til en forskningsinfrastruktur"@no ,
                                "A Instalação Regional está associada a uma Infraestrutura de Investigação"@pt ,
                                "Facilitatea regională este asociată cu o infrastructură de cercetare"@ro ;
                     skos:prefLabel "Η Περιφερειακή Εγκατάσταση συνδέεται με μια Ερευνητική Υποδομή"@el ,
                                    "Regional Facility is associated with a Research Infrastructure"@en ,
                                    "La Instalación Regional está asociada con una Infraestructura de Investigación"@es ,
                                    "L'installation régionale est associée à une infrastructure de recherche"@fr ,
                                    "La Struttura Regionale è associata a una Infrastruttura di Ricerca"@it ,
                                    "Regional fasilitet er knyttet til en forskningsinfrastruktur"@no ,
                                    "A Instalação Regional está associada a uma Infraestrutura de Investigação"@pt ,
                                    "Facilitatea regională este asociată cu o infrastructură de cercetare"@ro .

###  https://w3id.org/earthsemantics/OSO#containsPlatform
OSO:containsPlatform rdf:type owl:ObjectProperty ;
                     rdfs:domain OSO:Site ;
                     rdfs:range OSO:Platform ;
                     owl:inverseOf OSO:isPlatformOf ;
                     rdfs:comment "A site contains one or more platforms."@en ,
                                  "Un site contient une ou plusieurs plateformes."@fr ,
                                  "Un sitio contiene una o varias plataformas."@es ,
                                  "Un sito contiene una o più piattaforme."@it ,
                                  "Um local contém uma ou mais plataformas."@pt ,
                                  "Et sted inneholder én eller flere plattformer."@no ,
                                  "Un sit conține una sau mai multe platforme."@ro ,
                                  "Μια τοποθεσία περιέχει μία ή περισσότερες πλατφόρμες."@el ;
                     rdfs:label "contains platform"@en ,
                                "contient une plateforme"@fr ,
                                "contiene una plataforma"@es ,
                                "contiene una piattaforma"@it ,
                                "contém uma plataforma"@pt ,
                                "inneholder plattform"@no ,
                                "conține platformă"@ro ,
                                "περιέχει πλατφόρμα"@el ;
                     skos:prefLabel "contains platform"@en ,
                                    "contient une plateforme"@fr ,
                                    "contiene una plataforma"@es ,
                                    "contiene una piattaforma"@it ,
                                    "contém uma plataforma"@pt ,
                                    "inneholder plattform"@no ,
                                    "conține platformă"@ro ,
                                    "περιέχει πλατφόρμα"@el .

###  https://w3id.org/earthsemantics/OSO#containsSite
OSO:containsSite rdf:type owl:ObjectProperty ;
                 rdfs:domain OSO:RegionalFacility ;
                 rdfs:range OSO:Site ;
                 owl:inverseOf OSO:isSiteOf ;
                 rdfs:comment "A Regional Facility contains one or more Sites."@en ,
                              "Une infrastructure régionale contient un ou plusieurs sites."@fr ,
                              "Una infraestructura regional contiene uno o varios sitios."@es ,
                              "Una infrastruttura regionale contiene uno o più siti."@it ,
                              "Uma infraestrutura regional contém um ou mais locais."@pt ,
                              "En regional infrastruktur inneholder ett eller flere steder."@no ,
                              "O infrastructură regională conține unul sau mai multe situri."@ro ,
                              "Μια περιφερειακή υποδομή περιέχει μία ή περισσότερες τοποθεσίες."@el ;
                 rdfs:label "contains site"@en ,
                            "contient un site"@fr ,
                            "contiene un sitio"@es ,
                            "contiene un sito"@it ,
                            "contém um local"@pt ,
                            "inneholder sted"@no ,
                            "conține sit"@ro ,
                            "περιέχει τοποθεσία"@el ;
                 skos:prefLabel "contains site"@en ,
                                "contient un site"@fr ,
                                "contiene un sitio"@es ,
                                "contiene un sito"@it ,
                                "contém um local"@pt ,
                                "inneholder sted"@no ,
                                "conține sit"@ro ,
                                "περιέχει τοποθεσία"@el .

###  https://w3id.org/earthsemantics/OSO#containsSubPlatform
OSO:containsSubPlatform rdf:type owl:ObjectProperty ;
                        rdfs:domain OSO:Platform ;
                        rdfs:range OSO:SubPlatform ;
                        owl:inverseOf OSO:isSubPlatformOf ;
                        rdfs:label "περιέχει υπο-πλατφόρμα"@el ,
                                   "contains sub-platform"@en ,
                                   "contiene subplataforma"@es ,
                                   "contient une sous-plateforme"@fr ,
                                   "contiene sotto-piattaforma"@it ,
                                   "inneholder underplattform"@no ,
                                   "contém subplataforma"@pt ,
                                   "conține subplatformă"@ro ;
                        skos:prefLabel "περιέχει υπο-πλατφόρμα"@el ,
                                       "contains sub-platform"@en ,
                                       "contiene subplataforma"@es ,
                                       "contient une sous-plateforme"@fr ,
                                       "contiene sotto-piattaforma"@it ,
                                       "inneholder underplattform"@no ,
                                       "contém subplataforma"@pt ,
                                       "conține subplatformă"@ro ;
                        rdfs:comment "Συνδέει μια πλατφόρμα με μία ή περισσότερες υπο-πλατφόρμες που αποτελούν μέρος της."@el ,
                                     "Links a platform to one or more sub-platforms that are part of it."@en ,
                                     "Relaciona una plataforma con una o varias subplataformas que forman parte de ella."@es ,
                                     "Relie une plateforme à une ou plusieurs sous-plateformes qui en font partie."@fr ,
                                     "Collega una piattaforma a una o più sotto-piattaforme che ne fanno parte."@it ,
                                     "Knytter en plattform til én eller flere underplattformer som er del av den."@no ,
                                     "Liga uma plataforma a uma ou mais subplataformas que fazem parte dela."@pt ,
                                     "Leagă o platformă de una sau mai multe subplatforme care fac parte din aceasta."@ro .

###  https://w3id.org/earthsemantics/OSO#federatesResearchInfrastructure
OSO:federatesResearchInfrastructure rdf:type owl:ObjectProperty ;
                                    rdfs:domain OSO:ERIC ;
                                    rdfs:range OSO:ResearchInfrastructure ;
                                    rdfs:label "ομοσπονδοποιεί ερευνητική υποδομή"@el ,
                                               "federates research infrastructure"@en ,
                                               "federa infraestructura de investigación"@es ,
                                               "fédère une infrastructure de recherche"@fr ,
                                               "federa infrastruttura di ricerca"@it ,
                                               "fødererer forskningsinfrastruktur"@no ,
                                               "federa infraestrutura de investigação"@pt ,
                                               "federează infrastructură de cercetare"@ro ;
                                    skos:prefLabel "ομοσπονδοποιεί ερευνητική υποδομή"@el ,
                                                   "federates research infrastructure"@en ,
                                                   "federa infraestructura de investigación"@es ,
                                                   "fédère une infrastructure de recherche"@fr ,
                                                   "federa infrastruttura di ricerca"@it ,
                                                   "fødererer forskningsinfrastruktur"@no ,
                                                   "federa infraestrutura de investigação"@pt ,
                                                   "federează infrastructură de cercetare"@ro ;
                                    rdfs:comment "Συνδέει ένα ERIC με μία ή περισσότερες ερευνητικές υποδομές που συντονίζει ή ομοσπονδοποιεί."@el ,
                                                 "Links an ERIC to one or more research infrastructures that it coordinates or federates."@en ,
                                                 "Relaciona un ERIC con una o varias infraestructuras de investigación que coordina o federa."@es ,
                                                 "Lie un ERIC à une ou plusieurs infrastructures de recherche qu’il coordonne ou fédère."@fr ,
                                                 "Collega un ERIC a una o più infrastrutture di ricerca che coordina o federa."@it ,
                                                 "Knytter et ERIC til én eller flere forskningsinfrastrukturer som det koordinerer eller fødererer."@no ,
                                                 "Liga um ERIC a uma ou mais infraestruturas de investigação que coordena ou federa."@pt ,
                                                 "Leagă un ERIC de una sau mai multe infrastructuri de cercetare pe care le coordonează sau le federează."@ro .

###  https://w3id.org/earthsemantics/OSO#hasBoundingBox
OSO:hasBoundingBox rdf:type owl:ObjectProperty ;
                   rdfs:domain OSO:RegionalFacility ;
                   rdfs:range OSO:BoundingBox ;
                   owl:inverseOf OSO:isBoundingBoxOf ;
                   rdfs:comment "Links a Regional Facility to its spatial extent, aligned with EX_Extent/EX_GeographicBoundingBox in ISO 19115-3."@en ,
