###  https://w3id.org/earthsemantics/OSO#Molene
OSO:Molene rdf:type owl:NamedIndividual ,
                    OSO:Site ;
           OSO:Site_is_part_of_a_RI OSO:EMSO-France ;
           OSO:containsPlatform OSO:Molene_AutonomousDevices ,
                                OSO:Molene_SubmarinePlatform ;
           OSO:hasSiteResponsible OSO:Nadine_LANTERI ;
           OSO:isTestSite true ;
           OSO:dateFirstDeployment "2012-06-13"^^xsd:date ;
           OSO:dateEndDeployment "2017-12-21"^^xsd:date ;
           dcterms:spatial <http://dbpedia.org/resource/Mol%C3%A8ne> ,
                           <http://dbpedia.org/resource/Iroise_Sea> ,
                           <http://dbpedia.org/resource/Brittany> ,
                           <http://dbpedia.org/resource/Parc_naturel_marin_d%27Iroise> ;
           schema:url <https://www.emso-fr.org/fr/Molene> ;
           rdfs:seeAlso <https://www.emso-fr.org/fr/Molene> ,
                        <https://www.emso-fr.org/fr/Iroise> ,
                        <https://parc-marin-iroise.fr/> ,
                        <https://www.amp.milieumarinfrance.fr/accueil-fr/rechercher/fiche-didentite-dune-amp?wdpaid=388659&gid=178> ,
                        <https://doi.org/10.17882/58790> ;
           skos:note "Located within the Parc naturel marin d’Iroise protected marine area (WDPA 388659, MNHN FR9100001)."@en ,
                      "Situé dans l’aire marine protégée du Parc naturel marin d’Iroise (WDPA 388659, MNHN FR9100001)."@fr ,
                      "Localizado na área marinha protegida do Parc naturel marin d’Iroise (WDPA 388659, MNHN FR9100001)."@pt ;
           dcterms:isReferencedBy <https://doi.org/10.17882/58790> ,
                                  <https://doi.org/10.17882/58789> ,
                                  <https://doi.org/10.17882/58764> ,
                                  <https://doi.org/10.17882/58727> ,
                                  <https://doi.org/10.17882/49960> ,
                                  <https://doi.org/10.17882/49959> ,
                                  <https://doi.org/10.17882/49874> ,
                                  <https://doi.org/10.17882/49245> ,
                                  <https://doi.org/10.17882/48840> ;
           dcterms:description "The Molène site was a coastal cabled observatory deployed offshore Molène Island in the Iroise Sea between 2012 and 2017. Dedicated to long-term and high-resolution monitoring of coastal biodiversity and biomass, it also served as a testing site for in situ qualification of sensors and marine equipment. The observatory cable was permanently damaged in 2017 and the site was subsequently dismantled."@en ,
                                "Le site de Molène était un observatoire côtier câblé déployé au large de l’île de Molène en mer d’Iroise entre 2012 et 2017. Dédié au suivi à long terme et à haute résolution de la biodiversité et de la biomasse côtières, il servait également de site de test pour la qualification in situ de capteurs et d’équipements marins. Le câble de l’observatoire a été définitivement endommagé en 2017 et le site a ensuite été démantelé."@fr ,
                                "O sítio Molène era um observatório costeiro cablado implantado ao largo da ilha de Molène, no mar de Iroise, entre 2012 e 2017. Dedicado à monitorização de longo prazo e alta resolução da biodiversidade e biomassa costeiras, serviu também como local de teste para qualificação in situ de sensores e equipamentos marinhos. O cabo do observatório foi permanentemente danificado em 2017 e o sítio foi posteriormente desmantelado."@pt ;
           rdfs:label "Molène"@el ,
                      "Molène"@en ,
                      "Molène"@es ,
                      "Molène"@fr ,
                      "Molène"@it ,
                      "Molène"@no ,
                      "Molène"@pt ,
                      "Molène"@ro ,
                      "Molenez"@br ;
           skos:prefLabel "Molène"@el ,
                          "Molène"@en ,
                          "Molène"@es ,
                          "Molène"@fr ,
                          "Molène"@it ,
                          "Molène"@no ,
                          "Molène"@pt ,
                          "Molène"@ro ,
                          "Molenez"@br ;
           skos:altLabel "Molene"@en ,
                         "Île de Molène"@fr ,
                         "Molène test site"@en ,
                         "Site test de Molène"@fr ,
                         "Enez Molenez"@br ;
           skos:definition "Coastal cabled marine observation site located in the Iroise Sea and operated as an EMSO-France test site between 2012 and 2017."@en ,
                           "Site côtier câblé d’observation marine situé en mer d’Iroise et exploité comme site test d’EMSO-France entre 2012 et 2017."@fr ,
                           "Lec’h sellout ouzh ar mor kevreet dre gebl e Mor Iroise, implijet evel lec’h arnodiñ ha heuliañ ar vevliesseurted hag ar biomassezhioù gant EMSO-France etre 2012 ha 2017."@br .
