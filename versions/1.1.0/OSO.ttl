                            "Liga um local a uma subdivisão ou sublocal componente."@pt ,
                            "Knytter et sted til et underområde eller delområde."@no ,
                            "Leagă un sit de o subdiviziune sau un subsit component."@ro ,
                            "Συνδέει μια τοποθεσία με μια υποδιαίρεση ή υποτοποθεσία."@el ;
               rdfs:label "has subsite"@en ,
                          "a un sous-site"@fr ,
                          "tiene subsitio"@es ,
                          "ha sotto-sito"@it ,
                          "tem subsite"@pt ,
                          "har delområde"@no ,
                          "are subsite"@ro ,
                          "έχει υποτοποθεσία"@el ;
               skos:prefLabel "has subsite"@en ,
                              "a un sous-site"@fr ,
                              "tiene subsitio"@es ,
                              "ha sotto-sito"@it ,
                              "tem subsite"@pt ,
                              "har delområde"@no ,
                              "are subsite"@ro ,
                              "έχει υποτοποθεσία"@el .

###  https://w3id.org/earthsemantics/OSO#isBoundingBoxOf
OSO:isBoundingBoxOf rdf:type owl:ObjectProperty ;
                    rdfs:domain OSO:BoundingBox ;
                    rdfs:range OSO:RegionalFacility ;
                    owl:inverseOf OSO:hasBoundingBox ;
                    rdfs:comment "Links a bounding box to the Regional Facility it describes."@en ,
                                 "Lie une boîte englobante à l’infrastructure régionale qu’elle décrit."@fr ,
                                 "Relaciona una caja envolvente con la infraestructura regional que describe."@es ,
                                 "Collega un riquadro di delimitazione all'infrastruttura regionale che descrive."@it ,
                                 "Liga uma caixa delimitadora à infraestrutura regional que descreve."@pt ,
                                 "Knytter en avgrensningsboks til den regionale infrastrukturen den beskriver."@no ,
                                 "Leagă o bounding box de infrastructura regională pe care o descrie."@ro ,
                                 "Συνδέει ένα οριοθετημένο πλαίσιο με την περιφερειακή υποδομή που περιγράφει."@el ;
                    rdfs:label "is bounding box of"@en ,
                               "est la boîte englobante de"@fr ,
                               "es la caja envolvente de"@es ,
                               "è il riquadro di delimitazione di"@it ,
                               "é a caixa delimitadora de"@pt ,
                               "er avgrensningsboks for"@no ,
                               "este bounding box pentru"@ro ,
                               "είναι το οριοθετημένο πλαίσιο της"@el ;
                    skos:prefLabel "is bounding box of"@en ,
                                   "est la boîte englobante de"@fr ,
                                   "es la caja envolvente de"@es ,
                                   "è il riquadro di delimitazione di"@it ,
                                   "é a caixa delimitadora de"@pt ,
                                   "er avgrensningsboks for"@no ,
                                   "este bounding box pentru"@ro ,
                                   "είναι το οριοθετημένο πλαίσιο της"@el .

###  https://w3id.org/earthsemantics/OSO#isCampaignLinkedTo
OSO:isCampaignLinkedTo rdf:type owl:ObjectProperty ;
                       rdfs:domain OSO:OceanographicCampaign ;
                       rdfs:range OSO:RegionalFacility ;
