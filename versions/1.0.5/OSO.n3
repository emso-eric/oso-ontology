OSO:REVOSIMA a owl:NamedIndividual,
        OSO:FundedProject ;
    rdfs:label "REVOSIMA"@el,
        "REVOSIMA"@en,
        "REVOSIMA"@es,
        "REVOSIMA"@fr,
        "REVOSIMA"@it,
        "REVOSIMA"@no,
        "REVOSIMA"@pt,
        "REVOSIMA"@ro ;
    dcterms:description "Το REVOSIMA είναι το δίκτυο ηφαιστειολογικής και σεισμολογικής παρακολούθησης της Μαγιότ, που υποστηρίζει τη συνεχή παρατήρηση της εν εξελίξει σεισμοηφαιστειακής δραστηριότητας."@el,
        "REVOSIMA is the Mayotte volcanological and seismological monitoring network supporting continuous observation of the ongoing seismo-volcanic activity."@en,
        "REVOSIMA es la red de vigilancia volcanológica y sismológica de Mayotte que apoya la observación continua de la actividad sismo-volcánica en curso."@es,
        "REVOSIMA est le réseau de surveillance volcanologique et sismologique de Mayotte assurant le suivi continu de l’activité sismo-volcanique en cours."@fr,
        "REVOSIMA è la rete di monitoraggio vulcanologico e sismologico di Mayotte che supporta l’osservazione continua dell’attività sismo-vulcanica in corso."@it,
        "REVOSIMA er overvåkingsnettverket for vulkanologi og seismologi på Mayotte, som støtter kontinuerlig observasjon av pågående seismo-vulkansk aktivitet."@no,
        "REVOSIMA é a rede de monitorização vulcanológica e sismológica de Mayotte, que apoia a observação contínua da atividade sismo-vulcânica em curso."@pt,
        "REVOSIMA este rețeaua de monitorizare vulcanologică și seismologică din Mayotte, care susține observarea continuă a activității seismo-vulcanice în desfășurare."@ro ;
    rdfs:seeAlso <https://fr.wikipedia.org/wiki/Fani_Maor%C3%A9>,
        <https://fr.wikipedia.org/wiki/R%C3%A9seau_de_surveillance_volcanologique_et_sismologique_de_Mayotte>,
        <https://sextant.ifremer.fr/Ressources/Liste-des-catalogues-thematiques/Revosima>,
        <https://www.brgm.fr/fr/actualite/actualite/volcan-seismes-mayotte-surveillance-confiee-au-revosima> ;
    skos:altLabel "Mayotte Volcanological and Seismological Monitoring Network"@en,
        "Réseau de surveillance volcanologique et sismologique de Mayotte"@fr ;
    skos:exactMatch <https://www.wikidata.org/entity/Q66811844> ;
    skos:prefLabel "REVOSIMA"@el,
        "REVOSIMA"@en,
        "REVOSIMA"@es,
        "REVOSIMA"@fr,
        "REVOSIMA"@it,
        "REVOSIMA"@no,
        "REVOSIMA"@pt,
        "REVOSIMA"@ro ;
    foaf:homepage <https://www.ipgp.fr/en/observation/national-hosted-infrastructures/revosima/>,
        <https://www.ipgp.fr/observation/infrastructures-nationales-hebergees/revosima/> ;
