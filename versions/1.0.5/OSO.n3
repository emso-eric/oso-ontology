OSO:hasSpatialExtent a owl:ObjectProperty ;
    rdfs:label "έχει χωρική έκταση"@el,
        "has spatial extent"@en,
        "tiene extensión espacial"@es,
        "a une emprise spatiale"@fr,
        "ha estensione spaziale"@it,
        "har romlig utstrekning"@no,
        "tem extensão espacial"@pt,
        "are extindere spațială"@ro ;
    rdfs:comment "Συνδέει ένα χρηματοδοτούμενο έργο με τη γεωγραφική του έκταση, όπως ένα οριοθετημένο πλαίσιο ή μια περιοχή κάλυψης."@el,
        "Relates a funded project to its geographical extent, such as a bounding box or spatial coverage."@en,
        "Relaciona un proyecto financiado con su extensión geográfica, como una caja envolvente o una zona de cobertura."@es,
        "Relie un projet financé à son emprise géographique, comme une boîte englobante ou une zone de couverture."@fr,
        "Collega un progetto finanziato alla sua estensione geografica, come un riquadro di delimitazione o un'area di copertura."@it,
        "Knytter et finansiert prosjekt til dets geografiske utstrekning, for eksempel en avgrensningsboks eller et dekningsområde."@no,
        "Relaciona um projeto financiado com a sua extensão geográfica, como uma caixa delimitadora ou uma área de cobertura."@pt,
        "Leagă un proiect finanțat de extinderea sa geografică, cum ar fi o bounding box sau o zonă de acoperire."@ro ;
    rdfs:domain OSO:FundedProject ;
    rdfs:range wgs84_pos:BoundingBox ;
    rdfs:subPropertyOf geosparql:hasGeometry ;
    owl:inverseOf OSO:isSpatialExtentOf ;
