OSO:Iberian_Margin a owl:NamedIndividual,
        OSO:RegionalFacility ;
    rdfs:label "Iberian Margin"@el,
        "Iberian Margin"@en,
        "Iberian Margin"@es,
        "Iberian Margin"@fr,
        "Iberian Margin"@it,
        "Iberian Margin"@no,
        "Iberian Margin"@pt,
        "Iberian Margin"@ro ;
    dcterms:description "The area of Gulf of Cadiz  is very important for geo-hazards. It was the site where one of the worst earthquakes that hit Europe occurred in 1755, coupled with a destructive tsunami. Here African and European tectonic plates converge. It is a seismic volcanic region. The Iberian Margin is also a pivotal ocean region where Atlantic and Mediterranean exchange waters, with the later spreading at intermediate levels playing a key role in the salt and heat budget and AMOC (Atlantic Meridional Overturning Circulation). The Iberian Margin is the northernmost region of the productive CCUS (Canary Current Upwelling System), one of the four EBUS (Eastern Boundary Upwelling Systems) of the global ocean, where a highly variable upwelling regime dominates along with a strong mesoscale activity. The geologic and oceanographic features of this region favour the presence of highly diverse benthic communities and have also a central role in the distribution of several marine mammals and fish species."@en ;
    dcterms:spatial <http://dbpedia.org/resource/Gulf_of_Cadiz> ;
    skos:note "IbMa"@en ;
    skos:prefLabel "Iberian Margin"@el,
        "Iberian Margin"@en,
        "Iberian Margin"@es,
        "Iberian Margin"@fr,
        "Iberian Margin"@it,
        "Iberian Margin"@no,
        "Iberian Margin"@pt,
        "Iberian Margin"@ro ;
    foaf:homepage <https://emso-pt.pt/>,
        <https://emso.eu/observatories-node/iberian-margin/> ;
    OSO:RegionalFacilityispartofRI OSO:EMSO-PT ;
    OSO:containsSite OSO:IbMaCSV_SaoVicenteCanyon,
        OSO:IbMaCSV_Seabed_Station,
        OSO:IbMaCSV_TUPEM_Fixed_SubSurface_Vertical_Profiler,
        OSO:IbMaCSV_TUPEM_SubSurface_Mooring,
        OSO:IbMaN ;
    OSO:dateFirstDeployment "2021-05-01"^^xsd:date ;
    OSO:distanceFromLand 11.0 ;
    OSO:hasERICMembership OSO:Iberian_Margin_EMSO_membership ;
    OSO:hasRegionalTeamLeader OSO:Carlos_SOUSA ;
    OSO:isLedByOrganization OSO:IPMA ;
    OSO:maxWaterDepth 1200 .

