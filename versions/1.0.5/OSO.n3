OSO:EMSO_DMSG a schema1:Organization,
        owl:NamedIndividual,
        foaf:Group,
        foaf:Organization,
        cerif:Organisation ;
    rdfs:label "Ομάδα υπηρεσιών διαχείρισης δεδομένων EMSO"@el,
        "EMSO Data Management Service Group"@en,
        "Grupo de servicios de gestión de datos de EMSO"@es,
        "Groupe de service pour la gestion des données EMSO"@fr,
        "Gruppo di servizio per la gestione dei dati EMSO"@it,
        "EMSO databehandlingstjenestegruppe"@no,
        "Grupo de serviço de gestão de dados do EMSO"@pt,
        "Grupul de servicii pentru gestionarea datelor EMSO"@ro ;
    dcterms:description "Η ομάδα υπηρεσιών διαχείρισης δεδομένων EMSO υποστηρίζει τη διαχείριση δεδομένων, τη διαλειτουργικότητα και τις πρακτικές FAIR στην κοινότητα EMSO."@el,
        "The EMSO Data Management Service Group supports data management, interoperability and FAIR data practices within the EMSO community."@en,
        "El grupo de servicios de gestión de datos de EMSO apoya la gestión de datos, la interoperabilidad y las prácticas FAIR dentro de la comunidad EMSO."@es,
        "Le groupe de service pour la gestion des données EMSO soutient la gestion des données, l’interopérabilité et les pratiques FAIR au sein de la communauté EMSO."@fr,
        "Il gruppo di servizio per la gestione dei dati EMSO supporta la gestione dei dati, l’interoperabilità e le pratiche FAIR all’interno della comunità EMSO."@it,
        "EMSO databehandlingstjenestegruppe støtter dataforvaltning, interoperabilitet og FAIR-praksis i EMSO-fellesskapet."@no,
        "O grupo de serviço de gestão de dados do EMSO apoia a gestão de dados, a interoperabilidade e as práticas FAIR na comunidade EMSO."@pt,
        "Grupul de servicii pentru gestionarea datelor EMSO sprijină gestionarea datelor, interoperabilitatea și practicile FAIR în cadrul comunității EMSO."@ro ;
    dcterms:isPartOf <https://ror.org/04xkqms46> ;
    schema1:parentOrganization <https://ror.org/04xkqms46> ;
    rdfs:seeAlso <https://emso.eu/> ;
    skos:altLabel "EMSO DMSG"@el,
        "EMSO DMSG"@en,
        "EMSO DMSG"@es,
        "EMSO DMSG"@fr,
        "EMSO DMSG"@it,
        "EMSO DMSG"@no,
        "EMSO DMSG"@pt,
        "EMSO DMSG"@ro ;
    skos:prefLabel "Ομάδα υπηρεσιών διαχείρισης δεδομένων EMSO"@el,
        "EMSO Data Management Service Group"@en,
        "Grupo de servicios de gestión de datos de EMSO"@es,
        "Groupe de service pour la gestion des données EMSO"@fr,
        "Gruppo di servizio per la gestione dei dati EMSO"@it,
        "EMSO databehandlingstjenestegruppe"@no,
        "Grupo de serviço de gestão de dados do EMSO"@pt,
        "Grupul de servicii pentru gestionarea datelor EMSO"@ro ;
    foaf:homepage <https://emso.eu/> .

