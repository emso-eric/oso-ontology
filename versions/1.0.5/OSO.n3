OSO:hasEDMO a owl:ObjectProperty ;
    rdfs:label "έχει EDMO"@el,
        "has an EDMO"@en,
        "tiene un EDMO"@es,
        "a un EDMO"@fr,
        "ha un EDMO"@it,
        "har en EDMO"@no,
        "tem um EDMO"@pt,
