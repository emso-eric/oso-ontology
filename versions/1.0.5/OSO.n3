OSO:AtlanticWhaleDealbbox a owl:NamedIndividual,
        wgs84_pos:BoundingBox ;
    wgs84_pos:Latitude 3.6e+01,
        6.2e+01 ;
    wgs84_pos:Longitude -2e+01,
