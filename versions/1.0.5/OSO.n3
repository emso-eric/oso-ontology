<https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/EMSO-Azores-SeaMoN-East.jpg> a schema1:ImageObject ;
    dcterms:creator <https://www.ifremer.fr> ;
    dcterms:description "Πλατφόρμα SeaMoN East εγκατεστημένη στο παρατηρητήριο EMSO Αζορών."@el,
