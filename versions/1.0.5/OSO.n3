        "Infrastructură regională"@ro .

OSO:Site a owl:Class ;
    rdfs:label "Τόπος παρατήρησης"@el,
        "Observatory Site"@en,
        "Sitio de observación"@es,
        "Site d'observation"@fr,
        "Sito di osservazione"@it,
        "Observasjonssted"@no,
        "Local de observação"@pt,
        "Loc de observare"@ro ;
    metadata:prefixIRI "OSO:Site" ;
    rdfs:comment "Ένας τοπικός τόπος παρατήρησης, συνδεδεμένος με μια περιφερειακή υποδομή, που μπορεί να φιλοξενήσει μία ή περισσότερες πλατφόρμες μέτρησης."@el,
        "A localized observatory site, attached to a regional facility, potentially hosting one or more measurement platforms."@en,
        "Un sitio de observación localizado, vinculado a una infraestructura regional, que puede albergar una o más plataformas de medición."@es,
        "Un site observatoire localisé, rattaché à un nœud régional, pouvant accueillir une ou plusieurs plateformes de mesure."@fr,
        "Un sito osservatorio localizzato, collegato a una struttura regionale, che può ospitare una o più piattaforme di misura."@it,
        "Et lokalisert observasjonssted tilknyttet en regional fasilitet, som potensielt huser en eller flere måleplattformer."@no,
        "Um local de observação localizado, associado a uma infraestrutura regional, podendo acolher uma ou mais plataformas de medição."@pt,
        "Un site observator localizat, asociat cu o facilitate regională, care poate găzdui una sau mai multe platforme de măsurare."@ro ;
    rdfs:seeAlso sweetRealmOcean: ;
    rdfs:subClassOf OSO:RegionalFacility ;
    skos:closeMatch sweetRealmOcean:OceanRegion ;
    skos:prefLabel "Τόπος παρατήρησης"@el,
        "Observatory Site"@en,
        "Sitio de observación"@es,
        "Site d'observation"@fr,
        "Sito di osservazione"@it,
        "Observasjonssted"@no,
        "Local de observação"@pt,
        "Loc de observare"@ro .

OSO:Platform a owl:Class ;
    rdfs:label "Πλατφόρμα παρατήρησης"@el,
        "Observation Platform"@en,
        "Plataforma de observación"@es,
        "Plateforme d'observation"@fr,
        "Piattaforma di osservazione"@it,
        "Observasjonsplattform"@no,
        "Plataforma de observação"@pt,
        "Platformă de observație"@ro ;
    metadata:prefixIRI "OSO:Platform" ;
    dcterms:source <http://vocab.nerc.ac.uk/collection/L06/current/> ;
    rdfs:comment "Μια πλατφόρμα παρατήρησης, σταθερή ή κινητή, εγκατεστημένη σε έναν τόπο ή υποτοποθεσία, υποστηρίζοντας ένα ή περισσότερα όργανα ή συστήματα συλλογής δεδομένων."@el,
        "An observation platform, fixed or mobile, installed on a site or subsite, supporting one or more instruments or acquisition systems."@en,
        "Una plataforma de observación, fija o móvil, instalada en un sitio o sub-sitio, que soporta uno o más instrumentos o sistemas de adquisición."@es,
        "Une plateforme d'observation fixe ou mobile, installée sur un site ou un sous-site, supportant un ou plusieurs instruments ou systèmes d'acquisition."@fr,
        "Una piattaforma di osservazione, fissa o mobile, installata su un sito o sotto-sito, che supporta uno o più strumenti o sistemi di acquisizione."@it,
        "En observasjonsplattform, fast eller mobil, installert på et sted eller underområde, som støtter ett eller flere instrumenter eller innhentingssystemer."@no,
        "Uma plataforma de observação, fixa ou móvel, instalada num local ou sublocal, suportando um ou mais instrumentos ou sistemas de aquisição."@pt,
        "O platformă de observație, fixă sau mobilă, instalată într-un site sau subsite, care suportă unul sau mai multe instrumente sau sisteme de achiziție."@ro ;
    rdfs:seeAlso <http://vocab.nerc.ac.uk/collection/L06/current/> ;
    rdfs:subClassOf OSO:Subsite ;
    skos:prefLabel "Πλατφόρμα παρατήρησης"@el,
        "Observation Platform"@en,
        "Plataforma de observación"@es,
        "Plateforme d'observation"@fr,
        "Piattaforma di osservazione"@it,
        "Observasjonsplattform"@no,
        "Plataforma de observação"@pt,
        "Platformă de observație"@ro .

[] a owl:Axiom ;
    owl:annotatedProperty rdf:type ;
    owl:annotatedSource OSO:Molène ;
    owl:annotatedTarget OSO:Site ;
    owl:deprecated true .

