OSO:CLASS a owl:NamedIndividual,
        OSO:FundedProject ;
    rdfs:label "CLASS"@el,
        "CLASS"@en,
        "CLASS"@es,
        "CLASS"@fr,
        "CLASS"@it,
        "CLASS"@no,
        "CLASS"@pt,
        "CLASS"@ro ;
    dcterms:description """CLASS will deliver the knowledge and understanding of the Atlantic Ocean system that society needs to make evidence-based decisions regarding ocean management.

We aim to address key knowledge gaps in our understanding of ocean variability, climate regulation and ocean services, and to assess how the ocean will evolve as a result of climate change and intensified human exploitation.

CLASS will be delivered through an Atlantic focused science programme, building on sustained ocean observation, world class model development and state of the art technology, delivered through Marine National Capability underpinning activities.""" ;
    dcterms:title "CLASS (Climate Linked Atlantic Sector Science)"@el,
        "CLASS (Climate Linked Atlantic Sector Science)"@en,
        "CLASS (Climate Linked Atlantic Sector Science)"@es,
        "CLASS (Climate Linked Atlantic Sector Science)"@fr,
        "CLASS (Climate Linked Atlantic Sector Science)"@it,
        "CLASS (Climate Linked Atlantic Sector Science)"@no,
        "CLASS (Climate Linked Atlantic Sector Science)"@pt,
        "CLASS (Climate Linked Atlantic Sector Science)"@ro ;
    schema1:endDate "2024-04"^^xsd:gYearMonth ;
    schema1:startDate "2018-04"^^xsd:gYearMonth ;
    skos:altLabel "Climate Linked Atlantic Sector Science"@en ;
    skos:definition """CLASS will deliver the knowledge and understanding of the Atlantic Ocean system that society needs to make evidence-based decisions regarding ocean management.

We aim to address key knowledge gaps in our understanding of ocean variability, climate regulation and ocean services, and to assess how the ocean will evolve as a result of climate change and intensified human exploitation.

CLASS will be delivered through an Atlantic focused science programme, building on sustained ocean observation, world class model development and state of the art technology, delivered through Marine National Capability underpinning activities."""@en ;
    skos:note "CLASS"@en ;
    skos:prefLabel "CLASS"@el,
        "CLASS"@en,
        "CLASS"@es,
        "CLASS"@fr,
        "CLASS"@it,
        "CLASS"@no,
        "CLASS"@pt,
        "CLASS"@ro ;
    foaf:homepage <https://projects.noc.ac.uk/class-project/> ;
    OSO:hasCountry OSO:United_Kingdom ;
    OSO:hasLogo <https://raw.githubusercontent.com/emso-eric/oso-ontology/8c80fcae432da3c2aec4f14049a6832a18edd971/images/class.jpg> .

