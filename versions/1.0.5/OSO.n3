OSO:northBoundLatitude a owl:DatatypeProperty ;
    rdfs:label "βόρειο όριο γεωγραφικού πλάτους"@el,
        "north bound latitude"@en,
        "latitud norte máxima"@es,
        "latitude nord maximale"@fr,
        "latitudine nord massima"@it,
        "nordlig breddegrad"@no,
        "latitude norte máxima"@pt,
        "latitudine nordică maximă"@ro ;
    rdfs:comment "Το βορειότερο γεωγραφικό πλάτος ενός γεωγραφικού πλαισίου, που αντιστοιχεί στο northBoundLatitude του ISO 19115-3."@el,
        "Northernmost latitude of a geographic bounding box, corresponding to northBoundLatitude in ISO 19115-3."@en,
        "Latitud norte máxima de una caja geográfica delimitadora, correspondiente a northBoundLatitude en ISO 19115-3."@es,
        "Latitude nord maximale d’une boîte englobante géographique, correspondant à northBoundLatitude dans l’ISO 19115-3."@fr,
        "Latitudine nord massima di un riquadro geografico, corrispondente a northBoundLatitude in ISO 19115-3."@it,
        "Nordligste breddegrad i en geografisk avgrensningsboks, tilsvarende northBoundLatitude i ISO 19115-3."@no,
        "Latitude norte máxima de uma caixa geográfica delimitadora, correspondente a northBoundLatitude na ISO 19115-3."@pt,
        "Latitudinea nordică maximă a unei zone geografice delimitate, corespunzătoare northBoundLatitude din ISO 19115-3."@ro ;
    rdfs:domain wgs84_pos:BoundingBox ;
    rdfs:range xsd:float ;
    skos:prefLabel "βόρειο όριο γεωγραφικού πλάτους"@el,
        "north bound latitude"@en,
        "latitud norte máxima"@es,
        "latitude nord maximale"@fr,
        "latitudine nord massima"@it,
        "nordlig breddegrad"@no,
        "latitude norte máxima"@pt,
        "latitudine nordică maximă"@ro .

