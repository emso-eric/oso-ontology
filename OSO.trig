    OSO:EMSO-France a owl:NamedIndividual,
            cerif:Organisation,
            OSO:ResearchInfrastructure ;
        rdfs:label "EMSO-France"@el,
            "EMSO-France"@en,
            "EMSO-France"@es,
            "EMSO-France"@fr,
            "EMSO-France"@it,
            "EMSO-France"@no,
            "EMSO-France"@pt,
            "EMSO-France"@ro ;
        dcterms:description """EMSO-France Research Infrastructure, included in the MESR roadmap, coordinates French initiatives on underwater observatories within the European programme and promotes their openness to a wide range of teams and disciplines. France’s involvement is driven by its expertise in data management, technological innovation, and the strategic selection of observatory deployment sites:

        the Azores site on the Mid-Atlantic Ridge, within Portugal’s EEZ,
        the Ligurian Sea site, east on the Nice slope and west in the deep continental margin area, linked to the IN2P3 neutrino telescope,
        the Marmara Sea site along the North Anatolian Fault,
        the Iroise Sea test site, initially located offshore Molène, currently being relocated to Brest harbour."""@en,
            """L’infrastructure de recherche EMSO-France, inscrite dans la feuille de route du MESR, coordonne les initiatives françaises sur les observatoires sous-marins du programme européen et favorise leur ouverture à un large éventail d’équipes et de disciplines. L’engagement de la France repose sur son expertise en gestion de données, en innovation technologique et sur le choix stratégique des sites d’implantation des observatoires :

        le site des Açores sur la dorsale médio-atlantique, dans la ZEE du Portugal,
        le site de la mer Ligure, à l’est sur la pente de Nice et à l’ouest dans la zone profonde du talus continental, en lien avec le télescope à neutrinos de l’IN2P3,
        le site de la mer de Marmara sur la faille nord-anatolienne,
        le site d’essai en mer d’Iroise, initialement au large de Molène, en cours de relocalisation en rade de Brest."""@fr ;
        dcterms:identifier "https://ror.org/0312sjw67" ;
        dcterms:relation OSO:ODATIS ;
        schema1:alternateName "European Multidisciplinary Seafloor and Water Column Observatory France" ;
        schema1:logo OSO:EMSOFranceLogo ;
        schema1:name "EMSO-France" ;
        schema1:url <https://www.emso-fr.org/>,
            <https://www.emso-fr.org/fr> ;
        rdfs:seeAlso <http://www.wikidata.org/entity/Q132157018>,
            <https://ror.org/0312sjw67>,
            <https://www.emso-fr.org/>,
            <https://www.emso-fr.org/fr> ;
        skos:altLabel "European Multidisciplinary Seafloor and Water Column Observatory France"@en,
            "European Multidisciplinary Seafloor and Water Column Observatory – France"@en,
            "French component of EMSO ERIC"@en,
            "Composante française d’EMSO ERIC"@fr ;
        skos:closeMatch <http://www.wikidata.org/entity/Q132157018>,
            <https://terra-vocabulary.org/ncl/DataTerraRepositoryFairIncubator/InfraRecherche/c_1ce4e5d0> ;
        skos:definition "The French component of EMSO ERIC, coordinating long-term multidisciplinary seafloor and water-column observatories operated by the French scientific community."@en,
            "La composante française d’EMSO ERIC, coordonnant les observatoires multidisciplinaires à long terme du fond marin et de la colonne d’eau opérés par la communauté scientifique française."@fr ;
        skos:exactMatch <https://ror.org/0312sjw67> ;
        skos:prefLabel "EMSO-France"@el,
            "EMSO-France"@en,
            "EMSO-France"@es,
            "EMSO-France"@fr,
            "EMSO-France"@it,
            "EMSO-France"@no,
            "EMSO-France"@pt,
            "EMSO-France"@ro ;
        dcat:keyword "EMSO"@en,
            "deep-sea observatory"@en,
            "long-term ocean observation"@en,
            "marine observatory"@en,
            "ocean observation"@en,
            "research infrastructure"@en,
            "seafloor observatory"@en,
            "water-column observation"@en,
            "infrastructure de recherche"@fr,
            "observation de la colonne d’eau"@fr,
            "observation océanique"@fr,
            "observation océanique à long terme"@fr,
