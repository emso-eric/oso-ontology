    OSO:ResearchProject a owl:Class ;
        rdfs:label "Ερευνητικό έργο"@el,
            "Research project"@en,
            "Proyecto de investigación"@es,
            "Projet de recherche"@fr,
            "Progetto di ricerca"@it,
            "Forskningsprosjekt"@no,
            "Projeto de investigação"@pt,
            "Proiect de cercetare"@ro ;
        rdfs:comment "Επιστημονική δραστηριότητα με σαφή δομή που αποσκοπεί στην παραγωγή νέας γνώσης, δεδομένων ή κατανόησης, εντός καθορισμένου πλαισίου και διάρκειας."@el,
            "A structured scientific activity designed to produce new knowledge, data, or understanding within a defined scope and duration."@en,
            "Una actividad científica estructurada destinada a producir nuevo conocimiento, datos o comprensión dentro de un alcance y una duración definidos."@es,
            "Une activité scientifique structurée visant à produire de nouvelles connaissances, données ou compréhensions dans un périmètre et une durée définis."@fr,
            "Un'attività scientifica strutturata progettata per produrre nuova conoscenza, dati o comprensione entro un ambito e una durata definiti."@it,
            "En strukturert vitenskapelig aktivitet som har som mål å produsere ny kunnskap, data eller forståelse innenfor et definert omfang og tidsrom."@no,
            "Uma atividade científica estruturada concebida para produzir novo conhecimento, dados ou compreensão dentro de um âmbito e duração definidos."@pt,
            "O activitate științifică structurată destinată să producă noi cunoștințe, date sau înțelegere într-un cadru și o durată definite."@ro ;
        rdfs:subClassOf foaf:Project .

