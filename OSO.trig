    OSO:ResearchInfrastructure a owl:Class ;
        rdfs:label "Ερευνητική Υποδομή"@el,
            "Research Infrastructure"@en,
            "Infraestructura de Investigación"@es,
            "Infrastructure de recherche"@fr,
            "Infrastruttura di Ricerca"@it,
            "Forskningsinfrastruktur"@no,
            "Infraestrutura de Investigação"@pt,
            "Infrastructură de cercetare"@ro ;
        metadata:prefixIRI "OSO:ResearchInfrastructure" ;
        rdfs:comment "Μια ερευνητική υποδομή μπορεί να συγκεντρώνει μία ή περισσότερες Περιφερειακές Εγκαταστάσεις."@el,
            "A research infrastructure may bring together one or more Regional Facilities."@en,
            "Una infraestructura de investigación puede reunir una o más Instalaciones Regionales."@es,
            "Une infrastructure de recherche peut regrouper une ou plusieurs installations régionales."@fr,
            "Una infrastruttura di ricerca può riunire una o più Strutture Regionali."@it,
            "En forskningsinfrastruktur kan samle én eller flere regionale fasiliteter."@no,
            "Uma infraestrutura de investigação pode reunir uma ou mais Instalações Regionais."@pt,
            "O infrastructură de cercetare poate reuni una sau mai multe facilități regionale."@ro ;
        rdfs:subClassOf foaf:Organization,
            cerif:Organisation ;
        skos:definition "The following definition for RI from Article 2 (6) of the Regulation (EU) No 1291/2013 of 11 December 2013: `Establishing Horizon 2020 - the Framework Programme for Research and Innovation (2014-2020)` applies: “RI are facilities, resources and services that are used by the research communities to conduct research and foster innovation in their fields. They include: major scientific equipment (or sets of instruments), knowledge-based resources such as collections, archives and scientific data, e-infrastructures, such as data and computing systems and communication networks and any other tools that are essential to achieve excellence in research and innovation.” Accordingly, RI are implemented along different organisational models, including central sources and laboratories for experiments and measurement sessions, coordination and management of geographically distributed observatories or laboratories, remotely accessible resources for computing, data banks, physical sample repositories, surveys and longitudinal studies."@en ;
        skos:note "ΕΥ"@el,
            "RI"@en,
            "IIdI"@es,
            "IR"@fr,
            "IR"@it,
            "FI"@no,
            "II"@pt,
            "IC"@ro ;
        skos:prefLabel "Ερευνητική Υποδομή"@el,
            "Research Infrastructure"@en,
            "Infraestructura de Investigación"@es,
            "Infrastructure de recherche"@fr,
            "Infrastruttura di Ricerca"@it,
            "Forskningsinfrastruktur"@no,
            "Infraestrutura de Investigação"@pt,
            "Infrastructură de cercetare"@ro .

