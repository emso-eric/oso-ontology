    OSO:MARLEY a owl:NamedIndividual,
            OSO:Platform ;
        rdfs:label "MARLEY"@el,
            "MARLEY"@en,
            "MARLEY"@es,
            "MARLEY"@fr,
            "MARLEY"@it,
            "MARLEY"@no,
            "MARLEY"@pt,
            "MARLEY"@ro ;
        dcterms:description "MARLEY (Monitoring deep-seA coRaL EcosYstems) is a deep seafloor observing system dedicated to the monitoring of cold-water coral habitats. The system has been deployed in the Lampaul Canyon off Brittany, France since August 2021 and is maintained annually during the ChEReef-Obs cruises. The study site is a coral garden dominated by Madrepora oculata located on a sedimented platform at 780 m depth."@en,
            "MARLEY (Monitoring deep-seA coRaL EcosYstems) est un système d’observation des grands fonds dédié au suivi des habitats de coraux d’eau froide. Le système est déployé dans le canyon de Lampaul au large de la Bretagne depuis août 2021 et est maintenu chaque année lors des campagnes ChEReef-Obs. Le site étudié correspond à un jardin de coraux dominé par Madrepora oculata situé sur une plateforme sédimentaire à 780 m de profondeur."@fr ;
        dcterms:isReferencedBy <https://doi.org/10.17882/111225> ;
        dcterms:spatial <http://dbpedia.org/resource/Bay_of_Biscay>,
            <http://dbpedia.org/resource/Brittany>,
            OSO:Lampaul_Canyon ;
        schema1:startDate "2021-08-01"^^xsd:date ;
        rdfs:seeAlso <https://campagnes.flotteoceanographique.fr/series/248/>,
            <https://doi.org/10.17882/111225>,
            <https://doi.org/10.18142/248>,
            <https://rd-technologiques.ifremer.fr/A-propos/Actualites-Archives-de-2013-a-2025/2022/L-observatoire-fond-de-Mer-MARLEY-Projet-MARHA>,
            <https://www.ifremer.fr/fr/presse/une-premiere-des-coraux-d-eau-froide-etudies-en-aquarium-sous-pression-pour-tester-leur>,
            <https://www.life-marha.fr/habitats-marins>,
            <https://www.life-marha.fr/node/483>,
            <https://www.seanoe.org/data/01001/111225/> ;
        skos:altLabel "MARLEY platform"@en,
            "Monitoring deep-seA coRaL EcosYstems"@en,
            "Observatoire fond de mer MARLEY"@fr,
            "Plateforme MARLEY"@fr ;
        skos:definition "Deep seafloor observing platform dedicated to the monitoring of cold-water coral habitats in the Lampaul Canyon off Brittany, France."@en,
            "Plateforme d’observation des grands fonds dédiée au suivi des habitats de coraux d’eau froide dans le canyon de Lampaul au large de la Bretagne."@fr,
            "Plataforma de observação dos fundos marinhos profundos dedicada ao acompanhamento de habitats de corais de águas frias no canyon de Lampaul, ao largo da Bretanha."@pt ;
        skos:note "The MARLEY observatory has been deployed since 2021 to monitor cold-water coral ecosystems at 780 m depth in the Lampaul Canyon."@en,
            "L’observatoire MARLEY est déployé depuis 2021 afin de suivre les écosystèmes de coraux d’eau froide à 780 m de profondeur dans le canyon de Lampaul."@fr ;
        skos:prefLabel "MARLEY"@el,
            "MARLEY"@en,
            "MARLEY"@es,
            "MARLEY"@fr,
            "MARLEY"@it,
            "MARLEY"@no,
            "MARLEY"@pt,
            "MARLEY"@ro ;
        OSO:isLinkedToCampaign OSO:ChEReef_2022 ;
        OSO:isLinkedToCampaignSeries OSO:CHEREEF_OBS ;
        OSO:isPartOfNetwork OSO:EMSO-France ;
        OSO:maxWaterDepth 780 .

