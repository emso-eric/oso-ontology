            "Ifremer"@fr,
            "Ifremer"@it,
            "Ifremer"@no,
            "Ifremer"@pt,
            "Ifremer"@ro ;
        foaf:depiction <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/ifremer.png> ;
        OSO:hasCountry OSO:France ;
        OSO:hasEDMO <https://edmo.seadatanet.org/report/1054> ;
