    OSO:Project_is_led_by_an_Organization a owl:ObjectProperty ;
        rdfs:label "Το έργο διευθύνεται από οργανισμό"@el,
            "Project is led by an organisation"@en,
            "El proyecto está dirigido por una organización"@es,
            "Le projet est dirigé par une organisation"@fr,
            "Il progetto è guidato da un'organizzazione"@it,
            "Prosjektet ledes av en organisasjon"@no,
            "O projeto é liderado por uma organização"@pt,
            "Proiectul este coordonat de o organizație"@ro ;
        rdfs:comment "Υποδεικνύει τον οργανισμό που είναι υπεύθυνος για τη διεύθυνση ή τον συντονισμό ενός ερευνητικού έργου."@el,
            "Indicates the organization responsible for leading or coordinating a research project."@en,
            "Indica la organización responsable de dirigir o coordinar un proyecto de investigación."@es,
            "Indique l'organisation responsable de la direction ou de la coordination d’un projet de recherche."@fr,
            "Indica l'organizzazione responsabile della direzione o del coordinamento di un progetto di ricerca."@it,
            "Angir organisasjonen som er ansvarlig for å lede eller koordinere et forskningsprosjekt."@no,
            "Indica a organização responsável pela liderança ou coordenação de um projeto de investigação."@pt,
            "Indică organizația responsabilă de coordonarea sau conducerea unui proiect de cercetare."@ro ;
        rdfs:domain OSO:ResearchProject ;
        rdfs:range foaf:Organization ;
        skos:definition "Συνδέει ένα ερευνητικό έργο με τον οργανισμό που είναι υπεύθυνος για τη διεύθυνση ή τον συντονισμό του."@el,
            "Relates a research project to the organisation responsible for leading or coordinating it."@en,
            "Relaciona un proyecto de investigación con la organización responsable de liderarlo o coordinarlo."@es,
            "Relie un projet de recherche à l’organisation responsable de sa direction ou de sa coordination."@fr,
            "Collega un progetto di ricerca all'organizzazione responsabile della sua direzione o coordinamento."@it,
            "Knytter et forskningsprosjekt til organisasjonen som leder eller koordinerer det."@no,
            "Liga um projeto de investigação à organização responsável pela sua coordenação ou liderança."@pt,
            "Leagă un proiect de cercetare de organizația responsabilă de coordonarea sau conducerea acestuia."@ro ;
        skos:prefLabel "Το έργο διευθύνεται από οργανισμό"@el,
            "Project is led by an organisation"@en,
            "El proyecto está dirigido por una organización"@es,
            "Le projet est dirigé par une organisation"@fr,
            "Il progetto è guidato da un'organizzazione"@it,
            "Prosjektet ledes av en organisasjon"@no,
            "O projeto é liderado por uma organização"@pt,
            "Proiectul este coordonat de o organizație"@ro .

    OSO:RegionalFacility_is_linked_to_a_project a owl:ObjectProperty ;
        rdfs:label "Η περιφερειακή υποδομή συνδέεται με έργο"@el,
            "Regional Facility is linked to a project"@en,
            "La infraestructura regional está vinculada a un proyecto"@es,
            "L’infrastructure régionale est liée à un projet"@fr,
            "L'infrastruttura regionale è collegata a un progetto"@it,
            "Regional infrastruktur er knyttet til et prosjekt"@no,
            "A infraestrutura regional está ligada a um projeto"@pt,
            "Infrastructura regională este legată de un proiect"@ro ;
        rdfs:comment "Συνδέει μια περιφερειακή υποδομή με ένα σχετικό ερευνητικό έργο."@el,
            "Links a regional facility to a related research project."@en,
            "Relaciona una infraestructura regional con un proyecto de investigación asociado."@es,
            "Lie une infrastructure régionale à un projet de recherche associé."@fr,
            "Collega un'infrastruttura regionale a un progetto di ricerca associato."@it,
            "Knytter en regional infrastruktur til et tilknyttet forskningsprosjekt."@no,
            "Liga uma infraestrutura regional a um projeto de investigação associado."@pt,
            "Leagă o infrastructură regională de un proiect de cercetare asociat."@ro ;
        rdfs:domain OSO:RegionalFacility ;
        rdfs:range OSO:ResearchProject ;
        skos:definition "Συνδέει μια περιφερειακή υποδομή με ένα ερευνητικό έργο με το οποίο σχετίζεται."@el,
            "Relates a regional facility to a research project with which it is associated."@en,
            "Relaciona una infraestructura regional con un proyecto de investigación al que está asociada."@es,
            "Relie une infrastructure régionale à un projet de recherche auquel elle est associée."@fr,
            "Collega un'infrastruttura regionale a un progetto di ricerca a cui è associata."@it,
            "Knytter en regional infrastruktur til et forskningsprosjekt som den er tilknyttet."@no,
            "Liga uma infraestrutura regional a um projeto de investigação ao qual está associada."@pt,
            "Leagă o infrastructură regională de un proiect de cercetare cu care este asociată."@ro ;
        skos:prefLabel "Η περιφερειακή υποδομή συνδέεται με έργο"@el,
            "Regional Facility is linked to a project"@en,
            "La infraestructura regional está vinculada a un proyecto"@es,
            "L’infrastructure régionale est liée à un projet"@fr,
            "L'infrastruttura regionale è collegata a un progetto"@it,
            "Regional infrastruktur er knyttet til et prosjekt"@no,
            "A infraestrutura regional está ligada a um projeto"@pt,
            "Infrastructura regională este legată de un proiect"@ro .

    OSO:RegionalFacility_is_part_of_a_RI a owl:ObjectProperty ;
        rdfs:label "Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής"@el,
            "Regional Facility is part of a Research Infrastructure"@en,
            "La infraestructura regional forma parte de una infraestructura de investigación"@es,
            "L’infrastructure régionale fait partie d’une infrastructure de recherche"@fr,
            "L'infrastruttura regionale fa parte di un'infrastruttura di ricerca"@it,
            "Regional infrastruktur er del av en forskningsinfrastruktur"@no,
            "A infraestrutura regional faz parte de uma infraestrutura de investigação"@pt,
            "Infrastructura regională face parte dintr-o infrastructură de cercetare"@ro ;
        rdfs:comment "Συνδέει μια περιφερειακή υποδομή με τη μητρική της ερευνητική υποδομή."@el,
            "Links a regional facility to its parent research infrastructure."@en,
            "Relaciona una infraestructura regional con su infraestructura de investigación principal."@es,
            "Lie une infrastructure régionale à son infrastructure de recherche parente."@fr,
            "Collega un'infrastruttura regionale alla sua infrastruttura di ricerca principale."@it,
            "Knytter en regional infrastruktur til dens overordnede forskningsinfrastruktur."@no,
            "Liga uma infraestrutura regional à sua infraestrutura de investigação principal."@pt,
            "Leagă o infrastructură regională de infrastructura sa principală de cercetare."@ro ;
        rdfs:domain OSO:RegionalFacility ;
        rdfs:range OSO:ResearchInfrastructure ;
        owl:inverseOf OSO:hasRegionalFacility ;
        skos:definition "Συνδέει μια περιφερειακή υποδομή με την ερευνητική υποδομή της οποίας αποτελεί μέρος."@el,
            "Relates a regional facility to the research infrastructure of which it is part."@en,
            "Relaciona una infraestructura regional con la infraestructura de investigación de la que forma parte."@es,
            "Relie une infrastructure régionale à l’infrastructure de recherche dont elle fait partie."@fr,
            "Collega un'infrastruttura regionale all'infrastruttura di ricerca di cui fa parte."@it,
            "Knytter en regional infrastruktur til forskningsinfrastrukturen den er en del av."@no,
            "Liga uma infraestrutura regional à infraestrutura de investigação da qual faz parte."@pt,
            "Leagă o infrastructură regională de infrastructura de cercetare din care face parte."@ro ;
        skos:prefLabel "Η περιφερειακή υποδομή αποτελεί μέρος ερευνητικής υποδομής"@el,
            "Regional Facility is part of a Research Infrastructure"@en,
            "La infraestructura regional forma parte de una infraestructura de investigación"@es,
            "L’infrastructure régionale fait partie d’une infrastructure de recherche"@fr,
            "L'infrastruttura regionale fa parte di un'infrastruttura di ricerca"@it,
            "Regional infrastruktur er del av en forskningsinfrastruktur"@no,
            "A infraestrutura regional faz parte de uma infraestrutura de investigação"@pt,
            "Infrastructura regională face parte dintr-o infrastructură de cercetare"@ro .

    OSO:RegionalFacility_is_related_to_RI a owl:ObjectProperty ;
        rdfs:label "Η περιφερειακή υποδομή σχετίζεται με ερευνητική υποδομή"@el,
            "Regional Facility is related to a Research Infrastructure"@en,
            "La infraestructura regional está relacionada con una infraestructura de investigación"@es,
            "L’infrastructure régionale est liée à une infrastructure de recherche"@fr,
            "L'infrastruttura regionale è collegata a un'infrastruttura di ricerca"@it,
            "Regional infrastruktur er relatert til en forskningsinfrastruktur"@no,
            "A infraestrutura regional está relacionada com uma infraestrutura de investigação"@pt,
            "Infrastructura regională este legată de o infrastructură de cercetare"@ro ;
        rdfs:comment "Μια περιφερειακή υποδομή μπορεί να σχετίζεται με μία ή περισσότερες ερευνητικές υποδομές χωρίς επίσημη σχέση μέρους-όλου."@el,
            "A regional facility may be related to one or more research infrastructures without a formal part-whole relationship."@en,
            "Una infraestructura regional puede estar relacionada con una o varias infraestructuras de investigación sin una relación formal de pertenencia."@es,
            "Une infrastructure régionale peut être liée à une ou plusieurs infrastructures de recherche sans relation formelle de composition."@fr,
            "Un'infrastruttura regionale può essere collegata a una o più infrastrutture di ricerca senza una relazione formale di appartenenza."@it,
            "En regional infrastruktur kan være knyttet til en eller flere forskningsinfrastrukturer uten et formelt del-forhold."@no,
            "Uma infraestrutura regional pode estar relacionada com uma ou mais infraestruturas de investigação sem uma relação formal de pertença."@pt,
            "O infrastructură regională poate fi legată de una sau mai multe infrastructuri de cercetare fără o relație formală de apartenență."@ro ;
        rdfs:domain OSO:RegionalFacility ;
        rdfs:range OSO:ResearchInfrastructure ;
        skos:definition "Συνδέει μια περιφερειακή υποδομή με μια ερευνητική υποδομή με την οποία έχει σχέση, χωρίς απαραίτητα να αποτελεί επίσημα μέρος της."@el,
            "Relates a regional facility to a research infrastructure with which it has an association, without necessarily being formally part of it."@en,
            "Relaciona una infraestructura regional con una infraestructura de investigación con la que mantiene una asociación, sin formar necesariamente parte formal de ella."@es,
            "Relie une infrastructure régionale à une infrastructure de recherche avec laquelle elle possède une association, sans nécessairement en faire formellement partie."@fr,
            "Collega un'infrastruttura regionale a un'infrastruttura di ricerca con cui ha un'associazione, senza necessariamente farne formalmente parte."@it,
            "Knytter en regional infrastruktur til en forskningsinfrastruktur som den har en tilknytning til, uten nødvendigvis å være formelt en del av den."@no,
            "Liga uma infraestrutura regional a uma infraestrutura de investigação com a qual possui uma associação, sem necessariamente fazer formalmente parte dela."@pt,
            "Leagă o infrastructură regională de o infrastructură de cercetare cu care are o asociere, fără a face neapărat parte oficial din aceasta."@ro ;
        skos:prefLabel "Η περιφερειακή υποδομή σχετίζεται με ερευνητική υποδομή"@el,
            "Regional Facility is related to a Research Infrastructure"@en,
            "La infraestructura regional está relacionada con una infraestructura de investigación"@es,
            "L’infrastructure régionale est liée à une infrastructure de recherche"@fr,
            "L'infrastruttura regionale è collegata a un'infrastruttura di ricerca"@it,
            "Regional infrastruktur er relatert til en forskningsinfrastruktur"@no,
            "A infraestrutura regional está relacionada com uma infraestrutura de investigação"@pt,
            "Infrastructura regională este legată de o infrastructură de cercetare"@ro .

