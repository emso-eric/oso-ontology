    OSO:EMSO-PT a owl:NamedIndividual,
            OSO:ResearchInfrastructure ;
        rdfs:label "EMSO Portugal"@el,
            "EMSO Portugal"@en,
            "EMSO Portugal"@es,
            "EMSO Portugal"@fr,
            "EMSO Portugal"@it,
            "EMSO Portugal"@no,
            "EMSO Portugal"@pt,
            "EMSO Portugal"@ro ;
        dcterms:description "EMSO Portugal is the Portuguese contribution to the EMSO European research infrastructure, coordinating long-term multidisciplinary ocean observation activities and technological developments, particularly in the Azores and Atlantic regions."@en,
            "EMSO Portugal est la contribution portugaise à l’infrastructure de recherche européenne EMSO, coordonnant des activités d’observation océanique multidisciplinaire à long terme et des développements technologiques, notamment dans les régions des Açores et de l’Atlantique."@fr,
            "O EMSO Portugal é a contribuição portuguesa para a infraestrutura europeia de investigação EMSO, coordenando atividades de observação oceânica multidisciplinar de longo prazo e desenvolvimentos tecnológicos, particularmente nas regiões dos Açores e do Atlântico."@pt ;
        schema1:logo <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_portugal.png> ;
        schema1:url <https://emso.waveweb.pt/en/> ;
        rdfs:seeAlso <https://emso.eu/observatories-node/azores-islands/>,
            <https://emso.waveweb.pt/en/>,
            <https://lsts.fe.up.pt/project/emso-pt>,
            <https://www.cesam-la.pt/en/projects/emso-pt-european-multidisciplinary-seafloor-observatory-portugal/>,
            <https://www.fct.pt/en/media/noticias/emso-pt-project-and-the-importance-of-sea-observatories/> ;
        skos:altLabel "EMSO Portugal Research Infrastructure"@en,
            "EMSO-PT"@en,
            "European Multidisciplinary Seafloor and Water Column Observatory Portugal"@en,
            "Portuguese component of EMSO ERIC"@en,
            "Componente portuguesa do EMSO ERIC"@pt,
            "EMSO Portugal"@pt,
            "EMSO-PT"@pt,
            "Infraestrutura EMSO Portugal"@pt ;
        skos:definition "The Portuguese component of EMSO ERIC, contributing to long-term multidisciplinary marine observation, notably through observatory activities in the Azores region."@en,
            "La composante portugaise d’EMSO ERIC, contribuant à l’observation marine multidisciplinaire à long terme, notamment à travers des activités d’observation dans la région des Açores."@fr,
            "A componente portuguesa do EMSO ERIC, que contribui para a observação marinha multidisciplinar de longo prazo, nomeadamente através de atividades de observação na região dos Açores."@pt ;
        skos:prefLabel "EMSO Portugal"@el,
            "EMSO Portugal"@en,
            "EMSO Portugal"@es,
            "EMSO Portugal"@fr,
            "EMSO Portugal"@it,
            "EMSO Portugal"@no,
            "EMSO Portugal"@pt,
            "EMSO Portugal"@ro ;
        dcat:keyword "Azores"@en,
            "EMSO"@en,
            "deep-sea observatory"@en,
            "marine observatory"@en,
            "ocean observation"@en,
            "research infrastructure"@en,
            "Açores"@pt,
            "infraestrutura de investigação"@pt,
            "observatório marinho"@pt,
            "observação oceânica"@pt ;
        foaf:depiction <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_portugal.png> ;
        OSO:hasCountry OSO:Portugal ;
        OSO:isLedByPerson OSO:Zuzia_STROYNOWSKI ;
        OSO:isManagedBy OSO:IPMA .

