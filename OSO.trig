    OSO:Western_Mediterranean_Sea a owl:NamedIndividual,
            OSO:RegionalFacility ;
        rdfs:label "Western Mediterranean Sea"@el,
            "Western Mediterranean Sea"@en,
            "Western Mediterranean Sea"@es,
