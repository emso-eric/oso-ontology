    OSO:EMSO_EVOLVE a schema1:Project,
            owl:NamedIndividual,
            cerif:Project,
            OSO:FundedProject ;
        rdfs:label "EMSO EVOLVE"@el,
            "EMSO EVOLVE"@en,
