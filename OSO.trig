            <https://www.ifremer.fr/>,
            <https://www.ifremer.fr/en>,
            <https://www.wikidata.org/wiki/Q1657069> ;
        owl:sameAs <https://dbpedia.org/resource/Ifremer>,
            <https://www.wikidata.org/entity/Q1657069> ;
        skos:altLabel "French National Institute for Ocean Science and Technology"@en,
            "French Research Institute for Exploitation of the Sea"@en,
            "IFREMER"@en,
            "IFREMER"@fr,
            "Institut français de recherche pour l’exploitation de la mer"@fr ;
        skos:closeMatch <https://edmo.seadatanet.org/report/1054> ;
        skos:definition "French public research institute dedicated to ocean science, marine technology, marine data, ocean observation, biodiversity, fisheries, aquaculture and the sustainable management of marine resources and ecosystems."@en,
            "Institut public français de recherche dédié aux sciences et technologies de l’océan, aux données marines, à l’observation de l’océan, à la biodiversité, aux pêches, à l’aquaculture et à la gestion durable des ressources et des écosystèmes marins."@fr ;
        skos:exactMatch <https://dbpedia.org/resource/Ifremer>,
            <https://ror.org/044jxhp58>,
            <https://www.wikidata.org/entity/Q1657069> ;
        skos:prefLabel "Ifremer"@el,
