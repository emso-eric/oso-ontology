    OSO:FundedProject a owl:Class ;
        rdfs:label "Χρηματοδοτούμενο έργο"@el,
            "Funded project"@en,
            "Proyecto financiado"@es,
            "Projet financé"@fr,
            "Progetto finanziato"@it,
            "Finansiert prosjekt"@no,
            "Projeto financiado"@pt,
            "Proiect finanțat"@ro ;
        rdfs:comment "Ένα ερευνητικό έργο που υποστηρίζεται από ειδική χρηματοδότηση από έναν ή περισσότερους οργανισμούς ή φορείς χρηματοδότησης."@el,
            "A research project supported by dedicated financial funding from one or more organizations or funding bodies."@en,
            "Un proyecto de investigación respaldado por financiación específica de una o más organizaciones o entidades financiadoras."@es,
            "Un projet de recherche soutenu par un financement dédié provenant d'une ou plusieurs organisations ou agences de financement."@fr,
            "Un progetto di ricerca sostenuto da finanziamenti dedicati provenienti da una o più organizzazioni o enti finanziatori."@it,
            "Et forskningsprosjekt støttet av dedikert finansiering fra en eller flere organisasjoner eller finansieringskilder."@no,
            "Um projeto de investigação apoiado por financiamento específico proveniente de uma ou mais organizações ou entidades financiadoras."@pt,
            "Un proiect de cercetare susținut prin finanțare dedicată din partea uneia sau mai multor organizații sau organisme de finanțare."@ro ;
        rdfs:subClassOf OSO:ResearchProject .

