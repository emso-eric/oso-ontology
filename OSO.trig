    OSO:EMSO-Italia a owl:NamedIndividual,
            OSO:ResearchInfrastructure ;
        rdfs:label "EMSO-Italia"@el,
            "EMSO-Italia"@en,
            "EMSO-Italia"@es,
            "EMSO-Italia"@fr,
            "EMSO-Italia"@it,
            "EMSO-Italia"@no,
            "EMSO-Italia"@pt,
            "EMSO-Italia"@ro ;
        dcterms:description "Το EMSO-Italia αποτελεί την ιταλική συμβολή στην ευρωπαϊκή ερευνητική υποδομή EMSO, συντονίζοντας πολυεπιστημονικά θαλάσσια παρατηρητήρια και δραστηριότητες μακροχρόνιας ωκεανογραφικής παρατήρησης στη Μεσόγειο Θάλασσα."@el,
            "EMSO-Italia is the Italian contribution to the EMSO European research infrastructure, coordinating multidisciplinary marine observatories and long-term ocean observation activities in the Mediterranean Sea."@en,
            "EMSO-Italia es la contribución italiana a la infraestructura europea de investigación EMSO, coordinando observatorios marinos multidisciplinares y actividades de observación oceánica a largo plazo en el mar Mediterráneo."@es,
            "EMSO-Italia est la contribution italienne à l’infrastructure de recherche européenne EMSO, coordonnant des observatoires marins multidisciplinaires et des activités d’observation océanique à long terme en mer Méditerranée."@fr,
            "EMSO-Italia è il contributo italiano all'infrastruttura di ricerca europea EMSO, coordinando osservatori marini multidisciplinari e attività di osservazione oceanica a lungo termine nel Mar Mediterraneo."@it,
            "EMSO-Italia er det italienske bidraget til den europeiske forskningsinfrastrukturen EMSO, og koordinerer tverrfaglige marine observatorier og langsiktige havobservasjonsaktiviteter i Middelhavet."@no,
            "EMSO-Italia é a contribuição italiana para a infraestrutura europeia de investigação EMSO, coordenando observatórios marinhos multidisciplinares e atividades de observação oceânica de longo prazo no Mar Mediterrâneo."@pt,
            "EMSO-Italia reprezintă contribuția italiană la infrastructura europeană de cercetare EMSO, coordonând observatoare marine multidisciplinare și activități de observare oceanografică pe termen lung în Marea Mediterană."@ro ;
        schema1:logo <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_italia.png> ;
        schema1:url <https://www.ingv.it/monitoraggio-e-infrastrutture/emso> ;
        rdfs:seeAlso <https://emso.eu/>,
            <https://www.ingv.it/monitoraggio-e-infrastrutture/emso>,
            <https://www.ogs.it/it/european-multidisciplinary-seafloor-and-water-column-observatory-emso-eric> ;
        skos:altLabel "EMSO Italia"@en,
            "Italian component of EMSO ERIC"@en,
            "Componente italiana di EMSO ERIC"@it,
            "EMSO Italia"@it ;
        skos:definition "Η ιταλική συνιστώσα του EMSO ERIC, αφιερωμένη στη μακροχρόνια πολυεπιστημονική παρατήρηση του θαλάσσιου πυθμένα και της υδάτινης στήλης στην περιοχή της Μεσογείου."@el,
            "The Italian component of EMSO ERIC, supporting long-term multidisciplinary observation of the seafloor and water column in the Mediterranean region."@en,
            "La componente italiana de EMSO ERIC, dedicada a la observación multidisciplinaria a largo plazo del fondo marino y de la columna de agua en la región mediterránea."@es,
            "La composante italienne d’EMSO ERIC, dédiée à l’observation multidisciplinaire à long terme du fond marin et de la colonne d’eau dans la région méditerranéenne."@fr,
            "La componente italiana di EMSO ERIC, dedicata all’osservazione multidisciplinare a lungo termine del fondale marino e della colonna d’acqua nella regione mediterranea."@it,
            "Den italienske delen av EMSO ERIC, dedikert til langsiktig tverrfaglig observasjon av havbunnen og vannsøylen i Middelhavsregionen."@no,
            "A componente italiana do EMSO ERIC, dedicada à observação multidisciplinar de longo prazo do fundo marinho e da coluna de água na região mediterrânica."@pt,
            "Componenta italiană a EMSO ERIC, dedicată observației multidisciplinare pe termen lung a fundului marin și a coloanei de apă din regiunea mediteraneană."@ro ;
        skos:prefLabel "EMSO-Italia"@el,
            "EMSO-Italia"@en,
            "EMSO-Italia"@es,
            "EMSO-Italia"@fr,
            "EMSO-Italia"@it,
            "EMSO-Italia"@no,
            "EMSO-Italia"@pt,
            "EMSO-Italia"@ro ;
        dcat:keyword "EMSO"@en,
            "Mediterranean Sea"@en,
            "deep-sea observatory"@en,
            "marine observatory"@en,
            "ocean observation"@en,
            "research infrastructure"@en,
            "Mar Mediterraneo"@it,
            "infrastruttura di ricerca"@it,
            "osservatorio marino"@it,
            "osservazione oceanica"@it ;
        foaf:depiction <https://raw.githubusercontent.com/emso-eric/oso-ontology/main/images/emso_italia.png> ;
        foaf:name "European Multidisciplinary Seafloor and Water Column Observatory Italy"@en ;
        OSO:hasCountry OSO:Italy ;
        OSO:isManagedBy OSO:INGV .

