    OSO:Ligurian_Sea a owl:NamedIndividual,
            OSO:RegionalFacility ;
        rdfs:label "Λιγουρική Θάλασσα"@el,
            "Ligurian Sea"@en,
            "Mar de Liguria"@es,
            "Mer Ligure"@fr,
            "Mar Ligure"@it,
            "Liguriahavet"@no,
            "Mar da Ligúria"@pt,
            "Marea Ligurică"@ro ;
        dcterms:description "This Regional Facility covers an active seismic marine region characterized by a narrow and steep continental slope, alpine reliefs, submarine canyons, slope instability, strong atmospheric inputs, and significant implications for seismic hazard, tsunami risk, and marine biomass production."@en,
            "Cette installation régionale couvre une zone marine sismiquement active caractérisée par une pente continentale étroite et abrupte, des reliefs alpins, des canyons sous-marins, une instabilité des pentes, de fortes influences atmosphériques et des enjeux importants en matière de risques sismiques, de tsunamis et de production de biomasse marine."@fr,
            "Questa infrastruttura regionale copre una regione marina sismicamente attiva caratterizzata da una scarpata continentale stretta e ripida, rilievi alpini, canyon sottomarini, instabilità dei versanti, forti influenze atmosferiche e importanti implicazioni per il rischio sismico, gli tsunami e la produzione di biomassa marina."@it ;
        dcterms:spatial <http://dbpedia.org/resource/French_Riviera>,
            <http://dbpedia.org/resource/Gulf_of_Lion>,
            <http://dbpedia.org/resource/Ligurian_Sea>,
            <http://dbpedia.org/resource/Mediterranean_Sea> ;
        schema1:url <https://www.emso-fr.org/>,
            <https://www.emso-fr.org/fr/Ligure-Ouest> ;
        rdfs:comment "Regional Facility covering a broad north-western Mediterranean marine area, including the Ligurian Sea, the French Riviera, the Gulf of Lion, and the intermediate marine space."@en,
            "Installation régionale couvrant une vaste zone marine du nord-ouest de la Méditerranée, incluant la mer Ligure, la Côte d’Azur, le golfe du Lion ainsi que l’espace marin intermédiaire."@fr,
            "Infrastruttura regionale che copre un’ampia area marina del Mediterraneo nord-occidentale, includendo il Mar Ligure, la Costa Azzurra, il Golfo del Leone e lo spazio marino intermedio."@it ;
        rdfs:seeAlso <https://emso.eu/observatories-node/ligurian-sea/>,
            <https://www.emso-fr.org/fr/Ligure-Ouest>,
            <https://www.wikidata.org/wiki/Q182822> ;
        skos:closeMatch <http://dbpedia.org/resource/French_Riviera>,
            <http://dbpedia.org/resource/Gulf_of_Lion> ;
        skos:definition "Regional Facility of EMSO-France dedicated to multidisciplinary marine observation in the Ligurian Sea and north-western Mediterranean region."@en,
            "Regional Facility d’EMSO-France dédiée à l’observation marine multidisciplinaire en mer Ligure et en Méditerranée nord-occidentale."@fr,
            "Regional Facility di EMSO-France dedicata all’osservazione marina multidisciplinare nel Mar Ligure e nel Mediterraneo nord-occidentale."@it ;
        skos:exactMatch <https://www.wikidata.org/entity/Q182822> ;
        skos:note "Regional Facility associated with long-term multidisciplinary observation of the north-western Mediterranean Sea."@en,
            "Regional Facility associée à l’observation multidisciplinaire à long terme de la Méditerranée nord-occidentale."@fr,
            "Regional Facility associata all’osservazione multidisciplinare a lungo termine del Mediterraneo nord-occidentale."@it ;
        skos:prefLabel "Λιγουρική Θάλασσα"@el,
            "Ligurian Sea"@en,
            "Mar de Liguria"@es,
            "Mer Ligure"@fr,
            "Mar Ligure"@it,
            "Liguriahavet"@no,
            "Mar da Ligúria"@pt,
            "Marea Ligurică"@ro ;
        OSO:RegionalFacility_is_part_of_a_RI OSO:EMSO-France ;
        OSO:containsSite OSO:BILLION,
            OSO:DYFAMED,
            OSO:LION,
            OSO:LO,
            OSO:Nice ;
        OSO:dateFirstDeployment "1998-01-01"^^xsd:date ;
